T i[ind]=
	IF THEN ELSE(case1 i[ind]>0, UFC T iv[ind,T1], 
	IF THEN ELSE(case2 i[ind]>0,min(UFC T iv[ind,T1], UFC T iv[ind,T2]), 
	IF THEN ELSE(case3 i[ind]>0,min(UFC T iv[ind,T1], UFC T iv[ind,T3]), 
	IF THEN ELSE(case4 i[ind]>0,min(UFC T iv[ind,T1], min(UFC T iv[ind,T2],UFC T iv[ind,
T3])),
	IF THEN ELSE(case5 i[ind]>0,min(UFC T iv[ind,T1], UFC T iv[ind,T4]), 
	IF THEN ELSE(case6 i[ind]>0,min(UFC T iv[ind,T1], min(UFC T iv[ind,T2], UFC T iv[ind
,T4])),
	IF THEN ELSE(case7 i[ind]>0,min(UFC T iv[ind,T1], min(UFC T iv[ind,T3],UFC T iv[ind,
T4])),
	min(min(UFC T iv[ind,T1],UFC T iv[ind,T2]) ,min(UFC T iv[ind,T3],UFC T iv[ind,T4]))
	)))))))
	~	Euro/Goods
	~	choice of adopted technology
	|

target markup i[ind] :EXCEPT:           [public],[education],[health]=
	max(0,markup init alt[ind]*(1+markup calibration parm i[ind]*(uc i[ind]-uc init[ind]
	)))*IF THEN ELSE(activated markup shocks=1,markup shocks[ind],1) ~~|
