ratio growth exports to growth trend=
	1.00564
	~	
	~		|

ratio growth gov c to growth trend=
	0.991001
	~	
	~		|

ratio K FE constrained fd[ind] :EXCEPT:   [households]=
	min(min(max((y FC i[ind]-y real unconstrained i[ind]+own inputs vector[ind
	]-own inputs PNRR
	[ind])/own inputs no PNRR[ind],0),1),factor FE constraint) ~~|
ratio K FE constrained fd[households]=
	factor FE constraint
	~	Dmnl [0,1]
	~		|

ratio L indirect and induced over L direct gov bs 6 policy 4 or 5 i[ind]=
	ZIDZ(L indirect and induced gov bs 6 policy 4 or 5 i[ind], delta L from gov c real policy increase i
[ind])
	~	
	~	Ratio of additional induced and indirect jobs created in each sector over \
		the ones directly created from policy
	|

ratio L supply demand s[skill]=
	labour supply s[skill]/sum(L is unconstrained[ind!,skill])
	~	
	~		|

ratio labour productivity T iv[ind,techn]=
	lambda T iv[ind,techn]/initial lambda i[ind]-1
	~	Dmnl
	~		|

ratio working age to total population=
	working age pop total/population total
	~	1
	~		~	:SUPPLEMENTARY 
	|

ratio y FC to unconstrained i[ind] :EXCEPT:        [households]=
	y FC i[ind]/y real unconstrained i[ind] ~~|
ratio y FC to unconstrained i[households]=
	1
	~	
	~	ratio between the output unconstrained, determined by demand, and the \
		maximum output according to capital stock and the structure of \
		intermediate demand
	|

real demand i[ind]=
	final demand real i[ind]-Z imp real i[ind]
	~	
	~		|

real electrification investment=
	electrification costs per TJ init*electrified end use
	~	Euro constant/Year
	~		|

real estate inv=
	delay real estate inv*(1+g real estate inv)
	~	
	~		|

real estate inv real=
	real estate inv
	*IF THEN ELSE(Time<S Time Policy start,
	                1,
	                1+(Time-S Time Policy start)*(Act cons red*S mpc/(S Time end-S Time Policy start
	))
	                )
	~	
	~		|

real salary per capita gs[gender,skill]=
	(GWB gs[gender,skill]/L gs[gender,skill])/CPI
	~	Euro constant/(Year*Person)
	~		|

real trade balance=
	total exp real
	-total imp real
	~	Euro constant/Year
	~		~	:SUPPLEMENTARY 
	|

real wage=
	wage/CPI
	~	Euro constant/(Hours*Person)
	~		|

real wage delay= DELAY FIXED (
	real wage, 1, initial real wage)
	~	Euro constant/(Hours*Person)
	~		|

real wage g[gender]=
	mean wage g[gender]/CPI
	~	Euro constant/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

real wage g delay[gender]= DELAY FIXED (
	real wage g[gender], 1, initial real wage g[gender])
	~	Euro constant/(Hours*Person)
	~		|

real wage g mi[gender, macroind]=
	sum(real wage gis[gender,ind!,skill!]*actual hours i[ind!]*L gis[gender,ind!,skill!]
*ind to macroind map
	[ind!,macroind])/
	sum(actual hours i[ind!]*L gis[gender,ind!,skill!]*ind to macroind map[ind!,macroind
	])
	~	Euro constant/(Hours*Person)
	~		|

real wage gis[gender,ind,skill]=
	wage gis[gender,ind,skill]/CPI
	~	Euro constant/(Hours*Person)
	~		|

real wage gs[gender,skill]=
	mean wage gs[gender,skill]/CPI
	~	Euro constant/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

real wage gs delay[gender, skill]= DELAY FIXED (
	real wage gs[gender,skill], 1, initial real wage gs[gender,skill])
	~	Euro/(Hours*Person)
	~		|

real wage gs mi[gender, skill, macroind]=
	sum(real wage gis[gender,ind!,skill]*actual hours i[ind!]*L gis[gender,ind!,skill]*ind to macroind map
[ind!,macroind])/
	sum(actual hours i[ind!]*L gis[gender,ind!,skill]*ind to macroind map[ind!,macroind]
)
	~	Euro constant/(Hours*Person)
	~		|

real wage high to low=
	real wage s[hig]-real wage s[low]
	~	Euro constant/(Hours*Person)
	~		|

real wage high to mid=
	real wage s[hig]-real wage s[mid]
	~	Euro constant/(Hours*Person)
	~		|

real wage i[ind]=
	wage i[ind]/CPI
	~	Euro constant/(Hours*Person)
	~		|

real wage i delay[ind]= DELAY FIXED (
	real wage i[ind], 1, initial real wage i[ind])
	~	Euro constant/(Hours*Person)
	~		|

real wage mi[macroind]=
	wage mi[macroind]/CPI
	~	Euro constant/(Hours*Person)
	~		|

real wage mi delay[macroind]= DELAY FIXED (
	real wage mi[macroind], 1, initial real wage mi[macroind])
	~	Euro constant/(Hours*Person)
	~		|

real wage mid to low=
	real wage s[mid]-real wage s[low]
	~	Euro constant/(Hours*Person)
	~		|

real wage s[skill]=
	mean wage s[skill]/CPI
	~	Euro constant/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

real wage s delay[skill]= DELAY FIXED (
	real wage s[skill],1,initial real wage s[skill])
	~	Euro/(Hours*Person)
	~		|

realised delta a ii[ind,toind]=
	IF THEN ELSE(a delay ii[ind,toind]=0,0,
	ZIDZ(a ii[ind,toind],a delay ii[ind,toind])-1
	)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

realised lambda i[ind]=
	IF THEN ELSE(lambda delay i[ind]=0,0,
	ZIDZ(lambda pre electricity i[ind],lambda delay i[ind])-1
	)
	~	Goods/People/Hours
	~		~	:SUPPLEMENTARY 
	|

redist of uw d[inc cat]=
	ZIDZ(delta total uw change empl * uw share not empl d[inc cat]
	, pop d[inc cat])*People 1
	~	Hours
	~	uw working time redistributed among not employed in proportion to their previous \
		share in overall uw by not employed
		
		uw_share_not_empl = 0 for employed (and capitalists)
	|

reduction in ff use through efficiency households iterative[regions,quintiles]=
	
	(sum(E use before ESc fd dom[regions,quintiles,ff!])*baseline efficiency gains hhs delay
	-sum(E use before ESc fd dom[regions,quintiles,ff!])*baseline efficiency gains hhs delay2
	)
	~	TJ/Year
	~		|

reduction in transformation use[ind,ff] :EXCEPT:         [e sectors,ff]=
	E transformation use before ESc[ind,ff]*economy wide rate of reduction of ffs related to transformation use delayed
 ~~|
reduction in transformation use[e sectors,ff] :EXCEPT:      [mining,ff],[gas ind,ff]=
	0 ~~|
reduction in transformation use[mining,ff]=
	E transformation use before ESc[mining,ff]*electrification i[mining] ~~|
reduction in transformation use[gas ind,ff]=
	electricity module switch*(E transformation use before ESc[gas ind,ff]*parameter of hydrogen provisioning share
	)
	+(1-electricity module switch)*0
	~	TJ/Euro constant
	~		|

reduction in transformation use imp[ind,ff] :EXCEPT:   [e sectors,ff]=
	E transformation use before ESc imp[ind,ff]*economy wide rate of reduction of ffs related to transformation use delayed
 ~~|
reduction in transformation use imp[e sectors,ff] :EXCEPT:  [mining,ff]=
	0 ~~|
reduction in transformation use imp[mining,ff]=
	E transformation use before ESc imp[mining,ff]*electrification i[mining]
	~	TJ/Euro constant
	~		|

