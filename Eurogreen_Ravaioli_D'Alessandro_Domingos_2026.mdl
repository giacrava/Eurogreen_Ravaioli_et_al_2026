yd shares rq nonMI[regions,quintiles]=
	(yd rq nonMI[regions,quintiles])/sum(yd rq nonMI[regions!,quintiles!])
	~	
	~		|

yd static rq[regions,quintiles]=
	sd rq[regions,quintiles] +
	cb rq[regions,quintiles] +
	other benefits rq[regions,quintiles]+
	BI rq[regions,quintiles] +
	JG rq n[regions,quintiles]
	~	Euro/Year
	~		|

yd static rq hh[regions,quintiles]=
	yd static rq[regions,quintiles]/num hhs rq delayed[regions,quintiles]
	~	Euro/(Year*Household)
	~		|

yd static rq hh delay[regions,quintiles]= DELAY FIXED (
	yd static rq hh[regions,quintiles], Year 1, initial yd static rq hh
[regions,quintiles])
	~	Euro/(Year*Household)
	~		|

yd static rq hh real delay[regions,quintiles]=
	yd static rq hh delay[regions,quintiles]/CPI rq delay[regions,quintiles
]
	~	Euro/(Year*Household)
	~		|

Year 0=
	0
	~	Year
	~		|

Year 1=
	1
	~	Year
	~		|

yearly exp adapt=
	1e+10
	~	Euro/Year
	~	1e+9 --> adaptation slow
		10e+9 --> adaptation fast
	|

yearly increase in care wages gis[gender, skill, ind] :EXCEPT:         [female, skill
,
 ind], [male, mid, ind], [male, low, ind]=
	IF THEN ELSE(Act Increase care wages=1 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[gender,skill,ind],
	
	0) ~~|
yearly increase in care wages gis[female,hig,ind]=
	IF THEN ELSE(Act Increase care wages=1 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[female,hig,ind],
	
	IF THEN ELSE(Act Increase care wages=2 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[female,hig,ind],
	
	0)) ~~|
yearly increase in care wages gis[female,mid,ind]=
	IF THEN ELSE(Act Increase care wages=1 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[female,mid,ind],
	
	IF THEN ELSE(Act Increase care wages=2 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[female,mid,ind],
	
	IF THEN ELSE(Act Increase care wages=3 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[female,mid,ind],
	
	0))) ~~|
yearly increase in care wages gis[female,low,ind]=
	IF THEN ELSE(Act Increase care wages=1 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[female,low,ind],
	
	IF THEN ELSE(Act Increase care wages=2 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[female,low,ind],
	
	IF THEN ELSE(Act Increase care wages=3 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[female,low,ind],
	
	0))) ~~|
yearly increase in care wages gis[male, mid, ind]=
	IF THEN ELSE(Act Increase care wages=1 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[male,mid,ind],
	
	IF THEN ELSE(Act Increase care wages=3 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[male,mid,ind],
	
	0)) ~~|
yearly increase in care wages gis[male, low, ind]=
	IF THEN ELSE(Act Increase care wages=1 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[male,low,ind],
	
	IF THEN ELSE(Act Increase care wages=3 :AND: Time >= S Time Policy start-1 :AND: Time
 
	<= S Time Shift end-1,
	S sectors increase in care wages[ind]*S increase in care wages/(S Time Shift end-S Time Policy start
	+1)*wage gis policy start delay[male,low,ind],
	
	0))
	~	Euro/Person/Hour
	~		|

yearly increase in care wages real gis[gender, skill, ind]=
	yearly increase in care wages gis[gender,skill,ind]/CPI
	~	Euro constant/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

ygross d[inc low u f]=
	GFI per capita gs[female,low] ~~|
ygross d[inc low u m]=
	GFI per capita gs[male,low] ~~|
ygross d[inc mid u f]=
	GFI per capita gs[female,mid] ~~|
ygross d[inc mid u m]=
	GFI per capita gs[male,mid] ~~|
ygross d[inc hig u f]=
	GFI per capita gs[female,hig] ~~|
ygross d[inc hig u m]=
	GFI per capita gs[male,hig] ~~|
ygross d[inc low e f]=
	GWB per capita gs[female,low]
	+GFI per capita gs[female,low] ~~|
ygross d[inc low e m]=
	GWB per capita gs[male,low]
	+GFI per capita gs[male,low] ~~|
ygross d[inc mid e f]=
	GWB per capita gs[female,mid]
	+GFI per capita gs[female,mid] ~~|
ygross d[inc mid e m]=
	GWB per capita gs[male,mid]
	+GFI per capita gs[male,mid] ~~|
ygross d[inc hig e f]=
	GWB per capita gs[female,hig]
	+GFI per capita gs[female,hig] ~~|
ygross d[inc hig e m]=
	GWB per capita gs[male,hig]
	+GFI per capita gs[male,hig] ~~|
ygross d[inc low o f]=
	GFI per capita gs[female,low] ~~|
ygross d[inc low o m]=
	GFI per capita gs[male,low] ~~|
ygross d[inc mid o f]=
	GFI per capita gs[female,mid] ~~|
ygross d[inc mid o m]=
	GFI per capita gs[male,mid] ~~|
ygross d[inc hig o f]=
	GFI per capita gs[female,hig] ~~|
ygross d[inc hig o m]=
	GFI per capita gs[male,hig] ~~|
ygross d[inc low p f]=
	gross annual income p gs[female,low]
	+GFI per capita gs[female,low] ~~|
ygross d[inc low p m]=
	gross annual income p gs[male,low]
	+GFI per capita gs[male,low] ~~|
ygross d[inc mid p f]=
	gross annual income p gs[female,mid]
	+GFI per capita gs[female,mid] ~~|
ygross d[inc mid p m]=
	gross annual income p gs[male,mid]
	+GFI per capita gs[male,mid] ~~|
ygross d[inc hig p f]=
	gross annual income p gs[female,hig]
	+GFI per capita gs[female,hig] ~~|
ygross d[inc hig p m]=
	gross annual income p gs[male,hig]
	+GFI per capita gs[male,hig] ~~|
ygross d[inc cap]=
	GFI per capita cap
	~	Euro/People
	~	individual market disposable income by income category. The idea here is \
		to remove all tax and transfers. We devided to leave Pensions.
	|

ygross order[inc cat]=
	VECTOR SORT ORDER(ygross d[inc cat], 1 )
	~	Dmnl
	~		|

ygross share[inc cat]=
	(ygross d[inc cat]*pop d[inc cat])/(sum(ygross d[inc cat!]*pop d[inc cat!]))
	~	Dmnl
	~		|

