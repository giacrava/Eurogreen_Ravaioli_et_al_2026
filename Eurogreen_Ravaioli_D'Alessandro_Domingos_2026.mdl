share c d[inc cat]=
	0
	~	percentage
	~	ZIDZ((c tot d[inc cat]*pop d[inc cat]),sum((c tot d[inc cat!]*pop d[inc \
		cat!])))
	~	:SUPPLEMENTARY 
	|

share c rq[regions,quintiles]=
	c rq[regions,quintiles]/c tot rq
	~	
	~		|

share delta yd cap in NFI d[inc cat]=
	ZIDZ(delta yd cap d per capita[inc cat],NFI d[inc cat])
	~	
	~		~	:SUPPLEMENTARY 
	|

share delta yd cap in yd d[inc cat]=
	ZIDZ(delta yd cap d per capita[inc cat],yd d[inc cat])
	~	
	~		~	:SUPPLEMENTARY 
	|

share demand components[consumption]=
	sum(c ESc nom bp dom i[ind!])/sum(final demand nom i[ind!]) ~~|
share demand components[investment]=
	sum(I supply dom nom i[ind!])/sum(final demand nom i[ind!]) ~~|
share demand components[government]=
	(sum(gov c dom nom i[ind!])+sum(inv pnrr[ind!]))/sum(final demand nom i[ind!]) ~~|
share demand components[export]=
	sum(ex ESc nom i[ind!])/sum(final demand nom i[ind!])
	~	
	~	why not investment demand here?
	~	:SUPPLEMENTARY 
	|

share demand components total[consumption]=
	sum(c ESc nom bp i[ind!])/sum(total demand nom i[ind!]) ~~|
share demand components total[investment]=
	sum(I supply nom i[ind!])/sum(total demand nom i[ind!]) ~~|
share demand components total[government]=
	(sum(gov c nom i[ind!])+sum(inv pnrr[ind!]))/sum(total demand nom i[ind!]) ~~|
share demand components total[export]=
	sum(ex real ESC i[ind!]*p i[ind!])/sum(total demand nom i[ind!])
	~	1
	~		~	:SUPPLEMENTARY 
	|

share imp GFCF i[ind]=
	unc share imp GCFC i[ind]*import factor K FE constraint[ind]
	~	Dmnl [0,1]
	~	share of imports with respect to domestic expenditure for final demand of \
		GFCF
	|

share imp gov i[ind]=
	unc share imp gov i[ind]*import factor K FE constraint[ind]
	~	percentage [0,1]
	~	share of imports with respect to domestic expenditure for final demand of \
		government
	|

share imp hh i[ind]=
	unc share imp hh i[ind]*import factor K FE constraint[ind]
	~	Dmnl [0,1]
	~	share of imports with respect to domestic expenditure for final demand of households
		
		*import factor K FE constraint[ind]
	|

share imp Z ESc ii[ind,toind]=
	IF THEN ELSE(a ii[ind,toind]=0,0,
	a imp ESc ii[ind,toind]/a ii[ind,toind])
	~	Dmnl
	~		|

share imp Z ESc ii delayed[ind,toind]= DELAY FIXED (
	share imp Z ESc ii[ind,toind], delay time, share imp Z ii[ind,toind])
	~	Dmnl
	~		|

share imp Z Esc ii delayed w efficiency trends[ind,toind] :EXCEPT:     [ind,electricity ind
]=
	share imp Z ESc ii delayed[ind,toind]*factor imp share[ind,toind] ~~|
share imp Z Esc ii delayed w efficiency trends[ind,electricity ind] :EXCEPT:        [
ffbio sectors,electricity ind]=
	share imp Z ESc ii delayed[ind,electricity ind]*factor imp share[ind,electricity ind
] ~~|
share imp Z Esc ii delayed w efficiency trends[ffbio sectors,electricity ind]=
	share imp Z ESc ii delayed[ffbio sectors,electricity ind]*factor imp share[ffbio sectors
,electricity ind]
	~	Dmnl
	~	in order to avoid simultaneous equations (e.g. Aimp -> tls -> final demand -> output \
		-> electricity demand -> electricity production structure -> Aimp), we \
		delay the impact of the electricity production structure by the minimal \
		amount
		share imp Z ESc ii delayed[ind,toind]*(1+trend impact Z imp share \
		delayed[ind,toind])
	|

share imp Z Esc ii delayed w efficiency trendsall[ind,toind] :EXCEPT:        [ind,electricity ind
]=
	share imp Z Esc ii delayed w efficiency trends[ind,toind]*(1+trend impact Z imp share delayed
[ind,toind]) ~~|
share imp Z Esc ii delayed w efficiency trendsall[ind,electricity ind] :EXCEPT:              
[ffbio sectors,electricity ind]=
	IF THEN ELSE(electricity module switch=0,
	share imp Z Esc ii delayed w efficiency trends[ind,electricity ind]*(1+trend impact Z imp share delayed
[ind,electricity ind]),
	share imp Z Esc ii delayed w efficiency trends[ind,electricity ind]*(1+g import shares electricity delayed
[ind])) ~~|
share imp Z Esc ii delayed w efficiency trendsall[ffbio sectors,electricity ind]=
	share imp Z Esc ii delayed w efficiency trends[ffbio sectors,electricity ind]*(1+(1-
electricity module switch)*trend impact Z imp share delayed[ffbio sectors,electricity ind
])
	~	Dmnl
	~	in order to avoid simultaneous equations (e.g. Aimp -> tls -> final demand -> output \
		-> electricity demand -> electricity production structure -> Aimp), we \
		delay the impact of the electricity production structure by the minimal \
		amount
		share imp Z ESc ii delayed[ind,toind]*(1+trend impact Z imp share \
		delayed[ind,toind])
	|

share imp Z ii[ind,toind]=
	max(S1 share imp Z ii[ind,toind]*IF THEN ELSE(Time<S Time Policy start,
	                1,
	                1+min(S Time end-S Time Policy start,Time-S Time Policy start)*(S share imp Z
/(S Time end-S Time Policy start))
	                ),0)
	~	Dmnl [0,1]
	~	share of imports with respect to domestic in intermediate trade
	|

share of selfemp capital income i[ind]=
	ZIDZ(selfemp share i[ind]*L i constrained[ind],sum(selfemp share i[ind!]*L i constrained
[
	ind!]))
	~	Dmnl
	~	Industry share of self-employment in total self-employment.
	|

share of trans use from imports[ffbio]=
	IF THEN ELSE(E transformation use before ESc[electricity ind,ffbio]+E transformation use before ESc imp
[electricity ind
	,ffbio]=0,0,
	E transformation use before ESc imp[electricity ind,ffbio]/
	(E transformation use before ESc[electricity ind,ffbio]+E transformation use before ESc imp
[electricity ind,ffbio])
	)
	~	Dmnl
	~		|

share threshold of direct and embedded emissions rq[regions,quintiles]=
	min(ZIDZ(active threshold progressive CT,per capita direct and embedded emissions C rq
	[regions,quintiles]),1)
	~	
	~		|

share yd dynamic[regions,quintiles]=
	yd dynamic rq hh[regions,quintiles]/(yd dynamic rq hh[regions,quintiles]+yd static rq hh
[regions,quintiles])
	~	
	~		~	:SUPPLEMENTARY 
	|

shares adjustment time=
	1
	~	Year
	~		|

shift delta lambda pos i[ind]=
	IF THEN ELSE(Time >= S Time Policy start,
	S shift delta lambda pos*sum(S shift delta lambda pos ON mi[macroind!]*ind to macroind map
[ind,macroind!]),
	0)
	~	
	~		|

shock inflation imp i[ind]=
	IF THEN ELSE(Time=10,p imp shock 21[ind],IF THEN ELSE(Time=11,p imp shock 22[ind],IF THEN ELSE
(Time=12,p imp shock 23[ind],0)))
	~	
	~	Note that p imp enters one period after in the price module (as p i  is a \
		stock variable), thus the shock enters one period before the actual period.
	|

shortfall c nom[ind]=
	desired c nom[ind]-c ESc nom bp i[ind]
	~	Euro/Year
	~		|

shortfall gov c nom[ind]=
	desired gov nom i[ind]-gov c nom i[ind]
	~	Euro/Year
	~		|

shortfall I supply nom[ind]=
	desired I supply nom[ind]-I supply nom i[ind]
	~	Euro/Year
	~		|

skill:
	low,
	mid,
	
	hig
	~	
	~		|

"skill & cap":
	skill, cap
	~	
	~		|

skill distribution demand initial is[ind,skill]=
	GET XLS CONSTANTS('?main', 'labour', 'skilldist_init')
	~	Dmnl
	~	Computed based on EU-KLEMS data.
		C, D, H subsectors take values from their parent sectors.
		Composite J_R_S and H_M_N sectors are means of their respective sectors weighted by \
		their gross output shares.
		Shares for T sector are computed using the shares and employment for the \
		whole economy (all sectors) and for industries only (sectors A-S).
	|

skill distribution trend is[ind,skill]=
	GET XLS CONSTANTS('?main', 'labour', 'skilldisttrend')
	~	Dmnl/Year
	~	Slope coefficients of time trend in linear regressions for the period \
		2010-2019. Shares compute based on EU-KLEMS data.
	~	:SUPPLEMENTARY 
	|

skill share 1524 gs[gender, skill]=
	(Skills 1524 gs[gender,skill]/sum(Skills 1524 gs[gender,skill!]))
	~	1
	~		|

skill share 2544 gs[gender,skill]=
	(Skills 2544 gs[gender,skill]/sum(Skills 2544 gs[gender,skill!]))
	~	1
	~		|

skill share 4564 gs[gender,skill]=
	(Skills 4564 gs[gender,skill]/sum(Skills 4564 gs[gender,skill!]))
	~	1
	~		|

"skill share 65+ gs"[gender,skill]=
	("Skills 65+ gs"[gender,skill]/sum("Skills 65+ gs"[gender,skill!]))
	~	1
	~		|

skill share demand is[ind,skill] :EXCEPT:     [ind,mid]=
	max(min skill share[skill],min(max skill share[skill],
	
	skill share demand is delayed[ind,skill]
	+trend s impact delayed[skill]
	+lab prod change impact[ind,skill]*(
	
	IF THEN ELSE(flag exogenous labour productivity i[ind]<>0,
	delta exogenous lambda[ind],
	IF THEN ELSE(Act change labour productivity<>0,
	delta lambda pre exogenous scenario[ind],
	delta labour productivity[ind]))
	
	/initial lambda i[ind])
	)) ~~|
skill share demand is[ind,mid]=
	1-skill share demand is[ind,hig]-skill share demand is[ind,low]
	~	Dmnl [0,1]
	~	exogenous trend in changes in skill distribution per industry
		check job polarization!
	|

skill share demand is delayed[ind,skill]=
	DELAY FIXED( skill share demand is[ind,skill], delay time, skill distribution demand initial is
[ind
	,skill])
	~	1
	~		|

skill share demand T isv[ind,skill,techn] :EXCEPT:    [ind,mid,techn]=
	max(min skill share[skill],min(max skill share[skill],
	skill distribution demand initial is[ind,skill]+lab prod change impact[ind,skill]*ratio labour productivity T iv
[ind,techn])) ~~|
skill share demand T isv[ind,mid,techn]=
	1-skill share demand T isv[ind,hig,techn]-skill share demand T isv[ind,low,techn]
	~	Dmnl [0,1]
	~	exogenous trend in changes in skill distribution per industry
		check job polarization!
	|

skill share working age pop[skill]=
	sum(working age pop gs[gender!,skill])/sum(working age pop gs[gender!,skill!])
	~	1
	~		|

skill shares[skill]=
	sum(L is[ind!,skill])/sum(L is[ind!,skill!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

skill transformation JG adjustment time=
	1
	~	Year
	~		|

skill transition 1524 in[gender,mid]=
	Skills 1524 gs[gender,low]*S1 trend entry skill gs[p1524,gender,low] ~~|
skill transition 1524 in[gender,hig]=
	Skills 1524 gs[gender,mid]*S1 trend entry skill gs[p1524,gender,mid] ~~|
skill transition 1524 in[gender,low]=
	0
	~	People/Year
	~		|

skill transition 1524 out[gender,low]=
	Skills 1524 gs[gender,low]*S1 trend entry skill gs[p1524,gender,low] ~~|
skill transition 1524 out[gender,mid]=
	Skills 1524 gs[gender,mid]*S1 trend entry skill gs[p1524,gender,mid] ~~|
skill transition 1524 out[gender,hig]=
	0
	~	People/Year
	~		|

skill transition 2544 in[gender,mid]=
	IF THEN ELSE(u s[mid]<u s[low],
	Skills 2544 gs[gender,low]*sens skill cs[low,p2544]*(u s[low]-u s[mid])
	,0)
	
	+IF THEN ELSE(u s[hig]<u s[low],
	Skills 2544 gs[gender,low]*sens skill cs[low,p2544]*(u s[low]-u s[hig])
	,0) ~~|
skill transition 2544 in[gender,hig]=
	IF THEN ELSE(u s[hig]<u s[mid],
	Skills 2544 gs[gender,mid]*sens skill cs[mid,p2544]*(u s[mid]-u s[hig])
	,0) ~~|
skill transition 2544 in[gender,low]=
	0
	~	People/Year
	~		|

skill transition 2544 out[gender,low]=
	IF THEN ELSE(u s[mid]<u s[low],
	Skills 2544 gs[gender,low]*sens skill cs[low,p2544]*(u s[low]-u s[mid])
	,0)
	
	+IF THEN ELSE(u s[hig]<u s[low],
	Skills 2544 gs[gender,low]*sens skill cs[low,p2544]*(u s[low]-u s[hig])
	,0) ~~|
skill transition 2544 out[gender,mid]=
	IF THEN ELSE(u s[hig]<u s[mid],
	Skills 2544 gs[gender,mid]*sens skill cs[mid,p2544]*(u s[mid]-u s[hig])
	,0) ~~|
skill transition 2544 out[gender,hig]=
	0
	~	People/Year
	~		|

skill transition 4564 in[gender,mid]=
	IF THEN ELSE(u s[mid]<u s[low],
	Skills 4564 gs[gender,low]*sens skill cs[low,p4564]*(u s[low]-u s[mid])
	,0)
	
	+IF THEN ELSE(u s[hig]<u s[low],
	Skills 4564 gs[gender,low]*sens skill cs[low,p4564]*(u s[low]-u s[hig])
	,0) ~~|
skill transition 4564 in[gender,hig]=
	IF THEN ELSE(u s[hig]<u s[mid],
	Skills 4564 gs[gender,mid]*sens skill cs[mid,p4564]*(u s[mid]-u s[hig])
	,0) ~~|
skill transition 4564 in[gender,low]=
	0
	~	People/Year
	~		|

skill transition 4564 out[gender,low]=
	IF THEN ELSE(u s[mid]<u s[low],
	Skills 4564 gs[gender,low]*sens skill cs[low,p4564]*(u s[low]-u s[mid])
	,0)
	
	+IF THEN ELSE(u s[hig]<u s[low],
	Skills 4564 gs[gender,low]*sens skill cs[low,p4564]*(u s[low]-u s[hig])
	,0) ~~|
skill transition 4564 out[gender,mid]=
	IF THEN ELSE(u s[hig]<u s[mid],
	Skills 4564 gs[gender,mid]*sens skill cs[mid,p4564]*(u s[mid]-u s[hig])
	,0) ~~|
skill transition 4564 out[gender,hig]=
	0
	~	People/Year
	~		|

Skills 1524 gs[gender,skill]= INTEG (
	in skills 1425 gs[gender,skill]*fraction non capitalists
	- in skills 2544 gs[gender,skill] - deaths 1524 gs[gender,skill]
	-skill transition 1524 out[gender,skill]
	+skill transition 1524 in[gender,skill]
	+net migration skills 1524[gender,skill]*fraction non capitalists
	+JG transition 1524[gender,skill],
		Pop 1524 g[gender]*init distr skill cgs[p1524,gender,skill]*fraction non capitalists
)
	~	People
	~		|

Skills 2544 gs[gender,skill]= INTEG (
	in skills 2544 gs[gender,skill]-in skills 4564 gs[gender,skill]-deaths 2544 gs[gender
	,skill]
	+skill transition 2544 in[gender,skill]
	-skill transition 2544 out[gender,skill]
	+net migration skills 2544[gender,skill]*fraction non capitalists
	+JG transition 2544[gender,skill]
	,
		Pop 2544 g[gender]*init distr skill cgs[p2544,gender,skill]*fraction non capitalists
)
	~	People
	~		|

Skills 4564 gs[gender,skill]= INTEG (
	+in skills 4564 gs[gender,skill]-"in skills 65+ gs"[gender,skill]-deaths 4564 gs[gender
	,skill]
	+skill transition 4564 in[gender,skill]
	-skill transition 4564 out[gender,skill]
	+net migration skills 4564[gender,skill]*fraction non capitalists
	+JG transition 4564[gender,skill]
	,
		Pop 4564 g[gender]*init distr skill cgs[p4564,gender,skill]*fraction non capitalists
)
	~	People
	~		|

"Skills 65+ gs"[gender,skill]= INTEG (
	+"in skills 65+ gs"[gender,skill]-"deaths 65+ gs"[gender,skill]
	+"net migration skills 65+"[gender,skill]*fraction non capitalists
	,
		"Pop 65+ g"[gender]*init distr skill cgs[p65,gender,skill]*fraction non capitalists
)
	~	People
	~		|

smooth expectations time=
	5
	~	Year
	~		|

soc sec contr e gis[gender,ind,skill]=
	gross annual income e gis[gender,ind,skill]*ss rate employee
	~	Euro/Person/Year
	~	individual compulsory scial security contributsions
	|

soc sec contr employer gis[gender,ind,skill]=
	gross annual income e gis[gender,ind,skill]*ss rate employer
	~	Euro/Year/Person
	~	social secutity contributions from employers per individual
	|

soc sec contr from households=
	sum(L gis[gender!,ind!,skill!]*soc sec contr e gis[gender!,ind!,skill!])
	~	
	~		|

soc sec employee=
	sum(soc sec contr e gis[gender!,ind!,skill!]*L gis[gender!,ind!,skill!])
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

soc sec employer=
	sum(soc sec contr employer gis[gender!,ind!,skill!]*L gis[gender!,ind!,skill!])
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

soc sec rev=
	(sum(soc sec contr employer gis[gender!,ind!,skill!]*L gis[gender!,ind!,skill!])
	+sum(soc sec contr e gis[gender!,ind!,skill!]*L gis[gender!,ind!,skill!]))
	~	Euro/Year
	~	government revenue from social security contributions:
		sum(soc_sec_contr_employer_gis[gender!,ind!,skill!]*L_gis[gender!,ind!,skill!])
		+sum(soc_sec_contr_e_gis[gender!,ind!,skill!]*L_gis[gender!,ind!,skill!])
		+sum(soc_sec_contr_u_gs[gender!,skill!]*L_u_gs[gender!,skill!])
		+sum(soc_sec_contr_p_gs[gender!,skill!]*"Skills_65+_gs"[gender!,skill!])
	|

solid bio share of wastebio=
	IF THEN ELSE(Time+initial year<=last year wastebio shares,
	
	solid bio share of wastebio lookup(Time+initial year),
	
	solid bio share of wastebio lookup(last year wastebio shares))
	~	Dmnl
	~		|

solid bio share of wastebio lookup(
	GET XLS LOOKUPS('?main', 'electricity' , 'time_bio' , 'share_wastebio_solid' ))
	~	Dmnl
	~		|

spread 2021=
	0.013
	~	1/Year
	~		|

spread 2021 adjusted=
	(spread 2021
	-
	final spread b*(1-convergence 11))
	/(convergence 11)
	~	
	~		|

spread b=
	init spread b + (spread 2021 adjusted-init spread b)*min(1,Time/11)
	+
	(final spread b -(init spread b + (spread 2021 adjusted-init spread b)*min(1,Time/11
)))*(1-convergence)
	~	
	~		|

spread b input=
	GET XLS LOOKUPS('?main' , 'finance' , 'time_spread' ,'spread_b' )
	~	
	~		|

SRF paid=
	sum(embedded usrf bp nom paid[ind!]*final demand nom i[ind!])
	~	
	~		|

SRF paid alt=
	sum(embedded usrf bp nom paid[ind!]*I supply real i[ind!]*p i[ind!]*(1-share imp GFCF i
[ind!]))
	+
	sum(embedded usrf bp nom paid[ind!]*gov c nom i[ind!]*(1-share imp gov i[ind!]))
	
	+
	sum((c ESc pp i[ind!]-substitution spending hhs pp[ind!])*embedded u srf pp paid[ind
!]/(1+tls[ind!]))
	+
	sum(embedded usrf bp nom paid[ind!]* ex ESc nom i[ind!])
	~	Euro/Year
	~		|

SRF paid alt check=
	SRF supply side-SRF paid alt
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

SRF paid check=
	SRF paid-SRF supply side
	~	
	~		~	:SUPPLEMENTARY 
	|

srf phaseout year=
	30
	~	Year
	~		|

SRF supply side=
	sum(u SRF change cumulative[ind!]*y real i[ind!])
	~	Euro/Year
	~		|

ss rate employee=
	S1 ss rate employee*IF THEN ELSE(Time<S Time Policy start,
	                1,
	                1+min(S Time end-S Time Policy start,Time-S Time Policy start)*(S ss rate employee
/(S Time end-S Time Policy start))
	                )
	~	percentage
	~	social security contribution rate of employees
	|

ss rate employer=
	S1 ss rate emplyer*IF THEN ELSE(Time<S Time Policy start,
	                1,
	                1+min(S Time end-S Time Policy start,Time-S Time Policy start)*(S ss rate employer
/(S Time end-S Time Policy start))
	                )
	~	percentage
	~	social security contribution rate of employers
	|

steepness logistic curve=
	0.4
	~	Dmnl
	~		|

storage capacity[storage technologies]= INTEG (
	storage capacity almost constructed investment[storage technologies]-storage depreciation
[storage technologies],
		init storage capacity[storage technologies])
	~	GW
	~	Capital stock of storage technologies.
	|

storage capacity almost constructed investment[storage technologies] :EXCEPT:   [batteries
]=
	storage capacity almost constructed investment nonBatteries[storage technologies] ~~|
storage capacity almost constructed investment[batteries]=
	storage investment[batteries]
	~	GW/Year
	~		|

storage capacity almost constructed investment nonBatteries[storage technologies]= DELAY FIXED
 (
	 storage investment[storage technologies], storage construction time[storage technologies
]-Year 1, constructed storage investment initial
	[storage technologies])
	~	GW/Year
	~		|

storage capacity depreciation 1 year ahead[storage technologies]=
	storage depreciation[storage technologies]
	~	GW/Year
	~		|

storage capacity depreciation 2 years ahead[storage technologies]= DELAY FIXED (
	storage capacity depreciation 3 years ahead[storage technologies],Year 1,(init storage capacity
[storage technologies]/storage lifetime[storage technologies]))
	~	GW/Year
	~		|

storage capacity depreciation 3 years ahead[storage technologies]= DELAY FIXED (
	storage capacity depreciation 4 years ahead[storage technologies],Year 1,(init storage capacity
[storage technologies]/storage lifetime[storage technologies]))
	~	GW/Year
	~		|

storage capacity depreciation 4 years ahead[storage technologies]= DELAY FIXED (
	storage capacity depreciation 5 years ahead[storage technologies],Year 1,(init storage capacity
[storage technologies]/storage lifetime[storage technologies]))
	~	GW/Year
	~		|

storage capacity depreciation 5 years ahead[storage technologies]= DELAY FIXED (
	 storage capacity almost constructed investment[storage technologies], storage lifetime
[storage technologies]-Year 1*4,
	(init storage capacity[storage technologies]/storage lifetime[storage technologies])
)
	~	GW/Year
	~		|

storage capacity investment costs topay[storage technologies]=
	storage new capacity investment costs[storage technologies]*Year 1+storage ongoing investment financing
[storage technologies
	]
	~	Euro constant/Year
	~	We assume a linear expense schedule of investment costs over the time of \
		construction.
	|

storage capacity investment desired[storage technologies]=
	max(required storage capacity expected[storage technologies]-expected storage capacity ahead wo investment
[storage technologies],0)
	~	GW/Year
	~		|

storage capacity supply[ind]=
	storage capacity investment costs topay[batteries]*gfcf shares battery[ind]+
	storage capacity investment costs topay[power2gas]*gfcf shares p2g[ind]
	+storage capacity investment costs topay[e hydro]*gfcf shares electricity[ind,e hydro
]
	~	Euro constant/Year
	~		|

storage charge a[storage technologies] :EXCEPT:      [power2gas]=
	min(desired storage*current charge share by technology[storage technologies],current capacity factor storage
[storage technologies
	]*hours in year*storage capacity
	[storage technologies]) ~~|
storage charge a[power2gas]=
	min(desired storage*current charge share by technology[power2gas],
	min(current capacity factor storage[power2gas]*hours in year*storage capacity[power2gas
],
	current capacity factor[e gas]*hours in year*production capacity[e gas]*(1-current gas generation to gas production shares
)
	/efficiency by storage technology[power2gas]
	))
	~	GW*h/Year
	~		|

storage charge deficit by technology[storage technologies]=
	max(desired storage*current charge share by technology[storage technologies]
	-current capacity factor storage[storage technologies]*hours in year*storage capacity
	[storage technologies],0)
	~	GW*h/Year
	~		|

storage charge share=
	sum(storage charge a[storage technologies!])/desired electricity generation
	~	
	~		|

storage completely financed[storage technologies]=
	IF THEN ELSE(storage construction time[storage technologies]=1,
	storage new capacity investment costs[storage technologies],
	storage completely financed as delay[storage technologies]
	)
	~	Euro constant/(Year*Year)
	~	We assume a linear expense schedule of investment costs over the time of \
		construction.
		As the min delay time is TIMESTEP, for technologies with a construction \
		time of 1 year or less, the formulation avoids the delay.
	|

storage completely financed as delay[storage technologies]= DELAY FIXED (
	storage new capacity investment costs[storage technologies], storage construction time
[storage technologies]-Year 1, 
	0)
	~	Euro constant/(Year*Year)
	~		|

storage construction time[storage technologies]=
	5,
	1,
	2
	~	Year
	~	PHS same as hydro
		https://lorenz-g.github.io/tesla-megapack-tracker/all-big-batteries.html: \
		Sample of biggest batteries, none take longer than 12 months construction \
		time.
	|

storage depreciation[storage technologies]=
	DELAY FIXED(storage capacity almost constructed investment[storage technologies], storage lifetime
[storage technologies] , (init storage capacity[storage technologies]/storage lifetime
[storage technologies]))
	~	GW/Year
	~	Storage depreciation, as a pipeline delay. Initial capacity linearly \
		depreciates and is fully depreciated, once the pipeline delay kicks in.
	|

storage discharge a[storage technologies]=
	storage charge a[storage technologies]*efficiency by storage technology[storage technologies
]
	~	GW*h/Year
	~		|

storage discharge deficit by technology[storage technologies]=
	storage charge deficit by technology[storage technologies]*efficiency by storage technology
[storage technologies]
	~	GW*h/Year
	~		|

storage expected investments ahead[storage technologies]=
	IF THEN ELSE(storage construction time[storage technologies]=2,
	storage investment delayed 1[storage technologies],
	
	IF THEN ELSE(storage construction time[storage technologies]=3,
	storage investment delayed 1[storage technologies]+storage investment delayed 2[storage technologies
],
	
	IF THEN ELSE(storage construction time[storage technologies]=4,
	storage investment delayed 1[storage technologies]+storage investment delayed 2[storage technologies
]+storage investment delayed 3[storage technologies],
	
	IF THEN ELSE(storage construction time[storage technologies]=5,
	storage investment delayed 1[storage technologies]+storage investment delayed 2[storage technologies
]+storage investment delayed 3[storage technologies]+storage investment delayed 4[storage technologies
],
	
	0)
	)
	)
	)
	~	GW/Year
	~		|

storage investment[storage technologies]=
	max(min(storage capacity investment desired[storage technologies],scale constraint multiplier
*storage max investment scale
	[storage technologies]),0)*financial constraint factor electricity
	~	GW/Year
	~	Actual investment in storage, desired investment is constrained by \
		financial resources and a maximum expansion of scale. These constraints \
		can be switched off/on.
	|

storage investment costs[storage technologies]=
	storage investment[batteries]*storage investment costs per unit capacity[storage technologies
]
	~	Euro constant/Year
	~	We assume a linear expense schedule of investment costs over the time of \
		construction. But since construction time is only 1 year all is being paid \
		at the moment of investment.
	|

storage investment costs per capacity initial[e hydro]=
	capacity investment costs per unit capacity initial[e hydro] ~~|
storage investment costs per capacity initial[power2gas]=
	p2g investment costs init ~~|
storage investment costs per capacity initial[batteries]=
	battery investment costs per capacity initial
	~	Euro constant/GW
	~		|

storage investment costs per unit capacity[e hydro]=
	capacity investment costs per unit capacity[e hydro] ~~|
storage investment costs per unit capacity[batteries]=
	battery investment costs per unit capacity ~~|
storage investment costs per unit capacity[power2gas]=
	p2g investment costs per unit capacity
	~	Euro constant/GW
	~		|

storage investment delayed 1[storage technologies]= DELAY FIXED (
	storage investment[storage technologies], Year 1 , 0)
	~	GW/Year
	~		|

storage investment delayed 2[storage technologies]= DELAY FIXED (
	storage investment delayed 1[storage technologies], Year 1 , 0)
	~	GW/Year
	~		|

storage investment delayed 3[storage technologies]= DELAY FIXED (
	storage investment delayed 2[storage technologies], Year 1 , 0)
	~	GW/Year
	~		|

storage investment delayed 4[storage technologies]= DELAY FIXED (
	storage investment delayed 3[storage technologies], Year 1 , 0)
	~	GW/Year
	~		|

storage lifetime[storage technologies]=
	80,
	10,
	20
	~	Year
	~	IEA data (IEA costs of electricity report \
		(https://www.iea.org/reports/projected-costs-of-generating-electricity-2020\
		)).
		PHS as hydro
	|

storage loss a=
	sum((1-efficiency by storage technology[storage technologies!])*storage charge a[storage technologies
!])
	~	GW*h/Year
	~		|

storage max investment scale[storage technologies]=
	max(max scale increase storage[storage technologies]*smooth(storage capacity[storage technologies
],scale impacts adjustment time
	),
	min max scale increase)
	~	GW/Year
	~	The maximum amount that capacity can increase within a year due to limited \
		production capabilities. This reflects, capital stock expansions are \
		limited by current infrastructure on the goround and that the larger the \
		capacity is, the larger its absolute increase can be due to more expansive \
		infrastructure. The smooth function reflects that this infrastructure does \
		not immediately materialise with added capacity, but slowly builds up over \
		time.
		battery capacity for learning init is not installed capacity in Italy but \
		taken from ETRI, 2014. Thus, we assume that scale effects initial refer to \
		this value until actual capacity exceeds it.
	|

storage new capacity investment costs[storage technologies]=
	storage investment costs[storage technologies]/storage construction time[storage technologies
]
	~	Euro constant/(Year*Year)
	~	We assume a linear expense schedule of investment costs over the time of \
		construction.
	|

storage ongoing investment financing[storage technologies]= INTEG (
	storage new capacity investment costs[storage technologies]-storage completely financed
[storage technologies],
		0)
	~	Euro constant/Year
	~	We assume a linear expense schedule of investment costs over the time of \
		construction.
	|

storage shortfall for max generation=
	VECTOR SELECT(current charge share by technology[storage technologies!] , storage shortfall for max generation by technology
	[storage technologies!], 
	0 , 8,1 )
	~	Dmnl
	~	we assume fixed fractions so that most limiting technology limits whole \
		system and not another storage technology can compensate due to their \
		different characteristics
	|

storage shortfall for max generation by technology[storage technologies]=
	min(1,
	ZIDZ(max storage discharge by technology[storage technologies],(required storage discharge for max generation
*current charge share by technology[storage technologies])))
	~	Dmnl
	~		|

storage technologies:
	e hydro, batteries, power2gas
	~	
	~		|

Subs RES fossil SRF i[ind] :EXCEPT:      [mining],[petroleum],[electricity ind],[transport
]=
	0 ~~|
Subs RES fossil SRF i[mining]=
	IF THEN ELSE(Time <S Time Policy start,0,
	Act RES public*(exog fund VAT*y nom i[mining]/(y nom i[mining]+y nom i[petroleum]+y nom i
[electricity ind]+y nom i[transport])
	+ exog fund Enrg*y nom i[mining]/(y nom i[mining]+y nom i[petroleum]+y nom i[electricity ind
]))
	) ~~|
Subs RES fossil SRF i[petroleum]=
	IF THEN ELSE(Time <S Time Policy start, 0,
	Act RES public*(exog fund VAT*y nom i[petroleum]/(y nom i[mining]+y nom i[petroleum]
+y nom i[electricity ind]+y nom i[transport])+
	exog fund Enrg*y nom i[petroleum]/(y nom i[mining]+y nom i[petroleum]+y nom i[electricity ind
]))
	) ~~|
Subs RES fossil SRF i[electricity ind]=
	IF THEN ELSE(Time <S Time Policy start,0,
	Act RES public*(exog fund VAT*y nom i[electricity ind]/(y nom i[mining]+y nom i[petroleum
]+y nom i[electricity ind]+y nom i[transport])+
	exog fund Enrg*y nom i[electricity ind]/(y nom i[mining]+y nom i[petroleum]+y nom i[
electricity ind]))
	) ~~|
Subs RES fossil SRF i[transport]=
	IF THEN ELSE(Time <S Time Policy start,0, 
	Act RES public*(exog fund VAT*y nom i[transport]/(y nom i[mining]+y nom i[petroleum]
+y nom i[electricity ind]+y nom i[transport])
	+exog fund Transport)
	)
	~	Euro/Year
	~		|

Subs RES fossil SRF init[ind] :EXCEPT:         [mining],[petroleum],[electricity ind]
,[transport]=
	0 ~~|
Subs RES fossil SRF init[mining]=
	Act SRF*(exog fund VAT*y real init[mining]/(y real init[mining]+y real init[petroleum
]+y real init[electricity ind
	]+y real init[transport
	])
	+ exog fund Enrg*y real init[mining]/(y real init[mining]+y real init[petroleum]+y real init
[electricity ind])) ~~|
Subs RES fossil SRF init[petroleum]=
	Act SRF*(exog fund VAT*y real init[petroleum]/(y real init[mining]+y real init[petroleum
]+y real init[electricity ind
	]+y real init[transport
	])+
	exog fund Enrg*y real init[petroleum]/(y real init[mining]+y real init[petroleum]+y real init
[electricity ind])) ~~|
Subs RES fossil SRF init[electricity ind]=
	Act SRF*(exog fund VAT*y real init[electricity ind]/(y real init[mining]+y real init
[petroleum]+y real init[electricity ind
	]+y real init
	[transport])+
	exog fund Enrg*y real init[electricity ind]/(y real init[mining]+y real init[petroleum
]+y real init[electricity ind])) ~~|
Subs RES fossil SRF init[transport]=
	Act SRF*(exog fund VAT*y real init[transport]/(y real init[mining]+y real init[petroleum
]+y real init[electricity ind
	]+y real init[transport
	])
	+exog fund Transport)
	~	Euro/Year
	~		|

substitution emissions hhs=
	sum(per unit emissions hh[ind!]*shortfall c nom[ind!]/p i[ind!])
	~	tCO2eq/Year
	~		|

substitution energy use hhs[nrg]=
	sum(per unit end use hhs[ind!,nrg]*shortfall c nom[ind!]/p i[ind!])
	~	TJ/Year
	~		|

substitution imports[ind]=
	shortfall c nom[ind]+shortfall gov c nom[ind]+shortfall I supply nom[ind]
	~	Euro/Year
	~		|

substitution spending government=
	sum(shortfall gov c nom[ind!]*(1+tls gov[ind!]))
	~	Euro/Year
	~		|

substitution spending government real=
	sum(shortfall gov c nom[ind!]*(1+tls gov[ind!])/p i[ind!])
	~	Euro constant/Year
	~		|

substitution spending hhs pp[ind]=
	(shortfall c nom[ind]*(1+ttm[ind])
	-ttm shares[ind]*sum(ttm[ind!]*shortfall c nom[ind!]))
	*(1+tls[ind])
	~	Euro/Year
	~		|

substitution spending real gov i[ind]=
	shortfall gov c nom[ind]*(1+tls gov[ind])/(p i[ind])
	~	Euro constant/Year
	~		~	:SUPPLEMENTARY 
	|

substitution tls paid to domestic government gov=
	sum(shortfall gov c nom[ind!]*init tls gov)
	~	Euro/Year
	~		|

substitution tls paid to domestic government hhs cc=
	sum(direct ucc bp nom[ind!]*shortfall c nom[ind!])
	~	Euro/Year
	~		|

substitution tls paid to domestic government hhs no cc=
	sum(substitution spending hhs pp[ind!]*tls init[ind!]/(1+tls[ind!]))
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

