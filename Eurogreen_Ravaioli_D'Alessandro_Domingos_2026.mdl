wage gis cat[m households hig] = wage gis[male,households,hig]*actual hours i[households
]
	~	Euro/(Year*Person)
	~		|

wage gis delay[gender,ind,skill]= DELAY FIXED (
	wage gis[gender,ind,skill], 1, initial wage gis[gender,ind,skill])
	~	Euro/(Hours*Person)
	~		|

wage gis policy start delay[gender, skill, ind]=SAMPLE IF TRUE(
	Time=(S Time Policy start-1), wage gis[gender,ind,skill], 0)
	~	Euro/Person/Hour
	~		|

wage gs[gender,skill]=
	sum(wage gis[gender,ind!,skill]*L gis[gender,ind!,skill])/sum(L gis[gender,ind!,skill
])
	~	Euro/People/Hour
	~	mean hourly wages by gender and skill
	|

wage i[ind]=
	sum(wage gis[gender!,ind,skill!]*actual hours i[ind]*L gis[gender!,ind,skill!])/sum
	(actual hours i[ind]*L gis[gender!,ind,skill!])
	~	Euro/(Person*Hours)
	~	Mean wage in each industry
	|

wage i delay[ind]= DELAY FIXED (
	wage i[ind], 1, initial wage i[ind])
	~	Euro/(Person*Hours)
	~		|

wage JG=
	wage JG init*max(1,(1+(cumulative inflation since policy start-1)*omega price))
	~	Euro/Person/Hour
	~	hourly wage paid by the JG program
	|

wage JG init=
	12
	~	Euro/Person/Hour
	~		|

wage mi[macroind]=
	sum(wage i[ind!]*ind to macroind map[ind!,macroind]*tot hours i[ind!])/sum(tot hours i
[ind!]*ind to macroind map[ind!,macroind])
	~	Euro/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

wage ratio MAX to MIN=
	MAX wage all/MIN wage all
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

wage s mi[skill, macroind]=
	sum(wage gis[gender!,ind!,skill]*actual hours i[ind!]*L gis[gender!,ind!,skill]*ind to macroind map
[ind!,macroind])/
	sum(actual hours i[ind!]*L gis[gender!,ind!,skill]*ind to macroind map[ind!,macroind
])
	~	Euro/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

wage scarcity adjustment[skill]=
	0.5
	~	
	~	firms adjust skill specific wages to the level of the industry with the \
		lowest wage that does not face constraints on this skill level
	|

wage si[skill, ind]=
	sum(wage gis[gender!,ind,skill]*actual hours i[ind]*L gis[gender!,ind,skill])/sum
	(actual hours i[ind]*L gis[gender!,ind,skill])
	~	Euro/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

wage WTR gov total cost=
	sum(level WTR gov paid i[ind!])
	~	Euro/Year
	~		|

wages initial gis[male,ind,skill]=
	GET XLS CONSTANTS('?main', 'labour', 'winitm') ~~|
wages initial gis[female,ind,skill]=
	GET XLS CONSTANTS('?main', 'labour', 'winitf')
	~	Euro
	~	Initial wages computed from EU-SILC data.
		Sectors not disaggregated in EU-SILC survey take the same value of the corresponding \
		sector.
		Composite sectors (J_R_S and H_M_N) take average values from the \
		corresponding sectors in EU-SILC survey, weighted by the employment shares \
		in EU-KLEMS data.
	|

wastebio share of nec=
	(1-RES transition)*wastebio share of nec no RES
	+RES transition*wastebioshare of nec RES
	~	Dmnl
	~		|

wastebio share of nec final=
	0.88069
	~	Dmnl
	~		|

wastebio share of nec lookup=
	GET XLS LOOKUPS('?main', 'electricity' , 'time_bio' , 'share_nec_wastebio' )
	~	Dmnl
	~		|

wastebio share of nec no RES=
	IF THEN ELSE(Time+initial year<=last year wastebio shares,
	
	wastebio share of nec lookup(Time+initial year),
	
	wastebio share of nec lookup(last year wastebio shares))
	~	Dmnl
	~		|

wastebioshare of nec RES=
	IF THEN ELSE(Time<S Time Policy start,wastebio share of nec no RES,
	
	wastebio share of nec no RES+
	(wastebio share of nec final-wastebio share of nec no RES)/
	(1+EXP(-steepness logistic curve*(Time-midpoint logistic curve))))
	~	Dmnl
	~		|

WB aids adjusted intercepts[regions,quintiles,ind]=
	init beta i[regions,quintiles,ind]
	-WB aids income coefficients[ind]*ln(init yd hhs rq[regions,quintiles])
	-WB aids income squared coefficients[ind]*ln(init yd hhs rq[regions,quintiles])^2
	-sum(WB aids wb coefficients[ind,wellbeing!]*Initial wellbeing indicators[regions,quintiles
,wellbeing!])
	~	
	~		|

WB aids income coefficients[ind]=
	GET XLS CONSTANTS( '?wb' , 'wellbeing' , 'coeff_inc_wb*' )
	~	
	~		|

WB aids income squared coefficients[ind]=
	GET XLS CONSTANTS( '?wb' , 'wellbeing' , 'coeff_inc2_wb*' )
	~	
	~		|

WB aids price coefficients[ind,toind]=
	GET XLS CONSTANTS( '?wb' , 'wellbeing' , 'coeff_prices_wb' )
	~	
	~		|

WB aids wb coefficients[ind,wellbeing]=
	GET XLS CONSTANTS( '?wb' , 'wellbeing' , 'wb_coefficients' )
	~	
	~		|

WB beta aids[regions,quintiles,ind]=
	max(0,WB aids adjusted intercepts[regions,quintiles,ind]
	+sum(WB aids price coefficients[ind,toind!]*ln(price index pp i delay[toind!]))
	+WB aids income coefficients[ind]*ln(expected yd rq real[regions,quintiles])
	+WB aids income squared coefficients[ind]*ln(expected yd rq real[regions,quintiles])
	^2)
	+sum(WB aids wb coefficients[ind,wellbeing!]*Wellbeing indicators rq[regions,quintiles
,wellbeing!])
	~	
	~		|

WB check beta aids[regions,quintiles]=
	sum(WB beta aids[regions,quintiles,ind!])
	~	
	~		|

wealth tax rate=
	0
	~	Dmnl/Year
	~	IF THEN ELSE(Act wealth tax=1,
		BI exp/sum(tot W[assets!]),0)
		
		*ramp(0.33,11,13)
		
		+IF THEN ELSE(Act WTR wage=1,
		(wage WTR gov total cost/sum(tot W[assets!])),0)
		
		+IF THEN ELSE(Act Job Guarantee=1,(total cost JG/sum(tot W[assets!])),0)
	|

wealth tax revenue=
	wealth tax rate*(sum(d gs[gender!,skill!])+sum(b gs[gender!,skill!])+sum(eq gs[gender
!,skill!])+d cap+b cap+eq cap)
	~	Euro/Year
	~		|

weekly hours=
	40
	~	Hours
	~		|

wellbeing:
	relationship,
	trust,
	access,
	neighbquality,
	environment,
	discrtime,
	discrtime sq,
	gini peer
	~	
	~		|

wellbeing indicators delay[regions,quintiles,wellbeing]= DELAY FIXED (
	Wellbeing indicators rq[regions,quintiles,wellbeing], 1 , Initial wellbeing indicators
[
regions,quintiles,wellbeing])
	~	
	~		|

Wellbeing indicators r[regions,wellbeing]=
	sum(Wellbeing indicators rq[regions,quintiles!,wellbeing]*num hhs rq delayed[regions
,quintiles!])/
	sum(num hhs rq delayed[regions,quintiles!])
	~	
	~		|

Wellbeing indicators rq[regions,quintiles,relationship]=
	Initial wellbeing indicators[regions,quintiles,relationship]
	+(coeff discrtime rel*
	(Wellbeing indicators rq[regions,quintiles,discrtime]-Initial wellbeing indicators[regions
	,quintiles,discrtime])
	+coeff discrtime2 rel*
	(Wellbeing indicators rq[regions,quintiles,discrtime sq]-Initial wellbeing indicators
[regions
	,quintiles,discrtime sq])) ~~|
Wellbeing indicators rq[regions,quintiles,trust]=
	Initial wellbeing indicators[regions,quintiles,trust] ~~|
Wellbeing indicators rq[regions,quintiles,access]=
	min(wellbeing indicators delay[regions,quintiles,access]
	*(1+max(Effect of public expenditure on access*
	per capita pub exp on access growth*Act Increase Access
	,0)),3) ~~|
Wellbeing indicators rq[regions,quintiles,neighbquality]=
	Initial wellbeing indicators[regions,quintiles,neighbquality] ~~|
Wellbeing indicators rq[regions,quintiles,environment]=
	min(4,
	Initial wellbeing indicators[regions,quintiles,environment]+
	((1/Life satisfaction coefficients[environment])*Env satisf to emissions ratio inital
[regions,quintiles]
	*(10/3)*(total emissions delay^Life satisfaction pollution elasticity
	-total emissions init exog^Life satisfaction pollution elasticity))) ~~|
Wellbeing indicators rq[regions,quintiles,discrtime]=
	Initial wellbeing indicators[regions,quintiles,discrtime]*
	(1-WTR impact on discretionary time[regions,quintiles]*
	(sum(hours i[ind!])/sum(S1 hours i[ind!])-1)*100) ~~|
Wellbeing indicators rq[regions,quintiles,discrtime sq]=
	(Wellbeing indicators rq[regions,quintiles,discrtime]^2
	+(Initial wellbeing indicators[regions,quintiles,discrtime sq]
	-Initial wellbeing indicators[regions,quintiles,discrtime]^2)) ~~|
Wellbeing indicators rq[regions,quintiles,gini peer]=
	Initial gini to palma ratio rq[regions,quintiles]*Palma ratio region delay[regions]
	~	Score
	~		|

workers shortage s[skill]=
	IF THEN ELSE(difference L supply demand s[skill]<0,
	-difference L supply demand s[skill],
	0)
	~	Person/Year
	~	It represents the number of workers missing to cover the shortage when in \
		full employment constraint is active
	|

working age check=
	sum(pop d working age gs[gender!,skill!]) - working age pop cgs total
	~	People
	~		~	:SUPPLEMENTARY 
	|

working age pop cgs total=
	sum(Working age population cgs[cohorts!,gender!,skill!])
	~	
	~		|

working age pop g[gender]=
	Pop 1524 g[gender]+Pop 2544 g[gender]+Pop 4564 g[gender]
	~	People
	~		|

working age pop gs[gender,skill]=
	Skills 1524 gs[gender,skill]+Skills 2544 gs[gender,skill]+Skills 4564 gs[gender,skill
]
	~	Person
	~		~	:SUPPLEMENTARY 
	|

working age pop total=
	sum(working age pop g[gender!])
	~	People
	~		|

Working age population cgs[p1524,gender,skill]=
	Skills 1524 gs[gender,skill] ~~|
Working age population cgs[p2544,gender,skill]=
	Skills 2544 gs[gender,skill] ~~|
Working age population cgs[p4564,gender,skill]=
	Skills 4564 gs[gender,skill] ~~|
Working age population cgs[cohorts,gender,skill] :EXCEPT:    [p1524,gender,skill],[p2544
,gender,skill],[p4564,gender,skill
]=
	0
	~	People
	~		|

working age population gs[gender,skill]=
	sum(Working age population cgs[cohorts!,gender,skill])
	~	People
	~		|

working days per week=
	5
	~	Days/Week
	~		|

working weeks per year=
	44.432
	~	Weeks/Year
	~		|

WTR impact on discretionary time[regions,quintiles]=
	GET XLS CONSTANTS( '?wb' , 'wellbeing' , 'wtr_discrtime_impact' )
	~	
	~	Percentage effect on mean discretionary time of a 1% reduction in mean \
		working time. Estimated from matched datasets HBS-AVQ-SHIW 2014-2016.
	|

y FC delayed[ind]=
	DELAY FIXED(y FC i[ind], Year 1, init FC)
	~	Euro constant/Year
	~		|

y FC electricity=
	potential demand met/electricity per output
	~	Euro constant/Year
	~		|

y FC electricity expected=
	potential demand met expected/electricity per output
	~	Euro constant/Year
	~		|

y FC expected[ind,techn] :EXCEPT: [electricity ind,techn]=
	capital expected[ind]*capital productivity T iv[ind,techn] ~~|
y FC expected[electricity ind,techn]=
	(1-electricity module switch)*
	capital expected[electricity ind]*capital productivity T iv[electricity ind,techn]+
	electricity module switch*y FC electricity expected
	~	Euro constant/Year
	~		|

y FC i[ind] :EXCEPT:    [electricity ind]=
	K i[ind]*capital productivity dynamic[ind] ~~|
y FC i[electricity ind]=
	(1-electricity module switch)*K i[electricity ind]*capital productivity dynamic[electricity ind
]+
	electricity module switch*y FC output constraint
	~	Euro constant/Year
	~	output under full capacity utilisation
	|

y FC output constraint=
	potential demand met/electricity per output delayed
	~	Euro constant/Year
	~		|

y FE delayed[ind]=
	DELAY FIXED(y FE i[ind], Year 1, init FC)
	~	Euro constant/Year
	~		|

y FE i[ind]=
	factor FE constraint*y real unconstrained i[ind]
	~	Euro constant/Year
	~		|

y initial i[ind]=
	5.1486e+10,
	8.4885e+09,
	7.6909e+11,
	5.50308e+10,
	7.18381e+10,
	6.19035e+10,
	1.96655e+10,
	3.55649e+08,
	4.07068e+10,
	2.53789e+11,
	3.21171e+11,
	1.08809e+11,
	9.84924e+10,
	2.08736e+11,
	1.32655e+11,
	2.18428e+11,
	3.25342e+11,
	1.36543e+11,
	7.45055e+10,
	1.4294e+11,
	1.80064e+10
	~	Euro constant/Year
	~	Modified to (21x1) vector; using IO -> Output (converted to euros and \
		multiplied by 1000000)
	~	:SUPPLEMENTARY 
	|

y nom i[ind]=
	y real i[ind]*p i[ind]
	~	Euro/Year
	~	Nominal output by industry
	|

y nom mi[macroind]=
	sum(y nom i[ind!]*ind to macroind map[ind!,macroind])
	~	Euro/Year
	~		|

y nom sh i[ind]=
	y nom i[ind]/tot y nom
	~	Dmnl
	~		|

y nom sh mi[macroind]=
	sum(y nom sh i[ind!]*ind to macroind map[ind!,macroind])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

y real delayed[ind]= DELAY FIXED (
	y real i[ind], Year 1, y real init[ind])
	~	Euro constant/Year
	~		|

y real delayed unconstrained[ind]= DELAY FIXED (
	y real unconstrained i[ind], Year 1, y real init[ind])
	~	Euro constant/Year
	~		|

y real i[ind]=
	sum(Leontief ii[ind,toind!]*final demand real i[toind!])
	~	Euro constant/Year
	~	21/05/24  y real unconstrained i[ind]*factor capacity constraint*factor FE constraint
		
		y real unconstrained i[ind]*factor capacity constraint*factor employment constraint
		
		Real output by industry: \
		min(sum(Leontief_ii[ind,toind!]*final_demand_real_i[toind!]),y_FC_i[ind])
	|

y real i 0[ind]=
	sum(Leontief ii[ind,toind!]*final demand real i[toind!])
	~	Euro constant/Year
	~		|

y real init[ind]=
	GET XLS CONSTANTS('?main', 'inputoutput', 'Output*')
	~	Euro constant/Year
	~		|

y real mi[macroind]=
	sum(ind to macroind map[ind!,macroind]*y real i 0[ind!])
	~	Euro constant/Year
	~		|

y real per worker=
	sum(y real per worker i[ind!]*L sh i[ind!])
	~	Euro constant/(Person*Year)
	~		|

y real per worker i[ind]=
	y real i[ind]/L constrained i[ind]
	~	Euro constant/(Person*Year)
	~		|

y real per worker mi[macroind]=
	sum(y real per worker i[ind!]*ind to macroind map[ind!,macroind]*L constrained i[ind
!])/sum(ind to macroind map
	[ind!,macroind]*L constrained i[ind!])
	~	Euro constant/(Person*Year)
	~		|

y real sh i[ind]=
	y real i 0[ind]/tot y real
	~	Dmnl
	~		|

y real sh mi[macroind]=
	sum(y real sh i[ind!]*ind to macroind map[ind!,macroind])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

y real target gov bs 6 i[ind]=
	L tot target gov bs 6 or 7 i[ind]*lambda i[ind]*hours i[ind]
	~	Euro constant/(Year)
	~		|

y real unconstrained i[ind]=
	sum(Leontief ii[ind,toind!]*desired domestic final demand real i[toind!])
	~	Euro constant/Year
	~	for capacity utilization
	|

yd after tls dec[deciles]=
	sum(yd rq after tls[regions!,quintiles!]*map rq dec[deciles,regions!,quintiles!])
	~	Euro/Year
	~		|

yd d[inc low u f]=
	NUB per unemployed person gs[female,low]
	+NFI per capita gs[female,low]
	+sd per cap
	+cb per capita gs[female,low]
	+mixed income per capita d[inc low u f]
	+CT redistrib per capita d delay[inc low u f]
	+BI per capita received
	+ JG income per unemployed person gs[female,low] ~~|
yd d[inc low u m]=
	NUB per unemployed person gs[male,low]
	+NFI per capita gs[male,low]
	+sd per cap
	+cb per capita gs[male,low]
	+mixed income per capita d[inc low u m]
	+ CT redistrib per capita d delay[inc low u m]
	+BI per capita received
	+ JG income per unemployed person gs[male,low] ~~|
yd d[inc mid u f]=
	NUB per unemployed person gs[female,mid]
	+NFI per capita gs[female,mid]
	+sd per cap
	+cb per capita gs[female,mid]
	+mixed income per capita d[inc mid u f]
	+ CT redistrib per capita d delay[inc mid u f]
	+BI per capita received
	+ JG income per unemployed person gs[female,mid] ~~|
yd d[inc mid u m]=
	NUB per unemployed person gs[male,mid]
	+NFI per capita gs[male,mid]
	+ sd per cap
	+cb per capita gs[male,mid]
	+ mixed income per capita d[inc mid u m]
	+ CT redistrib per capita d delay[inc mid u m]
	+BI per capita received
	+ JG income per unemployed person gs[male,mid] ~~|
yd d[inc hig u f]=
	NUB per unemployed person gs[female,hig]
	+NFI per capita gs[female,hig]
	+ sd per cap
	+cb per capita gs[female,hig]
	+ mixed income per capita d[inc hig u f]
	+ CT redistrib per capita d delay[inc hig u f]
	+BI per capita received
	+ JG income per unemployed person gs[female,hig] ~~|
yd d[inc hig u m]=
	NUB per unemployed person gs[male,hig]
	+NFI per capita gs[male,hig]
	+ sd per cap
	+cb per capita gs[male,hig]
	+ mixed income per capita d[inc hig u m]
	+ CT redistrib per capita d delay[inc hig u m]
	+BI per capita received
	+ JG income per unemployed person gs[male,hig] ~~|
yd d[inc low e f]=
	net labour income per capita gs[female,low]
	+NFI per capita gs[female,low]
	+ sd per cap
	+cb per capita gs[female,low]
	+ mixed income per capita d[inc low e f]
	+ CT redistrib per capita d delay[inc low e f]
	+BI per capita received ~~|
yd d[inc low e m]=
	net labour income per capita gs[male,low]
	+NFI per capita gs[male,low]
	+ sd per cap
	+cb per capita gs[male,low]
	+ mixed income per capita d[inc low e m]
	+ CT redistrib per capita d delay[inc low e m]
	+BI per capita received ~~|
yd d[inc mid e f]=
	net labour income per capita gs[female,mid]
	+NFI per capita gs[female,mid]
	+ sd per cap
	+cb per capita gs[female,mid]
	+ mixed income per capita d[inc mid e f]
	+ CT redistrib per capita d delay[inc mid e f]
	+BI per capita received ~~|
yd d[inc mid e m]=
	net labour income per capita gs[male,mid]
	+NFI per capita gs[male,mid]
	+ sd per cap
	+cb per capita gs[male,mid]
	+ mixed income per capita d[inc mid e m]
	+ CT redistrib per capita d delay[inc mid e m]
	+BI per capita received ~~|
yd d[inc hig e f]=
	net labour income per capita gs[female,hig]
	+NFI per capita gs[female,hig]
	+ sd per cap
	+cb per capita gs[female,hig]
	+ mixed income per capita d[inc hig e f]
	+ CT redistrib per capita d delay[inc hig e f]
	+BI per capita received ~~|
yd d[inc hig e m]=
	net labour income per capita gs[male,hig]
	+NFI per capita gs[male,hig]
	+ sd per cap
	+cb per capita gs[male,hig]
	+ mixed income per capita d[inc hig e m]
	+ CT redistrib per capita d delay[inc hig e m]
	+BI per capita received ~~|
yd d[inc low o f]=
	NFI per capita gs[female,low]
	+ sd per cap
	+cb per capita gs[female,low]
	+ other benefits per cap
	+ mixed income per capita d[inc low o f]
	+ CT redistrib per capita d delay[inc low o f]
	+BI per capita received ~~|
yd d[inc low o m]=
	NFI per capita gs[male,low]
	+ sd per cap
	+cb per capita gs[male,low]
	+ other benefits per cap
	+ mixed income per capita d[inc low o m]
	+ CT redistrib per capita d delay[inc low o m]
	+BI per capita received ~~|
yd d[inc mid o f]=
	NFI per capita gs[female,mid]
	+ sd per cap
	+cb per capita gs[female,mid]
	+ mixed income per capita d[inc mid o f]+
	+ CT redistrib per capita d delay[inc mid o f]
	+BI per capita received ~~|
yd d[inc mid o m]=
	NFI per capita gs[male,mid]
	+ sd per cap
	+cb per capita gs[male,mid]
	+ mixed income per capita d[inc mid o m]
	+ CT redistrib per capita d delay[inc mid o m]
	+BI per capita received ~~|
yd d[inc hig o f]=
	NFI per capita gs[female,hig]
	+ sd per cap
	+cb per capita gs[female,hig]
	+ mixed income per capita d[inc hig o f]
	+ CT redistrib per capita d delay[inc hig o f]
	+BI per capita received ~~|
yd d[inc hig o m]=
	NFI per capita gs[male,hig]
	+ sd per cap
	+cb per capita gs[male,hig]
	+ mixed income per capita d[inc hig o m]
	+ CT redistrib per capita d delay[inc hig o m]
	+BI per capita received ~~|
yd d[inc low p f]=
	NPB per capita gs[female,low]
	+NFI per capita gs[female,low]
	+ mixed income per capita d[inc low p f]+
	+ CT redistrib per capita d delay[inc low p f]
	+BI per capita received ~~|
yd d[inc low p m]=
	NPB per capita gs[male,low]
	+NFI per capita gs[male,low]
	+ mixed income per capita d[inc low p m]
	+ CT redistrib per capita d delay[inc low p m]
	+BI per capita received ~~|
yd d[inc mid p f]=
	NPB per capita gs[female,mid]
	+NFI per capita gs[female,mid]
	+ mixed income per capita d[inc mid p f]
	+ CT redistrib per capita d delay[inc mid p f]
	+BI per capita received ~~|
yd d[inc mid p m]=
	NPB per capita gs[male,mid]
	+NFI per capita gs[male,mid]
	+ mixed income per capita d[inc mid p m]
	+ CT redistrib per capita d delay[inc mid p m]
	+BI per capita received ~~|
yd d[inc hig p f]=
	NPB per capita gs[female,hig]
	+NFI per capita gs[female,hig]
	+ mixed income per capita d[inc hig p f]
	+ CT redistrib per capita d delay[inc hig p f]
	+BI per capita received ~~|
yd d[inc hig p m]=
	NPB per capita gs[male,hig]
	+NFI per capita gs[male,hig]
	+ mixed income per capita d[inc hig p m]
	+ CT redistrib per capita d delay[inc hig p m]
	+BI per capita received ~~|
yd d[inc cap]=
	NFI per capita cap
	+ mixed income per capita d[inc cap]
	+ CT redistrib per capita d delay[inc cap]
	+BI per capita received
	~	Euro/(Year*Person)
	~	individual disposable income by income category
		
		per capita child benefits were previously computed as:
		(ZIDZ(cb gs[female,low],L u gs[female,low])*People 1)
		+(ZIDZ(cb gs[male,low],L u gs[male,low])*People 1)
		+(ZIDZ(cb gs[female,mid],L u gs[female,mid])*People 1)
		+ (ZIDZ(cb gs[male,mid],L u gs[male,mid])*People 1)
		+ (ZIDZ(cb gs[female,hig],L u gs[female,hig])*People 1)
		+ (ZIDZ(cb gs[male,hig],L u gs[male,hig])*People 1)
		+ (ZIDZ(cb gs[female,low],L gs[female,low])*People 1)
		+ (ZIDZ(cb gs[male,low],L gs[male,low])*People 1)
		+ (ZIDZ(cb gs[female,mid],L gs[female,mid])*People 1)
		+ (ZIDZ(cb gs[male,mid],L gs[male,mid])*People 1)
		+ (ZIDZ(cb gs[female,hig],L gs[female,hig])*People 1)
		+ (ZIDZ(cb gs[male,hig],L gs[male,hig])*People 1)
		+ (ZIDZ(cb gs[female,low],N olf gs[female,low])*People 1)
		+ (ZIDZ(cb gs[male,low],N olf gs[male,low])*People 1)
		+ (ZIDZ(cb gs[female,mid],N olf gs[female,mid])*People 1)
		+ (ZIDZ(cb gs[male,mid],N olf gs[male,mid])*People 1)
		+ (ZIDZ(cb gs[female,hig],N olf gs[female,hig])*People 1)
		+ (ZIDZ(cb gs[male,hig],N olf gs[male,hig])*People 1)
	|

yd d ordered[gini order]=
	VECTOR REORDER(yd d[inc cat], yd order[inc cat] )
	~	
	~		~	:SUPPLEMENTARY 
	|

yd d real[inc cat]=
	yd d[inc cat]/CPI
	~	Euro constant/(Year*Person)
	~		|

yd d real tot[inc cat]=
	pop d[inc cat]*yd d real[inc cat]
	~	Euro/Year
	~	Real disposable income of indivudal categories (total, of all individuals \
		in the category)
	|

yd d rq check=
	yd d total - yd rq total
	~	
	~		~	:SUPPLEMENTARY 
	|

yd d total=
	sum(yd d[inc cat!]*pop d[inc cat!])
	~	
	~		|

yd dec real share[deciles]=
	yd dec real WRONG[deciles]/yd national real
	~	1
	~		|

yd dec real WRONG[deciles]=
	sum(yd rq[regions!,quintiles!]*map rq dec[deciles,regions!,quintiles!]/CPI rq[regions
	!,quintiles!])/
	sum(map rq dec[deciles,regions!,quintiles!])
	~	
	~		|

yd dec share[deciles]=
	yd dec WRONG[deciles]/yd national
	~	1
	~		|

yd dec WRONG[deciles]=
	sum(yd rq[regions!,quintiles!]*map rq dec[deciles,regions!,quintiles!])/
	sum(map rq dec[deciles,regions!,quintiles!])
	~	Euro/Year
	~		|

yd delay d[inc cat]= DELAY FIXED (
	yd d[inc cat], Year 1 , yd initial d[inc cat])
	~	Euro
	~		|

yd delay rq[regions,quintiles]= DELAY FIXED (
	yd rq[regions,quintiles], Year 1, yd rq init model[regions,quintiles])
	~	
	~		|

yd delay2 d[inc cat]= DELAY FIXED (
	yd d[inc cat], Year 1+Year 1 , yd initial d[inc cat])
	~	Euro
	~		~	:SUPPLEMENTARY 
	|

yd dynamic expectations perceived delayed adjustment[regions,quintiles]=
	(yd dynamic rq perceived[regions,quintiles]-yd dynamic rq perceived delayed[regions,
quintiles]
	)/expectations adjustment time
	~	Euro/(Year*Year*Household)
	~	Adjustement of perceived output delayed w.r.t. to output perceived.
	|

yd dynamic rq[regions,quintiles]=
	NWB rq[regions,quintiles] + 
	NUB rq[regions,quintiles] + 
	NPB rq[regions,quintiles] +
	NFI rq[regions,quintiles] +
	mixed income rq[regions,quintiles] +
	CT redistrib rq[regions,quintiles] -
	delta yd cap rq[regions,quintiles]+
	income cap redistribution hhs rq[regions,quintiles]*num hhs rq delayed[regions,quintiles
	]
	~	Euro/Year
	~		|

yd dynamic rq hh[regions,quintiles]=
	yd dynamic rq[regions,quintiles]/num hhs rq delayed[regions,quintiles]
	~	Euro/(Year*Household)
	~		|

yd dynamic rq hh delay[regions,quintiles]= DELAY FIXED (
	yd dynamic rq hh[regions,quintiles], Year 1, initial yd dynamic rq hh
[regions,quintiles])
	~	Euro/(Year*Household)
	~		|

yd dynamic rq hh real[regions,quintiles]=
	yd dynamic rq hh[regions,quintiles]/CPI rq[regions,quintiles
]
	~	Euro/(Year*Household)
	~		|

yd dynamic rq hh real delay[regions,quintiles]=
	yd dynamic rq hh delay[regions,quintiles]/CPI rq delay[regions,quintiles
]
	~	Euro/(Year*Household)
	~		|

yd dynamic rq perceived[regions, quintiles]= INTEG (
	yd dynamic rq perceived adjustment[regions,quintiles],
		initial yd dynamic rq hh[regions,quintiles])
	~	Euro/(Year*Household)
	~	Smoothed output for expectation formation.
	|

yd dynamic rq perceived adjustment[regions,quintiles]=
	(yd dynamic rq hh[regions,quintiles]-yd dynamic rq perceived[regions,quintiles
])/expectations adjustment time
	~	Euro/(Year*Year*Household)
	~	Adjustement of perceived output w.r.t. to actual observed output
	|

yd dynamic rq perceived adjustment real[regions,quintiles]=
	(yd dynamic rq hh real[regions,quintiles]-yd dynamic rq perceived real[regions
	,quintiles])/expectations adjustment time
	~	Euro/(Year*Year*Household)
	~	Adjustement of perceived output w.r.t. to actual observed output
	|

yd dynamic rq perceived adjustment real delay[regions,quintiles]=
	(yd dynamic rq perceived real[regions,quintiles]-yd dynamic rq perceived real delay
	[regions,quintiles]
	)/expectations adjustment time
	~	Euro/(Year*Year*Household)
	~	Adjustement of perceived output delayed w.r.t. to output perceived.
	|

yd dynamic rq perceived delayed[regions,quintiles]= INTEG (
	yd dynamic expectations perceived delayed adjustment[regions,quintiles],
		initial yd dynamic rq hh[regions,quintiles])
	~	Euro/(Year*Household)
	~	Smoothed output for expectation formation delayed, to calculate \
		expectation trend.
	|

yd dynamic rq perceived expected trend[regions,quintiles]=
	IF THEN ELSE(active shocks time=1,
	0,
	
	(yd dynamic rq perceived[regions,quintiles]-yd dynamic rq perceived delayed[regions,
	quintiles]
	)/yd dynamic rq perceived delayed[regions,quintiles]/expectations adjustment time
	)
	~	Dmnl/Year
	~	The trend formed in the expectation formation for output.
	|

yd dynamic rq perceived expected trend real[regions,quintiles]=
	IF THEN ELSE(active shocks time=1,
	0,
	
	(yd dynamic rq perceived real[regions,quintiles]-yd dynamic rq perceived real delay
	[regions,quintiles]
	)/yd dynamic rq perceived real delay[regions,quintiles]/expectations adjustment time
	)
	~	Dmnl/Year
	~	The trend formed in the expectation formation for output.
	|

yd dynamic rq perceived real[regions, quintiles]= INTEG (
	yd dynamic rq perceived adjustment real[regions,quintiles],
		initial yd dynamic rq hh[regions,quintiles])
	~	Euro/(Year*Household)
	~	Smoothed output for expectation formation.
	|

yd dynamic rq perceived real delay[regions,quintiles]= INTEG (
	yd dynamic rq perceived adjustment real delay[regions,quintiles],
		initial yd dynamic rq hh[regions,quintiles])
	~	Euro/(Year*Household)
	~	Smoothed output for expectation formation delayed, to calculate \
		expectation trend.
	|

yd hh after tls pre gini sum j[rq cat]=
	num hhs delayed shares rq cat[rq cat]*
	sum(num hhs delayed shares rq cat[rq cat j!] *
	ABS(yd shares rq cat after tls[rq cat]/num hhs delayed shares rq cat[rq cat] - 
	yd shares rq cat after tls[rq cat j!]/num hhs delayed shares rq cat[rq cat j!]))
	~	
	~		|

yd hh gini=
	0.5 *
	sum(yd hh pre gini sum j[rq cat!])
	~	Dmnl
	~	Net gini of households income
	~	:SUPPLEMENTARY 
	|

yd hh gini after tls=
	0.5*sum(yd hh after tls pre gini sum j[rq cat!])
	~	
	~		~	:SUPPLEMENTARY 
	|

yd hh gini index=
	yd hh gini/yd hh gini initial
	~	
	~		|

yd hh gini initial= INITIAL(
	yd hh gini)
	~	
	~		|

yd hh gini nonMI=
	0.5 *
	sum(yd hh pre gini sum j nonMI[rq cat!])
	~	
	~		|

yd hh pre gini sum j[rq cat]=
	sum(num hhs delayed shares rq cat[rq cat]*num hhs delayed shares rq cat[rq cat j!] *
	ABS(yd shares rq cat[rq cat]/num hhs delayed shares rq cat[rq cat] - 
	yd shares rq cat[rq cat j!]/num hhs delayed shares rq cat[rq cat j!]))
	~	
	~		|

yd hh pre gini sum j nonMI[rq cat]=
	sum(num hhs delayed shares rq cat[rq cat]*num hhs delayed shares rq cat[rq cat j!] *
	ABS(yd shares rq cat nonMI[rq cat]/num hhs delayed shares rq cat[rq cat] - 
	yd shares rq cat nonMI[rq cat j!]/num hhs delayed shares rq cat[rq cat j!]))
	~	
	~		|

yd hhs change after hh taxes rq[regions,quintiles]=
	yd hhs rq[regions,quintiles]-yd hhs pre hh tax rq[regions,quintiles]
	~	Euro/(Year*Household)
	~		~	:SUPPLEMENTARY 
	|

yd hhs dec[deciles]=
	sum(yd rq[regions!,quintiles!]*map rq dec[deciles,regions!,quintiles!])/
	sum(num hhs rq delayed[regions!,quintiles!]*map rq dec[deciles,regions!,quintiles!])
	~	Euro/(Year*Household)
	~		~	:SUPPLEMENTARY 
	|

yd hhs dec after tls[deciles]=
	sum(yd rq after tls[regions!,quintiles!]*map rq dec[deciles,regions!,quintiles!])/
	sum(num hhs rq delayed[regions!,quintiles!]*map rq dec[deciles,regions!,quintiles!])
	~	Euro/(Year*Household)
	~		~	:SUPPLEMENTARY 
	|

yd hhs dec real[deciles]=
	sum(yd rq[regions!,quintiles!]*map rq dec[deciles,regions!,quintiles!]/CPI rq[regions
!,quintiles!])/
	sum(num hhs rq delayed[regions!,quintiles!]*map rq dec[deciles,regions!,quintiles!])
	~	Euro/(Year*Household)
	~		~	:SUPPLEMENTARY 
	|

yd hhs pre hh tax rq[regions,quintiles]=
	yd pre hh tax rq[regions,quintiles] / num hhs rq delayed[regions,quintiles]
	~	Euro/(Year*Household)
	~	Household nominal disposable income per region quintile before eventual \
		taxation at the household level
	|

yd hhs pre tax rq delayed[regions,quintiles]= DELAY FIXED (
	yd hhs pre hh tax rq[regions,quintiles], Year 1, 0)
	~	Euro/(Year*Household)
	~		|

yd hhs rq[regions,quintiles]=
	yd hhs pre hh tax rq[regions,quintiles]-delta yd cap hhs rq[regions,quintiles]+income cap redistribution hhs rq
	[regions,quintiles]+reimbursed carbon costs hhs rq[regions,quintiles]
	~	Euro/(Year*Household)
	~	Household nominal disposable income per region quintile
	|

yd hhs rq after tls[regions,quintiles]=
	yd hhs rq[regions,quintiles]-c hhs ESc tls rq[regions,quintiles]
	~	Euro/(Year*Household)
	~	Average disposable household income after taxes less subsidies
	|

yd hhs rq after tls real[regions,quintiles]=
	yd hhs rq after tls[regions,quintiles]/CPI rq[regions,quintiles]
	~	Euro/(Year*Household)
	~		|

yd hhs rq delay[regions,quintiles]= DELAY FIXED (
	yd hhs rq[regions,quintiles], Year 1 , init yd hhs rq[regions,quintiles])
	~	Euro/(Year*Household)
	~		|

yd hhs rq real[regions,quintiles]=
	yd hhs rq[regions,quintiles]/CPI rq[regions,quintiles]
	~	Euro constant/(Year*Household)
	~	Real disposable household income per household, by region and quintile.
	|

yd initial d[inc cat]= INITIAL(
	yd d[inc cat])
	~	Euro
	~		|

yd national=
	sum(yd region[regions!])
	~	Euro/Year
	~		|

yd national delay= DELAY FIXED (
	yd national real,1,yd national initial)
	~	
	~		|

yd national delay 2=
	DELAY FIXED(yd national delay,1,yd national initial)
	~	
	~		|

yd national initial=
	1.05616e+12
	~	
	~	yd national
	|

yd national real=
	yd national/CPI
	~	Euro/Year
	~		|

yd national real per person=
	yd national real/population total
	~	
	~		|

