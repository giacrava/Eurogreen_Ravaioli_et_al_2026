	+sum(ub recipients[gender!,skill!]*
	min(tax floor 3-tax floor 2, 
	                      max(taxable inc u gs[gender!,skill!]-tax floor 2, 0)) )
	
	+sum("Skills 65+ gs"[gender!,skill!]*
	 min(tax floor 3-tax floor 2, 
	                      max(gross annual income p gs[gender!,skill!]-tax floor 2, 0)))
