JG rq n[regions,quintiles]=
	JG income gs[female,low]*hhs cat shares rq adj[regions, inc low u f, quintiles] +
	JG income gs[male,low]*hhs cat shares rq adj[regions, inc low u m, quintiles] +
	JG income gs[female,mid]*hhs cat shares rq adj[regions, inc mid u f, quintiles] +
	JG income gs[male,mid]*hhs cat shares rq adj[regions, inc mid u m, quintiles] +
	JG income gs[female,hig]*hhs cat shares rq adj[regions, inc hig u f, quintiles] +
	JG income gs[male,hig]*hhs cat shares rq adj[regions, inc hig u m, quintiles]
	~	Euro/Year
	~	Total income from job guarantee program per region-quintile
	|

