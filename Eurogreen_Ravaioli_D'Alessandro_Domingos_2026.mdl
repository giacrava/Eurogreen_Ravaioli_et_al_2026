uc electricity=
	electricity demand/potential demand met
	~	Dmnl
	~	Since we assume that grid output increases proportional to the grid capital, the \
		production share of the grid remains at its normal capacity utilisation.
		Since we model the grid passibvely and it is not linked to production or \
		production potential, we ignore it when calculating capacity utilisation.
	|

uc expected electricity=
	smooth(uc electricity, smooth expectations time)
	~	Dmnl
	~		|

uc expected i[ind]=
	ZIDZ(output expected[ind],(K i[ind]+delta K i[ind])*capital productivity dynamic[ind
	])
	~	Dmnl
	~		|

uc i[ind] :EXCEPT:  [electricity ind]=
	ZIDZ(y real i[ind],y FC i[ind]) ~~|
uc i[electricity ind]=
