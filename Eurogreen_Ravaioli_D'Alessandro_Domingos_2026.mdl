from delta gov c real care services to GDP to delta perc lamba=
	ZIDZ(delta perc lambda scenario timestep i[manufacturing],delta gov c real care services to GPD
)
	~	1
	~	How much a 1pp increase of care services spending to GDP directly \
		increases productivity in all sectors (in pp points).
	|

from delta perc gov c nom care services per capita to delta perc lamba=
	ZIDZ(delta perc lambda scenario timestep i[manufacturing],delta perc gov c nom care services
)
	~	
	~		|

from delta perc gov c real care services to delta perc lamba=
	ZIDZ(delta perc lambda scenario timestep i[manufacturing],delta perc gov c real care services
)
	~	1
	~		|

g a i electricity[ind]=
	ZIDZ(electricity sector production structure[ind]-a i delay[ind],a i delay[ind])
	~	Dmnl
	~		|

g a i electricity delayed[ind]= DELAY FIXED (
	g a i electricity[ind], TIME STEP, initial g a i electricity)
	~	Dmnl
	~	in order to avoid simultaneous equations (A -> output -> electricity \
		demand -> electricity production structure -> A), we delay the impact of \
		the electricity production structure by the minimal amount
	|

g a ii iteration[ind,toind,iteration]=
	RANDOM NORMAL(
	min delta a ii[ind,toind], 
	max delta a ii[ind,toind],
	median delta a ii[ind,toind], 
	sd delta a ii[ind,toind] , seed )
	~	Dmnl
	~		|

g a T2 ii[ind,toind] :EXCEPT:         [households,toind],[nohouseholds sectors,households
]=
	sum(selected a ii[T2,ind,toind,iteration!]) ~~|
g a T2 ii[households,toind]=
	0 ~~|
g a T2 ii[nohouseholds sectors,households]=
	0
	~	Dmnl
	~	*initial_a_ii[ind,toind]
		changes in technical coefficients for T2>
		RANDOM_NORMAL(min_delta_a_ii[ind,toind]+sd_delta_a_ii[ind,toind], \
		max_delta_a_ii[ind,toind]+sd_delta_a_ii[ind,toind] , 
		mean_delta_a_ii[ind,toind]+sd_delta_a_ii[ind,toind] , sd_delta_a_ii[ind,toind] , \
		seed )
		*a_delay_ii[ind,toind]
	|

g a T3 ii[ind,toind] :EXCEPT:      [households,toind],[nohouseholds sectors,households
]=
	sum(selected a ii[T3,ind,toind,iteration!]) ~~|
g a T3 ii[households,toind]=
	0 ~~|
g a T3 ii[nohouseholds sectors,households]=
	0
	~	Dmnl
	~	*initial_a_ii[ind,toind]
		changes in technical coefficients for T3>
		RANDOM_NORMAL(min_delta_a_ii[ind,toind]-sd_delta_a_ii[ind,toind], \
		max_delta_a_ii[ind,toind]-sd_delta_a_ii[ind,toind] , 
		mean_delta_a_ii[ind,toind]-sd_delta_a_ii[ind,toind] , sd_delta_a_ii[ind,toind] , \
		seed )
		*a_delay_ii[ind,toind]
	|

g a T4 ii[ind,toind] :EXCEPT:      [households,toind],[nohouseholds sectors,households
]=
	sum(selected a ii[T3,ind,toind,iteration!]) ~~|
g a T4 ii[households,toind]=
	0 ~~|
g a T4 ii[nohouseholds sectors,households]=
	0
	~	Dmnl
	~	*initial_a_ii[ind,toind]
		changes in technical coefficients for T4
	|

g e gs[gender,skill]=
	(e gs[gender,skill]-e delay gs[gender,skill])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

g E use intensity=
	sum(g E use intensity i[ind!]*VA real i[ind!])/VA real
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

g E use intensity i[ind]=
	IF THEN ELSE(E use intensity delay i[ind]>0, (E use intensity i[ind]-E use intensity delay i
[ind])/E use intensity delay i[ind], 0)
	~	Dmnl
	~		|

g emission intensity=
	sum(g emission intensity i[ind!]*VA real i[ind!])/VA real
	~	
	~		~	:SUPPLEMENTARY 
	|

g emission intensity i[ind]=
	IF THEN ELSE(emission intensity delay i[ind]>0, (emission intensity i[ind]-emission intensity delay i
[ind])/emission intensity delay i[ind],0)
	~	Dmnl
	~		|

g emission intensity mi[macroind]=
	sum(g emission intensity i[ind!]*ind to macroind map[ind!,macroind]*VA real i[ind!])
/sum(ind to macroind map[ind!,macroind]*VA real i[ind!])
	~	1
	~		~	:SUPPLEMENTARY 
	|

g emission intensity output=
	sum(g emission intensity output i[ind!]*y real i[ind!])/tot y real
	~	
	~		~	:SUPPLEMENTARY 
	|

g emission intensity output i[ind]=
	IF THEN ELSE(emission intensity output delay i[ind]>0, (emission intensity output i[
ind]-emission intensity output delay i
[ind])/emission intensity output delay i[ind],0)
	~	Dmnl
	~		|

g emission intensity output mi[macroind]=
	sum(g emission intensity output i[ind!]*ind to macroind map[ind!,macroind]*y real i[
ind!])
/sum(ind to macroind map[ind!,macroind]*y real i[ind!])
	~	1
	~		~	:SUPPLEMENTARY 
	|

g emissions per GDP=
	IF THEN ELSE(emissions per GDP delay>0,
	(emissions per GDP-emissions per GDP delay)/emissions per GDP delay,
	0)
	~	1
	~		|

g end use intensity=
	sum(g end use intensity i[ind!]*VA real i[ind!])/VA real
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

g end use intensity i[ind]=
	IF THEN ELSE(end use intensity delay i[ind]>0, (end use intensity i[ind]-end use intensity delay i
[ind])/end use intensity delay i[ind], 0)
	~	Dmnl
	~		|

g end use intensity mi[macroind]=
	sum(g end use intensity i[ind!]*ind to macroind map[ind!,macroind]*VA real i[ind!])/
sum(VA real i[ind!]*ind to macroind map[ind!,macroind])
	~	1
	~		~	:SUPPLEMENTARY 
	|

g end use intensity output=
	sum(g end use intensity output i[ind!]*y real i[ind!])/tot y real
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

g end use intensity output i[ind]=
	IF THEN ELSE(end use intensity output delay i[ind]>0, (end use intensity output i[ind
]-end use intensity output delay i
[ind])/end use intensity output delay i[ind], 0)
	~	Dmnl
	~		|

g end use intensity output mi[macroind]=
	sum(g end use intensity output i[ind!]*ind to macroind map[ind!,macroind]*y real i[
ind!])
/sum(ind to macroind map[ind!,macroind]*y real i[ind!])
	~	1
	~		~	:SUPPLEMENTARY 
	|

g energy labour ratio=
	sum(g energy labour ratio i[ind!] * tot hours sh i[ind!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

g energy labour ratio i[ind]=
	IF THEN ELSE(energy labour ratio i delay[ind]>0, (energy labour ratio i[ind]-energy labour ratio i delay
[ind])/energy labour ratio i delay[ind],0)
	~	Dmnl
	~		|

g energy labour ratio mi[macroind]=
	sum(g energy labour ratio i[ind!]*ind to macroind map[ind!,macroind]*tot hours i[ind
!])/sum(tot hours i[ind!]*ind to macroind map[ind!,macroind])
	~	
	~		~	:SUPPLEMENTARY 
	|

g exp i[ind]=
	S1 g exp i capped[ind]*IF THEN ELSE(Time<S Time Policy start,
	                1,
	                1+min(S Time end-S Time Policy start,Time-S Time Policy start)*(S g exp
/(S Time end-S Time Policy start))
	                )
	~	Dmnl
	~	exogenous exp growth
	|

g ff ee T2 i[ind]=
	sum(selcted ee i T[T2,ind,iteration!])
	~	
	~		|

g ff ee T3 i[ind]=
	sum(selcted ee i T[T3,ind,iteration!])
	~	
	~		|

g ff ee T4 i[ind]=
	sum(selcted ee i T[T3,ind,iteration!])
	~	
	~		|

g final dom demand real households=
	IF THEN ELSE(final dom demand real households delay>0,
	(final dom demand real households-final dom demand real households delay)/final dom demand real households delay
,
	0)
	~	1
	~		~	:SUPPLEMENTARY 
	|

g GDP nom=
	(GDP nom-GDP nom delay)/GDP nom delay
	~	1
	~		~	:SUPPLEMENTARY 
	|

g GDP real=
	(GDP real - GDP real delay)/GDP real delay
	~	1
	~	real GDP growth rate
	|

g GDP real impact gov c real=
	min(max(g GDP real smooth delay,-0.02),0.02)
	~	1
	~		|

g GDP real smooth=
	g GPD real smoothing parameter*g GDP real+(1-g GPD real smoothing parameter)*g GDP real smooth delay
	~	1
	~		|

g GDP real smooth delay= DELAY FIXED (
	g GDP real smooth, 1, g GDP real smooth init)
	~	1
	~		|

g GDP real smooth init= INITIAL(
	0)
	~	1
	~		|

g GDP smoothed=
	smooth(g GDP real, expectations adjustment time)
	~	Dmnl
	~		|

g GDP smoothed delayed= DELAY FIXED (
	g GDP smoothed, Year 1, 0)
	~	Dmnl
	~		|

g GFCF real nore=
	IF THEN ELSE(GFCF real nore delay>0,
	(GFCF real nore-GFCF real nore delay)/GFCF real nore delay,
	0)
	~	1
	~		~	:SUPPLEMENTARY 
	|

g GFCF real realestate=
	IF THEN ELSE(GFCF real i delay[realestate]>0,
	(GFCF real realestate-GFCF real i delay[realestate])/GFCF real i delay[realestate],
	0)
	~	1
	~		~	:SUPPLEMENTARY 
	|

g GFCF real total=
	IF THEN ELSE(GFCF real total delay>0,
	(GFCF real total-GFCF real total delay)/GFCF real total delay,
	0)
	~	1
	~		|

g gov c dom real=
	IF THEN ELSE(gov c dom real delay>0,
	(gov c dom real-gov c dom real delay)/gov c dom real delay,
	0)
	~	1
	~		|

g gov c real=
	IF THEN ELSE(gov c real delay>0,
	(gov c real-gov c real delay)/gov c real delay,
	0)
	~	1
	~		~	:SUPPLEMENTARY 
	|

g gov c real GDP smooth and gap corrected i[ind]=
	g GDP real smooth+gov c real gap correction parameter*gov c real to GDP gap i[ind]
	~	1
	~		|

g GPD real smoothing parameter=
	1
	~	1
	~		|

g i ff ee iteration[ind,iteration]=
	RANDOM NORMAL(min g ee[ind], max g ee[ind] , median g ee[ind] , sd g ee[ind] , seed)
	~	Dmnl
	~		|

g import shares electricity[ind]=
	ZIDZ(import shares electricity sector production structure[ind]-import shares a i delay
[ind],import shares a i delay[ind])
	~	Dmnl
	~		|

g import shares electricity delayed[ind]=
	DELAY FIXED(g import shares electricity[ind], TIME STEP, initial g import shares electricity
)
	~	Dmnl
	~	in order to avoid simultaneous equations (e.g. Aimp -> tls -> final demand \
		-> output -> electricity demand -> electricity production structure -> \
		Aimp), we delay the impact of the electricity production structure by the \
		minimal amount
	|

g L gis[gender,ind,skill]=
	ZIDZ((L gis[gender,ind,skill]-L gis Delay[gender,ind,skill]),L gis Delay[gender,ind,
skill])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

g L i[ind]=
	ZIDZ(L i constrained[ind]-L i delay[ind],L i delay[ind])
	~	
	~		|

g L prod=
	sum(tot hours sh i[ind!]*g L prod i[ind!])
	~	1
	~		~	:SUPPLEMENTARY 
	|

g L prod i[ind]=
	g lambda i[ind]*y real i 0[ind]/VA real i[ind]
	~	1
	~		|

g L prod mi[macroind]=
	sum(g L prod i[ind!]*ind to macroind map[ind!,macroind]*tot hours i[ind!])/sum(ind to macroind map
[ind!,macroind]*tot hours i[ind!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

g lab prod=
	lab prod/lab prod delay - 1
	~	
	~		|

g lamba i[ind]=
	(lambda i[ind]-lambda delay i[ind])/lambda delay i[ind]
	~	Dmnl
	~		|

g lambda=
	sum(g lambda i[ind!]*tot hours sh i[ind!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

g lambda electricity=
	(labour productivity-labour productivyt delay)/labour productivyt delay
	~	Dmnl
	~	growth rate of labour productivity due to changes in electricity production
	|

g lambda electricity delayed=
	DELAY FIXED( g lambda electricity, TIME STEP, initial g lambda electricity)
	~	Dmnl
	~		|

g lambda i[ind]=
	IF THEN ELSE(lambda delay i[ind]>0, (lambda i[ind]-lambda delay i[ind])/lambda delay i
[ind],0)
	~	Dmnl
	~		|

g lambda iteration[ind,iteration]=
	RANDOM NORMAL(
	max delta lambda neg[ind]+shift delta lambda pos i[ind], 
	max delta lambda i[ind]+shift delta lambda pos i[ind],
	median delta lambda[ind]+shift delta lambda pos i[ind], 
	sd delta lambda[ind] , seed )
	~	Dmnl
	~	RANDOM NORMAL(
		max delta lambda neg[ind], 
		max delta lambda i[ind],
		mean delta lambda[ind] , 
		sd delta lambda[ind] , seed )
	|

g lambda mean during policy due to Act change labour productivity i[ind]=
	IF THEN ELSE(Time>S Time Shift end,
	delta perc lambda scenarios tot during policy due to Act change LP i[ind]/(S Time Shift end
	-S Time Policy start+1),
	0)
	~	1
	~	=A5/A1)^(1/(Y-1)) - 1
		
		IF THEN ELSE(Time>S Time Shift end,
		ZIDZ(lambda policy end i[ind],lambda policy start i[ind])^(1/(S Time Shift end-S \
		Time Policy start-1))-1,
		0)
	|

g lambda mi[macroind]=
	sum(g lambda i[ind!]*ind to macroind map[ind!,macroind]*tot hours i[ind!])/sum(tot hours i
[ind!]*ind to macroind map[ind!,macroind])
	~	1
	~		~	:SUPPLEMENTARY 
	|

g lambda noncareserv=
	sum(g lambda i[noncareserv!]*tot hours i[noncareserv!])/sum(tot hours i[noncareserv!
])
	~	1
	~		|

g lambda pre electricity i[ind]=
	IF THEN ELSE(lambda pre electricity i delay[ind]>0, 
	(lambda pre electricity i[ind]-lambda pre electricity i delay[ind])/lambda pre electricity i delay
[ind],
	0)
	~	Dmnl
	~		|

g lambda T2 i[ind]=
	sum(selcted lambda i T[T2,ind,iteration!])
	~	Dmnl
	~	*initial_lambda_i[ind]
		change in labour productivity for T2
	|

g lambda T3 i[ind]=
	sum(selcted lambda i T[T3,ind,iteration!])
	~	Dmnl
	~	change of labour productivity for T3
	|

g lambda T4 i[ind]=
	sum(selcted lambda i T[T2,ind,iteration!])
	~	Dmnl
	~	change in labour productivity for T4
	|

g national consumption based emissions=
	IF THEN ELSE(national consumption based emissions delay>0,
	(national consumption based emissions-national consumption based emissions delay)/national consumption based emissions delay
,
	0)
	~	1
	~		|

g NDP per hour=
	ZIDZ((NDP per hour-NDP per hour delay),NDP per hour delay)
	~	1
	~		|

g NDP real=
	ZIDZ(NDP real-NDP real delay,NDP real delay)
	~	1
	~		|

g net exp real=
	IF THEN ELSE(net exp real delay>0,
	(net exp real-net exp real delay)/net exp real delay,
	0)
	~	1
	~		|

g Pop 024=
	IF THEN ELSE(Pop 024 delay>0,
	(Pop 024-Pop 024 delay)/Pop 024 delay,
	0
	)
	~	1
	~		|

g Pop over65=
	IF THEN ELSE(Pop over65 delay>0,
	(Pop over65-Pop over65 delay)/Pop over65 delay
	,
	0)
	~	1
	~		|

g population total=
	IF THEN ELSE(population total delay>0,
	(population total-population total delay)/population total delay,
	0
	)
	~	1
	~		|

g real estate inv=
	IF THEN ELSE(activated eurocrisis inv shocks=1,
	inv shocks,
	IF THEN ELSE(activated superbonus shocks=1,
	superbonus shocks,
	sens real estate inv*g relevant yd national real delay))
	~	
	~		|

g real wage=
	IF THEN ELSE(real wage delay>0, (real wage-real wage delay)/real wage delay,0)
	~	1
	~		|

g real wage g[gender]=
	IF THEN ELSE(real wage g delay[gender]>0, (real wage g[gender]-real wage g delay[gender
])/real wage g delay[gender],0)
	~	1
	~		|

g real wage gs[gender, skill]=
	IF THEN ELSE(real wage gs delay[gender,skill]>0, (real wage gs[gender,skill]-real wage gs delay
[gender,skill])/real wage gs delay[gender,skill
	],0)
	~	1
	~		|

g real wage i[ind]=
	IF THEN ELSE(real wage i delay[ind]>0, (real wage i[ind]-real wage i delay[ind])/real wage i delay
[ind], 0)
	~	1
	~		|

g real wage mi[macroind]=
	IF THEN ELSE(real wage mi delay[macroind]>0, (real wage mi[macroind]-real wage mi delay
[macroind])/real wage mi delay[macroind],0)
	~	1
	~		|

g real wage s[skill]=
	IF THEN ELSE(real wage s delay[skill]>0, (real wage s[skill]-real wage s delay[skill
])/real wage s delay
	[skill],0)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

g relative UC i[ind]=
	ZIDZ((ZIDZ((UIC i[ind]+embedded costs[ind]),ULC i[ind])),
	(ZIDZ((UIC delay i[ind]+embedded costs delayed[ind]),ULC delay i[ind])))-1
	~	Dmnl
	~	growth rate of relative unit costs
	|

g relevant yd national real delay=
	IF THEN ELSE(
	active shocks delay=1 :OR: active shocks delay2=1,
	0,
	
	TREND(relevant yd national real delay,average time g,0))
	~	1
	~		|

g tot y real=
	ZIDZ((tot y real-tot y real delayed),tot y real delayed)
	~	1
	~		|

g total emissions=
	IF THEN ELSE(total emissions delay>0,
	(total emissions-total emissions delay)/total emissions delay,
	0)
	~	1
	~		|

g total exp real=
	IF THEN ELSE(total exp real delay>0, 
	(total exp real-total exp real delay)/total exp real delay,
	0)
	~	1
	~		~	:SUPPLEMENTARY 
	|

g wage=
	IF THEN ELSE(wage delay>0, (wage-wage delay)/wage delay,0)
	~	1
	~		~	:SUPPLEMENTARY 
	|

g wage gis[gender, ind, skill]=
	IF THEN ELSE(wage gis delay[gender,ind,skill]>0, (wage gis[gender,ind,skill]-wage gis delay
[gender,ind,skill])/wage gis delay[gender,ind,skill],0)
	~	Dmnl
	~		|

g wage i[ind]=
	IF THEN ELSE(wage i delay[ind]>0, (wage i[ind]-wage i delay[ind])/wage i delay[ind],
0)
	~	Dmnl
	~		|

g wage mi[macroind]=
	sum(g wage i[ind!]*ind to macroind map[ind!,macroind]*tot hours i[ind!])/sum(tot hours i
[ind!]*ind to macroind map[ind!,macroind])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

g y real per worker=
	sum(L sh i[ind!]*"g y real per worker i WRONG!"[ind!])
	~	1
	~		|

"g y real per worker i WRONG!"[ind]=
	g lambda i[ind]*tot hours i[ind]/L constrained i[ind]
	~	Person*Year/Hours
	~		|

g y real per worker mi[macroind]=
	sum("g y real per worker i WRONG!"[ind!]*ind to macroind map[ind!,macroind]*L constrained i
[ind!])/sum(ind to macroind map
	[ind!,macroind]*L constrained i[ind!])
	~	Dmnl
	~		|

g yd national exp=
	(yd national delay/yd national delay 2)-1
	~	
	~		|

gamma p translog price index[ind]=
	sum(aids price coefficients[ind,toind!]*ln(price index pp i[toind!]))
	~	Dmnl
	~		|

gas per unit B hhs demand=
	av energy use per unit hh consumption be[mining, gas]
	~	TJ/Euro constant
	~		|

GDP bp pp conversion initial= INITIAL(
	GDP nom/total real demand)
	~	
	~		|

GDP initial=
	1.61794e+12
	~	Euro/Year
	~	From Eurostat
	|

GDP nom=
	sum(final demand nom i[ind!])- sum(Z imp nom i[ind!])+gov revenue tls
	~	Euro/Year
	~	GDP, nominal
	|

GDP nom delay= DELAY FIXED (
	GDP nom, Year 1 , GDP initial)
	~	Euro/Year
	~		|

GDP real=
	total real demand*GDP bp pp conversion initial
	~	Euro constant/Year
	~	sum(final demand real i[ind!]*pp i init[ind!])-sum(Z imp real i[ind!]*pp i \
		init[ind!])
	|

GDP real delay= DELAY FIXED (
	GDP real, Year 1 , GDP initial/CPI init)
	~	Euro constant/Year
	~		|

GDP real production=
	sum(final production i[ind!])*GDP bp pp conversion initial
	~	
	~	GDP computed with the production approach
		
		*pp i init[ind!]
	~	:SUPPLEMENTARY 
	|

GDP real Time Policy start delay=SAMPLE IF TRUE(
	Time=S Time Policy start, GDP real delay, 0)
	~	Euro constant/Year
	~		|

GDPpc real=
	GDP real/population total
	~	Euro constant/(Person*Year)
	~		|

GDPpc real decomp=
	100*(GDP real/population total)/(Initial GDP real/Initial Pop)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

gender:
	female,
	male
	~	
	~		|

gender employed over working age pop gap=
	employed over working age pop g[male]-employed over working age pop g[female]
	~	1
	~		~	:SUPPLEMENTARY 
	|

gender employed over working age pop gap s[skill]=
	employed over working age pop gs[male,skill]-employed over working age pop gs[female
,skill]
	~	1
	~		~	:SUPPLEMENTARY 
	|

gender employed over working age pop ratio=
	employed over working age pop g[female]/employed over working age pop g[male]
	~	
	~		|

gender employed ratio=
	L g[female]/L g[male]
	~	1
	~		~	:SUPPLEMENTARY 
	|

gender employment gap=
	(1-u g[male])-(1-u g[female])
	~	1
	~		~	:SUPPLEMENTARY 
	|

gender employment gap s[skill]=
	(1-u gs[male, skill])-(1-u gs[female, skill])
	~	1
	~		~	:SUPPLEMENTARY 
	|

gender labour income gap ratio=
	average daily labou income g[female]/average daily labou income g[male]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

gender labour income gap ratio s[skill]=
	average daily labour income gs[female, skill]/average daily labour income gs[male, skill
]
	~	
	~		~	:SUPPLEMENTARY 
	|

gender labour income gap s[skill]=
	(average daily labour income gs[male,skill]-average daily labour income gs[female,skill
])/average daily labour income gs[male,skill]
	~	1
	~		|

gender LFPR gap=
	LFPR g[male]-LFPR g[female]
	~	1
	~		~	:SUPPLEMENTARY 
	|

gender LFPR gap s[skill]=
	LFPR gs[male,skill]-LFPR gs[female,skill]
	~	
	~		~	:SUPPLEMENTARY 
	|

gender wage gap i[ind]=
	(wage gi[male,ind]-wage gi[female,ind])/wage gi[male,ind]
	~	
	~		|

gender wage gap ratio=
	(mean wage g[male]-mean wage g[female])/mean wage g[male]
	~	1
	~		~	:SUPPLEMENTARY 
	|

gender wage gap ratio s[skill]=
	(mean wage gs[male, skill]-mean wage gs[female, skill])/mean wage gs[male, skill]
	~	
	~		~	:SUPPLEMENTARY 
	|

gender wage gap si[ind, skill]=
	(wage gis[male, ind, skill]-wage gis[female, ind, skill])/wage gis[male, ind, skill]
	~	1
	~		|

generation by technology a[e techn] :EXCEPT:    [e gas]=
	min(desired electricity generation*current electricity demand technology share[e techn
],current capacity factor[e techn
	]*hours in year*production capacity[e techn]) ~~|
generation by technology a[e gas]=
	min(desired electricity generation*current electricity demand technology share[e gas
],current capacity factor[e gas]*hours in year
	*production capacity[e gas]-storage discharge a[power2gas])
	~	GW*h/Year
	~		|

generation deficit=
	sum(desired electricity generation*current electricity demand technology share[e techn
!]-generation by technology a[e techn
	!])
	~	GW*h/Year
	~		|

gfcf dom check=
	sum(paid embedded ucc bp nom[ind!]*I supply real i[ind!]*p i[ind!]*(1-share imp GFCF i
[ind!]))
	-Inv paid alt
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

GFCF import trend delayed[ind]= DELAY FIXED (
	GFCF import trends[ind],Year 1,1)
	~	Dmnl
	~		|

GFCF import trends[ind]=
	GFCF import trend delayed[ind]*(1+GFCF import trends capped[ind]*convergence)
	~	Dmnl
	~		|

GFCF import trends base[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'trend_impsh_gfcf')
	~	Dmnl/Year
	~	Geometric mean of growth rates of import shares, for the period 2000-2014 \
		(excluding 2008-2010), computed from input-output data. Sectors D1, D2 and \
		D3 take the same value of sector D in input-output tables.
	|

GFCF import trends capped[ind]=
	max(min(GFCF import trends base[ind],trend cap),-trend cap)
	~	Dmnl/Year
	~		|

GFCF real i[ind] :EXCEPT:                                [public],[careserv],
[
electricity ind]=
	IF THEN ELSE(activated c19 inv shocks=1,
	GFCF real i delay[ind]*(1+inv shocks),
	min(I desired i[ind],I max i[ind])
	) ~~|
GFCF real i[public]=
	IF THEN ELSE(activated c19 inv shocks=1,
	GFCF real i delay[public]*(1+inv shocks),
	I desired i[public]
	) ~~|
GFCF real i[careserv]=
	IF THEN ELSE(activated c19 inv shocks=1,
	GFCF real i delay[careserv]*(1+inv shocks),
	I desired i[careserv]
	) ~~|
GFCF real i[electricity ind]=
	IF THEN ELSE(electricity module switch=0,
	IF THEN ELSE(activated c19 inv shocks=1,
	GFCF real i delay[electricity ind]*(1+inv shocks),
	min(I desired i[electricity ind],I max i[electricity ind])
	),
	
	electricity module switch*monetary investment)
	~	Euro constant/Year
	~	actual GFCF real
		
		IF THEN ELSE(Time=10 :OR: Time=11,
		GFCF real i delay[ind]*(1+c19 shock inv),
		min(I desired i[ind],I max i[ind])
		)
		
		IF THEN ELSE(activated c19 inv shocks=1,
		GFCF real i delay[ind]*(1+inv shocks),
		min(I desired i[ind],I max i[ind])
		)
	|

GFCF real i delay[ind]= DELAY FIXED (
	GFCF real i[ind], Year 1 , initial GFCF real i[ind])
	~	Euro constant/Year
	~		|

GFCF real noncareserv=
	sum(GFCF real i[noncareserv!])
	~	Euro constant/Year
	~		|

GFCF real nore=
	sum(GFCF real i[ind!])-GFCF real i[realestate]
	~	Euro constant/Year
	~		|

GFCF real nore delay= DELAY FIXED (
	GFCF real nore,1,initial GFCF real nore)
	~	
	~		|

GFCF real realestate=
	GFCF real i[realestate]
	~	Euro constant/Year
	~		|

GFCF real total=
	sum(GFCF real i[ind!])
	~	Euro constant/Year
	~		~	:SUPPLEMENTARY 
	|

GFCF real total delay= DELAY FIXED (
	GFCF real total, 1, initial GFCF real total)
	~	Euro constant/Year
	~		|

gfcf shares battery[ind]=
	GET XLS CONSTANTS('?main', 'electricity', 'gfcf_shares_battery*' )
	~	Dmnl
	~	We allocate all investment demand for batteris to C27: manufacture of \
		electrical equipment. This is an overestimation as part of the costs will \
		go to other sectors for instance for installment. However, since we did \
		not find any data on this distribution of these costs for batteries and we \
		assume the majority of the costs will go to C27, we allocate all there.
	|

gfcf shares electricity[ind,electricity subs]=
	GET XLS CONSTANTS('?main', 'electricity', 'gfcf_shares' )
	~	Dmnl
	~	Source: Locomotion
	|

gfcf shares p2g[ind]=
	GET XLS CONSTANTS('?main', 'electricity', 'gfcf_shares_p2g*' )
	~	Dmnl
	~		|

gfcf tls paid=
	sum(GFCF real i[ind!]*price capital i[ind!]*tls gfcf[ind!])
	~	Euro/Year
	~		|

GFCG real mi[macroind]=
	sum(GFCF real i[ind!]*ind to macroind map[ind!,macroind])
	~	Euro constant/Year
	~		|

GFI check=
	GFI rq total - gross fin inc - gross fin inc cap
	~	
	~		~	:SUPPLEMENTARY 
	|

GFI per capita cap=
	ZIDZ(gross fin inc cap,pop cap)
	~	Euro/(Year*Person)
	~		|

GFI per capita gs[gender,skill]=
	ZIDZ(gross fin inc gs[gender,skill],adult population gs[gender,skill])
	~	Euro/(Year*Person)
	~		|

GFI r[regions]=
	sum(GFI rq[regions,quintiles!])
	~	
	~		~	:SUPPLEMENTARY 
	|

GFI rq[regions,quintiles]=
	GFI rq bonds[regions,quintiles]+GFI rq eq[regions,quintiles]
	~	Euro/Year
	~	Gross financial income, total nominal value per region-quintile
		
		Before evasion and differentiated tax rates:
		sum((gross fin inc gs[gender!,skill!])*rq shares gs[gender!,skill!,regions,quintiles
		])
		 + (gross fin inc cap)*hhs cat shares rq adj[regions,inc cap,quintiles]
	|

GFI rq bonds[regions,quintiles]=
	sum((gross fin inc gs bonds[gender!,skill!])*rq shares gs[gender!,skill!,regions,quintiles
	])
	 + (gross fin inc cap bonds)*hhs cat shares rq adj[regions,inc cap,quintiles]
	~	Euro/Year
	~	Gross financial income, total nominal value per region-quintile
	|

GFI rq eq[regions,quintiles]=
	sum((gross fin inc gs eq[gender!,skill!])*rq shares gs[gender!,skill!,regions,quintiles
	])
	 + (gross fin inc cap eq)*hhs cat shares rq adj[regions,inc cap,quintiles]
	~	Euro/Year
	~	Gross financial income, total nominal value per region-quintile
	|

GFI rq total=
	sum(GFI rq[regions!,quintiles!])
	~	
	~		|

GHG decomp=
	100*total emissions/total emissions init
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

gini=
	1-(pop share ordered gini[gini1]*ygross share cumulative gini[gini1]
	+(ygross share cumulative gini[gini2]+ygross share cumulative gini[gini1])*pop share ordered gini
[gini2]
	+(ygross share cumulative gini[gini3]+ygross share cumulative gini[gini2])*pop share ordered gini
[gini3]
	+(ygross share cumulative gini[gini4]+ygross share cumulative gini[gini3])*pop share ordered gini
[gini4]
	+(ygross share cumulative gini[gini5]+ygross share cumulative gini[gini4])*pop share ordered gini
[gini5]
	+(ygross share cumulative gini[gini6]+ygross share cumulative gini[gini5])*pop share ordered gini
[gini6]
	+(ygross share cumulative gini[gini7]+ygross share cumulative gini[gini6])*pop share ordered gini
[gini7]
	+(ygross share cumulative gini[gini8]+ygross share cumulative gini[gini7])*pop share ordered gini
[gini8]
	+(ygross share cumulative gini[gini9]+ygross share cumulative gini[gini8])*pop share ordered gini
[gini9]
	+(ygross share cumulative gini[gini10]+ygross share cumulative gini[gini9])*pop share ordered gini
[gini10]
	+(ygross share cumulative gini[gini11]+ygross share cumulative gini[gini10])*pop share ordered gini
[gini11]
	+(ygross share cumulative gini[gini12]+ygross share cumulative gini[gini11])*pop share ordered gini
[gini12]
	+(ygross share cumulative gini[gini13]+ygross share cumulative gini[gini12])*pop share ordered gini
[gini13]
	+(ygross share cumulative gini[gini14]+ygross share cumulative gini[gini13])*pop share ordered gini
[gini14]
	+(ygross share cumulative gini[gini15]+ygross share cumulative gini[gini14])*pop share ordered gini
[gini15]
	+(ygross share cumulative gini[gini16]+ygross share cumulative gini[gini15])*pop share ordered gini
[gini16]
	+(ygross share cumulative gini[gini17]+ygross share cumulative gini[gini16])*pop share ordered gini
[gini17]
	+(ygross share cumulative gini[gini18]+ygross share cumulative gini[gini17])*pop share ordered gini
[gini18]
	+(ygross share cumulative gini[gini19]+ygross share cumulative gini[gini18])*pop share ordered gini
[gini19]
	+(ygross share cumulative gini[gini20]+ygross share cumulative gini[gini19])*pop share ordered gini
[gini20]
	+(ygross share cumulative gini[gini21]+ygross share cumulative gini[gini20])*pop share ordered gini
[gini21]
	+(ygross share cumulative gini[gini22]+ygross share cumulative gini[gini21])*pop share ordered gini
[gini22]
	+(ygross share cumulative gini[gini23]+ygross share cumulative gini[gini22])*pop share ordered gini
[gini23]
	+(ygross share cumulative gini[gini24]+ygross share cumulative gini[gini23])*pop share ordered gini
[gini24]
	+(ygross share cumulative gini[gini25]+ygross share cumulative gini[gini24])*pop share ordered gini
[gini25])
	~	Dmnl
	~	Gross gini of individual income
	|

gini emissions=
	0.5 *
	sum(gini emissions sum j[rq cat!])
	~	
	~		~	:SUPPLEMENTARY 
	|

gini emissions sum j[rq cat]=
	sum(num hhs delayed shares rq cat[rq cat]*num hhs delayed shares rq cat[rq cat j!] *
	ABS(consumption emissions rq cat shares[rq cat]/num hhs delayed shares rq cat[rq cat
] - 
	consumption emissions rq cat shares[rq cat j!]/num hhs delayed shares rq cat[rq cat j
!]))
	~	
	~		|

Gini gross decomp=
	100*gini/initial gini gross
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Gini net decomp=
	100*(GINI yd/initial Gini net)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

gini order:
	gini1,gini2,gini3,gini4,gini5,gini6,gini7,gini8,gini9,gini10,gini11,gini12,gini13,gini14
,gini15,gini16,gini17,gini18,gini19,gini20,gini21,gini22,gini23,gini24,gini25 -> inc cat
	~	
	~		|

Gini ratio decomp=
	100*(GINI yd/gini)/(initial Gini net/initial gini gross)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

