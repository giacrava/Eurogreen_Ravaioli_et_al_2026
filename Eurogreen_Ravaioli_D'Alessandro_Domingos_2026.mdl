min wage level=
	min wage level init*max(cumulative inflation since policy start,1)
	~	Euro
	~	10
	|

min wage level init=
	10
	~	Euro/(Hours*Person)
	~		|

Minimum Wage Value=
	IF THEN ELSE(Time <S Time Policy start,0,Act minimum wage * min wage level)
	~	Euro/Person/Hour
	~		|

miscalculated check=
	total miscaulated ETS costs-
	(total paid prod side-total cc)
	~	
	~		~	:SUPPLEMENTARY 
	|

mission:
	m1,m2,m3,m4,m5,m6
	~	
	~		|

mixed income checks1=
	sum(share of selfemp capital income i[ind!])
	~	
	~		|

mixed income per capita d[inc cat]=
	Total mixed income distributed to households*People 1/sum(pop d[inc cat!])
	~	Euro/(Year*Person)
	~	sum(total mixed income r[regions!])*People 1/sum(pop d[inc cat!])
	|

Mixed income rents=
	sum(mixed income rents r[regions!])
	~	
	~	1: sum(mixed income rents r[regions!])
		2: Initial mixed income 2*Initial rents share of mixed income*(p i[realestate]/p \
		init i alt)
		3: sum(Mixed income rents rq[regions!,quintiles!])
	|

mixed income rents r[regions]=
	initial mixed income r[regions]*rent shares r[regions]*(p i[realestate]/p init i alt
)
	~	Euro/Year
	~		|

mixed income rq[regions, quintiles]=
	(total mixed income r[regions]/sum(total mixed income r[regions!]))*
	Total mixed income distributed to households*mixed income rq shares[regions,quintiles
]
	~	
	~	1: (total mixed income r[regions]/sum(total mixed income r[regions!]))*
		Total mixed income distributed to households*mixed income rq \
		shares[regions,quintiles]
		2: Total mixed income distributed to households*mixed income rq shares \
		2[regions,quintiles]
		3. (Total mixed income rq[regions,quintiles]/sum(Total mixed income \
		rq[regions!,quintiles!]))
		*Total mixed income distributed to households
		
		
		Mixed income, total nominal value per region-quintile
		Previous: until 21/01/2026
		total mixed income r[regions]*mixed income rq shares[regions,quintiles]
		
		Previous:
		Mixed income shares hhs rq[regions,quintiles]*mixed income total
	|

mixed income rq hhs[regions,quintiles]=
	mixed income rq[regions,quintiles]/ num hhs rq delayed[regions,quintiles]
	~	
	~		|

mixed income rq shares[regions,quintiles]=
	GET XLS CONSTANTS('?main', 'regions', 'profits_nifi_shares')
	~	
	~		|

Mixed income selfemp=
	sum(mixed income selfemp r[regions!])
	~	
	~	1: sum(mixed income selfemp r[regions!])
		2: VA*Mixed income selfemp to VA ratio
		3: sum(Mixed income selfemp rq[regions!,quintiles!])
	|

mixed income selfemp r[regions]=
	GWB r[regions]*mixed income selfemp to labour income ratio r[regions]
	~	Euro/Year
	~		|

mixed income selfemp to labour income ratio r[regions]=
	(1-rent shares r[regions])*initial mixed income r[regions]/initial GWB r[regions]
	~	Dmnl
	~		|

mixed income share=
	sum(mixed income rq[regions!,quintiles!])/sum(yd pre hh tax rq[regions!,quintiles!])
	~	
	~		|

modelled generation to PNIEC=
	(electricity generation expected[e distribution]/modelled generation to PNIEC initial
)/electricity generation PNIEC
	~	Dmnl
	~		|

modelled generation to PNIEC initial=
	initial expected generation/electricity generation PNIEC lookup(initial year)
	~	GW*h/Mtoe
	~		|

monetary capital= INTEG (
	monetary investment-monetary depreciation,
		initial grid value+
		sum(init storage capacity[storage technologies!]*storage investment costs per capacity initial
[storage technologies!])
		+
		sum(capacity initial[e techn!]*capacity investment costs per unit capacity initial[
e techn!]))
	~	Euro constant
	~		|

monetary capital storage[storage technologies]= INTEG (
	monetary investment storage[storage technologies]-monetary depreciation storage[storage technologies
],
		init storage capacity[storage technologies]*storage investment costs per capacity initial
[storage technologies])
	~	Euro constant
	~		|

monetary capital techn[e techn]= INTEG (
	monetary investment techn[e techn]-monetary depreciation techn[e techn],
		capacity initial[e techn]*capacity investment costs per unit capacity initial[e techn
])
	~	Euro constant
	~		|

monetary depreciation=
	grid depreciation+sum(monetary depreciation storage[storage technologies!])+sum(monetary depreciation techn
[e techn!])
	~	Euro constant/Year
	~		|

monetary depreciation storage[storage technologies]=
	monetary capital storage[storage technologies]/storage lifetime[storage technologies
]
	~	Euro constant/Year
	~		|

monetary depreciation techn[e techn]=
	monetary capital techn[e techn]*(1/capacity lifetime[e techn])
	~	Euro constant/Year
	~		|

monetary investment=
	sum(storage capacity investment costs topay[storage technologies!])+sum(capacity investment costs topay
[e techn!])+grid investment
	~	Euro constant/Year
	~		|

monetary investment storage[storage technologies]=
	storage capacity investment costs topay[storage technologies]
	~	Euro constant/Year
	~		|

monetary investment techn[e techn]=
	capacity investment costs topay[e techn]
	~	Euro constant/Year
	~		|

mortality rate cg[cohorts,gender]=
	IF THEN ELSE(Time=10*Year 1,
	initial mortality rate[cohorts,gender]*covid19 mortality impact 2020[cohorts,female]
,
	
	
	IF THEN ELSE(Time=11*Year 1 ,
	initial mortality rate[cohorts,gender]*covid mortality impact 2021[cohorts,female],
	
	initial mortality rate[cohorts,gender]))
	~	Dmnl/Year
	~		|

