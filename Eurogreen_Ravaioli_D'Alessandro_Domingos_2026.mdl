relative poverty gap=
	sum(num hhs delayed shares rq[regions!,quintiles!]*poverty gap hhs rq[regions!,quintiles
!]/relative poverty line)
	~	Dmnl
	~	National average of the distance to the poverty line as a percentage of \
		the poverty line.
	|

relative poverty gap pre hh tax=
	sum(num hhs delayed shares rq[regions!,quintiles!]*poverty gap hhs pre hh tax rq[regions
	!,quintiles!]/relative poverty line pre hh tax)
	~	Dmnl
	~	National average of the distance to the poverty line as a percentage of \
		the poverty line before taxes on households.
	|

relative poverty line=
	0.6*sum(yd hhs rq[regions!,quintiles!]*num hhs delayed shares rq[regions!,quintiles!
	])
	~	Euro/(Year*Household)
	~	60% of average disposable income after taxes on households.
	|

relative poverty line pre hh tax=
	0.6*sum(yd hhs pre hh tax rq[regions!,quintiles!]*num hhs delayed shares rq[regions!
	,quintiles!])
	~	Euro/(Year*Household)
	~	60% of average disposable income before taxes on households.
	|

relative poverty rate=
	sum(hhs in poverty rq[regions!,quintiles!]*num hhs delayed shares rq[regions!,quintiles
	!])
	~	Dmnl
	~	Poverty headcount ratio.
	|

relative poverty rate pre hh tax=
	sum(hhs in poverty pre hh tax rq[regions!,quintiles!]*num hhs delayed shares rq[regions
!,quintiles
!])
	~	Dmnl
	~		|

