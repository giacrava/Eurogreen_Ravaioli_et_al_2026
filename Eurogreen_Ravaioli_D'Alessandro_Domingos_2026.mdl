tls paid by gov=
	sum((gov c nom i[ind!]+shortfall gov c nom[ind!])*tls gov[ind!])
	~	Euro/Year
	~		|

tls paid carbon costs=
	sum(
	c ESc pp i[ind!]*(embedded ucc pp[ind!]+direct ucc pp[ind!]+embedded u srf pp[ind!])
	/(1+tls[ind!])
	)
	+
	sum((I supply nom i[ind!]+shortfall I supply nom[ind!])*(embedded u srf bp nom[ind!]
	+embedded ucc bp nom[ind!]))
	+
	sum((gov c nom i[ind!]+shortfall gov c nom[ind!]+inv pnrr[ind!])*(embedded u srf bp nom
[ind!]+embedded ucc bp nom
	[ind!]))
	
	+sum(ex ESc nom i[ind!]*(embedded usrf bp nom paid[ind!]+ paid embedded ucc bp nom[ind
!]))
	~	Euro/Year
	~		|

tls paid wo carbon cost=
	sum(
	c ESc pp i[ind!]*tls init[ind!]/(1+tls[ind!])
	)
	+
	sum(GFCF real i[ind!]*price capital i[ind!])*initl tls gfcf
	+
	sum((gov c nom i[ind!]+inv pnrr[ind!])*init tls gov)
	+substitution tls paid to domestic government gov
	~	Euro/Year
	~		|

tls pnrr=
	sum(tls pnrr i[ind!])
	~	Euro/Year [0,0]
	~		|

tls pnrr domestic government=
	sum(inv pnrr[ind!]*(embedded usrf bp nom paid[ind!]+ paid embedded ucc bp nom[ind!])
)
	~	Euro/Year
	~		|

tls pnrr i[ind]=
	inv pnrr[ind]*(embedded u srf bp nom[ind]+embedded ucc bp nom[ind]+init tls gov)
	~	Euro/Year
	~		|

tls row=
	gfcf tls paid+total tls households+tls paid by gov+tls pnrr+tls exports-(gov revenue tls
+tls embedded in imports
	+total ets profits impact
	)
	~	Euro/Year
	~		|

tls techn[electricity technologies]=
	initl tls gfcf+sum((embedded u srf bp nom[ind!]+embedded ucc bp nom[ind!])*nom investment shares techn
	[ind!,electricity technologies])
	~	Dmnl
	~		|

toassets<->
	assets
	~	
	~		|

tocohorts<->
	cohorts
	~	
	~		|

tocoicop<->
	coicop
	~	
	~		|

togender<->
	gender
	~	
	~		|

toind<->
	ind
	~	
	~		|

tonrg<->
	nrg
	~	
	~		|

top 10 direct emissions C intensity=
	sum(direct emissions hh rq[regions!,quintiles!]*top 10 rq[regions!,quintiles!])/
	sum(c hhs ESc nom bp rqi desired[regions!,quintiles!,ind!]*num hhs rq delayed[regions
!,quintiles!]*top 10 rq[regions!,quintiles
	!])
	~	tCO2eq/Euro
	~		~	:SUPPLEMENTARY 
	|

top 10 direct emissions per capita=
	sum(direct emissions hh rq[regions!,quintiles!]*top 10 rq[regions!,quintiles!])/
	sum(pop rq[regions!,quintiles!]*top 10 rq[regions!,quintiles!])
	~	tCO2eq/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

top 10 direct emissions share=
	sum(direct emissions hh rq[regions!,quintiles!]*top 10 rq[regions!,quintiles!])/
	sum(direct and embedded emissions C rq[regions!,quintiles!]*top 10 rq[regions!,quintiles
!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

top 10 rq[regions,quintiles]=
	IF THEN ELSE(deciles rq[regions,quintiles]=10, 1 , 0 )
	~	Dmnl
	~		|

top 10 share in C direct emissions=
	sum(direct emissions hh rq[regions!,quintiles!]*top 10 rq[regions!,quintiles!])/sum(
direct emissions hh rq
	[regions!,quintiles!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

toskill<->
	skill
	~	
	~		|

tot c real target baseline gov bs 6 or 7 i[ind]=
	IF THEN ELSE(Act Change baseline gov consumption = 6 :OR: Act Change baseline gov consumption
 = 7,
	ZIDZ(L tot target gov bs 6 or 7 i[ind] * lambda i[ind] * hours i[ind], (1-share imp gov i
[ind])),
	0)
	~	Euro constant/Year
	~		|

tot c real target gov bs 6 or 7 i[ind]=
	delta gov c real i[ind]+tot c real target baseline gov bs 6 or 7 i[ind]
	~	Euro constant/Year
	~		|

tot Div=
	sum(Div i[ind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

tot final demand nom=
	sum(final demand nom i[ind!])
	~	Euro/Year
	~		|

tot final demand real=
	sum(final demand real i[ind!])
	~	Euro constant/Year
	~		~	:SUPPLEMENTARY 
	|

tot gov exp=
	gov exp gov c+transfers exp+I gov+gov interest+adaptation exp+wage WTR gov total cost
	+pnrr gov spend+total cost JG
	+gov rev cap redistributed
	+electrification costs*Act electrification costs paid by gov
	~	Euro/Year
	~		|

tot gov rev=
	soc sec rev+inc tax rev+fin tax rev+corp tax rev effective+wealth tax revenue+gov revenue tls
+
	government gross profits+gov rev cap
	~	Euro/Year
	~	total government revenue
	|

tot hours=
	sum(tot hours i[ind!])
	~	Hours/Year
	~		|

tot hours i[ind]=
	actual hours i[ind]*L constrained i[ind]
	~	Hours/Year
	~	total hours worked in each industry
	|

tot hours i delay[ind]= DELAY FIXED (
	tot hours i[ind], 1, 0)
	~	Dmnl
	~		|

tot hours mi[macroind]=
	sum(tot hours i[ind!]*ind to macroind map[ind!,macroind])
	~	Hours/Year
	~		|

tot hours sh i[ind]=
	tot hours i[ind]/tot hours
	~	Dmnl
	~		|

tot hours sh mi[macroind]=
	sum(tot hours sh i[ind!]*ind to macroind map[ind!,macroind])
	~	1
	~		~	:SUPPLEMENTARY 
	|

tot inc tax rev=
	fin tax rev+inc tax rev
	~	Euro/Year
	~		|

tot nom check=
	c total nom bp-c tot pp
	~	
	~		~	:SUPPLEMENTARY 
	|

tot W[assets]=
	W cap[assets]+sum(W gs[gender!,skill!,assets])
	~	Euro
	~		~	:SUPPLEMENTARY 
	|

tot y nom=
	sum(y nom i[ind!])
	~	Euro/Year
	~		|

tot y real=
	sum(y real i[ind!])
	~	Euro constant/Year
	~		|

tot y real delayed=
	sum(y real delayed[ind!])
	~	
	~		|

tot Z imp=
	sum(Z imp nom i[ind!])
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

total additional expenditure=
	additional BI expenditure+additional focalised benefits expenditure expected+total cost JG
+wage WTR gov total cost
	~	Euro/Year
	~		|

total adjustment[regions,inc cat,quintiles]=
	allocate discrepancies across rows[regions,inc cat,quintiles]+
	negatives equal to zero[regions,inc cat,quintiles]
	~	
	~		|

total c hhs and gov real=
	c total real bp+gov c real
	~	
	~		~	:SUPPLEMENTARY 
	|

total capacity[e techn] :EXCEPT:    [e hydro]=
	production capacity[e techn] ~~|
total capacity[e hydro]=
	production capacity[e hydro]+storage capacity[e hydro]
	~	GW
	~		|

total capacity init[e techn] :EXCEPT:  [e hydro]=
	capacity initial[e techn] ~~|
total capacity init[e hydro]=
	capacity initial[e hydro]+init storage capacity[e hydro]
	~	GW
	~		|

total cc=
	sum(total cc ind[ind!])
	~	Euro/Year
	~		|

total cc ind[ind]=
	emissions i[ind]* (1 - selection ETS i[ind])*carbon tax rate
	+Total ETS cost i[ind]
	~	Euro/Year
	~		|

total checks=
	total cc-paid cc+total miscaulated ETS costs
	~	
	~		~	:SUPPLEMENTARY 
	|

total cost JG=
	JG L tot *wage JG*hours mean
	~	
	~		|

total costs govsec[govsec]=
	labour costs i[govsec]+z demand i[govsec]+depreciation K i[govsec]*price capital pp i
[govsec]
	~	Euro/Year
	~		|

total demand nom i[ind]=
	c ESc nom bp i[ind]
	+I supply nom i[ind]
	+ex real ESC i[ind]*p i[ind]
	+gov c nom i[ind]
	+ inv pnrr[ind]
	~	Euro/Year
	~		|

total demand real=
	sum(total demand real i[ind!])
	~	Euro constant/Year
	~		|

total demand real i[ind]=
	total demand nom i[ind]/p i[ind]
	~	Euro constant/Year
	~		|

total electricity production=
	sum(production by technology b[e techn!])+production by technology b[batteries]
	~	GW*Hour/Year
	~		|

total electricity production intitial=
	INITIAL(total electricity production)
	~	GW*Hour/Year
	~		|

total embedded costs T iv[ind,techn]=
	embedded u srf a T iiv[ind,techn]+embedded ucc a T iiv[ind,techn]
	~	Euro/Euro constant
	~		|

total emission use=
	sum(emission use C nrg[nrg!]+emission use Z nrg[nrg!])
	~	TJ/Year
	~		~	:SUPPLEMENTARY 
	|

total emissions=
	emissions C+emissions Z
	~	tCO2eq/Year
	~		|

total emissions delay= DELAY FIXED (
	total emissions, 1 , total emissions init exog)
	~	tCO2eq/Year
	~		|

total emissions init= INITIAL(
	total emissions)
	~	tCO2eq/Year
	~		|

total emissions init exog=
	3.85303e+08
	~	tCO2eq/Year
	~		|

total end use=
	sum(end use Z nrg[nrg!]+end use C nrg[nrg!])
	~	TJ/Year
	~		|

total end use industry=
	sum(end use mi[macroind!])
	~	TJ/Year
	~		|

total end use init= INITIAL(
	total end use)
	~	TJ/Year
	~		|

total end use intensity=
	total end use/VA real
	~	TJ/Euro constant
	~		~	:SUPPLEMENTARY 
	|

total energy source share[nrg]=
	(sum(E use Z inrg[ind!,nrg]))/(sum(E use Z inrg[ind!,nrg!]))
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

total energy use i[ind]=
	sum(E use Z inrg[ind,nrg!])
	~	TJ/Year
	~		|

total energy use per output=
	(sum(total energy use i[ind!]))/(sum(y real i[ind!]))
	~	TJ/Euro constant
	~		~	:SUPPLEMENTARY 
	|

Total ETS allowances historic=
	GET XLS LOOKUPS('?main', 'emissionstrading' , 'time' , 'total_allowances' )
	~	tCO2eq/Year
	~		|

total ETS auctioned=
	sum(auctioned ETS i[ind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

Total ETS cost i[ind]=
	Auctioned ETS cost i[ind]+Excess emissions ETS cost i[ind]
	~	Euro/Year
	~		|

Total ETS cost i expected[ind]=
	Auctioned ETS cost i expected[ind]+Excess emissions ETS cost i expected[ind]
	~	Euro/Year
	~		|

total ets profits impact=
	sum(ets profits impact[ind!])
	~	Euro/Year
	~		|

Total exp i real delay[ind]= DELAY FIXED (
	total exp real i[ind], Year 1 , exp initial i[ind]/p init i alt)
	~	Euro constant/Year
	~		|

total exp nom=
	sum(ex ESc nom i[ind!])+tls exports
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

total exp nom i[ind]=
	total exp real i[ind]*p i[ind]
	~	Euro/Year [0,?]
	~	max(IF THEN ELSE(Time=10* Year 1,
		             Total exp i nom delay[ind]*(1+c19 shock exp),
		             IF THEN ELSE(Time=11* Year 1,
		                          Total exp i nom delay[ind]*(1+c19 shock exp),
		                          1.2*exp initial i[ind]*(1 - elast p exp * inflation i[ind])
		+(g exp i[ind]*Time/Year 1*euro 1)      )
		             ),0* euro 1)
		
		
		exp_initial_i[ind]*
		(1 - elast_p_exp * inflation_i[ind])
		+(g_exp_i[ind]*Time*convergence)
	~	:SUPPLEMENTARY 
	|

total exp real=
	sum(ex ESc nom i[ind!]/p i[ind!])
	~	Euro constant/Year
	~		|

total exp real delay= DELAY FIXED (
	total exp real, 1, initial total exp real)
	~	Euro constant/Year
	~		|

total exp real i[ind]=
	max(
	IF THEN ELSE(activated c19 shocks=1,Total exp i real delay[ind]*(1+exp shocks),
	Total exp i real delay[ind]*(1 + trend impact g exp delayed[ind]))
	*IF THEN ELSE(Act inflation dependent exports=1,
	1-elast p exp*(inflation i[ind]-average inflation),
	1)
	,0)
	*S mpc export impact
	~	Euro constant/Year
	~		|

total free ETS=
	sum(Free ETS i[ind!])
	~	tCO2eq/Year
	~		~	:SUPPLEMENTARY 
	|

total generation=
	sum(baseload deficit production[e techn!]+flex deficit production[e techn!]+generation by technology a
[e techn!])
	~	GW*h/Year
	~		|

total gov c nom=
	sum(gov c nom i[ind!]*(1+tls gov[ind!]))
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

total government provision costs=
	government sectors output costs*fraction gov costs to get profits equal capital costs
	~	Euro/Year
	~		|

total government provision costs govsec[public]=
	min(total costs govsec[public],total government provision costs) ~~|
total government provision costs govsec[health]=
	min(
	max(total government provision costs-total government provision costs govsec[public]
,0)
	*proportional government costs health over education and health
	,total costs govsec[health]) ~~|
total government provision costs govsec[education]=
	min(
	max(total government provision costs-total government provision costs govsec[public]
,0)
	*(1-proportional government costs health over education and health)
	,total costs govsec[education])
	~	Euro/Year
	~		|

total GVA to output=
	sum(GVA real i[ind!])/sum(y real i[ind!])
	~	1
	~		|

total heat use D1=
	sum(a e before ESc[heat,ind!,electricity ind]+a e imp before ESc[heat,ind!,electricity ind
])
	~	TJ/Euro constant
	~		|

total households carbon cost=
	sum(carbon costs rq[regions!,quintiles!])
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

total imp nom=
	sum(total imp nom i[ind!])+tls embedded in imports
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

total imp nom i[ind]=
	Z imp nom i[ind]+final demand imp i[ind]
	~	Euro/Year
	~	total nominal import by industry
	|

total imp real=
	findem imp real
	+Z imp real tot
	~	
	~		|

total imp real i[ind]=
	total imp nom i[ind]/p i[ind]
	~	
	~		~	:SUPPLEMENTARY 
	|

Total loans initial=
	GET XLS CONSTANTS( '?main' , 'investments' , 'total_loans_init' )
	~	
	~		|

total miscaulated ETS costs=
	sum(ets profits impact[ind!])
	~	Euro/Year
	~		|

total mixed income=
	sum(mixed income rq[regions!,quintiles!])
	~	Euro/Year
	~	Profits Not in Financial Income
		The capital income of households coming from imputed rents, actual rents, \
		and the capital component of self-employment income
	|

Total mixed income distributed to households=
	sum(Profits free rents[ind!]+Profits free selfemp capital income[ind!])
	+Mixed income rents*Imputed rents share of mixed income rents
	~	
	~		|

Total mixed income pre tax and deductions=
	Mixed income rents+Mixed income selfemp
	~	
	~		|

total mixed income r[regions]=
	mixed income rents r[regions]+mixed income selfemp r[regions]
	~	Euro/Year
	~	GWB r[regions]*mixed income selfemp to labour income ratio r[regions]
	|

total net labour income=
	sum(net labour income per capita gs[gender!,skill!]*L gs[gender!,skill!])
	~	Euro/Year
	~		|

total net migration[cohorts]=
	GET XLS LOOKUPS('?main', 'migration' , 'time_mig' , 'total_mig' )
	~	People*Euro
	~		|

total paid prod side=
	sum(UCC i[ind!]*y real i[ind!])
	~	Euro/Year
	~		|

total population skills=
	adult population s cap total+sum(Pop 014 g[gender!])
	~	People
	~		~	:SUPPLEMENTARY 
	|

total poverty gap pre hh tax=
	sum(num hhs rq delayed[regions!,quintiles!]*poverty gap hhs pre hh tax rq[regions!,quintiles
	!])
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

total real demand=
	sum(real demand i[ind!])
	~	Euro constant/Year
	~		|

total savings checl=
	sum(savings rq[regions!,quintiles!])
	-sum(savings hhs gs[gender!,skill!])
	-savings hhs cap
	~	
	~		|

total storage charge deficit=
	sum(storage charge deficit by technology[storage technologies!])
	~	GW*h/Year
	~		~	:SUPPLEMENTARY 
	|

total storage discharge deficit=
	sum(storage discharge deficit by technology[storage technologies!])
	~	GW*h/Year
	~		|

total tls=
	sum(c tls i[ind!])
	~	Euro/Year
	~	Total nominal value of taxes-less subsidies from consumption
	~	:SUPPLEMENTARY 
	|

total tls cc check=
	total cc+Carbon tax hh tot-(tls carbon costs paid to domestic government-total miscaulated ETS costs
)
	~	Euro/Year
	~		|

total tls households=
	sum(c ESc tls i[ind!])
	~	Euro/Year
	~		|

total tls paid check=
	sum(c ESc tls i[ind!])+tls paid by gov+gfcf tls paid+tls exports+tls pnrr
	
	
	-tls paid carbon costs-tls paid wo carbon cost
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

total trade balance nom=
	sum(trade balance nom i[ind!])-tls embedded in imports+tls exports
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

total ULC=
	sum(GWB i[ind!]*(1+ss rate employer)-level WTR gov paid i[ind!])/sum(y real i[ind!])
	~	Euro/Euro constant
	~		|

Total unitary ETS cost i[ind]=
	Total ETS cost i[ind]/y real i[ind]
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

Total unitary ETS cost i expected[ind]=
	Total ETS cost i expected[ind]/output expected[ind]
	~	Euro/Euro constant
	~	Prima (expected ets ucc = )
		expected ets cc[ind]/output expected[ind]
	|

total use=
	(sum(E C imp nrg[nrg!]+E C nrg[nrg!])+sum(E use Z inrg[ind!,nrg!]))
	~	TJ/Year
	~		~	:SUPPLEMENTARY 
	|

total yd check=
	GWB+GFI rq total+total mixed income
	-soc sec contr from households
	-personal taxes
	+transfers exp
	~	
	~		~	:SUPPLEMENTARY 
	|

totel end use=
	sum(end use C nrg[nrg!]+end use Z nrg[nrg!])
	~	TJ/Year
	~		~	:SUPPLEMENTARY 
	|

totimeuse<->
	timeuse
	~	
	~		|

track tech choice[ind]=
	IF THEN ELSE(ratio y FC to unconstrained i[ind]<1,capital prod techn[ind],
	
	IF THEN ELSE(factor FE constraint<1,lab saving techn[ind],
	
	
	IF THEN ELSE(T i[ind]=UFC T iv[ind,T1],1,
	IF THEN ELSE(T i[ind]=UFC T iv[ind,T2],2,
	IF THEN ELSE(T i[ind]=UFC T iv[ind,T3],3,
	IF THEN ELSE(T i[ind]=UFC T iv[ind,T4],4,0)
	)))
	))
	~	Dmnl
	~	Priority of technological choice:
		1. Capital constraint (because labour affects all industries so firms first focus on \
		capital even if labour is the binding constraint)
		2. Labour constraint
		3. Costs
		IF THEN ELSE(factor capacity constraint i<1,capital prod techn[ind],
		
		IF THEN ELSE(factor FE constraint<1,lab saving techn[ind],
		
		
		IF THEN ELSE(T i[ind]=UFC T iv[ind,T1],1,
		IF THEN ELSE(T i[ind]=UFC T iv[ind,T2],2,
		IF THEN ELSE(T i[ind]=UFC T iv[ind,T3],3,
		IF THEN ELSE(T i[ind]=UFC T iv[ind,T4],4,0)
		)))
		))
	|

trade balance nom i[ind]=
	ex ESc nom i[ind] - total imp nom i[ind]
	~	Euro/Year
	~		|

trade balance real i[ind]=
	(ex ESc nom i[ind]/p i[ind])
	-sum(Z imp real ii[ind,toind!])
	-(final demand imp i[ind]/p i[ind])
	~	Euro constant/Year
	~		~	:SUPPLEMENTARY 
	|

trade rows=
	sum(trade balance nom i[ind!])
	-
	(sum(ex ESc nom i[ind!])-sum(gov c imp nom i[ind!])-sum(c ESc nom bp imp i[ind!])-sum
	(I imp i[ind!])-sum(Z imp nom i[ind
	!])-sum(substitution imports[ind!]))
	~	Euro/Year
	~		|

trans use[ffbio] :EXCEPT:  [gas]=
	Transformation use in electricity production 0[ffbio] ~~|
trans use[gas]=
	Transformation use in electricity production 0[gas]*(1-hydro share in gas)
	~	TJ/Year
	~		|

trans use per output electricity sector[ffbio]=
	trans use[ffbio]/y real i[electricity ind]
	~	TJ/Euro constant
	~		|

trans use per output electricity sector delayed[ffbio]= DELAY FIXED (
	trans use per output electricity sector[ffbio], TIME STEP , initial trans use per output electricity sector
	[ffbio])
	~	TJ/Euro constant
	~		|

transfers exp=
	GUB exp+GPB exp+SD exp+CB exp+other benefits exp+
	CT redistrib total+BI exp+reimbursed carbon costs total
	~	Euro/Year
	~		|

transfers in kind=
	sum(gov c nom i[nongovsec!])
	~	Euro/Year
	~		|

Transformation use in electricity production 0[coal]=
	((production by technology b[e coal])/TJ to GWh)/ffbio fuel conversion efficiencies[
coal] ~~|
Transformation use in electricity production 0[gas]=
	(production by technology b[e gas]/TJ to GWh)/ffbio fuel conversion efficiencies[gas
] ~~|
Transformation use in electricity production 0[oil]=
	production by technology b[e petroleum]/TJ to GWh/ffbio fuel conversion efficiencies
[oil] ~~|
Transformation use in electricity production 0[bio]=
	production by technology b[e nec]*wastebio share of nec*solid bio share of wastebio/
TJ to GWh/ffbio fuel conversion efficiencies[bio]
	~	TJ/Year
	~		|

translog price index[regions,quintiles]=
	IF THEN ELSE(Time=0,0,
	sum(aids adjusted intercepts[regions,quintiles,ind!]*ln(price index pp i[ind!]))
	+0.5*sum(ln(price index pp i[ind!])*gamma p translog price index[ind!]))
	~	Dmnl
	~		|

trend cap=
	0.03
	~	Dmnl/Year
	~		|

trend entry skill gs[gender,skill]=
	S1 trend entry skill gs[p1524,gender,skill]*IF THEN ELSE(Time<S Time Policy start,
	                1,
	                1+min(S Time end-S Time Policy start,Time-S Time Policy start)*(S skill supply trend
/(S Time end-S Time Policy start))
	                )
	~	Dmnl/Year
	~	observed trend in skill endowment when entering working age
		*IF_THEN_ELSE(Time<S_begining,
		                1,
		                \
		1+min(S_end-S_begining,Time-S_begining)*(S_working_hours/(S_end-S_begining)\
		)
		                )
	|

trend gov c i[ind] :EXCEPT:    [health],[education]=
	S1 trend gov c i capped[ind]
	*IF THEN ELSE(Time<S Time Policy start,
	                euro 1,
	                euro 1*(1+min(S Time end-S Time Policy start,Time-S Time Policy start
	)*(S trend Gcons/(S Time end-S Time Policy start
	)))
	                ) ~~|
trend gov c i[health]=
	S1 trend gov c i capped[health]
	*IF THEN ELSE(Time<S Time Policy start,
	                euro 1,
	                euro 1*(1+min(S Time end-S Time Policy start,Time-S Time Policy start
	)*(S trend Gcons/(S Time end-S Time Policy start
	))+
	IF THEN ELSE(Act Increase Access=0,0,pub exp on access growth)
	)
	                ) ~~|
trend gov c i[education]=
	S1 trend gov c i capped[education]
	*IF THEN ELSE(Time<S Time Policy start,
	                euro 1,
	                euro 1*(1+min(S Time end-S Time Policy start,Time-S Time Policy start
	)*(S trend Gcons/(S Time end-S Time Policy start
	))+
	IF THEN ELSE(Act Increase Access=0,0,pub exp on access growth)
	)
	                )
	~	Euro
	~	historic initial gov c trend[ind](Time)
		
		IF THEN ELSE(Time<13,historic initial gov c trend[ind](Time),S1 trend gov \
		c i capped[ind])
	|

trend impact g exp[ind]=
	g exp i[ind] + (ratio growth exports to growth trend*long run growth rate - g exp i[
ind])*(1-convergence)
	~	Dmnl/Year
	~	g exp i[ind] + (long run growth rate - g exp i[ind])*(1-convergence)
	|

trend impact g exp delayed[ind]=
	DELAY FIXED(trend impact g exp[ind], delay time, 0)
	~	Dmnl
	~		|

trend impact gov c[ind] :EXCEPT:                 [health],[education]=
	IF THEN ELSE(Act Change baseline gov consumption=1 :AND: Time>=S Time Change baseline gov consumption
,
	             0,
	             IF THEN ELSE((Act Change baseline gov consumption=2 :OR: Act Change baseline gov consumption
=4) :AND: Time>=S Time Change baseline gov consumption,
	                          g GDP real,
	                          IF THEN ELSE(Act Change baseline gov consumption=3 :AND: Time
>=S Time Change baseline gov consumption,
	                                       g gov c real GDP smooth and gap corrected i[ind
],
	trend gov c i[ind] + (ratio growth gov c to growth trend*long run growth rate - trend gov c i
[ind])*(1-convergence)
	)
	)
	) ~~|
trend impact gov c[health]=
	IF THEN ELSE(Act Change baseline gov consumption=1 :AND: Time>=S Time Change baseline gov consumption
,
	             0,
	             IF THEN ELSE(Act Change baseline gov consumption=2 :AND: Time
	>=S Time Change baseline gov consumption
	,
	                          g GDP real,
	                          IF THEN ELSE(Act Change baseline gov consumption=3 :AND: Time
	>=S Time Change baseline gov consumption,
	                                       g gov c real GDP smooth and gap corrected i[health
	],
	                                       IF THEN ELSE(Act Change baseline gov consumption
	=4 :AND: Time
	>=S Time Change baseline gov consumption,
	                                                    g Pop over65,
	trend gov c i[health] + (ratio growth gov c to growth trend*long run growth rate - trend gov c i
[health])*(1-convergence
	)
	)
	)
	)
	) ~~|
trend impact gov c[education]=
	IF THEN ELSE(Act Change baseline gov consumption=1 :AND: Time>=S Time Change baseline gov consumption
,
	             0,
	             IF THEN ELSE(Act Change baseline gov consumption=2 :AND: Time
	>=S Time Change baseline gov consumption
	,
	                          g GDP real,
	                          IF THEN ELSE(Act Change baseline gov consumption=3 :AND: Time
	>=S Time Change baseline gov consumption,
	                                       g gov c real GDP smooth and gap corrected i[education
	],
	                                       IF THEN ELSE(Act Change baseline gov consumption
	=4 :AND: Time
	>=S Time Change baseline gov consumption,
	                                                    g Pop 024,
	             trend gov c i[education] + (ratio growth gov c to growth trend*long run growth rate
 - trend gov c i[education
	])*(1-convergence
	)
	)
	)
	)
	)
	~	Dmnl/Year
	~	trend gov c i[ind] + (ratio growth gov c to growth trend*long run growth \
		rate - trend gov c i[ind])*(1-convergence)
	|

trend impact gov c delayed[ind]=
	DELAY FIXED(trend impact gov c[ind], delay time, 0)
