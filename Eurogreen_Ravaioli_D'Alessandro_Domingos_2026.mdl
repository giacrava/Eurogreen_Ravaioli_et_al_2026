		capitalists)
	|

NFI rq[regions,quintiles]=
	NFI rq bonds[regions,quintiles]+NFI rq eq[regions,quintiles]
	~	
	~	Net financial income, total nominal value per region-quintile
		
		Without evasion nor different effective tax rates:
		GFI rq[regions,quintiles] * (1 - financial income tax rate)
	|

NFI rq bonds[regions,quintiles]=
	(1-fin inc tax rate bonds effective)*GFI rq bonds[regions,quintiles]
	~	Euro/Year
	~		|

NFI rq eq[regions,quintiles]=
	(1-fin inc tax rate eq effective)*GFI rq eq[regions,quintiles]
	~	
	~		|

NFI rq total=
	sum(NFI rq[regions!,quintiles!])
	~	
	~		|

