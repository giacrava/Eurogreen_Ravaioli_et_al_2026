	NFI rq[regions,quintiles]-indexed initial NFI rq[regions,quintiles]
	~	
	~		|

delta nonmarket output after policy i[govsec]=SAMPLE IF TRUE(
	Time = S Time Shift end, delta nonmarket output during policy i[govsec], 0)
