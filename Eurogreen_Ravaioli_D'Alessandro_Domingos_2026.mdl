	~		|

delta wage WTR gov paid[gender,ind,skill]=
	delta wage WTR[gender,ind,skill]*gov share wage WTR
	~	Euro/(Person*Hours)
	~		|

delta y FC i[ind]=
	IF THEN ELSE(
	(Act change gov investment=1:OR:Act change gov investment=2)
	,
	additional yearly delta gov c real i[ind],
	0
	)
	~	Euro constant/Year
	~		|

delta yd cap d[inc cat]=
	sum(delta yd cap rq[regions!,quintiles!]*
	hhs cat shares rq adj[regions!,inc cat,quintiles!]*
	(pop d[inc cat]/adult pop rq[regions!,quintiles!]))
	~	Euro/Year
	~		|

delta yd cap d check=
	sum(delta yd cap d[inc cat!])-gov rev cap
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

delta yd cap d per capita[inc cat]=
	ZIDZ(delta yd cap d[inc cat],pop d[inc cat])
	~	Euro/(Year*Person)
	~		|

delta yd cap hhs rq[regions, quintiles]=
	IF THEN ELSE((:NOT:Act income cap=0):AND:Time >= S Time Policy start,
	max(0, yd hhs pre hh tax rq[regions,quintiles]-effective current income cap),0)
	~	Euro/(Year*Household)
	~	Reduction of disposable income/tax paid due to cap for each households in \
		each region quintile
	|

delta yd cap hhs rq exp[regions,quintiles]=
	IF THEN ELSE((:NOT:Act income cap=0):AND:Time >= S Time Policy start,
	max(0, yd hhs pre tax rq delayed[regions,quintiles]-effective income cap delayed),0)
	~	Euro/(Year*Household)
	~		|

delta yd cap rq[regions, quintiles]=
	delta yd cap hhs rq[regions,quintiles]*num hhs rq delayed[regions,quintiles]
	~	Euro/Year
	~	Reduction of disposable income/tax paid due to cap of each region quintile \
		representative household
