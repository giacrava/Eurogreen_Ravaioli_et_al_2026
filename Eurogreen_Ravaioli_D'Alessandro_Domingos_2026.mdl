production capacity[e techn]= INTEG (
	capacity almost constructed investment[e techn]-capacity depreciation[e techn],
		capacity initial[e techn])
	~	GW
	~	Stock of productive capacity by techology.
	|

production shares[e techn]=
	production by technology b[e techn]/sum(production by technology b[e techn!])
	~	Dmnl
	~		|

production shares nonhydro[e techn, electricity technologies]=
	expected electricity demand technology shareno transition[e techn,electricity technologies
]/
	(sum(expected electricity demand technology shareno transition[e techn!,electricity technologies
])-expected electricity demand technology shareno transition[e hydro,electricity technologies
])
	~	Dmnl
	~		|

profit share i[ind]=
	(profits i[ind])/
	(VA i[ind])
	~	Dmnl
	~	sum(GWB gis[gender!,ind,skill!]) +(sum(soc sec contr employer \
		gis[gender!,ind,skill!]*L gis[gender!,ind,skill!])/People 1) + 
		carbon cost tot i[ind]+sum(level WTR gov paid \
		gis[gender!,ind,skill!]*hours i[ind]*L gis[gender!,ind,skill!]))
	~	:SUPPLEMENTARY 
	|

profit transfers capital[ind]=
	debt repayment i[ind]
	+profits residual[ind]
	+Investment spending[ind]
	~	Euro/Year
	~	sum(debt repayment i[ind!])
		-sum(profits residual[ind!])
		-sum(Investment spending[ind!])
		+min(Investment spending[ind],post debt repayment profits i effective[ind])
	|

profit transfers household=
	Total mixed income distributed to households
	+sum(Div i[ind!])
	~	Euro/Year
	~		|

Profits=
	sum(profits i[ind!])
	~	Euro/Year
	~		|

Profits free[ind]=
	post debt repayment profits i effective[ind]-Investment spending[ind]
	~	Euro/Year
	~		|

Profits free nonMI[ind]=
	Profits free[ind]*post tax nonMI profits share i[ind]
	~	
	~		|

Profits free rents[ind]=
	Profits free[ind]*post tax rents profits share i[ind]
	~	
	~		|

Profits free selfemp capital income[ind]=
	Profits free[ind]*post tax selfemp profits share i[ind]
	~	
	~		|

profits fully distributed check=
	sum(profits i[ind!]
	-corp tax i effective[ind!]
	-interest payment i[ind!]
	-profit transfers capital[ind!])
	-profit transfers household
	-government gross profits
	~	Euro/Year
	~		|

profits i[ind]=
	VA i[ind] 
	- labour costs i[ind]
	+ets profits impact[ind]
	~	Euro/Year
	~		|

profits post imputed rents i[ind] :EXCEPT:     [realestate]=
	profits i[ind] ~~|
profits post imputed rents i[realestate]=
	profits i[realestate]-Mixed income rents*Imputed rents share of mixed income rents
	~	Euro/Year
	~		|

profits post interest i[ind]=
	profits post imputed rents i[ind]-interest payment i[ind]
	~	Euro/Year
	~		|

profits postimpr nonMI share i[ind]=
	1-profits postimpr rents share i[ind]-profits postimpr selfemp share i[ind]
	~	
	~		|

profits postimpr rents share i[ind] :EXCEPT:      [realestate]=
	0 ~~|
profits postimpr rents share i[realestate]=
	ZIDZ(Mixed income rents*(1-Imputed rents share of mixed income rents),profits post imputed rents i
	[realestate])
	~	
	~		|

profits postimpr selfemp share i[ind]=
	min(1,ZIDZ(Mixed income selfemp*share of selfemp capital income i[ind],profits post imputed rents i
[ind]))
	~	
	~		|

profits residual[ind]=
	Profits free nonMI[ind]-Div i[ind]
	~	Euro/Year
	~	residual profits after paying dividents, used to pay outstanding debt
		
		BEFORE:
		post selfemp capital income profits i[ind]-Div i[ind]
	|

prog inc tax 2=
	0.1
	~	Dmnl
	~		|

prog inc tax 3=
	0.25
	~	Dmnl
	~		|

prog inc tax 4=
	0.55
	~	Dmnl
	~		|

prog inc tax 5=
	0.85
	~	Dmnl
	~		|

prog inc tax 6=
	0.9
	~	Dmnl
	~		|

prop pop d[inc cat]=
	pop d[inc cat]/(sum(pop d[inc cat!])+sum(Pop 014 g[gender!]))
	~	
	~		~	:SUPPLEMENTARY 
	|

proportional government costs govsec[govsec]=
	government output share govsec[govsec]*total costs govsec[govsec]
	~	Euro/Year
	~		|

proportional government costs health over education and health=
	proportional government costs govsec[health]/(proportional government costs govsec[health
]+proportional government costs govsec[education])
	~	Dmnl
	~		|

pub exp on access growth=
	per capita pub exp on access growth+population growth
	~	Dmnl
	~		|

public education spending per 024=
	gov c real i[education]/(Pop 014+Pop 1524)
	~	Euro constant/(Person*Year)
	~		~	:SUPPLEMENTARY 
	|

public healthcare and pensions spending per over65=
	(gov c real i[health]+GPB exp real)/Pop over65
	~	
	~		~	:SUPPLEMENTARY 
	|

public healthcare spending per 014 and over65=
	gov c real i[health]/(Pop 014+Pop over65)
	~	Euro constant/(Person*Year)
	~		~	:SUPPLEMENTARY 
	|

public healthcare spending per over65=
	gov c real i[health]/Pop over65
	~	Euro constant/(Person*Year)
	~		~	:SUPPLEMENTARY 
	|

quintile electrification impact[quintiles]=
	1
	~	Dmnl
	~	Multiplicative impact on electrification rates of households
	~	:SUPPLEMENTARY 
	|

quintiles:
	q1,
	q2,
	q3,
	q4,
	q5
	~	
	~		|

r target=
	0
	~	
	~	target value for the real interest rate, included in the taylor rule.
	|

rate of electrification=
	(cumulative electrification-delayed cumulative electrification)/(1-delayed cumulative electrification
)
	~	Dmnl/Year
	~		|

rate of electrification expected[electricity technologies]=
	(cumulative electrification expected[electricity technologies]-cumulative electrification expected delayed
	[electricity technologies])/(1-cumulative electrification expected delayed[electricity technologies
	]
	)
	~	Dmnl
	~		|

rate of electrification expected delayed 1[electricity technologies]= DELAY FIXED (
	rate of electrification expected[electricity technologies], Year 1 , initial rate of electrification expected
)
	~	Dmnl
	~		|

rate of electrification expected delayed 2[electricity technologies]= DELAY FIXED (
	rate of electrification expected delayed 1[electricity technologies], Year 1 , initial rate of electrification expected
)
	~	Dmnl
	~		|

rate of electrification expected delayed 3[electricity technologies]= DELAY FIXED (
	rate of electrification expected delayed 2[electricity technologies], Year 1 , initial rate of electrification expected
)
	~	Dmnl
	~		|

rate of electrification expected delayed 4[electricity technologies]= DELAY FIXED (
	rate of electrification expected delayed 3[electricity technologies], Year 1 , initial rate of electrification expected
)
	~	Dmnl
	~		|

rate of electrification expected delayed 5[electricity technologies]= DELAY FIXED (
	rate of electrification expected delayed 4[electricity technologies], Year 1 , initial rate of electrification expected
)
	~	Dmnl
	~		|

rate of electrification expected delayed 6[electricity technologies]= DELAY FIXED (
	rate of electrification expected delayed 5[electricity technologies], Year 1 , initial rate of electrification expected
)
	~	Dmnl
	~		|

rate of electrification expected delayed 7[electricity technologies]= DELAY FIXED (
	rate of electrification expected delayed 6[electricity technologies], Year 1
	 , initial rate of electrification expected)
	~	Dmnl
	~		|

ratio final total demand=
	sum(ratio final total demand i[ind!]*y real i 0[ind!])/sum(y real i 0[ind!])
	~	1
	~		~	:SUPPLEMENTARY 
	|

ratio final total demand i[ind]=
	final demand real i[ind]/y real i 0[ind]
	~	Dmnl
	~	Ratio of final demand over total output of a sector.
		The lower, the more the sector produces intermediate goods.
	|

ratio final total demand mi[macroind]=
	sum(ratio final total demand i[ind!]*ind to macroind map[ind!,macroind]*y real i 0[ind
!])/sum(y real i 0[ind!]*ind to macroind map[ind!,macroind])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

ratio from Ed to E C i[ind]=
	0.860508,
	0.74741,
	0.535862,
	0.0796489,
	0.805603,
	0.776894,
	0.473686,
	0.415064,
	0.90135,
