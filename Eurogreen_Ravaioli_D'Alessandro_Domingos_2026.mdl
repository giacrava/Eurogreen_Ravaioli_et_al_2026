	IF THEN ELSE(Time=9,c19 LFPR 2020[gender,skill],
	IF THEN ELSE(Time=10,c19 LFPR 2021[gender,skill],
	IF THEN ELSE(Time=11,c19 LFPR 2022[gender,skill],
	IF THEN ELSE(Time=12,c19 LFPR 2023[gender,skill],0))))
	~	
	~	IF THEN ELSE(Time=9,c19 LFPR 2020[gender,skill]*3.5,
		IF THEN ELSE(Time=10,c19 LFPR 2021[gender,skill]*4,
		IF THEN ELSE(Time=11,c19 LFPR 2022[gender,skill]*6,0)))
	|

cap chek=
	(adult population g total-adult population s total)/adult population g total
	~	People
	~		~	:SUPPLEMENTARY 
	|

capacity almost constructed investmen nonRES[e techn]= DELAY FIXED (
	 capacity investment[e techn], capacity construction time[e techn]-Year 1, constructed capacity investment initial
[e techn])
	~	GW/Year
	~	Constructed capacity for non-RES technologies are represented by a \
		pipeline delay. The delay time is construction time-1 as it takes an \
		additional period for capacity to accumulate in the capacity stock. The \
		initial value runs until the delay time is reached, hence we assume \
		constant constructed investment within this time period. As the \
		construction time for RES is 1 year, but the minimum delay time in delay \
		fixed is TIME STEP, RES investment constructed is equal to RES investment.
	|

capacity almost constructed investment[e techn] :EXCEPT: [e wind],[e solarpv],[e solarth
]=
	capacity almost constructed investmen nonRES[e techn] ~~|
capacity almost constructed investment[e wind]=
	capacity investment[e wind] ~~|
capacity almost constructed investment[e solarpv]=
	capacity investment[e solarpv] ~~|
capacity almost constructed investment[e solarth]=
	capacity investment[e solarth]
	~	GW/Year
	~	Constructed capacity for non-RES technologies are represented by a \
		pipeline delay. The delay time is construction time-1 as it takes an \
		additional period for capacity to accumulate in the capacity stock. The \
		initial value runs until the delay time is reached, hence we assume \
		constant constructed investment within this time period. As the \
		construction time for RES is 1 year, but the minimum delay time in delay \
		fixed is TIME STEP, RES investment constructed is equal to RES investment.
	|

capacity construction time[e coal]=
	4 ~~|
capacity construction time[e gas]=
	3 ~~|
capacity construction time[e nuclear]=
	7 ~~|
capacity construction time[e hydro]=
	5 ~~|
capacity construction time[e wind]=
	1 ~~|
capacity construction time[e petroleum]=
	3 ~~|
capacity construction time[e solarpv]=
	1 ~~|
capacity construction time[e solarth]=
	1 ~~|
capacity construction time[e nec]=
	RES transition*
	(integer
	(IF THEN ELSE(Time>=S Time Policy start,
	init construction time nec+
	(final constrcution time nec-init construction time nec)/
	(1+EXP(-steepness logistic curve*(Time-midpoint logistic curve
	))),
	init construction time nec)))
	
	+(1-RES transition)*
	(integer
	(init construction time nec))
	~	Year
	~	Construction time by technology based on IEA data (IEA costs of electricity report \
		(https://www.iea.org/reports/projected-costs-of-generating-electricity-2020\
		)).
		Due to the change of mix bewtween bio and geothermal in nec, the value for nec is \
		dynamic. For simplicity we again assume a liner extrapolation over time.
		We the value for petroleum is the same as for gas and solarth same as \
		solarpv.
	|

capacity deprciation 7 years ahead[e techn]=
	DELAY FIXED(  capacity almost constructed investment[e techn], capacity lifetime[e techn
]-Year 1*6,(capacity initial[e techn]/capacity lifetime[e techn]) )
	~	GW/Year
	~		|

capacity depreciation[e techn]=
	DELAY FIXED(capacity almost constructed investment[e techn], capacity lifetime[e techn
] , (capacity initial[e techn]/capacity lifetime[e techn]))
	~	GW/Year
	~	Capacity depreciation, as a pipeline delay. Initial capacity linearly \
		depreciates and is fully depreciated, once the pipeline delay kicks in.
	|

capacity depreciation 1 year ahead[e techn]= DELAY FIXED (
	 capacity almost constructed investment[e techn], capacity lifetime[e techn],(capacity initial
[e techn]/capacity lifetime[e techn]))
	~	GW/Year
	~		|

capacity depreciation 2 years ahead[e techn]= DELAY FIXED (
	  capacity almost constructed investment[e techn], capacity lifetime[e techn]-Year 1
,(capacity initial[e techn]/capacity lifetime[e techn]))
	~	GW/Year
	~		|

capacity depreciation 3 years ahead[e techn]= DELAY FIXED (
	capacity almost constructed investment[e techn], capacity lifetime[e techn]-Year 1*2
,(capacity initial[e techn]/capacity lifetime[e techn]))
	~	GW/Year
	~		|

capacity depreciation 4 years ahead[e techn]= DELAY FIXED (
	  capacity almost constructed investment[e techn], capacity lifetime[e techn]-Year 1
*3,(capacity initial[e techn]/capacity lifetime[e techn]))
	~	GW/Year
	~		|

capacity depreciation 5 years ahead[e techn]=
	DELAY FIXED(  capacity almost constructed investment[e techn], capacity lifetime[e techn
]-Year 1*4,(capacity initial[e techn]/capacity lifetime[e techn]) )
	~	GW/Year
	~		|

capacity depreciation 6 years ahead[e techn]=
	DELAY FIXED(  capacity almost constructed investment[e techn], capacity lifetime[e techn
]-Year 1*5,(capacity initial[e techn]/capacity lifetime[e techn]) )
	~	GW/Year
	~		|

capacity factor generation[e techn]=
	ZIDZ(production by technology b[e techn],production capacity[e techn]*hours in year)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

capacity initial[e techn]=
	capacity initial MW[e techn]*MW to GW
	~	GW
	~	Data for 2010 from Jaxa-Rozen et al., 2022. Hydro include PHES and petroleum is \
		approximated using capacity factors for Italy for fossil fuels from Bolson \
		et al., 2022 and production data from Eurostat averaged between 2010 and \
		2019 due to the high fluctuation of fossil fuel capacity factors during \
		this period.
		Correction for /autoproduction: scaled by non autoproduction shares using \
		Eurostat capacity by operator shares where available (i.e. solar,hydro, \
		wind) and Eurostat energy balance production shares by operator as proxy \
		for other technologies
	|

capacity initial MW[e techn]=
	GET XLS CONSTANTS('?main', 'electricity', 'cap_init*' )
	~	MW
	~	Data for 2010 from Jaxa-Rozen et al., 2022. Hydro include PHES and \
		petroleum is approximated using capacity factors for Italy for fossil \
		fuels from Bolson et al., 2022 and production data from Eurostat averaged \
		between 2010 and 2019 due to the high fluctuation of fossil fuel capacity \
		factors during this period.
	|

capacity investment[e techn]=
	max(min(capacity investment desired[e techn],scale constraint multiplier*capacity max investment scale
[e techn]),0)*financial constraint factor electricity
	~	GW/Year
	~	Actual capacity investment. Desired investment is constrained by potential limited \
		financial resources allocated to the technology and a scale expansion \
		constrained. Both constraints can be switched off/on.
		max(min(min(capacity investment desired[techn],scale constraint multiplier*capacity \
		max investment scale[techn]),financial constraint multiplier
		*financial constraint technologies allocated[techn]/capacity investment \
		costs per unit capacity[techn]),0)
	|

capacity investment costs per unit capacity[e techn]=
	capacity investment costs per unit capacity initial[e techn]*capacity learning effect
[e techn]
	~	Euro constant/GW
	~		|

capacity investment costs per unit capacity initial[e coal]=
	1.63877e+09 ~~|
capacity investment costs per unit capacity initial[e gas]=
	5.71612e+08 ~~|
capacity investment costs per unit capacity initial[e nuclear]=
	3.58566e+09 ~~|
capacity investment costs per unit capacity initial[e hydro]=
	RES transition*
	(IF THEN ELSE(Time>=S Time Policy start,
	init per unit inv costs hydro+
	(final per unit inv costs hydro-init per unit inv costs hydro)/
	(1+EXP(-steepness logistic curve*(Time-midpoint logistic curve
	))),
	init per unit inv costs hydro))
	
	+(1-RES transition)*
	(init per unit inv costs hydro) ~~|
capacity investment costs per unit capacity initial[e wind]=
	1.98038e+09 ~~|
capacity investment costs per unit capacity initial[e petroleum]=
	9.48875e+08 ~~|
capacity investment costs per unit capacity initial[e solarpv]=
	4.03995e+09 ~~|
capacity investment costs per unit capacity initial[e solarth]=
	4.03995e+09 ~~|
capacity investment costs per unit capacity initial[e nec]=
	RES transition*
	(IF THEN ELSE(Time>=S Time Policy start,
	init per unit inv costs nec+
	(final per unit inv costs nec-init per unit inv costs nec)/
	(1+EXP(-steepness logistic curve*(Time-midpoint logistic curve
	))),
	init per unit inv costs nec))
	
	+(1-RES transition)*
	(init per unit inv costs nec)
	~	Euro constant/GW
	~	Investment costs per GW for years closest to 2010 from Jaxa Rozen et al., 2022 in \
		EUR/GW.
		Due to the change of mix bewtween bio and geothermal in nec and between PHS, Dam and \
		RoR in Hydro, the value for nec is dynamic. For simplicity we again assume \
		a liner extrapolation over time. Note that this dynamic is absent of any \
		learning effects, which is why it takes place in the 'initial' costs.
		We assume solarth is same as solarpv.
		
		Adjusted to 2010 Euros using WIOD 2016 exchange rates and core consumter \
		price inflation from Ha et al. (2023). For values from different years we \
		use capacity values and learning rates both from Jaxa-Rozen et al. (2022) \
		to obtain cost values for 2010.
	|

capacity investment costs topay[e techn]=
	new capacity investment costs[e techn]*Year 1+ongoing investment financing[e techn]
	~	Euro constant/Year
	~	We assume a linear expense schedule of investment costs over the time of \
		construction.
	|

capacity investment desired[e techn]=
	max(required capacity expected[e techn]-expected capacity ahead wo investment[e techn
],0)
	~	GW/Year
	~	Desired capacity investment is driven by desired increases in capacity as \
		well as depreciation replacements.
	|

capacity learning effect[e techn]=
	(ZIDZ(smooth(total capacity[e techn],scale impacts adjustment time),total capacity init
[e techn]))^IF THEN ELSE( total capacity[e techn]>0, capacity learning rate beta[e techn
], 0 )
	~	Dmnl
	~	The fractional impact of learning effects on investment costs. We use a \
		common learning curve formulation with capacity driving improvements and a \
		smooth function to reflect that learning effects don't immediately \
		materialise with added capacity, but slowly evolve over time.
	|

capacity learning rate beta[e coal]=
	-0.125006 ~~|
capacity learning rate beta[e gas]=
	-0.217591 ~~|
capacity learning rate beta[e nuclear]=
	0.0143553 ~~|
capacity learning rate beta[e hydro]=
	-0.0203404 ~~|
capacity learning rate beta[e wind]=
	-0.184425 ~~|
capacity learning rate beta[e petroleum]=
	-0.217591 ~~|
capacity learning rate beta[e solarpv]=
	-0.37707 ~~|
capacity learning rate beta[e solarth]=
	-0.37707 ~~|
capacity learning rate beta[e nec]=
	RES transition*
	(IF THEN ELSE(Time>=S Time Policy start,
	learning rate beta nec init+
	(learning rate beta nec final-learning rate beta nec init)/
	(1+EXP(-steepness logistic curve*(Time-midpoint logistic curve
	))),
	learning rate beta nec init))
	
	+(1-RES transition)*
	(learning rate beta nec init)
	~	Dmnl
	~	Learning rate expression exponentials calculated from learning rates from given by \
		Jaxa Rozen et al.,2022.
		Due to the change of mix bewtween bio and geothermal in nec, the value for nec is \
		dynamic. For simplicity we again assume a liner extrapolation over time.
		We assume the value for solarth is the same as solarpv.
	|

capacity lifetime[e coal]=
	40 ~~|
capacity lifetime[e nec]=
	RES transition*
	(integer
	(IF THEN ELSE(Time>=S Time Policy start,
	init lifetime nec+
	(final lifetime nec-init lifetime nec)/
	(1+EXP(-steepness logistic curve*(Time-midpoint logistic curve
	))),
	init lifetime nec)))
	
	+(1-RES transition)*
	(integer
	(init lifetime nec)) ~~|
capacity lifetime[e gas]=
	30 ~~|
capacity lifetime[e nuclear]=
	60 ~~|
capacity lifetime[e hydro]=
	80 ~~|
capacity lifetime[e wind]=
	25 ~~|
capacity lifetime[e petroleum]=
	30 ~~|
capacity lifetime[e solarpv]=
	25 ~~|
capacity lifetime[e solarth]=
	25
	~	Year
	~	Lifetime by technology based on IEA data (IEA costs of electricity report \
		(https://www.iea.org/reports/projected-costs-of-generating-electricity-2020\
		)) and Jaxa-Rozen et al. (2022) where IEA data not available (i.e. for \
		petroleum and bio).
		Due to the change of mix bewtween bio and geothermal in nec, the value for nec is \
		dynamic. For simplicity we again assume a liner extrapolation over time.
		We assume solarth same as solarpv.
	|

capacity max investment scale[e techn]=
	max(max scale increase[e techn]*smooth(production capacity[e techn],scale impacts adjustment time
),min max scale increase)
	~	GW/Year
	~	The maximum amount that capacity can increase within a year due to limited \
		production capabilities. This reflects, capital stock expansions are \
		limited by current infrastructure on the ground and that the larger the \
		capacity is, the larger its absolute increase can be due to more expansive \
		infrastructure. The smooth function reflects that this infrastructure does \
		not immediately materialise with added capacity, but slowly builds up over \
		time.
	|

capital expected[ind]=
	K i[ind]-depreciation K i[ind]*Year 1+in K i[ind]*Year 1
	~	Euro constant
	~		|

capital price techn[electricity subs]=
	sum(gfcf shares electricity[ind!,electricity subs]*p i[ind!]) ~~|
capital price techn[power2gas]=
	sum(gfcf shares p2g[ind!]*p i[ind!]) ~~|
capital price techn[batteries]=
	sum(gfcf shares battery[ind!]*p i[ind!])
	~	Euro/Euro constant
	~		|

capital price technology pp[electricity technologies]=
	capital price techn[electricity technologies]*(1+tls techn[electricity technologies]
)
	~	Euro/Euro constant
	~		|

capital prod techn[toind]=
	IF THEN ELSE(min delta a[toind]=sum(a T iiv[ind!,toind,T2]),2,
	IF THEN ELSE(min delta a[toind]=sum(a T iiv[ind!,toind,T3]),3,
	IF THEN ELSE(min delta a[toind]=sum(a T iiv[ind!,toind,T4]),4,
	1)))
	~	Dmnl
	~		|

capital productivity dynamic[ind]=
	initial cap prod i[ind]
	~	Dmnl/Year
	~	capital productivity moves in line with production efficiency but does not fall
		max(capital productivity dynamic delay[ind],
		initial cap prod i[ind]*min(ZIDZ(initial unit int dem i[ind],unit intermedite demand \
		i
		[ind])
		,1+maximum capital productivity growth
		))
	|

capital productivity dynamic delay[ind]= DELAY FIXED (
	capital productivity dynamic[ind], Year 1, initial cap prod i[ind])
	~	Dmnl
	~		|

capital productivity T iv[ind,techn]=
	initial cap prod i[ind]*min(ZIDZ(initial unit int dem i[ind],unit intermediate demand T iv
[ind
	,techn]),1+maximum capital productivity growth)
	~	Dmnl/Year
	~		|

capital shares[e techn] :EXCEPT: [e hydro]=
	monetary capital techn[e techn]/(grid+sum(monetary capital storage[storage technologies
!])+sum(monetary capital techn[e techn!])) ~~|
capital shares[e distribution]=
	grid/(grid+sum(monetary capital storage[storage technologies!])+sum(monetary capital techn
[e techn!])) ~~|
capital shares[power2gas]=
	monetary capital storage[power2gas]/(grid+sum(monetary capital storage[storage technologies
!])+sum(monetary capital techn[e techn!])) ~~|
capital shares[batteries]=
	monetary capital storage[batteries]/(grid+sum(monetary capital storage[storage technologies
!])+sum(monetary capital techn[e techn!])) ~~|
capital shares[e hydro]=
	(monetary capital techn[e hydro]+monetary capital storage[e hydro])/(grid+sum(monetary capital storage
[storage technologies!])+sum(monetary capital techn[e techn!]))
	~	Dmnl
	~		|

carbon cost tot i[ind]=
	carbon tax i[ind] +
	CO2 cost ETS i[ind]
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

carbon costs hhs rq[regions,quintiles]=
	sum(carbon costs hhs rqi[regions,quintiles,ind!])
	~	Euro/(Year*Household)
	~		|

carbon costs hhs rqi[regions,quintiles,ind]=
	c hhs ESc pp rqi[regions,quintiles,ind]*(embedded ucc pp[ind]+direct ucc pp[ind]+embedded u srf pp
[ind])
	/(1+tls[ind])
	~	Euro/(Year*Household)
	~		|

carbon costs rq[regions,quintiles]=
	carbon costs hhs rq[regions,quintiles]*num hhs rq delayed[regions,quintiles]
	~	Euro/Year
	~		|

Carbon tax hh d[inc cat]=
	0
	~	
	~	Carbon tax hh tot*share c d[inc cat]
	~	:SUPPLEMENTARY 
	|

Carbon tax hh rq[regions,quintiles]=
	Carbon tax hh tot*share c rq[regions,quintiles]
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

Carbon tax hh tot=
	carbon tax rate*emissions C
	~	Euro/Year
	~	tot co2 tax by hh
	|

carbon tax i[ind]=
	carbon tax rate*CO2 for CT i[ind]
	~	Euro/Year
	~		|

Carbon tax nace=
	sum(carbon tax i[ind!])
	~	Euro/Year
	~		|

carbon tax rate=
	IF THEN ELSE(Time<S Time Policy start,
	            0,
	            IF THEN ELSE(Act carbon tax=1,
	                        initial CT + (S carbon tax max - initial CT)*(Time - S Time Policy start
	 -Year 1)/(S Time end - S Time Policy start),
	                        IF THEN ELSE(Act carbon tax = 2,
	                                     Policy time increment*S carbon tax max,
	                                     IF THEN ELSE(Act carbon tax = 3,
	                                                  initial CT + Policy time increment
 * (S carbon tax max-initial CT),
	                                                  0)
	                        )
	            )
	)
	~	Euro/tCO2eq
	~	Time<S Time Policy start,
		0,
		IF THEN ELSE(Time<S Time Policy start,
		             0,
		            Act carbon tax*(initial CT + (S carbon tax max - initial \
		CT)*(Time - S Time Policy start -Year 1)/(S Time end - S Time Policy \
		start)))
	|

carbon tax related costs hhs rq[regions,quintiles]=
	sum(carbon tax related costs hhs rqi[regions,quintiles,ind!])
	~	
	~		|

carbon tax related costs hhs rqi[regions,quintiles,ind]=
	c hhs ESc pp rqi[regions,quintiles,ind]*(embedded ucc pp[ind]+direct ucc pp[ind])
	/(1+tls[ind])
	~	
	~		|

Carbon tax tot=
	Carbon tax nace + Carbon tax hh tot
	~	Euro/Year
	~		|

Carbon tax tot to GDP=
	Carbon tax tot/GDP nom
	~	1
	~		~	:SUPPLEMENTARY 
	|

careserv:
	health,education
	~	
	~		|

case1 i[ind]=
	(1-draw T2 i[ind])*(1-draw T3 i[ind])*(1-draw T4 i[ind])
	~	Dmnl
	~	only T1 is available
	|

case2 i[ind]=
	draw T2 i[ind]*(1-draw T3 i[ind])*(1-draw T4 i[ind])
	~	Dmnl
	~	T1 and T2 available
	|

case3 i[ind]=
	draw T3 i[ind]*(1-draw T2 i[ind])*(1-draw T4 i[ind])
	~	Dmnl
	~	T1 and T3 available
	|

case4 i[ind]=
	draw T2 i[ind]*draw T3 i[ind]*(1-draw T4 i[ind])
	~	Dmnl
	~	T1, T2 and T3 available
	|

case5 i[ind]=
	(1-draw T2 i[ind])*(1-draw T3 i[ind])*draw T4 i[ind]
	~	Dmnl
	~	T4 available
	|

case6 i[ind]=
	draw T2 i[ind]*(1-draw T3 i[ind])*draw T4 i[ind]
	~	Dmnl
	~		|

case7 i[ind]=
	(1-draw T2 i[ind])*draw T3 i[ind]*draw T4 i[ind]
	~	Dmnl
	~		|

case8 i[ind]=
	draw T2 i[ind]*draw T3 i[ind]*draw T4 i[ind]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

CB exp=
	sum(cb gs[gender!,skill!])
	~	Euro/Year
	~		|

cb exp check=
	cb total - CB exp
	~	
	~		~	:SUPPLEMENTARY 
	|

cb gs[gender,skill]=
	(IF THEN ELSE(Time<S Time Policy start,
	sum(Pop 014 g[gender!]) * (sum(Working age population cgs[cohorts!,gender,skill]) / 
	sum(Working age population cgs[cohorts
	!,gender!,skill!])) * benefit per child*CPI,
	(1-Act BI) * sum(Pop 014 g[gender!]) *max(0,sum(Working age population cgs[cohorts!,
	gender,skill]) / sum(Working age population cgs
	[cohorts!,gender!,skill!])) * benefit per child*CPI
	))
	~	Euro/Year
	~	child benefits received by group
		
		(1+CPI fw cumulative inflation delay)
	|

cb per capita gs[gender,skill]=
	ZIDZ(cb gs[gender,skill],sum(Working age population cgs[cohorts!,gender,skill]))
	~	Euro/(Year*Person)
	~	Child benefits per capita per gender and skill
	|

cb per capita total=
	sum(Working age population cgs[cohorts!,gender!,skill!]*cb per capita gs[gender!,skill
!])
	~	
	~		|

cb rq[regions,quintiles]=
	(IF THEN ELSE(Time<S Time Policy start,
	             benefit per child*sum(Pop 014 g[gender!])*children shares rq adj[regions
	,quintiles]*CPI,
	             benefit per child*sum(Pop 014 g[gender!])*children shares rq adj[regions
	,quintiles]*CPI*(1-Act BI))
	            )
	~	Euro/Year
	~	Child benefits, total nominal value per region-quintile
	|

cb total=
	sum(cb rq[regions!,quintiles!])
	~	Euro/Year
	~		|

cb total check=
	cb per capita total - cb total
	~	
	~		~	:SUPPLEMENTARY 
	|

cc per unit hh consumption before elc i[ind]=
	per unit emissions hh be[ind]*carbon tax rate
	~	Euro/Euro constant
	~		|

cc per unit hh consumption i[ind]=
	per unit emissions hh[ind]*carbon tax rate
	~	Euro/Euro constant
	~		|

cc per unit output[ind]=
	emissions per unit output i[ind] * (1-selection ETS i[ind]) * carbon tax rate
	~	Euro/Euro constant
	~		|

cc revenue domestic check emissions=
	tls carbon costs paid to domestic government-total cc-total miscaulated ETS costs
	-SRF paid
	-Carbon tax hh tot
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

cc revenue domestic check pp=
	tls carbon costs paid to domestic government
	-exports cc paid-Inv paid alt-gov paid alt-hh dom alt
	-SRF paid alt
	-direct cc hhs paid
	-tls pnrr domestic government
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

cc revenue domestic check supply side=
	tls carbon costs paid to domestic government-total paid prod side-SRF supply side-direct cc hhs paid
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

change autoproduction B[nrg,ind,toind] :EXCEPT:   [elecheat,mining,mining]=
	0 ~~|
change autoproduction B[heat,mining,mining]=
	-B autoproduction[mining]*(E Z source share init nrgii[heat,mining,mining]/sum(E Z source share init nrgii
[elecheat!,mining
,mining])) ~~|
change autoproduction B[elec,mining,mining]=
	-B autoproduction[mining]*(E Z source share init nrgii[elec,mining,mining]/sum(E Z source share init nrgii
[elecheat!,mining
,mining]))
	~	TJ/Euro constant
	~		|

CHANGE DEF RULE=
	1
	~	
	~	0: OLD DEFICIT RULE
		1: NEW (16/02) DEF RULE
	|

change direct EREU per unit imported input Z imp iinrg[ind,toind,nrg]=
	direct EREU per unit imported input Z imp iinrg[ind,toind,nrg]*trends direct EREU per unit imported input Z imp iinrg
	[ind,toind,nrg]*convergence/Year 1
	~	TJ/(Euro constant*Year)
	~		|

change embedded EREU per output final imp inrg[ind,nrg]=
	embedded EREU per unit output final imp inrg[ind,nrg]*trends embedded EREU per unit output final imp inrg
	[ind,nrg]*convergence/Year 1
	~	TJ/(Euro constant*Year)
	~		|

change end use elec hhs[nrg] :EXCEPT:  [elec]=
	0 ~~|
change end use elec hhs[elec]=
	(sum(electrified fd dom[regions!,quintiles!])
	+sum(electrified fd imp[regions!,quintiles!])*dom electrification switch)
	*(1-efficiency gains elec)
	~	TJ/Year
	~		|

change enduse[nrg,ind,toind] :EXCEPT:             [ff,ind,toind],[elec,electricity ind
,toind]=
	0 ~~|
change enduse[ff,ind,toind]=
	-electrified Z end use[toind,ff]*ff supply share before ESc[ff,ind,toind] ~~|
change enduse[elec,electricity ind,toind]=
	(sum(electrified Z end use[toind,ff!])
	+sum(electrified Z end use imp[toind,ff!])*dom electrification switch)
	*(1-efficiency gains elec)
	+B autoproduction[toind]
	~	TJ/Euro constant
	~		|

change enduse imp[nrg,ind,toind] :EXCEPT:    [ff,ind,toind],[elec,electricity ind,toind
]=
	0 ~~|
change enduse imp[ff,ind,toind]=
	-electrified Z end use imp[toind,ff]*ff supply share imp before ESc[ff,ind,toind] ~~|
change enduse imp[elec,electricity ind,toind]=
	sum(electrified Z end use imp[toind,ff!])*(1-dom electrification switch)*(1-efficiency gains elec
)
	~	TJ/Euro constant
	~		|

change government consumption 45 after exogenous lambda adj i[ind]=
	S change government consumption i[ind] *
	IF THEN ELSE(Act exogenous labour productivity=3,
	(1-delta perc lambda from Time Policy start i[ind]),
	1)
	~	Person
	~		|

change in bonds=
	gov def
	~	Euro/Year
	~		|

change in deposits=
	in deposits cap+sum(in deposits gs[gender!,skill!])
	~	Euro/Year
	~		|

change in ff use ff ee innovation[T2,ind]=
	min(g ff ee T2 i[ind]*fraction new capital[ind],1.99) ~~|
change in ff use ff ee innovation[T3,ind]=
	max(g ff ee T3 i[ind]*fraction new capital[ind],-0.99) ~~|
change in ff use ff ee innovation[T4,ind]=
	max(g ff ee T4 i[ind]*fraction new capital[ind],-0.99) ~~|
change in ff use ff ee innovation[T1,ind]=
	0
	~	
	~		|

change in loans=
	sum(in Loans i[ind!])-sum(out Loans i[ind!])
	~	Euro/Year
	~		|

change in net foreign assets=
	total trade balance nom+pnrr EU spending
	~	Euro/Year
	~		|

change Leontief ii imp[ind,toind]=
	Leontief ii imp[ind,toind]*trends Leontief ii imp[ind,toind]*convergence/Year 1
	~	Dmnl/Year
	~		|

change prob T mi[macroind]=
	0, 0, 0, 0, 0, 0, 0
	~	
	~	Defines for each macroindustry how much we change probability of T... technology.
		Final change and on which kind of technology depends on product with \
		change prob T2 and change prob T4.
	|

change prob T2=
	0
	~	
	~	Defines for all sectors how much we change probability of T2 technology.
		Final change depends on product with change prob T mi for the specific \
		macroindustry.
	|

change prob T2 i[ind]=
	change prob T2*sum(ind to macroind map[ind,macroind!]*change prob T mi[macroind!])
	~	
	~		|

change prob T4=
	0
	~	
	~	Defines for all sectors how much we change probability of T4 technology.
		Final change depends on product with change prob T mi for the specific \
		macroindustry.
	|

change prob T4 i[ind]=
	change prob T4*sum(ind to macroind map[ind,macroind!]*change prob T mi[macroind!])
	~	
	~		|

change transformation related use[nrg,ind,toind] :EXCEPT: [nrg,ind,electricity ind]=
	change transformation use[nrg,ind,toind]+change autoproduction B[nrg,ind,toind] ~~|
change transformation related use[nrg,ind,electricity ind]=
	change transformation use electrcitiy[nrg,ind]
	~	TJ/Euro constant
	~		|

change transformation related use imp[nrg,ind,toind] :EXCEPT:  [nrg,ind,electricity ind
]=
	change transformation use imp[nrg,ind,toind] ~~|
change transformation related use imp[nrg,ind,electricity ind]=
	change transformation use electricity imp[nrg,ind]
	~	TJ/Euro constant
	~		|

change transformation use[nrg,ind,toind] :EXCEPT:   [ff,ind,toind]=
	0 ~~|
change transformation use[ff,ind,toind]=
	-reduction in transformation use[toind,ff]*ff supply share before ESc[ff,ind,toind]
	~	TJ/Euro constant
	~		|

change transformation use electrcitiy[nrg,ind] :EXCEPT:   [ffbio,ind]=
	0 ~~|
change transformation use electrcitiy[ffbio,ind]=
	electricity module switch*
	(delta transformation use electricity sector[ffbio]*ffbio supply share before ESc[ffbio
,ind,electricity ind])
	+
	(1-electricity module switch)*
	change transformation use[ffbio,ind,electricity ind]
	~	TJ/Euro constant
	~		|

change transformation use electricity imp[nrg,ind] :EXCEPT:       [ffbio,ind]=
	0 ~~|
change transformation use electricity imp[ffbio,ind]=
	electricity module switch*
	(delta transfomation use electricity sector imports[ffbio]*ffbio supply share before ESc imports
[ffbio,ind,electricity ind
])
	+
	(1-electricity module switch)*
	change transformation use imp[ffbio,ind,electricity ind]
	~	TJ/Euro constant
	~		|

change transformation use imp[nrg,ind,toind] :EXCEPT:   [ff,ind,toind]=
	0 ~~|
change transformation use imp[ff,ind,toind]=
	-reduction in transformation use imp[toind,ff]*ff supply share imp before ESc[ff,ind
,toind]
	~	TJ/Euro constant
	~		|

changes in hydro use elec=
	electricity module switch*(
	trans use per output electricity sector delayed[gas]*hydro share in gas delayed/(1-hydro share in gas delayed
)
	-(E transformation use before ESc[electricity ind,gas]+E transformation use before ESc imp
[electricity ind,gas])*hydro share in gas delayed2
	/(1-hydro share in gas delayed2))
	+
	(1-electricity module switch)*0
	~	TJ/Euro constant
	~	hydro=(1/(1-hydro share)-1)*gas
		
		assume hydro share applies same for imports and domestic i.e. replaced at \
		same rate; however, we assume that hydro is mainly produced domestically \
		as in Maeder et al., thus it only has an impact on domestic D2 distribution
	|

changes in trans use elec by ind[ind]=
	electricity module switch*(
	sum(delta transformation use electricity sector[ffbio!]*ffbio supply share before ESc
[ffbio!,ind,electricity ind]))
	+(1-electricity module switch)*0
	~	TJ/Euro constant
	~		|

changes in trans use elec by ind imp[ind]=
	electricity module switch*(
	sum(delta transfomation use electricity sector imports[ffbio!]*ffbio supply share before ESc imports
[ffbio!,ind,electricity ind
	])
	)
	+(1-electricity module switch)*0
	~	TJ/Euro constant
	~		|

charge share check[electricity technologies]=
	sum(expeced storage charge share by technology transition[storage technologies!,electricity technologies
])
	~	
	~		~	:SUPPLEMENTARY 
	|

