	0 ~~|
VRES share[e wind]=
	(1-storage charge share)*production by technology b[e wind]/electricity demand ~~|
VRES share[e solarpv]=
	(1-storage charge share)*production by technology b[e solarpv]/electricity demand
	~	Dmnl
	~	VRES (i.e. wind and solar) share of electricity production directly fed \
		into the grid. Production that is used to charge storage is assumed to be \
		the same for all production technologies.
	|

VRES timing[e wind,electricity technologies]=
	IF THEN ELSE(Time+expectation horizon technology[electricity technologies]-Year 1+initial year
	>last year lookup tech share,
	
	VRES growth19 23[e wind],
	
	0) ~~|
VRES timing[e solarpv,electricity technologies]=
	IF THEN ELSE(Time+expectation horizon technology[electricity technologies]-Year 1+initial year
	>last year lookup tech share,
	
	VRES growth19 23[e solarpv],
	
	0)
	~	Dmnl
	~	IF THEN ELSE(Time+initial year+Year 1>phaseout year coal elec,
		VRES growth18 22[e wind],
		0)
	|

W cap[deposits]=
	d cap ~~|
W cap[bonds]=
	b cap ~~|
W cap[equities]=
	eq cap
	~	Euro
	~	total wealth held by capitalists
	|

W gs[gender,skill,deposits]=
	d gs[gender,skill] ~~|
W gs[gender,skill,bonds]=
	+b gs[gender,skill] ~~|
W gs[gender,skill,equities]=
	+eq gs[gender,skill]
	~	Euro
	~	total wealth held by skill group
	|

w0=
	initial wealth per adult*sum(adult population s[skill!])/People 1
	~	Euro
	~	initial total national wealth.
	|

w0 s[skill]=
	initial wealth distribution per skill s[skill]*w0/euro 1
	~	Euro
	~	initial wealth by skill
	|

"w0\_cap"=
	w0-sum(w0 s[skill!])
	~	Euro [0,?]
	~	initial wealth held by capitalists
	|

wage=
	sum(wage i[ind!]*actual hours i[ind!]*L gis[gender!,ind!,skill!])/sum(actual hours i
[ind!]*L gis[gender!,ind!,skill!])
	~	Euro/(Person*Hours)
	~		|

wage adjustment constrain is[ind,skill]=
	min(IF THEN ELSE(y FE i[ind]<y FC i[ind] :AND: VMAX(labour scarcity s[skill!])=labour scarcity s
[skill],
	    wage scarcity adjustment[skill]*labour scarcity s[skill],
	    0),
	max wage adjustment constrain)
	~	Dmnl
	~	Percentage increase in wages, caused by the constraint, applied to the most \
		constrained skill-level.
		
		industries only try to fill the most constrained skill level as this determines \
		employment of others
		if there is no labour scarcity, labour scarcity s is equal to 0.
	|

wage adjustment constrain s[ind,skill]=
	min(IF THEN ELSE(y FE i[ind]<y FC i[ind] :AND: VMAX(labour scarcity s[skill!])=labour scarcity s
	[skill],
	wage scarcity adjustment[skill]*labour scarcity s[skill],
	0),max wage adjustment constrain)
	~	Dmnl
	~	Percentage increase in wages, caused by the constraint, applied to the most \
		constrained skill-level.
		
		industries only try to fill the most constrained skill level as this determines \
		employment of others
		if there is no labour scarcity, labour scarcity s is equal to 0.
	|

