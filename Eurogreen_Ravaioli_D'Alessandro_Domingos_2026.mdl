	desired domestic final demand real i[construction]*Leontief ii[construction,construction
] ~~|
own inputs vector[trade]=
	desired domestic final demand real i[trade]*Leontief ii[trade,trade] ~~|
own inputs vector[transport]=
	desired domestic final demand real i[transport]*Leontief ii[transport,transport] ~~|
own inputs vector[hospitality]=
	desired domestic final demand real i[hospitality]*Leontief ii[hospitality,hospitality
] ~~|
own inputs vector[ict]=
	desired domestic final demand real i[ict]*Leontief ii[ict,ict] ~~|
own inputs vector[finance]=
	desired domestic final demand real i[finance]*Leontief ii[finance,finance] ~~|
own inputs vector[realestate]=
	desired domestic final demand real i[realestate]*Leontief ii[realestate,realestate] ~~|
own inputs vector[profserv]=
	desired domestic final demand real i[profserv]*Leontief ii[profserv,profserv] ~~|
own inputs vector[public]=
	desired domestic final demand real i[public]*Leontief ii[public,public] ~~|
own inputs vector[education]=
	desired domestic final demand real i[education]*Leontief ii[education,education] ~~|
own inputs vector[health]=
	desired domestic final demand real i[health]*Leontief ii[health,health] ~~|
own inputs vector[households]=
	desired domestic final demand real i[households]*Leontief ii[households,households]
	~	Euro constant/Year
	~	manufacturing,
		petroleum,
		vehicles,
		electricity ind,
		gas ind,
		heat ind,
		water,
		construction,
		trade,
		transport,
		hospitality,
		ict,
