activated c19 inv shocks=
	IF THEN ELSE(Act c19 shocks=1 :AND: Time shocks 10 11=1,1,0)
	~	
	~		|

activated c19 LFPR shocks=
	IF THEN ELSE(Act c19 LFPR shocks=1 :AND: Time c19 shock LFPR=1,1,0)
	~	
	~		|

activated c19 shocks=
	IF THEN ELSE(Act c19 shocks=1 :AND: Time c19 shock=1,1,0)
	~	
	~		|

activated eurocrisis gov shocks=
	IF THEN ELSE(Act eurocrisis gov shocks=1 :AND: Time euro crisis gov shocks=1,1,0)
	~	
	~		|

activated eurocrisis inv shocks=
	IF THEN ELSE(Act eurocrisis inv shocks=1 :AND: Time euro crisis inv shocks=1,1,0)
	~	
	~		|

activated imp price shocks=
	IF THEN ELSE(Act imp price shocks=1 :AND: Time shocks 10 11 12=1,1,0)
	~	
	~		|

activated markup shocks=
	IF THEN ELSE(Act markup shocks=1 :AND: Time shocks 10 11=1,1,0)
	~	
	~		|

activated output expected covid shocks=
	IF THEN ELSE(Act output expected covid shocks=1 :AND: Time shocks 10 11=1,1,0)
	~	
	~		|

