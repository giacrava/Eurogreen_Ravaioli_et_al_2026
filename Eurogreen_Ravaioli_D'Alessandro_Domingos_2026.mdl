{UTF-8}
A columns electricity[ind,electricity subs]=
	GET XLS CONSTANTS('?main', 'electricity', 'a_dom_elec' )
	~	Dmnl
	~	IO A maxtrix columns for electricity technologies. Source: LOCOMOTION
	|

A columns electricity import shares[ind,electricity subs]=
	GET XLS CONSTANTS('?main', 'electricity', 'a_imp_sh_elec' )
	~	Dmnl
	~		|

a delay ii[ind,toind]= DELAY FIXED (
	a ii[ind,toind], Year 1, initial a ii[ind,toind])
	~	Dmnl
	~		|

a diffusion ii[ind,toind]=
	a ii[ind,toind]
	~	Dmnl
	~	a ii[ind,toind]*(1+delta a chosen delay[ind,toind]*fraction new \
		capital[toind])
	|

a e before ESc[nrg,ind,toind]=
	a e ii[ind,toind]*E Z source share delay[nrg,ind,toind]
	~	TJ/Euro constant
	~	Energy AE by source before this period's electrification process.
	|

a e ESc[ind,toind]=
	a e ii[ind,toind]+ESc a[ind,toind]
	~	TJ/Euro constant
	~		|

a e ii[ind,toind]=
	a m e ii[ind,toind]*E Z intensity ii[ind,toind]
	~	TJ/Euro constant
	~		|

a e imp before ESc[nrg,ind,toind]=
	a e imp ii[ind,toind]*E Z source share imp delay[nrg,ind,toind]
	~	TJ/Euro constant
	~	Energy AE by source before this period's electrification process.
	|

a e imp ii[ind,toind]=
	a m e imp ii[ind,toind]*E Z intensity imp ii[ind,toind]
	~	TJ/Euro constant
	~		|

a ESc ii m A post techn ii[ind,toind]=
	a ii[ind,toind]-a post techn post electricity[ind,toind]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

a i delay[ind]= DELAY FIXED (
	electricity sector production structure[ind], Year 1, initial a i[ind])
	~	Dmnl
	~		|

a ii[ind,toind]=
	a m e ESc ii[ind,toind]+a no e ii[ind,toind]+ESc a distribution[ind,toind]
	~	Dmnl
	~		|

a imp e ESc[ind,toind]=
	a e imp ii[ind,toind]+ESc a imp[ind,toind]
	~	TJ/Euro constant
	~		|

a imp ESc ii[ind,toind]=
	a imp m e ESc ii[ind,toind]+a imp no e ii[ind,toind]+ESc a imp distribution[ind,toind
]
	~	Dmnl
	~		|

a imp ii[ind,toind]=
	a post techn post electricity[ind,toind]*share imp Z Esc ii delayed w efficiency trendsall
[ind,toind]
	~	Dmnl
	~		|

a imp ii m a imp ESc ii[ind,toind]=
	a imp ESc ii[ind,toind]-a imp ii[ind,toind]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

a imp m e ESc ii[ind,toind]=
	IF THEN ELSE( E Z intensity imp ii[ind,toind]=0, 0, a imp e ESc[ind,toind]/E Z intensity imp ii
[ind,toind] )
	~	Dmnl
	~	ZIDZ(a imp e ESc[ind,toind],E Z intensity imp ii[ind,toind])
	|

a imp no e ii[ind,toind]=
	a imp ii[ind,toind]*(1-E Z M share delayed post efficiency imp[ind,toind])
	~	Dmnl
	~		|

a m e ESc ii[ind,toind]=
	IF THEN ELSE( E Z intensity ii[ind,toind]=0, 0, a e ESc[ind,toind]/E Z intensity ii[
ind,toind] )
	~	Dmnl
	~	ZIDZ(a e ESc[ind,toind],E Z intensity ii[ind,toind])
	|

a m e ii[ind,toind]=
	a post techn post electricity[ind,toind]*E Z M share delayed post efficiency[ind,toind
]
	~	Dmnl
	~		|

a m e imp ii[ind,toind]=
	a imp ii[ind,toind]*E Z M share delayed post efficiency imp[ind,toind]
	~	Dmnl
	~		|

a no e ii[ind,toind]=
	a post techn post electricity[ind,toind]*(1-E Z M share delayed post efficiency[ind,
toind])
	~	Dmnl
	~		|

a param beta distribution i[ind] :EXCEPT:     [agri]=
	10*ABS(400/23 - Temperature) ~~|
a param beta distribution i[agri]=
	10*ABS(1540/73 - Temperature)
	~	Dmnl
	~	a parameter of the climate damage Beta distribution
	|

a post techn energy eff Zimpshares[ind,toind] :EXCEPT:    [ind,electricity ind]=
	a post techn ii[ind,toind]*
	(1+share imp Z Esc ii delayed w efficiency trends[ind,toind])/(1+(1+trend impact Z imp share delayed
	[ind,toind])*share imp Z Esc ii delayed w efficiency trends[ind,toind]) ~~|
a post techn energy eff Zimpshares[ind,electricity ind]=
	a post techn ii[ind,electricity ind]
	*
	IF THEN ELSE(electricity module switch=0,(1+share imp Z Esc ii delayed w efficiency trends
	[ind,electricity ind])/(1+(1+trend impact Z imp share delayed[ind,electricity ind])*
share imp Z Esc ii delayed w efficiency trends
	[ind,electricity ind]),1)
	~	
	~		|

a post techn ii[ind,toind]= INTEG (
	in a post techn[ind,toind],
		initial a ii[ind,toind])
	~	Dmnl
	~	isso estava somando no denominador na penultima linha (16/2/23)
		+IF THEN ELSE(Time>10*Year 1,delta damage multiplier i[ind],0)
		%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
		Final da formula 4*delta damage multiplier i[ind],0)),
		%%%%%%%%%%%%%%%%
		IF_THEN_ELSE (Time=0,initial_a_ii[ind,toind],
		max(
		    (IF_THEN_ELSE(T_i[ind]=UFC_T_iv[ind,T1], a_diffusion_ii[ind,toind] , 
		                  IF_THEN_ELSE( \
		T_i[ind]=UFC_T_iv[ind,T2],a_delay_ii[ind,toind]*(1+delta_a_T2_ii[ind,toind]\
		), 
		                                IF_THEN_ELSE( T_i[ind]=UFC_T_iv[ind,T3] , \
		a_delay_ii[ind,toind]*(1+delta_a_T3_ii[ind,toind]) ,
		                                a_delay_ii[ind,toind]*(1+delta_a_T4_ii[ind,toind]) \
		))))
		   /
		   (1+delta_damage_multiplier_i[ind]),
		0))
	|

a post techn post electricity[ind,toind] :EXCEPT:          [ind,electricity ind]=
	a post techn energy eff Zimpshares[ind,toind] ~~|
a post techn post electricity[ind,electricity ind] :EXCEPT:     [ffbio sectors,electricity ind
]=
	a post techn energy eff Zimpshares[ind,electricity ind]+electricity module switch*g a i electricity delayed
[ind]*a post techn energy eff Zimpshares
	[ind,electricity ind
	] ~~|
a post techn post electricity[ffbio sectors,electricity ind]=
	a post techn energy eff Zimpshares[ffbio sectors,electricity ind]
	~	Dmnl
	~	in order to avoid simultaneous equations (A -> output -> electricity \
		demand -> electricity production structure -> A), we delay the impact of \
		the electricity production structure by the minimal amount
	|

a post techn post electricity wcd[ind,toind]=
	a post techn post electricity[ind,toind]/ (1+delta damage multiplier i[toind])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

a T iiv[ind,toind,T1]=
	a diffusion ii[ind,toind]*factor a ii dom energyee T current[ind,toind,T1] ~~|
a T iiv[ind,toind,T2]=
	a ii[ind,toind]*(1+g a T2 ii[ind,toind]*fraction new capital[toind])*factor a ii dom energyee T current
[ind,toind,T2] ~~|
a T iiv[ind,toind,T3]=
	a ii[ind,toind]*(1+g a T3 ii[ind,toind]*fraction new capital[toind])*factor a ii dom energyee T current
[ind,toind,T3] ~~|
a T iiv[ind,toind,T4]=
	a ii[ind,toind]*(1+g a T4 ii[ind,toind]*fraction new capital[toind])*factor a ii dom energyee T current
[ind,toind,T4]
	~	Dmnl
	~		|

a T iivbefore ee[ind,toind,T1]=
	a diffusion ii[ind,toind] ~~|
a T iivbefore ee[ind,toind,T2]=
	a ii[ind,toind]*(1+g a T2 ii[ind,toind]*fraction new capital[toind]) ~~|
a T iivbefore ee[ind,toind,T3]=
	a ii[ind,toind]*(1+g a T3 ii[ind,toind]*fraction new capital[toind]) ~~|
a T iivbefore ee[ind,toind,T4]=
	a ii[ind,toind]*(1+g a T4 ii[ind,toind]*fraction new capital[toind])
	~	Dmnl
	~		|

Act adapt=
	0
	~	Dmnl
	~	1--> active
		0 --> inactive
	|

Act additional expense compensation=
	0
	~	Dmnl
	~	If expenses from socioeconomic policies should be compensated by financial \
		and corporate tax increases
	|

Act BI=
	0
	~	Dmnl
	~	0 - inactive
		1 - active (financed by Income Tax, Act wealth tax to have it financed by \
		the wealth tax and cancel the increase in income tax)
	|

Act c19 LFPR shocks=
	1
	~	
	~		|

Act c19 shocks=
	1
	~	
	~		|

Act carbon tax=
	0
	~	Dmnl
	~	0 = inactive
		1 = active
		2 = increases until S Time Shift end and then constant
	|

Act Change baseline gov consumption=
	0
	~	1
	~	Determines the growth rate of government final consumption.
		
		0: growth rate converges to long run growth rate as in benchmark v3.0
		1: growth rate after 2025 set to 0 (constant spending)
		2: growth rate after 2025 set to growth rate of GDP in previous period (targets a \
		constant share of GDP as value in 2025)
		3: growth rate after 2025 set to g gov c real GDP smooth and gap corrected i, with a \
		smoothing depending on gov c real to GDP gap i and a gap correction \
		depending on gov c real to GDP gap parameter.
		4: growth rate after 2025 of final consumption of health equal to growth rate of \
		population over 65 and of education equal to growth rate of population \
		0-24. For consumption of other sectors same as 2 (constant to GDP).
		5: government connsumption targets a constant share of GDP, the same as in 2024 by \
		default. Need to set the g GDP smoothing parameter (by default = 1) and \
		the gov c real gap correction parameter (by default equal to 0.5).
		6: spends in healthcare and education to keep constant total workfoce (both private \
		and public) per 1000 people, in others as 0
		7: starts to adjust linearly jobs from 2023 to reach a total workforce of \
		L tot abs target gov bs 7 people i at S Time Shift End. From S Time Shift \
		End +1 spends to keep constant total workforce (both private and public) \
		per 1000 people (as for 6) at the target value
	|

Act Change betas=
	0
	~	Dmnl
	~	1 to active change in households' betas according to changes in beta \
		change p until time S Time Shift End
	~	:SUPPLEMENTARY 
	|

Act change gov consumption=
	0
	~	
	~	0 = inactive
		1 = increase government spending in selected industries, increasing it linearly from \
		0 in *S Time Policy star*t to ***S change government consumption i*** % of \
		spending in that industry at *S Time Shift end*
		2 = increase government spending in each industry by S change government consumption \
		i % of GDP in the previous year, from *S Time Policy start*
		3 = increase government spending in each industry by S change government consumption \
		i % of GDP in S Time Policy start -1
		4 = increase government spending to create additional *S change government \
		consumption i* number of jobs in the corresponding sector
		5 = increase government spending to reach a total number of jobs in the \
		corresponding sectors of *S change government consumption i* between \
		private and public jobs at *S Time Shift End (IMPORTANT: works only if \
		baseline is Act Change baseline gov consumption=6)
		
		IMPORTANT: if Act change baseline gov consumption = 4 and gov c real to \
		GDP gap parameter!=0, only case 2 can be used, otherwise not working \
		(shares not updated)
	|

Act change gov investment=
	0
	~	1
	~	0 = No change
		1 = Government invest to build additional capacity to cover additional consumption \
		when Act change gov consumption
		2 = As 1, but desired investment adjusted to consider additional expected \
		depreciation
	|

Act change labour productivity=
	0
	~	1
	~	Increase productivity lineraly from S Time Policy start to S Time Shift End, in the \
		sectors specified by S Sectors change labour productivity i
		
		0: no change
		1: increase by S delta per lambda scenario total * lambda at S Time Policy Start
		2 (DEACTIVATED): increase proportionately to increase in employment in care services \
		(only if act change government consumption = 7), with proportion defined \
		by S from delta perc L care services to delta perc lambda
		3 (DEACTIVATED): as 2, but we assume that after S Time Shift End it keeps on \
		increasing at a growth rate that is the average between S Time Policy \
		Start and S Time Shift End scaled by S lambda post policy increase
		4 (TO FIX!): increase proportionately to increase government real spending, with \
		proportion defined by S from delta perc gov c real care services to delta \
		perc lambda
		5: as 4, but we assume that after S Time Shift End it keeps on increasing \
		at a growth rate that is the average between S Time Policy Start and S \
		Time Shift End scaled by S lambda post policy increase
	|

