final consumption import trend[ind]=
	final consumption import trend hhs delay[ind]*(1+final consumption import trend hhs capped
[ind]*convergence)
	~	Dmnl
	~		|

final consumption import trend hhs base[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'trend_impsh_hhs')
	~	Dmnl/Year
	~	Geometric mean of growth rates of import shares, for the period 2000-2014 \
		(excluding 2008-2010), computed from input-output data. Sectors D1, D2 and \
		D3 take the same value of sector D in input-output tables.
	|

final consumption import trend hhs capped[ind]=
	max(min(final consumption import trend hhs base[ind],trend cap),-trend cap)
	~	Dmnl/Year
	~		|

final consumption import trend hhs delay[ind]=
	DELAY FIXED(final consumption import trend[ind], Year 1, 1)
	~	Dmnl
	~		|

final demand imp i[ind]=
	gov c imp nom i[ind] + I imp i[ind] +c ESc nom bp imp i[ind]+substitution imports[ind
	]
	~	Euro/Year
	~		|

final demand nom i[ind]=
	c ESc nom bp dom i[ind]+ I supply dom nom i[ind] + gov c dom nom i[ind] + ex ESc nom i
	[ind] + inv pnrr[ind]
	+electrification demand dom[ind]
	~	Euro/Year
	~	Final demand for domestically produced goods, nominal
	|

final demand real i[ind]=
	final demand nom i[ind]/p i[ind]
	~	Euro constant/Year
	~	Final demand for domestically produced goods, real
	|

final demand share i[ind]=
	final demand real i[ind]/sum(final demand real i[ind!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

final demand structure[ind]=
	total demand real i[ind]/total demand real
	~	Dmnl
	~		|

final dom demand exp sh mi[macroind]=
	sum(final dom demand sh exp i[ind!]*ind to macroind map[ind!,macroind]*final demand nom i
[ind!])/sum(final demand nom i
	[ind!]*ind to macroind map[ind!,macroind])
	~	1
	~		~	:SUPPLEMENTARY 
	|

final dom demand gov sh mi[macroind]=
	sum(final dom demand sh gov i[ind!]*ind to macroind map[ind!,macroind]*final demand nom i
[ind!])/sum(final demand nom i
	[ind!]*ind to macroind map[ind!,macroind])
	~	1
	~		~	:SUPPLEMENTARY 
	|

final dom demand hhs sh mi[macroind]=
	sum(final dom demand sh hhs i[ind!]*ind to macroind map[ind!,macroind]*final demand nom i
[ind!])/sum(final demand nom i[ind!]*ind to macroind map[ind!,macroind])
	~	1
	~		~	:SUPPLEMENTARY 
	|

final dom demand nom households=
	sum(c ESc nom bp dom i[ind!])
	~	Euro/Year
	~		|

final dom demand nom sh i[ind]=
	final demand nom i[ind]/tot final demand nom
	~	Dmnl
	~		|

final dom demand nom sh mi[macroind]=
	sum(ind to macroind map[ind!,macroind]*final dom demand nom sh i[ind!])
	~	Dmnl
	~	Share of nominal final demand in each macro-sector (which % of final \
		demand is in macro- sector i?)
	~	:SUPPLEMENTARY 
	|

final dom demand real households=
	sum(c ESc real bp dom i[ind!])
	~	Euro constant/Year
	~		|

final dom demand real households delay= DELAY FIXED (
	final dom demand real households, 1, initial final dom demand real households)
	~	Euro constant/Year
	~		|

final dom demand real sh households=
	final dom demand real households/sum(final demand real i[ind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

final dom demand real sh mi[macroind]=
	sum(final dom demand share i[ind!]*ind to macroind map[ind!,macroind])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

final dom demand sh exp=
	sum(ex ESc nom i[ind!])/tot final demand nom
	~	1
	~		~	:SUPPLEMENTARY 
	|

final dom demand sh exp i[ind]=
	ex ESc nom i[ind]/final demand nom i[ind]
	~	1
	~	Share of final nominal demand from exports in each sector
	|

final dom demand sh gov=
	sum(gov c dom nom i[ind!])/tot final demand nom
	~	1
	~		~	:SUPPLEMENTARY 
	|

final dom demand sh gov i[ind]=
	gov c dom nom i[ind]/final demand nom i[ind]
	~	1
	~	Share of final nominal demand from government in each sector
	|

final dom demand sh hhs i[ind]=
	c ESc nom bp dom i[ind]/final demand nom i[ind]
	~	1
	~	Share of final nominal demand from households in each sector
