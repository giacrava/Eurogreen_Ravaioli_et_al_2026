[inc hig p m])
	
	*sum(savings rq[regions!,quintiles!]) ~~|
savings hhs gs[female,hig]=
	(pop share d[inc hig u f]+pop share d[inc hig e f]+pop share d[inc hig o f]+pop share d
[inc hig p f])
	
	*sum(savings rq[regions!,quintiles!])
	~	
	~		|

savings inc cat[inc cat]=
	sum(savings rq[regions!,quintiles!]*income share rq inc cat[regions!,inc cat,quintiles
	!])
	~	Euro/Year
	~	sum(savings rq[regions!,quintiles!]*pop share rq[regions!,inc \
		cat,quintiles!])
	|

savings per cap cap=
	savings cap/pop cap
	~	Euro/(Year*Person)
	~		|

savings per cap gs[gender,skill]=
	savings gs[gender,skill]/adult population gs[gender,skill]
	~	Euro/(Year*Person)
	~		|

savings rq[regions,quintiles]=
	yd rq[regions,quintiles]-c rq[regions,quintiles]
	~	Euro/Year
	~		|

scale constraint multiplier=
	IF THEN ELSE(scale constraint switch=1,1,1e+20)
	~	Dmnl
	~	If the scale constraint is active it is multiplied by 1, if it is not \
		active by 1e+20, which renders the constrained non-binding.
	|

scale constraint switch=
	0
	~	Dmnl
	~	At 1, the constrained is active, otherwise it is non-binding.
	|

scale impacts adjustment time=
	5
	~	Year
	~	Exponential smooth adjustment time, used to smooth capacity stocks used in \
		scale constraints and learning effects. The rational behind this smoothing \
		is that these effects do not immediately react to current stock levels, \
		but adjust more slowly over time.
	|

sd delta a ii[ind,toind]=
	GET XLS CONSTANTS('?main', 'technology', 'u_norm_all_sd')
	~	Dmnl
	~		|

sd delta a neg[ind,toind]=
	GET XLS CONSTANTS('?main', 'technology', 'u_sd_neg_norm')
	~	Dmnl
	~		|

sd delta a pos[ind,toind]=
	GET XLS CONSTANTS('?main', 'technology', 'u_sd_pos_norm')
	~	Dmnl
	~	Sample standard deviation of the percentage change of technical \
		coefficients, for the period 2000-2014 (excluding 2008 and 2009), computed \
		from input-output data. Sectors D1, D2 and D3 take the same value of \
		sector D in input-output tables.
	|

sd delta lambda[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'lp_norm_all_sd')
	~	Dmnl
	~		|

sd delta lambda neg[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'lp_norm_neg_sd')
	~	Dmnl
	~	Sample standard deviation of the percentage change of chain linked labour \
		productivity scaled by investment and capital, for the period 2000-2019 \
		(excluding 2008 and 2009),computed from EU KLEMS data. Note that  Sectors \
		D1, D2 and D3 take the same value of sector D and that values for sector T \
		are not scaled by investment and capital.
	|

sd delta lambda pos[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'lp_norm_pos_sd')
	~	Dmnl
	~	Sample standard deviation of the percentage change of chain linked labour \
		productivity scaled by investment and capital, for the period 2000-2019 \
		(excluding 2008 and 2009),computed from EU KLEMS data. Note that  Sectors \
		D1, D2 and D3 take the same value of sector D and that values for sector T \
		are not scaled by investment and capital.
	|

SD exp=
	sd per cap*sum(Working age population cgs[cohorts!,gender!,skill!])
	~	Euro/Year
	~	total sick and disability transfers
		
		sd per cap*working age pop total
	|

sd exp check=
	sd total - SD exp
	~	
	~		~	:SUPPLEMENTARY 
	|

sd g ee[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'eneff_norm_sd')
	~	Dmnl
	~		|

sd per cap=
	IF THEN ELSE(Time<S Time Policy start,
	             init sd per cap*CPI,
	             (1-Act BI)*init sd per cap*CPI
	            )
	~	Euro/(Year*Person)
	~		|

sd rq[regions,quintiles]=
	sd per cap*pop d[inc low u f]*hhs cat shares rq adj[regions,inc low u f,quintiles] +
	sd per cap*pop d[inc low u m]*hhs cat shares rq adj[regions,inc low u m,quintiles] +
	sd per cap*pop d[inc mid u f]*hhs cat shares rq adj[regions,inc mid u f,quintiles] +
	sd per cap*pop d[inc mid u m]*hhs cat shares rq adj[regions,inc mid u m,quintiles] +
	sd per cap*pop d[inc hig u f]*hhs cat shares rq adj[regions,inc hig u f,quintiles] +
	sd per cap*pop d[inc hig u m]*hhs cat shares rq adj[regions,inc hig u m,quintiles] +
	sd per cap*pop d[inc low e f]*hhs cat shares rq adj[regions,inc low e f,quintiles] +
	sd per cap*pop d[inc low e m]*hhs cat shares rq adj[regions,inc low e m,quintiles] +
	sd per cap*pop d[inc mid e f]*hhs cat shares rq adj[regions,inc mid e f,quintiles] +
	sd per cap*pop d[inc mid e m]*hhs cat shares rq adj[regions,inc mid e m,quintiles] +
	sd per cap*pop d[inc hig e f]*hhs cat shares rq adj[regions,inc hig e f,quintiles] +
	sd per cap*pop d[inc hig e m]*hhs cat shares rq adj[regions,inc hig e m,quintiles] +
	sd per cap*pop d[inc low o f]*hhs cat shares rq adj[regions,inc low o f,quintiles] +
	sd per cap*pop d[inc low o m]*hhs cat shares rq adj[regions,inc low o m,quintiles] +
	sd per cap*pop d[inc mid o f]*hhs cat shares rq adj[regions,inc mid o f,quintiles] +
	sd per cap*pop d[inc mid o m]*hhs cat shares rq adj[regions,inc mid o m,quintiles] +
	sd per cap*pop d[inc hig o f]*hhs cat shares rq adj[regions,inc hig o f,quintiles] +
	sd per cap*pop d[inc hig o m]*hhs cat shares rq adj[regions,inc hig o m,quintiles]
	~	Euro/Year
	~	Total sick and disability benefits per region-quintile
	|

sd total=
	sum(sd rq[regions!,quintiles!])
	~	Euro/Year
	~		|

seed=
	1
	~	Dmnl
	~	40
	|

