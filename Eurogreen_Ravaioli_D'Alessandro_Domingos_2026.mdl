	~	number of unemployed people by gender and skill
	|

L unconstrained before change gov cons i[ind]=SAMPLE IF TRUE(
	Time=S Time Change baseline gov consumption,L actual delay i[ind],0)
	~	Person
	~		|

L unconstrained before change gov cons per 1000 people i[ind]=
	L unconstrained before change gov cons i[ind]/population total delay*1000
	~	1
	~		|

L unconstrained s[skill]=
	sum(L is unconstrained[ind!,skill])
	~	Person/Year
	~		|

