	IF THEN ELSE(Act PNRR=1 :AND: Time pnrr>0,1,0)
	~	
	~		|

activated superbonus shocks=
	IF THEN ELSE(Act superbonus shocks=1 :AND: Time superbonus shocks=1,1,0)
	~	
	~		|

Active Environmental Policies=
	Act adapt+Act carbon tax+Act CT redistrib+Act elast beta+Act en eff+Act gradual adapt CT hh
+Act phase out+Act RES public
	~	
	~		~	:SUPPLEMENTARY 
	|

active shocks current=
	IF THEN ELSE(
	activated c19 inv shocks+activated c19 shocks+activated imp price shocks+activated markup shocks
	+activated superbonus shocks+activated pnrr shocks,
	1,0)
	~	Dmnl
	~		|

active shocks delay=
	DELAY FIXED(active shocks current, Year 1, 0)
	~	1
	~		|

active shocks delay2=
	DELAY FIXED(active shocks delay, Year 1, 0)
	~	Dmnl
	~		|

active shocks delayed adj time= DELAY FIXED (
	active shocks current, expectations adjustment time, 0)
	~	Dmnl
	~		|

active shocks time=
	IF THEN ELSE(
	active shocks current :OR: active shocks delayed adj time>0,
	1,0)
	~	Dmnl
	~	check if any of the large shocks is currently active
	|

Active Social Policies=
	Act BI+Act cons red+Act Dividend Reduction+Act fin tax+Act focalized benefit+Act Job Guarantee
+Act labour tax redistribution+Act minimum wage+Act progressive Inc Tax+Act wealth tax
+Act WTR+Act WTR wage+Act maximum wage
	~	
	~		~	:SUPPLEMENTARY 
	|

active threshold progressive CT=
	IF THEN ELSE(Act carbon tax=1:AND:Act progressive CT=1,threshold progressive CT,0)*IF THEN ELSE
(Time>S Time Policy start,1,0)
	~	
	~		|

actual hours i[ind]=
	hours i[ind]
	~	Hours/(Person*Year)
	~	max(min(implied hours[ind],max hours),hours i[ind])
	|

actual rents share of mixed income=
	0.067
	~	
	~		|

adaptation= INTEG (
	in adapation,
		initial adaptation)
	~	Dmnl
	~		|

adaptation exp=
	IF THEN ELSE(Time<(S Time Policy start), 0,IF THEN ELSE(Time<S Time Policy start + duration adapt
,yearly exp adapt*Act adapt,0))
	~	Euro/Year
	~		|

adaptation sensitivity=
	0.025
	~	Dmnl
	~		|

added heat use D1=
	sum(ESc a[ind!,electricity ind]*E Z source share delay[heat,ind!,electricity ind])
	+
	sum(ESc a imp[ind!,electricity ind]*E Z source share imp delay[heat,ind!,electricity ind
])
	~	TJ/Euro constant
	~		|

additional BI expenditure=
	max(BI exp-CB exp-SD exp-other benefits exp,0)
	~	Euro/Year
	~		|

additional focalised benefits expenditure expected=
	IF THEN ELSE(Act focalized benefit=1:AND:Time>S Time Policy start,
	max(Focalized benefit per capita-S1 init other benefits per cap,0)*CPI
	*(sum(N olf gs delayed[gender!,low])),
	0)
	~	Euro/Year
	~		|

additional nonmarket output policy=
	sum(additional nonmarket output policy i[govsec!])
	~	Euro/Year
	~	Required to avoid market output increasing only because we are increasing non-market \
		ouput when Act change gov consumption != 0.
		Note that market output increases if the increase of government spending \
		is due to an increase of wages, since delta gov c nom = 0 as it comes from \
		the delta real form policy. This makes sense since we are assuming wages \
		increase in all sector.
	|

additional nonmarket output policy i[govsec]=
	IF THEN ELSE(Time<=S Time Shift end,
	delta nonmarket output during policy i[govsec],
	delta nonmarket output after policy i[govsec]
	)
	~	Euro/Year
	~	Required to avoid market output increasing only because we are increasing non-market \
		ouput when Act change gov consumption != 0.
		Note that market output increases if the increase of government spending \
		is due to an increase of wages, since delta gov c nom = 0 as it comes from \
		the delta real form policy. This makes sense since we are assuming wages \
		increase in all sector.
	|

additional nonmarket policy to total output i[govsec]=
	additional nonmarket output policy i[govsec]/y nom i[govsec]
	~	1
	~		|

additional yearly delta gov c real i[ind]=
