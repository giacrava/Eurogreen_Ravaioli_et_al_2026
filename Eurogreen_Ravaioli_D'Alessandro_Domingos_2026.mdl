max flex compensation[e techn]=
	((max generation by technology[e techn]-max generation a*current electricity demand technology share
[e techn])
	+reserve production potential[e techn])*max(0,flexibility share techn[e techn])
	~	GW*h/Year
	~		|

max g ee[ind]=
	2.91418
	~	Dmnl
	~		|

max generation=
	max generation a
	
	
	+min(sum(max flex compensation[e techn!])/flex share production delayed,sum(max generation by technology
[e techn!]+reserve production potential
	[e techn!])-max generation a)
	~	GW*h/Year
	~	we assume fixed fractions so that most limiting technology limits whole system and \
		not another storage technology can compensate due to their different \
		characteristics
		compensatory ramp up is either constraint by available flexible production \
		potential or if not binding by overall (i.e. baseload) production potential
	|

max generation a=
	VECTOR SELECT( current electricity demand technology share[e techn!] , max generation a technology
[e techn!], 
	0 , 8,1 )
	~	GW*h/Year
	~	Min of all technologies that have a non-zero production share.
		http://vensim.com/documentation/fn_vector_select.html
	|

max generation a technology[e techn]=
	ZIDZ(max generation by technology[e techn],current electricity demand technology share
[e techn])
	~	GW*h/Year
	~	max demand being met by generation 
		we assume fixed fractions so that most limiting technology limits whole \
		system and not another storage technology can compensate due to their \
		different characteristics
	|

max generation by technology[e techn] :EXCEPT:    [e gas]=
	current capacity factor[e techn]*hours in year*production capacity[e techn] ~~|
max generation by technology[e gas]=
	current capacity factor[e gas]*hours in year*production capacity[e gas]*current gas generation to gas production shares
	~	GW*h/Year
	~		|

max generation hydro initial=
	57807.2
	~	GW*h/Year
	~		|

max hours=
	46*48
	~	Hours/Year
	~	46 working weeks in a year with max 48 hr weeks
		agriculture is exception due to working conditions
	~	:SUPPLEMENTARY 
	|

max hydro generation[electricity technologies]=
	RES transition*max hydro generation RES[electricity technologies]+
	(1-RES transition)*max generation hydro initial
	~	GW*h/Year
	~	max of historic generation from eurostat
	|

max hydro generation final=
	29870
	~	GW*h/Year
	~		|

max hydro generation RES[electricity technologies]=
	IF THEN ELSE(Time+expectation horizon technology[electricity technologies]-Year 1>=S Time Policy start
,
	
	
	
	max generation hydro initial+
	
	(max hydro generation final-max generation hydro initial)/
	(1+EXP(-steepness logistic curve*(Time+expectation horizon technology[electricity technologies
]-midpoint logistic curve
	))),
	
	max generation hydro initial)
	~	GW*h/Year
	~		|

max investment switch=
	0
	~	Dmnl
	~	0 - non maximum - industries invest as much as they want
		1 - fixed rule are function of ELR
		2 - maximum decreasing on leverage.
	|

max lambda in wage eq ON=
	0
	~	Dmnl
	~	If ON (==1), wage is indexed on the maximum between the sector-specific \
		productivity growth and the average productivity growth of the economy
	~	:SUPPLEMENTARY 
	|

max male share=
	0.99
	~	Dmnl
	~		|

max PHS charge=
	23060
	~	GW*h/Year
	~		|

max prob=
	0.95
	~	Dmnl
	~		|

max scale increase[e techn]=
	GET XLS CONSTANTS('?main', 'electricity', 'max_scale*' )
	~	Dmnl/Year
	~	Maximum relative increase of capacity between 1990 and 2019 derived from Jaxa-Rozen \
		et al., 2022.
		Note that we only consider time periods, where installed capacity >2GW to \
		ensure scale extrapolaridity. This means for solar and nec we consider the \
		period 2010-2019 and for wind 2007-2019. Again, we assume solarth has the \
		same values as solarpv.
	|

max scale increase storage[storage technologies]=
	1.10102,
	1.3,
	1.3
	~	Dmnl/Year
	~	PHS same as hydro, batteries and G2P assumption
	|

max sensitivity hig[gender,skill]=
	IF THEN ELSE(labour scarcity[skill]=VMAX(labour scarcity[skill!]),
	
	(1-hig skill transformation JG[gender,skill])/labour scarcity[skill],
	
	0)
	~	Dmnl
	~		|

max sensitivity low[gender,skill]=
	IF THEN ELSE(labour scarcity[skill]=VMAX(labour scarcity[skill!]),
	
	(1-low skill transformation JG[gender,skill])/labour scarcity[skill],
	
	0)
	~	Dmnl
	~		|

max sensitivity mid[gender,skill]=
	IF THEN ELSE(labour scarcity[skill]=VMAX(labour scarcity[skill!]),
	
	(1-mid skill transformation JG[gender,skill])/labour scarcity[skill],
	
	0)
	~	Dmnl
	~		|

max share hydro[electricity technologies]=
	max hydro generation[electricity technologies]/electricity generation expected[electricity technologies
]
	~	
	~		|

max share PHS[electricity technologies]=
	max PHS charge/expected storage generation[electricity technologies]
	~	GW*h/Year
	~		|

max skill share[skill]=
	0.99
	~	Dmnl
	~		|

max storage discharge by technology[storage technologies] :EXCEPT:       [power2gas]=
	current capacity factor storage[storage technologies]*hours in year*storage capacity
[storage technologies]*efficiency by storage technology
	[storage technologies] ~~|
max storage discharge by technology[power2gas]=
	min(
	current capacity factor storage[power2gas]*hours in year*storage capacity[power2gas]
*efficiency by storage technology[power2gas
	],
	current capacity factor[e gas]*hours in year*production capacity[e gas]*(1-current gas generation to gas production shares
	)
	)
	~	GW*h/Year
	~		|

max tax rate=
	0.9
	~	Dmnl
	~		|

max wage adjustment constrain=
	0.1
	~	
	~	This is the maximum value (in  %) of the skill-specific wage increase, in \
		the case of a labor contraint for this specific skill-level.
	|

MAX wage all=
	VMAX(wage gis[gender!,ind!,skill!])
	~	Euro/(Hours*Person)
	~		|

