completely financed[e techn]=
	IF THEN ELSE(capacity construction time[e techn]=1,
	new capacity investment costs[e techn],
	completely financed as delay[e techn]
	)
	~	Euro constant/(Year*Year)
	~	We assume a linear expense schedule of investment costs over the time of \
		construction.
		As the min delay time is TIMESTEP, for technologies with a construction \
		time of 1 year or less, the formulation avoids the delay.
	|

completely financed as delay[e techn]= DELAY FIXED (
	new capacity investment costs[e techn], capacity construction time[e techn]-Year 1, 
0)
	~	Euro constant/(Year*Year)
	~		|

component Theil L[gender,ind,skill]=
	IF THEN ELSE(ZIDZ(L gis share[gender,ind,skill],group wage share gis[gender,ind,skill
])=0, 
		0 , 
		L gis share[gender,ind,skill]*ln(L gis share[gender,ind,skill]/group wage share gis
[gender,ind,skill]))
	~	Dmnl
	~		|

component Theil L yd[inc cat]=
	pop share d[inc cat]*ln(XIDZ(pop share d[inc cat],yd share[inc cat],1))
	~	Dmnl
	~		|

component Theil T[gender,ind,skill]=
	IF THEN ELSE(ZIDZ(group wage share gis[gender,ind,skill],L gis share[gender,ind,skill
])=0 , 
	0 ,
	group wage share gis[gender,ind,skill]*ln(group wage share gis[gender,ind,skill]/L gis share
[gender,ind,skill]))
	~	Dmnl
	~		|

component Theil T yd[inc cat]=
	yd share[inc cat]*ln(XIDZ(yd share[inc cat],pop share d[inc cat],1))
	~	Dmnl
	~		|

condition a ii T[T2,ind,iteration]=
	IF THEN ELSE(delta a i iteration[ind,iteration]>=0,iteration,1e+10) ~~|
condition a ii T[T3,ind,iteration]=
	IF THEN ELSE(delta a i iteration[ind,iteration]<0,iteration,1e+10)
	~	Dmnl
	~		|

condition g ff ee T[T2,ind,iteration]=
	IF THEN ELSE(g i ff ee iteration[ind,iteration]>=0,iteration,1e+10) ~~|
condition g ff ee T[T3,ind,iteration]=
	IF THEN ELSE(g i ff ee iteration[ind,iteration]<0,iteration,1e+10)
	~	
	~		|

condition lambda i T[T2,ind,iteration]=
	IF THEN ELSE(g lambda iteration[ind,iteration]>0,iteration,1e+10) ~~|
condition lambda i T[T3,ind,iteration]=
	IF THEN ELSE(g lambda iteration[ind,iteration]<=0,iteration,1e+10)
	~	Dmnl
	~		|

