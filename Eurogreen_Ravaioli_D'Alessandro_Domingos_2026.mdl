tls carbon costs paid to domestic government=
	sum((embedded usrf bp nom paid[ind!]+ paid embedded ucc bp nom[ind!])*final demand nom i
[ind!])
	+sum(direct ucc bp nom[ind!]*c ESc nom bp i[ind!])
	+substitution tls paid to domestic government hhs cc
	~	Euro/Year
	~		|

tls embedded in imports=
	tls paid carbon costs-tls carbon costs paid to domestic government
	~	Euro/Year
	~		|

tls embedded in imports 2=
	sum(
	(final demand nom i[ind!]-ex ESc nom i[ind!])*
	(embedded u srf bp nom[ind!]+embedded ucc bp nom[ind!]-(embedded usrf bp nom paid[ind
!]+ paid embedded ucc bp nom[ind!]))
	)
	
	+sum((final demand imp i[ind!])*(embedded u srf bp nom[ind!]+embedded ucc bp nom[ind
!]))
	~	Euro/Year
	~		|

tls exports=
	+sum(ex ESc nom i[ind!]*(embedded usrf bp nom paid[ind!]+ paid embedded ucc bp nom[ind
!]))
	~	Euro/Year
	~		|

tls from gov c nom=
	sum(gov c nom i[ind!]*tls gov[ind!])
	~	Euro/Year
	~		|

tls gdp=
	sum(c ESc tls i[ind!]) + tls paid by gov +gfcf tls paid
	~	Euro/Year
