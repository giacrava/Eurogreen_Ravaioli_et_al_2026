	~	Dmnl
	~	If positive saving, saving parties invest in bonds. If no positive saving, bonds are \
		distributed based on existent wealth.
		IF THEN ELSE(sum(pos savings hhs gs[gender!,mid])+sum(pos savings hhs gs[gender!,hig
		])+pos savings cap>0,
		
		pos savings cap/(sum(pos savings hhs gs[gender!,mid])+sum(pos savings hhs gs[gender!
		,hig])+pos savings cap),
		
		sum(pos W cap[assets!])/(sum(pos W gs[gender!,mid,assets!])+sum(pos W gs[gender!,hig
		,assets!])+sum(pos W cap[assets!]))
		)
	|

in bonds weights hhs gs[gender,skill]=
	(1-init b share cap)*in b share gs[gender,skill]
	~	Dmnl
	~	If positive saving, saving parties invest in bonds. If no positive saving, bonds are \
		distributed based on existent wealth.
		
		IF THEN ELSE(sum(pos savings hhs gs[gender!,mid])+sum(pos savings hhs gs[gender!,hig
		])+pos savings cap>0,
		
		pos savings hhs gs[gender,skill]/(sum(pos savings hhs gs[gender!,mid])+sum(pos \
		savings hhs gs
		[gender!,hig])+pos savings cap
		),
		
		sum(pos W gs[gender,skill,assets!])/(sum(pos W gs[gender!,mid,assets!])+sum(pos W gs
		[gender!,hig,assets!])+sum(pos W cap[assets!]))
		)
	|

in cumulative salary[gender,skill]=
	real salary per capita gs[gender,skill]
	~	Euro constant/(Year*Person)
	~		|

in deposits cap=
	savings cap/Year 1-in bonds cap-wealth tax rate*d cap
	~	Euro/Year
	~		|

in deposits gs[gender,skill]=
	savings gs[gender,skill]-in bonds gs[gender,skill]-(wealth tax rate*d gs[gender,
	skill])
	~	Euro/Year
	~		|

in equity cap=
	sum(in Equity i[ind!])*
	(eq cap/(sum(eq gs[gender!,skill!])+eq cap))
	-wealth tax rate*eq cap
	~	Euro
	~		|

in equity gs[gender,skill]=
	sum(in Equity i[ind!])*
	(eq gs[gender,skill]/(sum(eq gs[gender!,skill!])+eq cap))
	-wealth tax rate*eq gs[gender,skill]
	~	Euro/Year
	~	FOR GENDER,HIG; 0 for rest
		sum(in Equity i[ind!])*(W gs[gender,hig,deposits]/(sum(W \
		gs[gender!,hig,deposits])+W cap[deposits]))/Year 1-wealth tax rate*eq \
		delay gs[gender,hig]
	|

in Equity i[ind]=
	Equity i[ind]-equity delay i[ind]
	~	Euro
	~		|

in ETS i[ind]=
	auctioned ETS i[ind]+Free ETS i[ind]
	~	tCO2eq/Year
	~		|

in ETS i expected[ind]=
	auctioned ETS i expected[ind]+Free ETS i[ind]
	~	tCO2eq/Year
	~		|

in interest rate=
	i+spread b
	~	1/Year
	~		|

in JG L gs[gender,skill]=
	IF THEN ELSE(Time <S Time Policy start JG :OR: Time>Final time job guarantee,0,
	
	IF THEN ELSE(u s[skill]>trigger JG,
	Act Job Guarantee * max(fraction of unemployed in JG after init*L u gs[gender,skill]
,0)
	,0)
	)
	~	People/Year
	~	IF THEN ELSE(Time <S Time Policy start :OR: Time>Final time job guarantee,0,
		IF THEN ELSE(Time = S Time Policy start, 
		Act Job Guarantee * max( (min(fraction of unemployed in init JG*L u \
		gs[gender,skill],JG maxL*share U number gs[gender,skill
		])),0),
		
		IF THEN ELSE(u>trigger JG:AND:e<e rate threshold,
		Act Job Guarantee * max(fraction of unemployed in JG after init*L u \
		gs[gender,skill],0)
		,0)
		))
	|

in K i[ind]=
	GFCF real i[ind]
	~	Euro constant/Year
	~		|

in lambda[ind] :EXCEPT:               [households],[electricity ind]=
	(IF THEN ELSE(track tech choice[ind]=1, lambda T iv[ind,T1], 
	IF THEN ELSE(track tech choice[ind]=2, lambda T iv[ind,T2], 
	IF THEN ELSE(track tech choice[ind]=3, lambda T iv[ind,T3],
	lambda T iv[ind,T4])))
	
	-lambda post delta scenario pre electricity i[ind])/technology adjustment time ~~|
in lambda[households]=
	0 ~~|
in lambda[electricity ind]=
	electricity module switch*
	((lambda T iv[electricity ind,T1]-lambda pre electricity i[electricity ind])/technology adjustment time
)
	
	+
	
	(1-electricity module switch)*
	((IF THEN ELSE(track tech choice[electricity ind]=1, lambda T iv[electricity ind,T1]
, 
	IF THEN ELSE(track tech choice[electricity ind]=2, lambda T iv[electricity ind,T2], 
	IF THEN ELSE(track tech choice[electricity ind]=3, lambda T iv[electricity ind,T3],
	lambda T iv[electricity ind,T4])))
	-lambda pre electricity i[electricity ind])/technology adjustment time)
	~	Euro constant/(Year*Hours*Person)
	~		|

in LFPR gs[gender,skill]=
	IF THEN ELSE(LFPR gs[gender,skill]+in LFPR gs unconstrained[gender,skill]>1,
	1-LFPR gs[gender,skill],
	in LFPR gs unconstrained[gender,skill])
	~	Dmnl/Year
	~	IF THEN ELSE(Time=9,LFPR gs[gender,skill]*(c19 LFPR 2020[gender,skill]),
		IF THEN ELSE(Time=10,LFPR gs[gender,skill]*(c19 LFPR 2021[gender,skill]),
		IF THEN ELSE(Time=11,LFPR gs[gender,skill]*(c19 LFPR 2022[gender,skill]),
		
		previous formula May/2023
		
		in LFPR gs[gender,skill]=IF THEN ELSE(Time=10*Year 1,LFPR delay gs[gender
		>	             ,skill]*(c19 LFPR 2020),IF THEN ELSE(Time=11*Year 1,LFPR delay gs[
		>	                  gender,skill]*(c19 LFPR 2021),IF THEN ELSE(Time=12*Year 1
		>	                                 ,LFPR delay gs[gender,skill]*(c19 LFPR 2022
		>	                            ),IF THEN ELSE(LFPR gs[gender,skill]+sens LFPR income[
		>	                                 skill]*((1-e gs[gender,skill])*(max(0
		>	                                                ,(exp inc ne gs[gender
		>	                                                ,skill]-exp inc ne delay gs[
		>	                                                     gender,skill])/exp inc ne \
		delay gs[
		>	                                                     gender,skill]))+e gs[
		>	                                           gender,skill]*(min(0,(exp inc e gs[
		>	                                                     gender,skill]-exp inc e delay \
		gs[
		>	                                                          gender,skill
		>	                                                          ])/exp inc e delay gs[
		>	                                                          gender,skill
		>	                                                          ])))>1,0,IF THEN ELSE(
		>	                                 Time>S Time Policy start+Year 1:AND:Act WTR
		>	                                      =1,max(0,sens LFPR income[skill]
		>	                                           *((1-e gs[gender,skill])*(max(
		>	                                                     0,(exp inc ne gs[
		>	                                                     gender,skill]-exp inc ne \
		delay gs[
		>	                                                          gender,skill
		>	                                                          ])/exp inc ne delay gs[
		>	                                                          gender,skill
		>	                                                          ]))+e gs[gender
		>	                                                ,skill]*(min(0,(exp inc e gs[
		>	                                                          gender,skill
		>	                                                          ]-exp inc e delay gs[
		>	                                                               gender,
		>	                                                               skill])
		>	                                                               /exp inc e delay gs[
		>	                                                               gender,
		>	                                                               skill])
		>	                                                     ))),sens LFPR income[
		>	                                 skill]*(1-e gs[gender,skill])*(max(0,
		>	                                           (exp inc ne gs[gender,skill
		>	                                           ]-exp inc ne delay gs[gender
		>	                                                ,skill])/exp inc ne delay gs[
		>	                                                gender,skill]))+e gs[gender
		>	                                      ,skill]*(min(0,(exp inc e gs[gender
		>	                                                ,skill]-exp inc e delay gs[
		>	                                                     gender,skill])/exp inc e \
		delay gs[
		>	                                                     gender,skill]))))
		>	                       )))/Year 1
		
		
		old
		sens_LFPR_income*(
		(1-e_gs[gender,skill])*
		  \
		max(0,(exp_inc_ne_gs[gender,skill]-exp_inc_ne_delay_gs[gender,skill])/exp_i\
		nc_ne_delay_gs[gender,skill]
		        )
		+e_gs[gender,skill]*
		  \
		min(0,(exp_inc_e_gs[gender,skill]-exp_inc_e_delay_gs[gender,skill])/exp_inc\
		_e_delay_gs[gender,skill])
		      )
		
		WITHOUT MIN MAX
		sens_LFPR_income*(
		(1-e_gs[gender,skill])*( \
		(exp_inc_ne_gs[gender,skill]-exp_inc_ne_delay_gs[gender,skill])/exp_inc_ne_\
		delay_gs[gender,skill]
		        )
		+e_gs[gender,skill]*((exp_inc_e_gs[gender,skill]-exp_inc_e_delay_gs[gender,skill])/ex\
		p_inc_e_delay_gs[gender,skill])
		      )
	|

in LFPR gs unconstrained[gender,skill]=
	IF THEN ELSE(activated c19 LFPR shocks=1,
	             LFPR gs[gender,skill]*c19 shock LFPR[gender,skill],
	
	sens LFPR income*LFPR gs[gender,skill]*percentage change exp inc e[gender
	,skill]
	
	)
	+LFPR trends[gender,skill]*late convergence
	~	Dmnl/Year
	~		|

