delta perc L from gov c real policy increase=
	ZIDZ(Jobs to create Act change gov consumption 4567,L tot abs target gov bs 7 people care services
)
	~	1
	~		|

delta perc L from gov c real policy increase Time shift end=SAMPLE IF TRUE(
	Time = S Time Shift end, delta perc L from gov c real policy increase, 0)
	~	1
	~		|

delta perc L from gov c real policy increase timestep=
	IF THEN ELSE(Time > S Time Shift end,
	delta perc L from gov c real policy increase Time shift end,
	delta perc L from gov c real policy increase)
	~	1
	~		|

delta perc lambda from Time Policy start i[ind]=
	IF THEN ELSE(Time > S Time Policy start,
	(lambda i[ind]-lambda Time Policy start i[ind])/lambda Time Policy start i
	[ind],
	0)
	~	1
	~		|

delta perc lambda scenario timestep i[ind]=
	(IF THEN ELSE(Act change labour productivity=1,
	S delta perc lambda scenario total*Policy time increment,
	IF THEN ELSE(Act change labour productivity=4 :OR: Act change labour productivity=5,
	S from delta perc gov c real care services to delta perc lambda
	* IF THEN ELSE(Time>S Time Shift end,
	delta perc hhs and gov c real care services policy end per capita,
	delta perc hhs and gov c real care services delay per capita),
	0))
	+ IF THEN ELSE(Act change labour productivity=5,
	S lambda post policy increase*cumul incr lambda mean during policy due to Act change labour productivity i
	[ind],
	0))
	*S delta lambda scenario ON i[ind]
	~	1
	~	Relative change in current timestep in productivity in each sector respect to S Time \
		policy start when Act change labour productivity !=0
		
		(IF THEN ELSE(Act change labour productivity=1,
		S delta perc lambda scenario total*Policy time increment,
		IF THEN ELSE(Act change labour productivity=2 :OR: Act change labour productivity=3,
		S from delta perc L care services to delta perc lamba*delta perc L from gov c real \
		policy increase timestep,
		IF THEN ELSE(Act change labour productivity=4 :OR: Act change labour productivity=5,
		S from delta perc gov c real care services to delta perc lambda*delta perc gov c \
		real care services delay,
		0))) 
		+ IF THEN ELSE(Act change labour productivity=3 :OR: Act change labour \
		productivity=5,
		S lambda post policy increase*cumul incr lambda mean during policy due to Act change \
		labour productivity i[ind],
		0))
		*S delta lambda scenario ON i[ind]
	|

delta perc lambda scenario total=
	IF THEN ELSE(Act change labour productivity=1,
	S delta perc lambda scenario total,
	IF THEN ELSE(Act change labour productivity=2,
	S from delta perc L care services to delta perc lamba*delta perc L from gov c real policy increase
,
	0))
	~	1
	~		|

delta perc lambda scenarios tot during policy due to Act change LP i[ind]=SAMPLE IF TRUE
(
	Time=S Time Shift end+1,delta perc lambda scenario timestep i[ind],0)
	~	1
	~		|

