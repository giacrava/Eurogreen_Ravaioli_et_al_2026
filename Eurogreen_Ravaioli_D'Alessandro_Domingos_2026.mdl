CPI=
	sum(price index pp i[ind!]*price weights base previous year pp i[ind!])
	~	Euro/Euro constant
	~	Consumer Price Index using purhcaser prices and updated consumption \
		weights from the previous year
	|

CPI decile[deciles]=
	sum(price index pp i[ind!] * price weights current period decile[deciles,ind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

CPI delay=
	DELAY FIXED(CPI, Year 1 , 1 )
	~	Euro/Euro constant
	~		|

CPI init=
	1
	~	Euro/Euro constant
	~		|

CPI rq[regions, quintiles]=
	sum(price index pp i[ind!] * price weights delay rqi[regions,quintiles,ind!])
	~	Euro/Euro constant
	~	Consumer Price Index per region-quintile using purhcaser prices and \
		updated consumption weights from the previous year
	|

CPI rq before elec[regions,quintiles]=
	sum(price index pp i before elec[ind!] * price weights delay rqi[regions,quintiles,ind
!])
	~	Dmnl
	~		|

CPI rq delay[regions,quintiles]= DELAY FIXED (
	CPI rq[regions,quintiles], Year 1 , 1)
	~	Dmnl
	~		|

CPI rq delay 2[regions,quintiles]= DELAY FIXED (
	CPI rq[regions,quintiles], Year 1+Year 1 , 1)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

CPI uw constant=
	DELAY INFORMATION( CPI, delay time CPI uw policies, 1 )
	~	Dmnl
	~		|

CT redistrib d[inc cat]=
	ZIDZ((tls carbon costs paid to domestic government-reimbursed carbon costs total)*(eligible CT d
[inc cat]*pop d[inc cat
	]),sum(eligible CT d[inc cat!]*pop d[inc cat!]))
	~	Euro/Year
	~	Total income from carbon tax redistribution per individual category, total \
		carbon tax revenue is distributed among eligible individual categories \
		proportionally to their population shares
	|

CT redistrib per capita d[inc cat]=
	IF THEN ELSE(Time<S Time Policy start,0,Act CT redistrib*(ZIDZ(CT redistrib d[inc cat
],pop d[inc cat])))
	~	Euro/(Year*Person)
	~	Per capita income from net tax redistribution net of carbon tax payments per \
		individual category
		
		New proposed equation:
		ZIDZ(((Act CT redistrib* CT redistrib d[inc cat]) - Carbon tax hh per capita d[inc \
		cat]),pop d[inc cat])*People 1
		
		Equation until 15/04/2024
		ZIDZ((Act CT redistrib* (CT redistrib d[inc cat] - Carbon tax hh d[inc \
		cat])),pop d[inc cat])*People 1
	|

CT redistrib per capita d delay[inc cat]= DELAY FIXED (
	 CT redistrib per capita d[inc cat], Year 1, 0* euro 1)
	~	Euro/(Year*Person)
	~	Per capita income from net tax redistribution net of carbon tax payments \
		per individual category, lagged
	|

CT redistrib rq[regions,quintiles]=
	sum(CT redistrib per capita d delay[inc cat!]*pop d[inc cat!]*hhs cat shares rq adj[
	regions,inc cat!,quintiles])
	~	
	~	Net income from carbon tax (payments - redistribution), total nominal \
		value per region-quintile
	|

CT redistrib total=
	sum(CT redistrib rq[regions!,quintiles!])
	~	Euro/Year
	~	Total national net carbon tax income
	|

