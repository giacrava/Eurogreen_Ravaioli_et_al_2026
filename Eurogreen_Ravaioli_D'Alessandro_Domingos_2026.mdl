	~	Euro/(Year*Person)
	~		|

yd order[inc cat]=
	VECTOR SORT ORDER(yd d[inc cat], 1 )
	~	Dmnl
	~		|

yd pre hh tax rq[regions, quintiles]=
	NWB rq[regions,quintiles] + 
	NUB rq[regions,quintiles] + 
	NPB rq[regions,quintiles] +
	NFI rq[regions,quintiles] +
	mixed income rq[regions,quintiles] +
	sd rq[regions,quintiles] +
	cb rq[regions,quintiles] +
	other benefits rq[regions,quintiles]+
	BI rq[regions,quintiles] +
	JG rq n[regions,quintiles] +
	CT redistrib rq[regions,quintiles]
	~	Euro/Year
	~	Total nominal disposable income per region-quintile before eventual \
		taxation at the household level
	|

yd real per capita bottom 50=
	sum(bottom 50 rq[regions!,quintiles!]*yd rq[regions!,quintiles!]/CPI rq[regions!,quintiles
!])/
	sum(pop rq[regions!,quintiles!]*bottom 50 rq[regions!,quintiles!])
	~	Euro/(Year*Person)
	~		|

yd real per capita bottom 50 after tls=
	sum(bottom 50 rq[regions!,quintiles!]*yd rq after tls[regions!,quintiles!]/CPI rq[regions
!,quintiles!])/
	sum(pop rq[regions!,quintiles!]*bottom 50 rq[regions!,quintiles!])
	~	Euro/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

yd real per capita bottom 50 pre tt=
	sum(bottom 50 rq[regions!,quintiles!]*yd rq pre tt[regions!,quintiles!]/CPI rq[regions
!,quintiles!])/
	sum(pop rq[regions!,quintiles!]*bottom 50 rq[regions!,quintiles!])
	~	Euro/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

yd real per capita middle 40=
	sum(middle 40 rq[regions!,quintiles!]*yd rq[regions!,quintiles!]/CPI rq[regions!,quintiles
!])/
	sum(pop rq[regions!,quintiles!]*middle 40 rq[regions!,quintiles!])
	~	Euro/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

yd real per capita middle 40 after tls=
	sum(middle 40 rq[regions!,quintiles!]*yd rq after tls[regions!,quintiles!]/CPI rq[regions
!,quintiles!])/
	sum(pop rq[regions!,quintiles!]*middle 40 rq[regions!,quintiles!])
	~	Euro/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

yd real per capita middle 40 pre tt=
	sum(middle 40 rq[regions!,quintiles!]*yd rq pre tt[regions!,quintiles!]/CPI rq[regions
!,quintiles!])/
	sum(pop rq[regions!,quintiles!]*middle 40 rq[regions!,quintiles!])
	~	Euro/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

yd real per capita top 10=
	sum(top 10 rq[regions!,quintiles!]*yd rq[regions!,quintiles!]/CPI rq[regions!,quintiles
!])/
	sum(pop rq[regions!,quintiles!]*top 10 rq[regions!,quintiles!])
	~	Euro/(Year*Person)
	~		|

yd real per capita top 10 after tls=
	sum(top 10 rq[regions!,quintiles!]*yd rq after tls[regions!,quintiles!]/CPI rq[regions
!,quintiles!])/
	sum(pop rq[regions!,quintiles!]*top 10 rq[regions!,quintiles!])
	~	Euro/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

yd real per capita top 10 bottom 50 ratio=
	yd real per capita top 10/yd real per capita bottom 50
	~	
	~		~	:SUPPLEMENTARY 
	|

yd real per capita top 10 pre tt=
	sum(top 10 rq[regions!,quintiles!]*yd rq pre tt[regions!,quintiles!]/CPI rq[regions!
,quintiles!])/
	sum(pop rq[regions!,quintiles!]*top 10 rq[regions!,quintiles!])
	~	Euro/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

yd region[regions]=
	sum(yd rq[regions,quintiles!])
	~	Euro/Year
	~	Total nominal disposable income of households, per region
	|

yd rq[regions,quintiles]=
	yd hhs rq[regions,quintiles] * num hhs rq delayed[regions,quintiles]
	~	Euro/Year
	~	Total nominal disposable income per region-quintile
	|

yd rq after tls[regions,quintiles]=
	yd hhs rq after tls[regions,quintiles]*num hhs rq delayed[regions,quintiles]
	~	Euro/Year
	~		|

yd rq init model[regions,quintiles]= INITIAL(
	yd rq[regions,quintiles])
	~	
	~		|

yd rq nonMI[regions,quintiles]=
	(yd hhs rq[regions,quintiles]-mixed income rq hhs[regions,quintiles]) * num hhs rq delayed
[regions,quintiles]
	~	Euro/Year
	~	Total nominal disposable income per region-quintile
	|

yd rq pre tt[regions,quintiles]=
	GFI rq[regions,quintiles]+GPB rq[regions,quintiles]+GWB rq[regions,quintiles]+mixed income rq
[regions,quintiles]
	~	
	~		|

yd rq real delay[regions,quintiles]=
	yd dynamic rq hh real delay[regions,quintiles]+yd static rq hh real delay[regions,quintiles
	]
	~	
	~		~	:SUPPLEMENTARY 
	|

yd rq real per capita[regions,quintiles]=
	(yd hhs rq[regions,quintiles]/CPI rq[regions,quintiles])
	*num hhs rq delayed[regions,quintiles]/pop rq[regions,quintiles]
	~	Euro constant/(Year*Person)
	~	Real disposable household income per person, by region and quintiles
	|

yd rq total=
	sum(yd rq[regions!,quintiles!])
	~	
	~	Total nominal disposable income of households, national aggregate
	|

yd share[inc cat]=
	(yd d[inc cat]*pop d[inc cat])/sum(yd d[inc cat!]*pop d[inc cat!])
	~	Dmnl
	~		|

yd share bottom 50=
	sum(yd rq[regions!,quintiles!]*bottom 50 rq[regions!,quintiles!])/
	sum(yd rq[regions!,quintiles!])
	~	Dmnl
	~		|

yd share bottom 50 after tls=
	sum(yd rq after tls[regions!,quintiles!]*bottom 50 rq[regions!,quintiles!])/
	sum(yd rq after tls[regions!,quintiles!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

yd share bottom 50 pre tt=
