delta perc gov c real care services policy end=SAMPLE IF TRUE(
	Time=S Time Shift end+1, delta perc gov c real care services delay, delta perc gov c real care services delay
)
	~	1
	~		|

delta perc hhs and gov c real care services delay per capita= DELAY FIXED (
	delta perc hhs and gov c real care services per capita,1,0)
	~	1
	~		|

