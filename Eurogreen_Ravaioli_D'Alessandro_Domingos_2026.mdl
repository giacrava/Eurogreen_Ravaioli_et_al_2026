	~		|

delayed cumulative electrification=
	DELAY FIXED(cumulative electrification, Year 1, 0)
	~	Dmnl
	~		|

delta a chosen[ind,toind]=
	IF THEN ELSE(track tech choice[toind]=1, 0, 
	IF THEN ELSE(track tech choice[toind]=2, g a T2 ii[ind,toind], 
	IF THEN ELSE(track tech choice[toind]=3, g a T3 ii[ind,toind],
	g a T4 ii[ind,toind])))
	~	Dmnl
	~		|

delta a chosen delay[ind,toind]=
	DELAY FIXED( delta a chosen[ind,toind], Year 1, 0 )
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

delta a i iteration[toind,iteration]=
	sum(new a iteration[ind!,toind,iteration])-sum(a ii[ind!,toind])
	~	Dmnl
	~		|

delta average duration of working time[gender]=
	growth duration of working life g[gender]*late convergence*average duration of working time g
[gender]
	~	Dmnl
	~		|

delta beta q5 q1 p[coicop]=
	basic beta q p[q5,coicop] - basic beta q p[q1,coicop]
	~	1
	~	Difference in consumption shares (beta) of each COICOP category between q5 (richest) \
		& q1 (poorest). 
		Proxy for demand share increase with income and income-elasticity of demand share.
		Positive value --> richer households consume proportionally more than \
		poorer
	|

delta damage multiplier i[ind]=
	IF THEN ELSE (Time<10,
	damage multiplier i[ind]-damage multiplier delay i[ind],
	damage*min(damage multiplier i[ind]-damage multiplier delay i[ind],0)*max(adaptation
,0))
	~	Dmnl
	~		|

delta delta wage i[ind]=
	delta wage-delta wage i[ind]
