c19 shock cons=
	IF THEN ELSE(Time=10*Year 1,c19 cons 2020,IF THEN ELSE(Time=11* Year 1,c19 cons 2021
,IF THEN ELSE(Time=12*Year 1,c19 cons 2022
	,0)))
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

c19 shock exp=
	IF THEN ELSE(Time=10,c19 exp 2020,IF THEN ELSE(Time=11,c19 exp 2021,IF THEN ELSE(Time
=12,c19 exp 2022,0)))
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

