[gini3]+pop share ordered gini[gini4]+pop share ordered gini[gini5]+pop share ordered gini
[gini6]+pop share ordered gini[gini7]+pop share ordered gini[gini8]+pop share ordered gini
[gini9]+pop share ordered gini[gini10]<0.4, gini11,
	IF THEN ELSE(pop share ordered gini[gini1]+pop share ordered gini[gini2]+pop share ordered gini
[gini3]+pop share ordered gini[gini4]+pop share ordered gini[gini5]+pop share ordered gini
[gini6]+pop share ordered gini[gini7]+pop share ordered gini[gini8]+pop share ordered gini
[gini9]<0.4, gini10, gini9
	)))))))
	~	Dmnl
