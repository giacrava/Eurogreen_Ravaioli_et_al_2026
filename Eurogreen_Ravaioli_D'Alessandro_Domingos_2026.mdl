mpc yd hhs rq[regions,quintiles]=
	max(0,mpc hhs exog[regions](expected yd rq real[regions,quintiles]))
	~	Dmnl
	~	Propensity to consume
		
		Previous equation (old alphas):
		max(0,lookup extrapolate(mpc hhs fct[regions],expected yd rq \
		real[regions,quintiles]))
		
		New equation (new alphas):
	|

Multiplier Innovation=
	0
	~	
	~	Factor that multiplies probability of innovation to make it weaker.
	~	:SUPPLEMENTARY 
	|

Multiplier Wage Indexation=
	0.5
	~	
	~		|

MW to GW=
	1/1000
	~	GW/MW
	~		|

N olf gs[gender,skill]=
	sum(Working age population cgs[cohorts!,gender,skill])-labour force[gender,skill]
	~	People
	~	number of people being out of labour force by gender and skill
	|

N olf gs delayed[gender,skill]=
	DELAY FIXED(N olf gs[gender,skill], Year 1, 0)
	~	People
	~		|

national consumption based emissions=
	direct emissions hh consumption+embedded emissions C+embedded emissions G+embedded emissions I
	~	tCO2eq/Year
	~		|

national consumption based emissions delay= DELAY FIXED (
	national consumption based emissions, 1, national consumption based emissions init)
	~	
	~		|

national consumption based emissions init= INITIAL(
	national consumption based emissions)
	~	tCO2eq/Year
	~		|

national consumption based EREU=
	direct EREU hh consumption+embedded EREU C+embedded EREU G+embedded EREU I
	~	TJ/Year
	~		~	:SUPPLEMENTARY 
	|

national direct emissions per capita=
	sum(direct emissions hh rq[regions!,quintiles!])/sum(pop rq[regions!,quintiles!])
	~	tCO2eq/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

national direct emissions per household=
	sum(direct emissions hh rq[regions!,quintiles!])/sum(num hhs rq delayed[regions!,quintiles
!])
	~	tCO2eq/(Year*Household)
	~		~	:SUPPLEMENTARY 
	|

national emissions per capita=
	sum(direct and embedded emissions C rq[regions!,quintiles!])/sum(pop rq[regions!,quintiles
!])
	~	tCO2eq/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

national emissions per household=
	sum(direct and embedded emissions C rq[regions!,quintiles!])/sum(num hhs rq delayed[
regions!,quintiles!])
	~	tCO2eq/(Year*Household)
	~		~	:SUPPLEMENTARY 
	|

NDP per hour=
	NDP real/tot hours
	~	Euro constant/Hours
	~		|

NDP per hour delay= DELAY FIXED (
	NDP per hour, 1, NDP per hour init)
	~	
	~		|

NDP per hour init= INITIAL(
	NDP per hour)
	~	Euro constant/Hours
	~		|

NDP real=
	GDP real-depreciation K
	~	Euro constant/Year
	~		|

NDP real delay= DELAY FIXED (
	NDP real, 1, NDP real init)
	~	
	~		|

NDP real init= INITIAL(
	NDP real)
	~	Euro constant/Year
	~		|

negatives equal to zero[regions,inc cat,quintiles]=
	-matrix of negatives[regions,inc cat,quintiles]
	~	
	~		|

net exp nom=
	total exp nom-tot Z imp
	~	Euro/Year
	~		|

net exp real=
	total exp real-Z imp real tot
	~	Euro constant/Year
	~		|

net exp real delay= DELAY FIXED (
	net exp real, 1, initial net exp real)
	~	Euro constant/Year
	~		|

net fin inc cap=
	net fin inc cap effective
	~	Euro/Year
	~	Without evasion nor different effective tax rates:
		gross fin inc cap*(1-financial income tax rate)
	|

net fin inc cap effective=
	(1-fin inc tax rate bonds effective)*gross fin inc cap bonds
	+(1-fin inc tax rate eq effective)*gross fin inc cap eq
	~	
	~		|

net fin inc gs[gender,skill]=
	net fin inc gs effective[gender,skill]
	~	Euro
	~	net financial income by skill
		
		Without evasion nor different effective tax rates:
		gross fin inc gs[gender,skill]*(1-financial income tax rate)
	|

net fin inc gs effective[gender,skill]=
	(1-fin inc tax rate bonds effective)*gross fin inc gs bonds[gender,skill]
	+(1-fin inc tax rate eq effective)*gross fin inc gs eq[gender,skill]
	~	Euro/Year
	~		|

net labour income per capita gis[gender,ind,skill]=
	max(Euro 0,(ZIDZ(GWB gis[gender,ind,skill],L gis[gender,ind,skill])*People 1)-soc sec contr e gis
[gender,ind,skill]-inc tax e gis[gender,ind,skill])
	~	Euro/(Year*Person)
	~	Net labour income per capita for employed persons.
	|

net labour income per capita gs[gender,skill]=
	ZIDZ(sum(net labour income per capita gis[gender,ind!,skill]*L gis[gender,ind!,skill
]),L gs[gender,skill])
	~	Euro/(Year*Person)
	~	Net labour income per capita per gender and skill
	|

net migration[male,cohorts]=
	total net migration[cohorts](Time)*male share net migration[cohorts](Time) ~~|
net migration[female,cohorts]=
	total net migration[cohorts](Time)*(1-male share net migration[cohorts](Time))
	~	People/Year
	~		|

net migration 014[gender]=
	net migration[gender,p0014]
	~	People/Year
	~		|

net migration 1524[gender]=
	net migration[gender,p1524]
	~	People/Year
	~		|

net migration 2544[gender]=
	net migration[gender,p2544]
	~	People/Year
	~		|

net migration 4564[gender]=
	net migration[gender,p4564]
	~	People/Year
	~		|

"net migration 65+"[gender]=
	net migration[gender,p65]
	~	People/Year
	~		|

net migration skills 1524[gender, skill]=
	net migration 1524[gender]*
	(Skills 1524 gs[gender,skill]/sum(Skills 1524 gs[gender,skill!]))
	~	People/Year
	~		|

net migration skills 2544[gender,skill]=
	net migration 2544[gender]*
	(Skills 2544 gs[gender,skill]/sum(Skills 2544 gs[gender,skill!]))
	~	People/Year
	~		|

net migration skills 4564[gender,skill]=
	net migration 4564[gender]*
	(Skills 4564 gs[gender,skill]/sum(Skills 4564 gs[gender,skill!]))
	~	People/Year
	~		|

"net migration skills 65+"[gender,skill]=
	"net migration 65+"[gender]*
	("Skills 65+ gs"[gender,skill]/sum("Skills 65+ gs"[gender,skill!]))
	~	People/Year
	~		|

net worth banks=
	sum(debt i[ind!])
	-sum(d gs[gender!,skill!])
	-d cap
	+foreign assets
	~	Euro
	~		|

net worth firms=
	sum(K i[nongovsec!]*price capital pp i[nongovsec!])
	-sum(debt i[nongovsec!])
	-sum(Equity i[nongovsec!])
	
	
	-K i[electricity ind]*price capital pp i[electricity ind]
	
	+
	(
	(1-electricity module switch)*(K i[electricity ind]*price capital pp i[electricity ind
	])+
	electricity module switch*(K i[electricity ind]*price of capital D1 pp)
	)
	
	
	
	
	+sum(K i[govsec!]*(1-fraction government profits investment capital[govsec!])*price capital pp i
[govsec!])
	-sum(debt i[govsec!])
	-sum(Equity i[govsec!])
	~	Euro
	~		|

net worth government=
	sum(K i[govsec!]*fraction government profits investment capital[govsec!]*price capital pp i
[govsec!])
	-b
	~	Euro
	~		|

net worth households=
	sum(d gs[gender!,skill!])+d cap
	+sum(b gs[gender!,skill!])+b cap
	+sum(eq gs[gender!,skill!])+eq cap
	~	Euro
	~		|

net worth sum=
	sum(K i[ind!]*price capital pp i[ind!])
	
	-K i[electricity ind]*price capital pp i[electricity ind]
	
	+
	(
	(1-electricity module switch)*(K i[electricity ind]*price capital pp i[electricity ind
	])+
	electricity module switch*(K i[electricity ind]*price of capital D1 pp)
	)
	
	
	
	
	
	+foreign assets
	-net worth banks
	-net worth firms
	-net worth government
	-net worth households
	~	Euro
	~		|

new a iteration[ind,toind,iteration]=
	a ii[ind,toind]*(1+g a ii iteration[ind,toind,iteration]*fraction new capital[toind]
)
	~	Dmnl
	~		|

new bridge check[ind,coicop]=
	bridge hhs pi[ind,coicop]-bridge industries to coicop[ind,coicop]
	~	
	~		~	:SUPPLEMENTARY 
	|

new capacity investment costs[e techn]=
	capacity investment[e techn]*capacity investment costs per unit capacity[e techn]/capacity construction time
[e techn]
	~	Euro constant/(Year*Year)
	~	We assume a linear expense schedule of investment costs over the time of \
		construction.
	|

new cat shares rqd[regions,inc cat,quintiles]=
	max(0,hhs cat shares rq adj delayed[regions,inc cat,quintiles] + 
	ZIDZ(total adjustment[regions,inc cat,quintiles],pop d shares nocap[inc cat]))
	~	
	~		|

new end use share ff[ind,ff]=
	IF THEN ELSE(E end use before ESc[ind,ff]+E end use imp before ESc[ind,ff]+delta end use ff
[ind,ff]
	+E transformation use before ESc[ind,ff]+E transformation use before ESc imp[ind,ff]
+delta transformation use ff[ind,ff
	]=0,0,
	
	(E end use before ESc[ind,ff]+E end use imp before ESc[ind,ff]+delta end use ff[ind,
ff])
	/
	(E end use before ESc[ind,ff]+E end use imp before ESc[ind,ff]+delta end use ff[ind,
ff]
	+E transformation use before ESc[ind,ff]+E transformation use before ESc imp[ind,ff]
+delta transformation use ff[ind,ff
	])
	)
	~	Dmnl
	~		|

new end use share heat D1=
	1/
	(1+(
	(1-end use share Z inrg delay[electricity ind,heat])/(end use share Z inrg delay[electricity ind
,heat]+(added heat use D1/total heat use D1))
	))
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

new end use shares electricity ind[ffbio]=
	IF THEN ELSE(E end use before ESc[electricity ind,ffbio]+E end use imp before ESc[electricity ind
,ffbio]+delta end use ff
	[electricity ind,ffbio]
	+E transformation use before ESc[electricity ind,ffbio]+E transformation use before ESc imp
[electricity ind,ffbio]+delta transformation use ffbio electricity ind
	[ffbio]=0,0,
	
	(E end use before ESc[electricity ind,ffbio]+E end use imp before ESc[electricity ind
,ffbio]+delta end use ff[electricity ind
	,ffbio])
	/
	(E end use before ESc[electricity ind,ffbio]+E end use imp before ESc[electricity ind
,ffbio]+delta end use ff[electricity ind
	,ffbio]
	+E transformation use before ESc[electricity ind,ffbio]+E transformation use before ESc imp
[electricity ind,ffbio]+delta transformation use ffbio electricity ind
	[ffbio])
	)
	~	
	~		|

NFI check=
	NFI rq total - NFI total
	~	
	~		~	:SUPPLEMENTARY 
	|

NFI d[inc low u f]=	NFI per capita gs[female,low] ~~|
NFI d[inc low u m]=	NFI per capita gs[male,low] ~~|
NFI d[inc mid u f]=	NFI per capita gs[female,mid] ~~|
NFI d[inc mid u m]=	NFI per capita gs[male,mid] ~~|
