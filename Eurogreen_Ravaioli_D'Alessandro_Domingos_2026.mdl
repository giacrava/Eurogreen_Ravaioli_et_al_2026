	+bank profit transfers gs[gender,hig]
	~	Euro/Year
	~	gross financial income by skill
	|

group wage share gis[gender,ind,skill]=
	GWB gis[gender,ind,skill]/GWB
	~	Dmnl
	~		|

growth duration of working life g[gender]=
	0.01348,
	0.00501
	~	Dmnl/Year
	~	https://doi.org/10.2908/LFSI_DWL_A
		mean growth rate 2010-2019
	|

GUB exp=
	sum(GUB gs[gender!,skill!])
	~	Euro/Year
	~		|

GUB gs[gender,skill]=
	ub coverage ratio*ub wage ratio*ZIDZ(GWB gs[gender,skill],L gs[gender,skill])*ub recipients
[gender,skill]
	~	Euro/Year
	~	total gross unemployment benefits paid by skill and gender
		
		IF_THEN_ELSE(Time<S_Time_Policy_start,
		             \
		max(0,ub_coverage_ratio*ub_wage_ratio*(GWB_gs[gender,skill]/L_gs[gender,ski\
		ll])*L_u_gs[gender,skill]),
		             \
		(1-Act_BI)*max(0,ub_coverage_ratio*ub_wage_ratio*(GWB_gs[gender,skill]/L_gs\
		[gender,skill])*L_u_gs[gender,skill])
		             )
	|

GVA real i[toind]=
	y real i[toind]-sum(Z imp real ii[ind!,toind])-sum(Z real ii[ind!,toind])
	~	Euro constant/Year
	~		|

GVA to output i[ind]=
	GVA real i[ind]/y real i[ind]
	~	1
	~		|

GWB=
	sum(GWB i[ind!])
	~	Euro/Year
	~		|

GWB gis[gender,ind,skill]=
	wage gis[gender,ind,skill]*actual hours i[ind]*L gis[gender,ind,skill]
	~	Euro/Year
	~	gross wage bill
		
		previous formula (changed 11/11/22)
		(max(wage min[gender,ind,skill],wage gis[gender,ind,skill])*hours i[ind]*L \
		gis[gender,ind,skill])/(People 1*Hours 1)
	|

GWB gs[gender,skill]=
	sum(GWB gis[gender,ind!,skill])
	~	Euro/Year
	~		|

GWB i[ind]=
	sum(GWB gis[gender!,ind,skill!])
	~	Euro/Year
	~		|

GWB per capita gs[gender,skill]=
	ZIDZ(GWB gs[gender,skill],L gs[gender,skill])
	~	Euro/(Year*Person)
	~		|

GWB r[regions]=
	sum(GWB rq[regions,quintiles!])
	~	Euro/Year
	~		|

GWB rq[regions,quintiles]=
	GWB gs[female,low] * hhs cat shares rq adj[regions,inc low e f,quintiles] +
	GWB gs[male,low] * hhs cat shares rq adj[regions,inc low e m,quintiles] + 
	GWB gs[female,mid] * hhs cat shares rq adj[regions,inc mid e f,quintiles] +
	GWB gs[male,mid] * hhs cat shares rq adj[regions,inc mid e m,quintiles] + 
	GWB gs[female,hig] * hhs cat shares rq adj[regions,inc hig e f,quintiles] +
	GWB gs[male,hig] * hhs cat shares rq adj[regions,inc hig e m,quintiles]
	~	Euro/Year
	~	Gross Wage Bill, total nominal value per region-quintile
	|

GWB T iv[ind,techn]=
	(sum(wage gis[gender!,ind,skill!]*hours i[ind]*L T gisv[gender!,ind,skill!,techn]))
	~	Euro/Year
	~		|

heat per unit D1 hhs demand=
	av energy use per unit hh consumption be[electricity ind,heat]
	~	TJ/Euro constant
	~		|

hh cat share checl[inc cat]=
	sum(hhs cat shares rq adj[regions!,inc cat,quintiles!])
	~	Dmnl
	~		|

hh dom alt=
	sum((c ESc pp i[ind!]-substitution spending hhs pp[ind!])/(1+tls[ind!])*paid embedded ucc pp
[ind!])
	~	Euro/Year
	~		|

hh tax alt=
	sum((c ESc nom bp i[ind!]+shortfall c nom[ind!])*direct ucc bp nom[ind!])
	-direct cc hhs paid
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

hhs and gov c real target baseline care services per capita=
	gov c real target baseline care services per capita+hhs c real care services per capita
	~	
	~		|

hhs C emissions bottom 50=
	sum(direct and embedded emissions C rq[regions!,quintiles!]*bottom 50 rq[regions!,quintiles
	!])/
	sum(num hhs rq delayed[regions!,quintiles!]*bottom 50 rq[regions!,quintiles!])
	~	
	~		~	:SUPPLEMENTARY 
	|

hhs C emissions middle 40=
	sum(direct and embedded emissions C rq[regions!,quintiles!]*middle 40 rq[regions!,quintiles
	!])/
	sum(num hhs rq delayed[regions!,quintiles!]*middle 40 rq[regions!,quintiles!])
	~	tCO2eq/(Year*Household)
	~		~	:SUPPLEMENTARY 
	|

hhs C emissions top 10=
	sum(direct and embedded emissions C rq[regions!,quintiles!]*top 10 rq[regions!,quintiles
	!]) / 
