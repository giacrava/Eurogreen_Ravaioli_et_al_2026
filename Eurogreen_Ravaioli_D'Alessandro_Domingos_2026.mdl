	real estate inv,1,initial GFCF i[realestate]*initial capital price pp i[realestate])
	~	
	~		|

delay time=
	1
	~	Year
	~		|

delay time CPI uw policies=
	1+STEP(FINAL TIME-S Time Policy start,S Time Policy start)
	~	
	~		|

delay time end use share=
	1+STEP(FINAL TIME-(S Time Policy start-1),S Time Policy start-1)
