Goods 0=
	0
	~	Goods
	~		|

goods 1=
	1
	~	Goods
	~		~	:SUPPLEMENTARY 
	|

gov c and I nom=
	I gov+gov c nom
	~	Euro/Year
	~		|

gov c and I nom careserv=
	gov c careserv nom+gov I nom careserv
	~	Euro/Year
	~		|

gov c and I nom i[govsec]=
	gov c nom i[govsec]+gov I nom i[govsec]
	~	Euro/Year
	~		|

gov c and I nom to GDP=
	gov c and I nom/GDP nom
	~	
	~		|

gov c and I real=
	gov c real+I gov real
	~	Euro constant/Year
	~		|

gov c and I real careserv=
	sum(gov c and I real i[careserv!])
	~	Euro constant/Year
	~		|

gov c and I real careserv per capita=
	gov c and I real careserv/population total
	~	Euro constant/(Person*Year)
	~		~	:SUPPLEMENTARY 
	|

gov c and I real careserv to GDP=
	sum(gov c and I real to GDP i[careserv!])
	~	1
	~		~	:SUPPLEMENTARY 
	|

gov c and I real i[ind]=
	gov c real i[ind]+gov I real i[ind]
	~	Euro constant/Year
	~		|

gov c and I real per capita=
	gov c and I real/population total
	~	Euro constant/(Person*Year)
	~		~	:SUPPLEMENTARY 
	|

gov c and I real to GDP=
	gov c real to GDP+I gov real to GDP
	~	1
	~		~	:SUPPLEMENTARY 
	|

gov c and I real to GDP i[ind]=
	gov c real to GDP i[ind]+gov I real to GDP i[ind]
	~	1
	~	Total real consumption and investmetn of government, without considering \
		eventual imported substitution spending
	|

gov c and I to GDP nom careserv=
	gov c and I nom careserv/GDP nom
	~	1
	~		|

gov c and I to GDP nom i[govsec]=
	gov c and I nom i[govsec]/GDP nom
	~	1
	~		|

gov c careserv nom=
	sum(gov c nom i[careserv!])
	~	Euro/Year
	~		|

gov c careserv to GDP nom=
	gov c careserv nom/GDP nom
	~	1
	~		|

gov c dom nom=
	sum(gov c dom nom i[ind!])
	~	Euro/Year
	~		|

gov c dom nom i[ind]=
	(1 - share imp gov i[ind])*gov c nom i[ind]
	~	Euro/Year
	~		|

gov c dom real=
	sum(gov c dom real i[ind!])
	~	Euro constant/Year
	~		|

gov c dom real delay= DELAY FIXED (
	gov c dom real, 1, initial gov c dom real)
	~	Euro constant/Year
	~		|

gov c dom real i[ind]=
	(1 - share imp gov i[ind])*gov c real i[ind]
	~	Euro constant/Year
	~		|

gov c imp nom i[ind]=
	share imp gov i[ind]*gov c nom i[ind]
	+Act electrification costs paid by gov*electrification demand imp[ind]
	~	Euro/Year
	~		|

gov c nom=
	sum(gov c nom i[ind!])
	~	Euro/Year
	~		|

gov c nom i[ind]=
	gov c real i[ind]*p i[ind]
	~	Euro/Year
	~		|

gov c nom target baseline care services per capita=
	sum(gov c real target baseline i[careserv!]*p i[careserv!])/population total
	~	Euro/Year
	~		|

gov c real=
	sum(gov c real i[ind!])
	~	Euro constant/Year
	~		|

gov c real delay=
	sum(gov c real delay i[ind!])
	~	Euro constant/Year
	~		|

gov c real delay i[ind]= DELAY FIXED (
	desired gov real i[ind], Year 1, init gov c real[ind])
	~	Euro constant/Year
	~	Note that we delay with the desired government consumption, since we \
		assume the output constraint has no longer lasting impact on government \
		consumption.,
	|

gov c real gap correction parameter=
	0.5
	~	1
	~		|

gov c real health edu per capita=
	(gov c real i[education]+gov c real i[health])/population total
	~	Euro constant/(Year*Person)
	~		|

gov c real health edu per capita growth=
	TREND(gov c real health edu per capita, 1 , 0 )
	~	Dmnl
	~		|

gov c real health edu per capita growth delay=
	DELAY FIXED(gov c real health edu per capita growth, 1 , 0 )
	~	Dmnl
	~		|

gov c real i[ind]=
	desired gov real i[ind] * ratio K FE constrained fd[ind]
	~	Euro constant/Year
	~	if def/GDP too high government spending can only fall
		
		It represents the real demand of government without considering possible \
		imports (shortfall gov c nom) due to domestic production constraints to \
		which the shortfall imported should be added.
	|

gov c real per capita=
	gov c real/population total
	~	Euro constant/(Person*Year)
	~		~	:SUPPLEMENTARY 
	|

gov c real per capita i[ind]=
	gov c real i[ind]/population total
	~	Euro constant/(Person*Year)
	~		|

gov c real target baseline care services=
	sum(gov c real target baseline i[careserv!])
	~	Euro constant/Year
	~		|

gov c real target baseline care services per capita=
	sum(gov c real target baseline i[careserv!])/population total
	~	Euro constant/Year
	~		|

gov c real target baseline i[ind] :EXCEPT:              [careserv]=
	IF THEN ELSE(Act Change baseline gov consumption = 5,
	gov c real gap correction parameter * gov c real to GDP target baseline i[ind] * GDP real delay
	* (1+g GDP real impact gov c real) + (1-gov c real gap correction parameter) *
	IF THEN ELSE(Time=S Time Change baseline gov consumption,
	gov c real delay i[ind],
	gov c real target baseline i delay[ind]
	),
	0
	) ~~|
gov c real target baseline i[careserv]=
	IF THEN ELSE(Act Change baseline gov consumption = 5,
	gov c real gap correction parameter * gov c real to GDP target baseline i[careserv] 
* 
	GDP real delay
	* (1+g GDP real impact gov c real) + (1-gov c real gap correction parameter) *
	IF THEN ELSE(Time=S Time Change baseline gov consumption,
	gov c real delay i[careserv],
	gov c real target baseline i delay[careserv]
	),
	IF THEN ELSE(Act Change baseline gov consumption = 6 :OR: Act Change baseline gov consumption
	 = 7,
	ZIDZ(L public target gov bs 6 or 7 i[careserv] * lambda i[careserv] * hours i[careserv
], (
	1-share imp gov i[careserv])),
	0
	)
	)
	~	Euro constant/Year
	~	IF THEN ELSE(
		(:NOT:(Act change gov consumption=0)) :AND: Time>=S Time Policy start :AND: Time<=S \
		Time Shift end,
		gov c real to GDP target actual i[ind] * GDP real delay * (1+g GDP real smooth \
		delay),
		gov c real to GDP gap parameter * gov c real to GDP target actual i[ind] * GDP real \
		delay * (1+g GDP real smooth delay) + 
		(1-gov c real to GDP gap parameter) * gov c real delay i[ind]
		)
	|

gov c real target baseline i delay[ind]= DELAY FIXED (
	gov c real target baseline i[ind], 1, 0)
	~	Euro constant/Year
	~		|

gov c real target baseline i to GDP[ind]=
	gov c real target baseline i[ind]/GDP real
	~	
	~		~	:SUPPLEMENTARY 
	|

gov c real to GDP=
	gov c real/GDP real
	~	1
	~		|

gov c real to GDP gap i[ind]=
	IF THEN ELSE(Time>=S Time Change baseline gov consumption, gov c real to GDP target actual i
[ind]-gov c real to GDP i delay
	[ind], 0)
	~	1
	~		|

gov c real to GDP i[ind]=
	gov c real i[ind]/GDP real
	~	1
	~		|

gov c real to GDP i delay[ind]= DELAY FIXED (
	gov c real to GDP i[ind], 1 , 0)
	~	1
	~		|

gov c real to GDP target actual=
	sum(gov c real to GDP target actual i[ind!])
	~	1
	~		~	:SUPPLEMENTARY 
	|

gov c real to GDP target actual i[ind]=
	gov c real to GDP target baseline i[ind]+
	IF THEN ELSE(Act change gov consumption=2,
	Policy time increment*S change government consumption i[ind],
	0)
	~	1
	~	If policy that adds S change government consumption i[ind] % to GDP, add \
		them to target shares
	|

gov c real to GDP target baseline i[ind]=SAMPLE IF TRUE(
	Time = S Time Change baseline gov consumption, gov c real to GDP i delay[ind], 0)
	~	1
	~		|

gov c sh of y i[ind]=
	gov c real i[ind]/y real i[ind]
	~	1
	~	Share of output that is covered by government final consumption.
		For public sector, healthcare and education it also represents the share \
		of output that is produced by the government to provide market services \
		for free. The rest is what is produced privately, or by the government for \
		market output or for services produced at non-economically significant \
		prices.
	~	:SUPPLEMENTARY 
	|

gov c to GDP nom=
	gov c nom/GDP nom
	~	1
	~		|

gov c to GDP nom i[ind]=
	gov c nom i[ind]/GDP nom
	~	1
	~		|

gov consumption import trend[ind]=
	gov consumption import trend delayed[ind]*(1+gov consumption import trend capped[ind
]*convergence)
	~	Dmnl
	~		|

gov consumption import trend base[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'trend_impsh_gov')
	~	Dmnl/Year
	~	Geometric mean of growth rates of import shares, for the period 2000-2014 \
		(excluding 2008-2010), computed from input-output data. Sectors D1, D2 and \
		D3 take the same value of sector D in input-output tables.
	|

gov consumption import trend capped[ind]=
	max(min(gov consumption import trend base[ind],trend cap),-trend cap)
	~	Dmnl/Year
	~		|

gov consumption import trend delayed[ind]= DELAY FIXED (
	gov consumption import trend[ind],Year 1,1)
	~	Dmnl
	~		|

gov def=
	tot gov exp-tot gov rev
	~	Euro/Year
	~	government deficit
	|

gov def spending trigger=
	0.03
	~	Dmnl
	~		|

gov dom check=
	sum(paid embedded ucc bp nom[ind!]*gov c nom i[ind!]*(1-share imp gov i[ind!]))
	-gov paid alt
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

gov exp gov c=
	sum(gov c nom i[ind!])+substitution spending government+tls from gov c nom
	~	Euro/Year
	~		|

gov exp minus gov c=
	tot gov exp-gov exp gov c
	~	Euro/Year
	~		|

gov I careserv to GDP nom=
	gov I nom careserv/GDP nom
	~	1
	~		|

gov I frac=
	1
	~	Dmnl
	~	fraction of government investment over total investment
		0.163816
	|

gov I nom careserv=
	gov I nom i[health]+gov I nom i[education]
	~	Euro/Year
	~		|

gov I nom i[govsec]=
	I demand nom i[govsec]*fraction government profits investment capital[govsec]
	~	Euro/Year
	~		|

gov I real i[ind] :EXCEPT:  [health], [education], [public]=
	0 ~~|
gov I real i[education]=
	gov I frac*GFCF real i[education] ~~|
gov I real i[health]=
	gov I frac*GFCF real i[health] ~~|
gov I real i[public]=
	GFCF real i[public]
	~	Euro constant/Year
	~		|

gov I real to GDP i[ind]=
	gov I real i[ind]/GDP real
	~	1
	~		|

gov interest=
	(average interest rate)*b
	~	Euro/Year
	~		|

gov interests to rev ratio=
	gov interest/tot gov rev
	~	1
	~		|

gov paid alt=
	sum(gov c dom nom i[ind!]*paid embedded ucc bp nom[ind!])
	~	
	~		|

gov paid tls=
	sum(gov c nom i[ind!]*tls gov[ind!])
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

gov rev cap=
	sum(delta yd cap rq[regions!,quintiles!])
	~	Euro/Year
	~	Government revenues from capping households' disposable income
	|

gov rev cap exp=
	sum(delta yd cap hhs rq exp[regions!,quintiles!]*num hhs rq delayed[regions!,quintiles
	!])
	~	Euro/Year
	~		|

gov rev cap redistributed=
	sum(income cap redistribution hhs rq[regions!,quintiles!]*num hhs rq delayed[regions
!,quintiles!])
	~	Euro/Year
	~		|

gov rev cap to GDP=
	gov rev cap/GDP nom
	~	1
	~		~	:SUPPLEMENTARY 
	|

gov revenue tls=
	tls carbon costs paid to domestic government+tls paid wo carbon cost
	-total miscaulated ETS costs
	~	Euro/Year
	~		|

gov sector profits=
	sum(post tax profits i effective[govsec!])
	~	Euro/Year
	~		|

gov share i[ind]=
	gov c real i[ind]*(1-share imp gov i[ind])/y real i[ind]
	~	Dmnl
	~	Share of output that is covered by government final consumption.
		For public sector, healthcare and education it also represents the share \
		of output that is produced by the government to provide market services \
		for free. The rest is what is produced privately, or by the government for \
		market output or for services produced at non-economically significant \
		prices.
	|

gov share wage WTR=
	0.5
	~	Dmnl
	~	share (%) of the wage increase covered by the government.
	|

gov shocks=
	gov shocks history(Time)
	~	
	~		|

gov shocks history=
	GET XLS LOOKUPS('?main', 'covid' , 'time2' , 'gov_shocks' )
	~	
	~		|

gov wages frac[ind] :EXCEPT: [public],[education],[health]=
	0 ~~|
gov wages frac[public]=
	1 ~~|
gov wages frac[education]=
	0.62806 ~~|
gov wages frac[health]=
	0.62806
	~	Dmnl
	~	fraction of government wages over wages paid in public,edu and health
	|

government consumption=
	transfers in kind+non market production
	~	Euro/Year
	~		|

government consumption real total=
	sum(gov c real i[ind!])
	~	Euro constant/Year
	~		|

government consumption row=
	sum(gov c dom nom i[ind!])
	+sum(gov c imp nom i[ind!])
	
	-sum(gov c nom i[ind!])
	~	Euro/Year
	~		|

government current=
	soc sec rev+inc tax rev+fin tax rev+corp tax rev effective+gov revenue tls
	+government gross profits
	
	-sum(gov c nom i[ind!])
	-gov interest
	-I gov
	-tls from gov c nom
	-transfers exp
	-pnrr gov spend
	-substitution spending government
	
	+ change in bonds
	~	Euro/Year
	~		|

government gross profits=
	sum(government profits govsec[govsec!])
	~	Euro/Year
	~		|

government gross profits govsec[govsec]=
	depreciation K i[govsec]*price capital pp i[govsec]*fraction government profits investment capital
[govsec]
	~	Euro/Year
	~		|

government output=
	market output gov+non market production
	~	Euro/Year
	~		|

government output govsec[govsec]=
	gov c nom i[govsec]+market output govsec gov[govsec]
	~	Euro/Year
	~		|

government output share govsec[govsec]=
	government output govsec[govsec]/y nom i[govsec]
	~	Dmnl
	~		|

government profit share govsec[govsec] :EXCEPT:   [public]=
	government gross profits govsec[govsec]/post tax profits i effective[govsec] ~~|
government profit share govsec[public]=
	1
	~	Dmnl
	~		|

government profits govsec[govsec]=
	government profit share govsec[govsec]*post tax profits i effective[govsec]
	~	Euro/Year
	~		|

government sectors output costs=
	consumption of fixed capital gov+intermediated consumption gov+labour costs gov
	~	Euro/Year
	~		|

govsec:
	education,public,health
	~	
	~		|

GPB exp=
	sum(GPB gs[gender!,skill!])
	~	Euro/Year
	~	sum(GPB rq[regions!,quintiles!])
	|

GPB exp real=
	GPB exp/CPI
	~	Euro constant/Year
	~		|

GPB gs[gender,skill]=
	pension wage ratio gs[gender,skill]*
	average pension relevant past salaries[gender,skill]*CPI*"Skills 65+ gs"[gender
	,skill]
	~	Euro/Year
	~		|

GPB rq[regions,quintiles]=
	GPB gs[female,low]*hhs cat shares rq adj[regions,inc low p f,quintiles]+
	GPB gs[male,low]*hhs cat shares rq adj[regions,inc low p m,quintiles]+
	GPB gs[female,mid]*hhs cat shares rq adj[regions,inc mid p f,quintiles]+
	GPB gs[male,mid]*hhs cat shares rq adj[regions,inc mid p m,quintiles]+
	GPB gs[female,hig]*hhs cat shares rq adj[regions,inc hig p f,quintiles]+
	GPB gs[male,hig]*hhs cat shares rq adj[regions,inc hig p m,quintiles]
	~	Euro/Year
	~		|

GPB to GDP=
	GPB exp/GDP nom
	~	1
	~		~	:SUPPLEMENTARY 
	|

GPB to GDP real=
	GPB exp real/GDP real
	~	1
	~		~	:SUPPLEMENTARY 
	|

grid= INTEG (
	grid investment-grid depreciation,
		initial grid value)
	~	Euro constant
	~		|

grid capacity supply[ind]=
	gfcf shares electricity[ind,e distribution]*grid investment costs
	~	Euro constant/Year
	~		|

grid depreciation=
	grid*grid depreciation rate
	~	Euro constant/Year
	~	Due to the financial nature of this capital stock, we chose geometric \
		depreciation as done in the rest of the model.
	|

grid depreciation rate=
	0.0574046
	~	Dmnl/Year
	~	Depreciation rate for transmission calculated from terna 2010 \
		(https://download.terna.it/terna/0000/0057/16.pdf): Depreciation of \
		property, plant and equipment over the respective assets end of 2009. \
		Subseuquently, we scale this rate of depreciation with the fraction of \
		lifetimes of transmission and distribution line infrastructure from ETRI, \
		2014 to obtain depreciation rates for the distribution grid. Overall \
		depreciation rates are a weighted average of these two rates. As weights \
		we use costs share of transmission and distribution network costs from \
		eurostat. Here, we use the weighted average (weighted by 2010 use share of \
		household and non-household electricity use from PEFA) from 19-2021 from \
		Eurostat.
	|

grid investment=
	(RES transition*grid investment PNIEC
	+(1-RES transition)*desired investment no transition)
	*financial constraint factor electricity
	~	Euro constant/Year
	~		|

grid investment costs=
	grid investment
	~	Euro constant/Year
	~		|

grid investment PNIEC=
	average yearly grid investment*modelled generation to PNIEC
	~	Euro constant/Year
	~		|

grid lifetime=
	50.8881
	~	Year
	~	Average lifetime of grid, we use a weighted average of distribution and \
		transimission line lifeteims from ETRI, 2014. As weights we use costs \
		share of transmission and distribution network costs from eurostat. Here, \
		we use the weighted average (weighted by 2010 use share of household and \
		non-household electricity use from PEFA) from 19-2021 from Eurostat.
	~	:SUPPLEMENTARY 
	|

grid over electricity production share=
	(grid/initial grid value)  / (total electricity production/total electricity production intitial
) * grid share electricity production initial
	~	Dmnl
	~	grid share of electricity production, i.e. grid output/electricity production \
		output, all monetary. We assume that grid output increases proportional to \
		the grid capital:
		output grid monetary =grid/initial grid * initial output grid monetary
		output elec production monetary= physical production/initial physical production * \
		initial monetary output
		-> grid/elec production = (grid/initial grid)  / (physical \
		procution/initial physical production) * initial grid/production share \
		monetary
	|

grid production share dynamic switch=
	0
	~	Dmnl
	~	1 the grid production share (We assume that grid output increases proportional to \
		the grid capital). 
		0 the grid production share stays at its initial value.
	|

grid share electricity production initial=
	1.68952
	~	Dmnl
	~	The initial share of grid in the electricity sector, i.e. grid output/electricity \
		production output, all monetary.
		Source: Locomotion
	|

grid share electricity sector=
	grid production share dynamic switch*
	(
	1/
	((1/grid over electricity production share)+1))
	
	+(1-grid production share dynamic switch)*
	(
	1/
	((1/grid share electricity production initial)+1))
	~	Dmnl
	~	Grid share of total D1 sector, i.e. grid/(grid+elec production)
		-> grid/(grid+elec production)=1 / ((elec production/grid)+1)
	|

gross annual income e=
	sum(gross annual income e i[ind!]*L actual i[ind!])/sum(L actual i[ind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

gross annual income e gis[gender,ind,skill]=
	wage gis[gender,ind,skill]*actual hours i[ind]
	~	Euro/Person/Year
	~	individual gross annual income employed
	|

gross annual income e gs[gender, skill]=
	sum(gross annual income e gis[gender,ind!,skill]*L gis[gender,ind!,skill])/sum(L gis
	[gender,ind!,skill])
	~	Euro/(Person*Year)
	~		~	:SUPPLEMENTARY 
	|

gross annual income e i[ind]=
	sum(gross annual income e is[ind,skill!]*L is[ind,skill!])/sum(L is
	[ind,skill!])
	~	Euro/(Person*Year)
	~		|

gross annual income e is[ind, skill]=
	sum(gross annual income e gis[gender!,ind,skill]*L gis[gender!,ind,skill])/sum(L gis
[gender!,ind,skill])
	~	Euro/(Person*Year)
	~		|

gross annual income e mi[macroind]=
	sum(gross annual income e i[ind!]*L actual i[ind!]*ind to macroind map[ind!,macroind
])/
	sum(ind to macroind map[ind!,macroind]*L actual i[ind!])
	~	Euro/(Person*Year)
	~		~	:SUPPLEMENTARY 
	|

gross annual income e s[skill]=
	sum(gross annual income e is[ind!,skill]*L is[ind!,skill])/sum(L is
	[ind!,skill])
	~	Euro/(Person*Year)
	~		~	:SUPPLEMENTARY 
	|

gross annual income e s mi[macroind, skill]=
	sum(gross annual income e is[ind!,skill]*L is[ind!,skill]*ind to macroind map
	[ind!,macroind])/
	sum(L is[ind!,skill]*ind to macroind map[ind!,macroind])
	~	Euro/(Person*Year)
	~		~	:SUPPLEMENTARY 
	|

gross annual income p gs[gender,skill]=
	ZIDZ(GPB gs[gender,skill],"Skills 65+ gs"[gender,skill])
