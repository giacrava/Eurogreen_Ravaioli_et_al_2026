	,
	L gis[male,ind,skill]/sum(L gis[gender!,ind,skill])-male share is[ind,skill],
	
	+IF THEN ELSE(
	male share is[ind,skill]+(sens male share unemp s*(max(u gs[male,skill],0)-max
	(u gs[female,skill],0))
	+late convergence*male share trend is[ind,skill])
	/shares adjustment time>max male share 
	:OR:
	male share is[ind,skill]+(sens male share unemp s*(max(u gs[male,skill],0)-max
	(u gs[female,skill],0))
	+late convergence*male share trend is[ind,skill])
	/shares adjustment time<min male share,
	
	0,
	 
	(sens male share unemp s*(max(u gs[male,skill],0)-max(u gs[female,skill],0))
	+late convergence*male share trend is[ind,skill])
	))
	/shares adjustment time
