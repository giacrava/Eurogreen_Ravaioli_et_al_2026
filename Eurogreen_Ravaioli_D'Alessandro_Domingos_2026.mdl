p adjustment alt[ind]=
	(target p[ind]-p i[ind])/p adjustment time alt
	~	
	~		|

p adjustment time alt=
	1
	~	Year
	~		|

p ETS=
	IF THEN ELSE(Act carbon tax = 0, pETS forecast(Time), 
	IF THEN ELSE(Time <S Time Policy start, pETS forecast(Time), 
	carbon tax rate))
	~	Euro/tCO2eq
	~		|

p i[ind]= INTEG (
	p adjustment alt[ind],
		p init i alt)
	~	Euro/Euro constant
	~	price of NACE industry
		
		previous forula 05/04/23
		(1+Delta UCC i[ind])*max(((euro 1+markup i[ind])*(1+vat rate[ind])*UFC \
		delay i[ind])/p init i[ind],p i delay[ind])
	|

p i delay[ind]= DELAY FIXED (
	p i[ind], Year 1 , 1)
	~	Euro/Good
	~		|

p imp i[ind] :EXCEPT: [exogenous price]=
	p i[ind] ~~|
p imp i[exogenous price]=
	IF THEN ELSE(Time=0,p imp i initial[exogenous price],p imp i delay[exogenous price]*
(1+inflation imp i[exogenous price])
	)
	~	Euro/Euro constant
	~	Price of imports. exogenous to the (domestic) price model.
	|

p imp i delay[ind]=
	DELAY FIXED(p imp i[ind],1,p imp i initial[ind])
	~	
	~		|

p imp i initial[ind]=
	1
	~	
	~		|

p imp shock 21[ind] :EXCEPT:  [mining],[electricity ind]=
	0 ~~|
p imp shock 21[mining]=
	0.285973 ~~|
p imp shock 21[electricity ind]=
	0.26776
	~	
	~		|

p imp shock 22[ind] :EXCEPT:   [mining],[electricity ind]=
	0 ~~|
p imp shock 22[mining]=
	0.40183 ~~|
p imp shock 22[electricity ind]=
	0.35704
	~	
	~		|

p imp shock 23[ind] :EXCEPT:    [mining],[electricity ind]=
	0 ~~|
p imp shock 23[mining]=
	-0.423193 ~~|
p imp shock 23[electricity ind]=
	-0.368449
	~	
	~		|

p init i alt=
	1
	~	Euro/Euro constant
	~		|

p2g investment costs init=
	INITIAL(p2g investment costs per unit capacity)
	~	Euro constant/GW
	~		|

p2g investment costs per unit capacity=
	(2.02e+36*EXP(-0.0379*(Time+initial year)))*1e+06
	~	Euro constant/GW
	~	base on Thema et al., 2019 for PEM electrolysers
	|

paid cc=
	sum(paid embedded ucc bp[ind!]*final demand real i[ind!])
	~	Euro/Year
	~		|

paid embedded ucc bp[toind]=
	sum(Leontief ii[ind!,toind]*UCC i[ind!])
	~	Euro/Euro constant
	~	Only domestic as used to calculate domestic government revenue
	|

paid embedded ucc bp nom[ind]=
	paid embedded ucc bp[ind]/p i[ind]
	~	Dmnl
	~		|

paid embedded ucc pp[ind]=
	(paid embedded ucc bp nom[ind]*(1-imp share hhs ESc i[ind])+
	ttm[ind]*sum(ttm shares[ind!]*(1-imp share hhs ESc i[ind!])*paid embedded ucc bp nom
	[ind!
	])
	)/(1+ttm[ind])
	~	Dmnl
	~		|

Palma ratio=
	smooth(ZIDZ( income SHARE top 10, income SHARE lowest 40),2)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

Palma ratio region[regions]=
	yd rq[regions,q5]/(yd rq[regions,q1]+yd rq[regions,q2])
	~	Dmnl
	~		|

Palma ratio region delay[regions]=
	DELAY FIXED(Palma ratio region[regions], 1 , Palma ratio region initial[regions] )
	~	Dmnl
	~		|

Palma ratio region initial[regions]=
	(num hhs rq init[regions,q5]*init yd hhs rq[regions,q5])/
	(num hhs rq init[regions,q1]*init yd hhs rq[regions,q1]+
	num hhs rq init[regions,q2]*init yd hhs rq[regions,q2])
	~	Dmnl
	~		|

parameter of hydrogen provisioning share=
	(hydrogen provision share of D2-hydrogen provision share of D2 delayed)/(1-hydrogen provision share of D2 delayed
)
	~	Dmnl
	~	exponential decay as for electrification
	|

partial net investment adjustment[ind]=
	max(0,desired net investment[ind]/desired investment adjustment time[ind]+depreciation K i
[ind])
	~	Euro constant/Year
	~		|

pctg change in poverty gap after hh taxes=
	relative poverty gap/relative poverty gap pre hh tax - 1
	~	
	~		~	:SUPPLEMENTARY 
	|

pctg change in poverty line after hh taxes=
	relative poverty rate/relative poverty rate pre hh tax - 1
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

pension entry age=
	65
	~	Year
	~		|

pension wage ratio=
	S1 pension wage ratio*IF THEN ELSE(Time<S Time Policy start,
	                1,
	                1+min(S Time end-S Time Policy start,Time-S Time Policy start)*(S pension ratio
/(S Time end-S Time Policy start))
	                )
	~	percentage
	~	pension's fraction of wages
	~	:SUPPLEMENTARY 
	|

pension wage ratio gs[gender, skill]=
	init pension wage ratio gs[gender,skill]*(1 - (pension wage ratio reduction rate/40)
*Time)
	~	Dmnl
	~		|

pension wage ratio reduction rate=
	0.239709
	~	
	~	Computed from the 2022 report "Mid-long term trends for the pension and \
		health care systems" by the Italian Ministry of Economy and Finance. It is \
		the percentage reduction in Gross Replacement Rates between 2010-2050 in \
		the base case, weighted average of the replacement rates for private \
		employees and the self-employed, with weights given by their shares in \
		total employment in 2010 from Eurostat.
	|

pension wage ratio yearly reduction[regions,quintiles]=
	S1 pension wage ratios rq[regions,quintiles]*pension wage ratio reduction rate/40
	~	
	~		|

pension wage ratios rq[regions,quintiles]=
	S1 pension wage ratios rq[regions,quintiles]-pension wage ratio yearly reduction[regions
,quintiles]*Time
	~	
	~	*IF THEN ELSE(Time<S Time Policy start,
		                1,
		                1+min(S Time end-S Time Policy start,Time-S Time Policy start)*(S \
		pension ratio
		/(S Time end-S Time Policy start))
		                )
	~	:SUPPLEMENTARY 
	|

People 1=
	1
	~	People
	~		|

per capita direct and embedded emissions C rq[regions, quintiles]=
	direct and embedded emissions C rq[regions,quintiles]/pop rq[regions,quintiles]
	~	tCO2eq/(Year*Person)
	~		|

per capita direct and embedded EREU C rq[regions,quintiles]=
	direct and embedded EREU C rq[regions,quintiles]/pop rq[regions,quintiles]
	~	TJ/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

per capita excess of direct and embedded emissions rq[regions,quintiles]=
	max(per capita direct and embedded emissions C rq[regions,quintiles]-active threshold progressive CT
	,0)
	~	
	~		~	:SUPPLEMENTARY 
	|

per capita GDP real=
	GDP real/population total*People 1
	~	Euro constant
	~		~	:SUPPLEMENTARY 
	|

per capita pub exp on access growth=
	0.02
	~	
	~		|

per output emission use Z i[ind]=
