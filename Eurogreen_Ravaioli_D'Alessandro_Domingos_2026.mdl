NFI d[inc low e m]=	NFI per capita gs[male,low] ~~|
NFI d[inc mid e f]=	NFI per capita gs[female,mid] ~~|
NFI d[inc mid e m]=	NFI per capita gs[male,mid] ~~|
NFI d[inc hig e f]=	NFI per capita gs[female,hig] ~~|
NFI d[inc hig e m]=	NFI per capita gs[male,hig] ~~|
NFI d[inc low o f]=	NFI per capita gs[female,low] ~~|
NFI d[inc low o m]=	NFI per capita gs[male,low] ~~|
NFI d[inc mid o f]=	NFI per capita gs[female,mid] ~~|
NFI d[inc mid o m]=	NFI per capita gs[male,mid] ~~|
NFI d[inc hig o f]=	NFI per capita gs[female,hig] ~~|
NFI d[inc hig o m]=	NFI per capita gs[male,hig] ~~|
NFI d[inc low p f]=	NFI per capita gs[female,low] ~~|
NFI d[inc low p m]=	NFI per capita gs[male,low] ~~|
NFI d[inc mid p f]=	NFI per capita gs[female,mid] ~~|
NFI d[inc mid p m]=	NFI per capita gs[male,mid] ~~|
NFI d[inc hig p f]=	NFI per capita gs[female,hig] ~~|
NFI d[inc hig p m]=	NFI per capita gs[male,hig] ~~|
NFI d[inc cap]=	NFI per capita cap
	~	
	~		|

NFI d total=
	sum(NFI d[inc cat!]*pop d[inc cat!])
	~	
	~		|

NFI per capita cap=
	ZIDZ(net fin inc cap,pop cap)
	~	Euro/(Year*Person)
	~	Net financial income per capita of the capitalists
	|

NFI per capita gs[gender,skill]=
	ZIDZ(net fin inc gs[gender,skill],adult population gs[gender,skill])
	~	Euro/(Year*Person)
