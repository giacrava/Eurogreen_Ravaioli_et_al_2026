	~	Dmnl
	~		|

ygross share ordered gini[gini order]=
	VECTOR REORDER(ygross share[inc cat], ygross order[inc cat])
	~	Dmnl
	~		|

Z cell import share trend[ind,toind]=
	GET XLS CONSTANTS('?main', 'technology', 'trend_impsh_Z')
	~	Dmnl/Year
	~	Geometric mean of growth rates of import shares, for the period 2000-2014 \
		(excluding 2008-2010), computed from input-output data. Sectors D1, D2 and \
		D3 take the same value of sector D in input-output tables.
	|

Z cell import share trend capped[ind,toind]=
	max(min(Z cell import share trend[ind,toind],trend cap),-trend cap)
	~	Dmnl/Year
	~		|

z demand i[toind]=
	sum(Z nom ii[ind!,toind])+Z imp nom i[toind]
	~	Euro/Year
	~	intermediate demand by industry including imports, nominal
	|

Z domestic production main producer=
	sum(E Z nrgii[elec,electricity ind,ind!])
	~	TJ/Year
	~		|

Z imp nom i[toind]=
	sum(p imp i delay[ind!]*Z imp real ii[ind!,toind])
	~	Euro/Year
	~		|

Z imp real from i[ind]=
	sum(Z imp real ii[ind,toind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

Z imp real i[ind]=
	sum(Z imp real ii[ind,toind!])
	~	
	~	Sum of import inputs per unit of output of each toind, at prices of the first period \
		(price equal to one).
		Needed for computing real GDP.
	|

Z imp real ii[ind,toind]=
	share imp Z ESc ii[ind,toind] * Z real ii[ind,toind]
	~	Euro constant/Year
	~		|

Z imp real tot=
	sum(Z imp real ii[ind!,toind!])
	~	Euro constant/Year
	~		|

Z nom ii[ind,toind]=
	Z real ii[ind,toind]*p i[ind]
	~	Euro/Year
	~	Interindustry trade matrix, nominal
	|

Z nom initial ii[ind,toind]=
	GET XLS CONSTANTS('?main', 'inputoutput', 'znominit')
	~	Euro
	~		|

Z real i[toind]=
	sum(Z real ii[ind!,toind])
	~	
	~		~	:SUPPLEMENTARY 
	|

Z real ii[ind,toind]=
	a ii[ind,toind]*y real i[toind]
	~	Euro constant/Year
	~	Interindustry trade matrix, real
		
		Before: exception for [ind,finance]
		IF THEN ELSE(Financial income switch=0,
		            a ii[ind,finance]*y real i[finance],
		            sum(ZIDZ(Financial industry revenue i[ind!],CPI))
		            )
	|

Z real ind[ind]=
	sum(Z real ii[ind,toind!])
	~	
	~	production of each industry used for intermediate demand
	|

Z T demand iv[toind,techn]=
	sum(z T nom total iiv[ind!,toind,techn])
	~	Euro/Year
	~		|

z T nom imp iiv[ind,toind,techn]=
	z T real imp iiv[ind,toind,techn]*p imp i delay[ind]
	~	Euro/Year
	~		|

z T nom total iiv[ind,toind,techn]=
	z T nom imp iiv[ind,toind,techn]+z T real iiv[ind,toind,techn]*p i[ind]
	~	Euro/Year
	~		|

z T real iiv[ind,toind,techn]=
	a T iiv[ind,toind,techn]*output expected[toind]
	~	Euro constant/Year
	~		|

z T real imp iiv[ind,toind,techn]=
	share imp Z ESc ii[ind,toind]*factor imp shareee T current[ind,toind,techn] * z T real iiv
[ind,toind,techn]
	~	Euro constant/Year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 40
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Year [0,?]
	~	The time step for the simulation.
	|

********************************************************
	.male,ind,skill
********************************************************~
	|

