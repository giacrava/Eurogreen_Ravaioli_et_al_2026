max wage level=
	max wage level init*max(cumulative inflation since policy start,1)
	~	
	~		|

max wage level init=
	40
	~	Euro/(Hours*Person)
	~		|

max y constrained[ind] :EXCEPT:     [households]=
	min(y FC i[ind],y FE i[ind]) ~~|
max y constrained[households]=
	y FE i[households]
	~	Dmnl
	~	min(y FC i[ind],y FE i[ind])
	|

max yd hhs rq=
	VMAX(yd hhs pre hh tax rq[regions!,quintiles!])
	~	Euro/(Year*Household)
	~		|

max yf hhs rq time policy start=SAMPLE IF TRUE(
	Time = S Time Policy start, max yd hhs rq, 0)
	~	Euro/(Year*Household)
	~		|

maximum capital productivity growth=
	0.05
	~	Dmnl
	~		|

Maximum Wage Value=
	IF THEN ELSE(Time <S Time Policy start,0 ,Act maximum wage * max wage level)
	~	Euro/(Hours*Person)
	~		|

mean delta a neg[ind,toind]=
	GET XLS CONSTANTS('?main', 'technology', 'u_mean_neg_norm')
	~	Dmnl
	~		|

mean delta a pos[ind,toind]=
	GET XLS CONSTANTS('?main', 'technology', 'u_mean_pos_norm')
	~	Dmnl
	~		|

mean delta lambda neg[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'lp_norm_neg_mean')
	~	Dmnl
	~	Mean of the percentage change of chain linked labour productivity scaled \
		by investment and capital, for the period 2000-2019 (excluding 2008 and \
		2009),computed from EU KLEMS data. Note that  Sectors D1, D2 and D3 take \
		the same value of sector D and that values for sector T are not scaled by \
		investment and capital.
	|

mean delta lambda pos[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'lp_norm_pos_mean')
	~	Dmnl
	~	Mean of the percentage change of chain linked labour productivity scaled \
		by investment and capital, for the period 2000-2019 (excluding 2008 and \
		2009),computed from EU KLEMS data. Note that  Sectors D1, D2 and D3 take \
		the same value of sector D and that values for sector T are not scaled by \
		investment and capital.
	|

mean g lambda pre electricity noncareserv=
	ZIDZ(sum(g lambda pre electricity i[noncareserv!]*tot hours i delay[noncareserv!]),sum
(tot hours i delay
	[noncareserv!]))
	~	Dmnl
	~		|

mean g wage gs[gender, skill]=
	(sum(g wage gis[gender,ind!,skill]*actual hours i[ind!]*L gis[gender
	,ind!,skill]))/
	(sum(actual hours i[ind!]*L gis[gender,ind!,skill]))
	~	Dmnl
	~		|

mean g wage noncareserv gs[gender, skill]=
	(sum(g wage gis[gender,noncareserv!,skill]*actual hours i[noncareserv!]*L gis[gender
,noncareserv!,skill]))/
	(sum(actual hours i[noncareserv!]*L gis[gender,noncareserv!,skill]))
	~	Dmnl
	~		|

mean wage g[gender]=
	(sum(wage gis[gender,ind!,skill!]*actual hours i[ind!]*L gis[gender,ind!,skill!]))/
	(sum(actual hours i[ind!]*L gis[gender,ind!,skill!]))
	~	Euro/(Hours*Person)
	~		|

mean wage gs[gender,skill]=
	(sum(wage gis[gender,ind!,skill]*actual hours i[ind!]*L gis[gender,ind!,skill]))/
	(sum(actual hours i[ind!]*L gis[gender,ind!,skill]))
	~	Euro/(Hours*Person)
	~		|

mean wage s[skill]=
	(sum(wage gis[gender!,ind!,skill]*actual hours i[ind!]*L gis[gender!,ind!,skill]))/
	(sum(actual hours i[ind!]*L gis[gender!,ind!,skill]))
	~	Euro/(Hours*Person)
	~		|

mean yd d real=
	sum(yd d real[inc cat!]*pop share d[inc cat!])
	~	Euro constant/(Year*Person)
	~		|

mean yd hhs real=
	sum(yd hhs rq real[regions!,quintiles!]*num hhs delayed shares rq[regions!,quintiles
!])
	~	Euro constant/(Year*Household)
	~	Real disposable household income per household, national average.
	|

mean yd r real per capita[regions]=
	sum((yd hhs rq[regions,quintiles!]/CPI rq[regions,quintiles!])
	*num hhs rq delayed[regions,quintiles!])/sum(pop rq[regions,quintiles!])
	~	Euro constant/(Year*Person)
	~	Real disposable household income per person, regional average.
	|

mean yd real per capita=
	sum(yd hhs rq[regions!,quintiles!]*num hhs rq delayed[regions!,quintiles!]/CPI rq[regions
!,quintiles!])/sum(pop rq[regions!,quintiles!])
	~	Euro constant/(Year*Person)
	~	Real disposable household income per person, national average.
	|

median delta a ii[ind,toind]=
	GET XLS CONSTANTS('?main', 'technology', 'u_norm_all_median')
	~	Dmnl
	~		|

median delta lambda[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'lp_norm_all_median')
	~	Dmnl
	~		|

median g ee[ind]=
	GET XLS CONSTANTS('?main', 'technology', 'eneff_norm_median')
	~	Dmnl
	~		|

mid skill transformation adjustment[gender,skill]=
	IF THEN ELSE(labour scarcity[skill]=VMAX(labour scarcity[skill!]),
	
	sum(increase skill transition[skill!]),
	
	-mid skill transformation JG[gender,skill]*decrease skill transition shares[skill]*
	
	ZIDZ(sum(increase skill transition[skill!]),sum(mid skill transformation JG[gender,skill
!]*decrease skill transition shares[skill!]))
	
	)
	/skill transformation JG adjustment time
	~	Dmnl/Year
	~		|

mid skill transformation JG[gender,skill]= INTEG (
	mid skill transformation adjustment[gender,skill],
		mid skill transformation JG init[gender,skill])
	~	Dmnl
	~		|

mid skill transformation JG init[gender,low]=
	0 ~~|
mid skill transformation JG init[gender, mid]=
	0.5 ~~|
mid skill transformation JG init[gender,hig]=
	0.5
	~	Dmnl
	~		|

middle 40 direct emissions C intensity=
	sum(direct emissions hh rq[regions!,quintiles!]*middle 40 rq[regions!,quintiles!])/
	sum(c hhs ESc nom bp rqi desired[regions!,quintiles!,ind!]*num hhs rq delayed[regions
!,quintiles!]*middle 40 rq[regions
	!,quintiles!])
	~	tCO2eq/Euro
	~		~	:SUPPLEMENTARY 
	|

middle 40 direct emissions per capita=
	sum(direct emissions hh rq[regions!,quintiles!]*middle 40 rq[regions!,quintiles!])/
	sum(pop rq[regions!,quintiles!]*middle 40 rq[regions!,quintiles!])
	~	tCO2eq/(Year*Person)
	~		~	:SUPPLEMENTARY 
	|

middle 40 direct emissions share=
	sum(direct emissions hh rq[regions!,quintiles!]*middle 40 rq[regions!,quintiles!])/
	sum(direct and embedded emissions C rq[regions!,quintiles!]*middle 40 rq[regions!,quintiles
!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

middle 40 rq[regions,quintiles]=
	IF THEN ELSE(deciles rq[regions,quintiles]>=6 :AND: deciles rq[regions,quintiles]<=9
, 1 , 0 )
	~	Dmnl
	~		|

middle 40 share in C direct emissions=
	sum(direct emissions hh rq[regions!,quintiles!]*middle 40 rq[regions!,quintiles!])/
	sum(direct emissions hh rq[regions!,quintiles!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

