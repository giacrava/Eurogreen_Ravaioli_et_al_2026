	sum(y nom i[ind!])
	-sum(z demand i[ind!])
	
	
	-sum(GWB i[ind!])
	-sum(soc sec contr employer gis[gender!,ind!,skill!]*L gis[gender!,ind!,
	skill!])
	
	-sum(interest payment i[ind!])
	-sum(corp tax i effective[ind!])
	
	-sum(profit transfers capital[ind!])
	-profit transfers household
	-government gross profits
	
	+sum(ets profits impact[ind!])
	~	Euro/Year
	~		|

fiscal rule growth gov c=
	0.03
	~	Dmnl/Year
	~		~	:SUPPLEMENTARY 
