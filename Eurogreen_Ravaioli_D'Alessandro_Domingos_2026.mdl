inc tax e gis[gender,ind,skill]=
	(1-Tax evasion rate e)*
	(inc tax rate 2* min(tax floor 3-tax floor 2, 
	                      max(taxable inc e gis[gender,ind,skill]-tax floor 2, 0)) +
	inc tax rate 3* min(tax floor 4-tax floor 3, 
	                     max(taxable inc e gis[gender,ind,skill]-tax floor 3, 0)) +
	inc tax rate 4* min(tax floor 5-tax floor 4, 
	                     max(taxable inc e gis[gender,ind,skill]-tax floor 4, 0)) +
	inc tax rate 5* min(tax floor 6-tax floor 5, 
	                     max(taxable inc e gis[gender,ind,skill]-tax floor 5, 0)) +
	inc tax rate 6*max(taxable inc e gis[gender,ind,skill]-tax floor 6,0))
	~	Euro/Person/Year
	~	individual income tax paid by each group
	|

inc tax p=
	sum(inc tax p gs[gender!,skill!]*"Skills 65+ gs"[gender!,skill!])
	~	
	~		~	:SUPPLEMENTARY 
	|

inc tax p gs[gender,skill]=
	inc tax rate 2* min(tax floor 3-tax floor 2, 
	                      max(gross annual income p gs[gender,skill]-tax floor 2, 0)) +
	inc tax rate 3* min(tax floor 4-tax floor 3, 
	                     max(gross annual income p gs[gender,skill]-tax floor 3, 0)) +
	inc tax rate 4* min(tax floor 5-tax floor 4, 
	                     max(gross annual income p gs[gender,skill]-tax floor 4, 0)) +
	inc tax rate 5* min(tax floor 6-tax floor 5, 
	                     max(gross annual income p gs[gender,skill]-tax floor 5, 0)) +
	inc tax rate 6*max(gross annual income p gs[gender,skill]-tax floor 6,0)
	~	Euro/Person/Year
	~	Per capita taxes payed by the unemployed recipients of unemployment \
		benefits
	|

inc tax rate 2=
	IF THEN ELSE(Act progressive Inc Tax=1:AND:Time>=S Time Policy start,prog inc tax 2,
S1 inc tax rate 2)
	~	Dmnl
	~		|

inc tax rate 3=
	IF THEN ELSE             (Act progressive Inc Tax=1:AND:Time>=S Time Policy start,prog inc tax 3
,S1 inc tax rate 3)
	~	Dmnl
	~		|

inc tax rate 4=
	IF THEN ELSE             (Act progressive Inc Tax=1:AND:Time>=S Time Policy start,prog inc tax 4
,S1 inc tax rate 4)
	~	Dmnl
	~		|

inc tax rate 5=
	IF THEN ELSE             (Act progressive Inc Tax=1:AND:Time>=S Time Policy start,prog inc tax 5
,S1 inc tax rate 5)
	~	Dmnl
	~		|

inc tax rate 6=
	IF THEN ELSE             (Act progressive Inc Tax=1:AND:Time>=S Time Policy start,prog inc tax 6
,S1 inc tax rate 6)
	~	Dmnl
	~		|

inc tax rev=
	sum(inc tax e gis[gender!,ind!,skill!]*L gis[gender!,ind!,skill!])
	+sum(inc tax u gs[gender!,skill!]*ub recipients[gender!,skill!])
	+sum(inc tax p gs[gender!,skill!]*"Skills 65+ gs"[gender!,skill!])
	~	Euro/Year
	~	government revenue from income tax
		
		+sum(inc tax p rq[regions!,quintiles!]*N p rq[regions!,quintiles!])
	|

inc tax u=
	sum(inc tax u gs[gender!,skill!]*ub recipients[gender!,skill!])
	~	Euro/Year
	~	Total taxes paid by unemployed recipients of unemployment benefits
	|

inc tax u gs[gender,skill]=
	inc tax rate 2* min(tax floor 3-tax floor 2, 
	                      max(taxable inc u gs[gender,skill]-tax floor 2, 0)) +
	inc tax rate 3* min(tax floor 4-tax floor 3, 
	                     max(taxable inc u gs[gender,skill]-tax floor 3, 0)) +
	inc tax rate 4* min(tax floor 5-tax floor 4, 
	                     max(taxable inc u gs[gender,skill]-tax floor 4, 0)) +
	inc tax rate 5* min(tax floor 6-tax floor 5, 
	                     max(taxable inc u gs[gender,skill]-tax floor 5, 0)) +
	inc tax rate 6*max(taxable inc u gs[gender,skill]-tax floor 6,0)
	~	Euro/Person/Year
	~	Per capita taxes payed by the unemployed recipients of unemployment \
		benefits
	|

income cap redistribution hhs rq[regions,quintiles]=
	IF THEN ELSE(Act income cap redistribution=1:AND:Time >= S Time Policy start,
	gov rev cap*poverty gap pre hh tax shares rq[regions,quintiles]/num hhs rq delayed[regions
,quintiles
],
	0)
	~	Euro/(Year*Household)
	~		|

income rq inc cat[regions,inc cat,quintiles]=
	pop share rq[regions,inc cat,quintiles]*yd only individual allocated income d[inc cat
]
	~	Euro/(Year*Person)
	~		|

