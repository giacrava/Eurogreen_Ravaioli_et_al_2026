demand:
	consumption,
	investment,
	government,
	export
	~	
	~		|

demand share check[electricity technologies]=
	sum(expected electricity demand technology share[e techn!,electricity technologies])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

depreciation expected[ind] :EXCEPT:  [electricity ind]=
	capital expected[ind]*depreciation rates i[ind] ~~|
depreciation expected[electricity ind]=
	(1-electricity module switch)*capital expected[electricity ind]*depreciation rates i
[electricity ind]+
	electricity module switch*capital expected[electricity ind]*depreciation rate electricity
	~	Euro constant/Year
	~		|

depreciation K=
	sum(depreciation K i[ind!])
	~	Euro constant/Year
	~		|

depreciation K i[ind] :EXCEPT:  [electricity ind]=
	K i[ind]*depreciation rates i[ind] ~~|
depreciation K i[electricity ind]=
	(1-electricity module switch)*K i[electricity ind]*depreciation rates i[electricity ind
]+
	electricity module switch*monetary depreciation
	~	Euro constant/Year
	~		|

depreciation rate electricity=
	monetary depreciation/monetary capital
	~	Dmnl/Year
	~		|

depreciation rates i[ind]=
	S1 depreciation rates i[ind]*IF THEN ELSE(Time<S Time Policy start,
	                Dmnl Year,
	                (1+min(S Time end-S Time Policy start,Time-S Time Policy start)*(S depreciation rates
/(S Time end-S Time Policy start)))
	                /Year 1)
	~	Dmnl/Year
	~		|

des delta gov c and I real=
	sum(des delta gov c and I real i[ind!])
	~	Euro constant/Year
	~		|

des delta gov c and I real i[ind]=
	delta gov c real i[ind]+integr delta I gov real add depr i[ind]+delta I gov real i[ind
]
	~	Euro constant/Year
	~		|

des delta gov c and I real to GDP=
	des delta gov c and I real/GDP real
	~	1
	~	Total desired change in government spending (consumption + investment) as a results \
		of increased public spending (when Act change gov consumption != 0) (does \
		not capture endogenous feedback on investment, especially the change in \
		desired investment after 2035, so it is just an estimation).
		Might differ from actual change in government consumption (gov c real) respect to \
		baseline because:
		1) Consumption might lower due to output constraints
		2) Desired investment is endogenous
		3) Government spends and invest in other sectors
	~	:SUPPLEMENTARY 
	|

des delta gov c nom=
	sum(delta gov c real i[ind!]*p i[ind!])
	~	Euro/Year
	~		|

des delta gov c real=
	sum(delta gov c real i[ind!])
	~	Euro constant/Year
	~		~	:SUPPLEMENTARY 
	|

des delta gov c real to GDP=
	sum(des delta gov c real to GDP i[ind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

des delta gov c real to GDP i[ind]=
	delta gov c real i[ind]/GDP real
	~	
	~		|

des delta I gov real=
	sum(des delta I gov real i[ind!])
	~	Euro constant/Year
	~		|

des delta I gov real i[ind]=
	delta I gov real i[ind]+integr delta I gov real add depr i[ind]
	~	Euro constant/Year
	~		|

des delta I gov real to GDP=
	sum(des delta I gov real to GDP i[ind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

des delta I gov real to GDP i[ind]=
	(delta I gov real i[ind]+integr delta I gov real add depr i[ind])/GDP real
	~	1
	~		|

desired c nom[ind]=
	c ESc pp i[ind]/((1+tls[ind])*(1+ttm[ind]))+
	ttm shares[ind]*sum((c ESc pp i[ind!]*ttm[ind!])/((1+tls[ind!])*(1+ttm[ind!])))
	~	Euro/Year
	~		|

desired c nom dom[ind]=
	desired c nom[ind]*(1-imp share hhs ESc i[ind])
	~	Euro/Year
	~		|

desired capital stock[ind] :EXCEPT:   [households]=
	output expected 2[ind]/(uc normal[ind]*capital productivity dynamic[ind]) ~~|
desired capital stock[households]=
	0
	~	Euro constant
	~		|

desired corporate income tax rate=
	basic corp tax rate+
	desired corporate tax revenue/corporate tax base delayed
	~	Dmnl
	~		|

desired corporate tax revenue=
	(1-fin corp tax fraction)*desired expenses covered by tax increase
	~	Euro/Year
	~		|

desired dom final demand no PNRR[ind]=
	(desired domestic final demand nom i[ind])/p i[ind]
	~	
	~		|

desired domestic final demand nom i[ind]=
	desired c nom dom[ind]+desired exports[ind]+desired gov dom nom i[ind]+desired I supply nom dom
[ind]
	~	Euro/Year
	~		|

desired domestic final demand real i[ind]=
	(desired domestic final demand nom i[ind]+inv pnrr[ind])/p i[ind]
	~	Euro constant/Year
	~		|

desired electricity generation=
	electricity demand+storage loss a
	~	GW*h/Year
	~		|

desired expenses covered by tax increase=
	total additional expenditure+expected income tax revenue shortfall-gov rev cap exp
	~	Euro/Year
	~		|

desired exports[ind]=
	(ex real e ESc i[ind]+ex real non e i[ind]+ESc ex distribution[ind])*p i[ind]
	~	Euro/Year
	~		|

desired financial income tax rate=
	basic financial income tax rate+
	desired financial income tax revenue/financial income tax base delayed
	~	Dmnl
	~		|

desired financial income tax revenue=
	fin corp tax fraction*desired expenses covered by tax increase
	~	Euro/Year
	~		|

desired gov dom nom i[ind]=
	desired gov nom i[ind]*(1-share imp gov i[ind])
	~	Euro/Year
	~		|

desired gov nom i[ind]=
	desired gov real i[ind]*p i[ind]
	~	Euro/Year
	~		|

desired gov real i[ind] :EXCEPT:     [health], [education]=
	IF THEN ELSE(activated eurocrisis gov shocks=1 :OR: activated c19 shocks=1, 
	             gov c real delay i[ind] * (1+gov shocks), 
				max(0,
				      IF THEN ELSE(def gdp delay > gov def spending trigger :AND: (Act deficit rule
	 =1 :OR: (Act deficit rule=2 :AND: Time<S Time Policy start) :AND: deficit rule time switch
=0), 
				                   (1+trend impact gov c delayed[ind])*gov c real delay i[ind] * 
(1-deficit rule impact),
	                                           IF THEN ELSE(Act Change baseline gov consumption
	 =5 :AND: Time > S Time Change baseline gov consumption,
	                                                        gov c real target baseline i
	[ind],
	                                                        (gov c real delay i[ind] - delta gov c real i delay
	[ind])* (1+ trend impact gov c delayed[ind]))
				                   + delta gov c real i[ind]
	)
	)
	) ~~|
desired gov real i[health]=
	IF THEN ELSE(activated eurocrisis gov shocks=1 :OR: activated c19 shocks=1, 
	             gov c real delay i[health] * (1+gov shocks), 
				max(0,
				      IF THEN ELSE(def gdp delay > gov def spending trigger:AND: (Act deficit rule
	 =1 :OR: (Act deficit rule=2 :AND: Time<S Time Policy start):AND: deficit rule time switch
=0), 
				                   (1+trend impact gov c delayed[health])*gov c real delay i[health
] * (1-deficit rule impact),
	                                           IF THEN ELSE((Act Change baseline gov consumption
	 =5 :OR: Act Change baseline gov consumption =6 :OR: Act Change baseline gov consumption
	 =7) :AND: Time >= S Time Change baseline gov consumption,
	                                                        gov c real target baseline i
	[health],
	                                                        (gov c real delay i[health] 
	- delta gov c real i delay[health])* (1+ trend impact gov c delayed[health]))
				                   + delta gov c real i[health]
	)
					)
				) ~~|
desired gov real i[education]=
	IF THEN ELSE(activated eurocrisis gov shocks=1 :OR: activated c19 shocks=1, 
	             gov c real delay i[education] * (1+gov shocks), 
				max(0,
				      IF THEN ELSE(def gdp delay > gov def spending trigger:AND: (Act deficit rule
	 =1 :OR: (Act deficit rule=2 :AND: Time<S Time Policy start):AND: deficit rule time switch
=0), 
				                   (1+trend impact gov c delayed[education])*gov c real delay i[education
] * (1-deficit rule impact),
	                                           IF THEN ELSE((Act Change baseline gov consumption
	 =5 :OR: Act Change baseline gov consumption =6 :OR: Act Change baseline gov consumption
	 =7) :AND: Time >= S Time Change baseline gov consumption,
	                                                        gov c real target baseline i
	[education],
	                                                        (gov c real delay i[education
	] - delta gov c real i delay[education])* (1+ trend impact gov c delayed[education])
)
				                   + delta gov c real i[education]
	)
					)
				)
	~	Euro constant/Year
	~	if def/GDP too high government spending can only fall
		
		IF THEN ELSE (def gdp delay > gov def spending trigger,
		max(0,(1+trend impact gov c delayed[ind])*gov c real delay[ind]),
		max(0,(1+trend impact gov c delayed[ind]+fiscal rule growth gov c)*gov c \
		real delay[ind]))
	|

desired grid investment=
	RES transition*grid investment PNIEC
	+(1-RES transition)*desired investment no transition
	~	Euro constant/Year
	~		|

desired grid no transition=
	initial grid over electricity demand*electricity generation expected[e distribution]
	~	Euro constant
	~	In the absence of a RES transition, we assume that the grid expands \
		proportional to overall expected electricity demand in order to maintain \
		the initial grid to electricity demand ratio.
	|

desired I supply nom[ind]=
	I supply real i desired[ind]*p i[ind]
	~	Euro/Year
	~		|

desired I supply nom dom[ind]=
	(1-share imp GFCF i[ind])*desired I supply nom[ind]
	~	Euro/Year
	~		|

desired investment adjustment time[ind]=
	1
	~	
	~		|

desired investment costs electricity=
	sum(desired investment production capacity[e techn!]*capacity investment costs per unit capacity
	[e techn!]*capital price technology pp[e techn!]/capacity construction time[e techn!
]
	)*Year 1+
	desired grid investment*capital price technology pp[e distribution]+
	sum(desired investment storage[storage technologies!]*storage investment costs per unit capacity
[storage technologies!]
	*capital price technology pp[storage technologies!]/storage construction time[storage technologies
!])*Year 1
	~	Euro/Year
	~		|

desired investment no transition=
	max(0,
	(desired grid no transition-grid)/inv adjustment time
	+grid depreciation)
	~	Euro constant/Year
	~		|

desired investment production capacity[e techn]=
	max(min(capacity investment desired[e techn],scale constraint multiplier*capacity max investment scale
[e techn]),0)
	~	GW/Year
	~		|

desired investment storage[storage technologies]=
	max(min(storage capacity investment desired[storage technologies],scale constraint multiplier
*storage max investment scale
	[storage technologies]),0)
	~	GW/Year
	~		|

desired net investment[ind]=
	desired capital stock[ind]-K i[ind]
	~	Euro constant/Year
	~		|

desired storage=
	electricity demand * current storage share of demand
	~	GW*h/Year
	~		|

dif s cap total=
	adult population g total-adult population s cap total
	~	People
	~		~	:SUPPLEMENTARY 
	|

diff pop total=
	population total-pop rq total
	~	
	~		~	:SUPPLEMENTARY 
	|

difference L supply demand s[skill]=
	labour supply s[skill]-L unconstrained s[skill]
	~	
	~		|

difference wage max wage gis[gender,ind,skill]=
	Maximum Wage Value-wage gis[gender,ind,skill]
	~	Euro/(Hours*Person)
	~		|

difference wage min wage gis[gender,ind,skill]=
	Minimum Wage Value-wage gis[gender,ind,skill]
	~	Euro/(Hours*Person)
	~		|

difference y real and constrained[ind]=
	max y constrained[ind]-y real i[ind]
	~	
	~	This is just a variable to test the effect of labor and capital \
		constraints.
	~	:SUPPLEMENTARY 
	|

direct and embedded emissions C i[ind]=
	sum(direct and embedded emissions C rqi[regions!,quintiles!,ind])
	~	tCO2eq/Year
	~		|

direct and embedded emissions C i after ttm[ind]=
	sum(direct and embedded emissions C rqi after ttm[regions!,quintiles!,ind])
	~	
	~		~	:SUPPLEMENTARY 
	|

direct and embedded emissions C p[coicop]=
	sum(direct and embedded emissions C rqp[regions!,quintiles!,coicop])
	~	tCO2eq/Year
	~		~	:SUPPLEMENTARY 
	|

direct and embedded emissions C rq[regions,quintiles]=
	sum(direct and embedded emissions C rqi[regions,quintiles,ind!])
	~	tCO2eq/Year
	~		|

direct and embedded emissions C rqi[regions,quintiles,ind]=
	direct emissions hh rqi[regions,quintiles,ind]+embedded emissions dom C rqi[regions,
quintiles,ind]+embedded emissions imp c rqi[regions,quintiles,ind]
	~	tCO2eq/Year
	~		|

direct and embedded emissions C rqi after ttm[regions,quintiles,ind]=
	direct emissions hh rqi[regions,quintiles,ind]+
	embedded emissions dom C rqi after ttm[regions,quintiles,ind]+
	embedded emissions imp c rqi after ttm[regions,quintiles,ind]
	~	tCO2eq/Year
	~		|

direct and embedded emissions C rqp[regions,quintiles,coicop]=
	sum(bridge hhs pi[ind!,coicop]*direct and embedded emissions C rqi after ttm[regions
,quintiles,ind!])
	~	tCO2eq/Year
	~		|

direct and embedded emissions hh=
	direct emissions hh consumption+embedded emissions C
	~	tCO2eq/Year
	~		|

direct and embedded emissions intensity hh=
	direct and embedded emissions hh/sum(c ESc real bp i[ind!]+shortfall c nom[ind!]/p i
[ind!])
	~	tCO2eq/Euro constant
	~		~	:SUPPLEMENTARY 
	|

direct and embedded emissions share hh=
	direct and embedded emissions hh/national consumption based emissions
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

direct and embedded EREU C rq[regions,quintiles]=
	sum(direct and embedded EREU C rqi[regions,quintiles,ind!])
	~	TJ/Year
	~		|

direct and embedded EREU C rqi[regions,quintiles,ind]=
	direct EREU hh consumption rqi[regions,quintiles,ind]+embedded EREU dom C rqi[regions
,quintiles,ind]
	~	TJ/Year
	~		|

direct cc check=
	Carbon tax hh tot-
	direct cc hhs paid
	~	Euro/Year
	~		~	:SUPPLEMENTARY 
	|

direct cc hhs paid=
	sum(c ESc pp i[ind!]*direct ucc pp[ind!]/(1+tls[ind!]))
	~	Euro/Year
	~		|

direct emissions hh consumption=
	sum(direct emissions hh consumption i[ind!])
	~	tCO2eq/Year
	~		|

direct emissions hh consumption i[ind]=
	direct emissions per unit hh consumption i[ind]*(c ESc real bp i[ind]+shortfall c nom
[ind]/p i[ind])
	~	tCO2eq/Year
	~		|

direct emissions hh rq[regions,quintiles]=
	sum(direct emissions hh rqi[regions,quintiles,ind!])
	~	tCO2eq/Year
	~		|

direct emissions hh rqi[regions,quintiles,ind]=
	hhs direct emissions hh consumption rqi[regions,quintiles,ind]*num hhs rq delayed[regions
,quintiles]
	~	tCO2eq/Year
	~		|

direct emissions per unit hh consumption i[ind]=
	sum(direct EREU per unit hh consumption inrg[ind,nrg!]*emission factor nrg[nrg!])
	~	tCO2eq/Euro constant
	~		|

direct emissions per unit output final dom i[ind]=
	emissions i[ind]/y real i[ind]
	~	tCO2eq/Euro constant
	~		|

direct emissions per worker i[ind]=
	emissions i[ind]/L actual i[ind]
	~	tCO2eq/(Person*Year)
	~		|

direct EREU hh consumption=
	sum(direct EREU hh consumption i[ind!])
	~	TJ/Year
	~		|

direct EREU hh consumption i[ind]=
	direct EREU per unit hh consumption i[ind]*(c ESc real bp i[ind]+shortfall c nom[ind
]/p i[ind])
	~	TJ/Year
	~		|

direct EREU hh consumption rqi[regions,quintiles,ind]=
	hhs direct EREU hh consumption rqi[regions,quintiles,ind]*num hhs rq delayed[regions
,quintiles]
	~	TJ/Year
	~		|

direct EREU per unit hh consumption i[ind]=
	sum(direct EREU per unit hh consumption inrg[ind,nrg!])
	~	TJ/Euro constant
	~		|

direct EREU per unit hh consumption inrg[ind,nrg]=
	av energy use per unit hh consumption[ind,nrg]*emission use share C nrg[nrg]
	~	TJ/Euro constant
	~		|

direct EREU per unit imported input Z imp iinrg[ind,toind,nrg]= INTEG (
	change direct EREU per unit imported input Z imp iinrg[ind,toind,nrg],
		base direct EREU per unit imported input Z imp iinrg[ind,toind,nrg])
	~	TJ/Euro constant
	~	L imp int nrg ii
	|

direct ucc bp[ind]=
	cc per unit hh consumption i[ind]
	~	Euro/Euro constant
	~		|

direct ucc bp nom[ind]=
	direct ucc bp[ind]/p i[ind]
	~	Dmnl
	~		|

direct ucc bp nom before elec[ind]=
	direcy ucc bp before elec[ind]/p i[ind]
	~	Dmnl
	~		|

direct ucc pp[ind]=
	((direct ucc bp nom[ind]+ttm[ind]*sum(ttm shares[ind!]*direct ucc bp nom[ind!]))
	/(1+ttm[ind]))
	~	Dmnl
	~		|

direct ucc pp before elec[ind]=
	(direct ucc bp nom before elec[ind]+
	ttm[ind]*sum(ttm shares[ind!]*direct ucc bp nom before elec[ind!])
	)/(1+ttm[ind])
	~	Dmnl
	~		|

direcy ucc bp before elec[ind]=
	cc per unit hh consumption before elc i[ind]
	~	Euro/Euro constant
	~		|

discrepancy pop rq[regions,quintiles]=
	sum(pop shares rqd nocap pre adj[regions,inc cat!,quintiles])-sum(pop shares rqd nocap
[regions,inc cat!,quintiles])
	~	
	~		|

Div i[ind]=
	max(0,Profits free nonMI[ind]*Div rate)
	~	Euro/Year
	~	dividents paid
		
		BEFORE:
		max(0,post selfemp capital income profits i[ind]*Div rate)
	|

Div rate=
	IF THEN ELSE(Act Dividend Reduction=1:AND:Time>S Time Policy start,1-percentage dividend reduction
,1)*0.3
	~	Dmnl
	~	fixed proportion of profits after investments distributed as dividends.
		calibrated: 24062021 - public, educ and health set to 0.
		 Div_rate[agri] = 0.0505971
		  Div_rate[mining] = 0.0719105
		  Div_rate[manufacturing] = 0.120411
		  Div_rate[petroleum] = 0.0834146
		  Div_rate[electricity] = 0.032472
		  Div_rate[water] = 0.261991
		  Div_rate[construction] = 0.0103556
		  Div_rate[trade] = 0.0992673
		  Div_rate[transport] = 0.167368
		  Div_rate[hospitality] = 0.191688
		  Div_rate[ict] = 0.245209
		  Div_rate[finance] = 0.199909
		  Div_rate[realestate] = 0.0265526
		  Div_rate[profserv] = 0.187114
		  Div_rate[public] = 0.278666
		  Div_rate[education] = 0.293568
		  Div_rate[health] = 0.0339958
		  Div_rate[entertainment] = 0.236237
		  Div_rate[otherserv] = 0.144203
	|

Dmnl Euro 1=
	1
	~	Dmnl/Euro
	~		|

Dmnl Year=
	1
	~	Dmnl/Year
	~		|

dom electrification switch=
	1
	~	Dmnl
	~	Whether imported energy demand is replaced by imported (=0) or domestic \
		(=1) electricity
	|

domestic only checl=
	total cc-domestic only impact-tls pnrr domestic government+total miscaulated ETS costs
	~	
	~		~	:SUPPLEMENTARY 
	|

domestic only impact=
	hh dom alt+gov paid alt+Inv paid alt+exports cc paid
	~	
	~		|

draw T2 i[ind]=
	IF THEN ELSE(random uniform(0,1,seed)>1-prob T2 i[ind], 1 , 0 )
	~	Dmnl
	~		|

draw T3 i[ind]=
	IF THEN ELSE(random uniform(0,1,seed)>1-prob T3 i[ind], 1 , 0 )
	~	Dmnl
	~		|

draw T4 i[ind]=
	IF THEN ELSE(random uniform(0,1,seed)>1-prob T4 i[ind], 1 , 0 )
	~	Dmnl
	~		|

duration adapt=
	4
	~	Year
	~	31 --> adaptation slow
		4 --> adaptation fast
	|

duration skill transition=
	1
	~	Year
	~		|

e=
	sum(L gis[gender!,ind!,skill!])/sum(Working age population cgs[cohorts!,gender!,skill
!])
	~	percentage [?,1]
	~		~	:SUPPLEMENTARY 
	|

E C imp inrg[ind,nrg]=
	E C source share imp inrg[ind,nrg]*E C total imp i[ind]
	~	TJ/Year
	~		|

E C imp nrg[nrg]=
	sum(E C imp inrg[ind!,nrg])
	~	TJ/Year
	~		|

E C inrg[ind,nrg]=
	E C source share post electrification inrg[ind,nrg]*E C total i[ind]
	~	TJ/Year
	~		|

E C intensity i[ind]=
	GET XLS CONSTANTS('?main', 'energy', 'INT_H*')
	~	TJ/Euro constant
	~		|

E C intensity imp i[ind]=
	GET XLS CONSTANTS('?main', 'energy', 'INT_IMP*')
	~	TJ/Euro constant
	~		|

E C M i[ind]=
	c ESc real bp dom i[ind]*E C M share i[ind]
	~	Euro constant/Year
	~		|

E C M imp i[ind]=
	c ESc real bp imp i[ind]*E C M imp share i[ind]
	~	Euro constant/Year
	~		|

E C M imp share i[ind]=
	ZIDZ(sum(c real imp e ESc i[regions!,quintiles!,ind]),c real imp ESc i[ind])
	~	Dmnl
	~	Energy share of total real imported consumption after electrification per \
		industry in basic prices
	|

E C M share i[ind]=
	ZIDZ(sum(c real dom e ESc i[regions!,quintiles!,ind]),c real dom ESc i[ind])
	~	Dmnl
	~	Energy share of total real domestic consumption after electrification per \
		industry in basic prices
	|

E C M share init i[ind]=
	GET XLS CONSTANTS('?main', 'energy', 'EM_SH_H*')
	~	Dmnl
	~		|

E C M share init imp i[ind]=
	GET XLS CONSTANTS('?main', 'energy', 'EM_SH_IMP*')
	~	Dmnl
	~		|

E C nrg[nrg]=
	sum(E C inrg[ind!,nrg])
	~	TJ/Year
	~		|

E C source share electricity sector[nrg]=
	(sum(E supply before ESc fd dom[regions!,quintiles!,electricity ind,nrg])+change end use elec hhs
[nrg])
	/(sum(E supply before ESc fd dom[regions!,quintiles!,electricity ind,nrg!])+sum(change end use elec hhs
[nrg!]))
	~	Dmnl
	~		|

E C source share imp inrg[ind,nrg]=
	GET XLS CONSTANTS('?main', 'energy', 'SOU_SH_FD_IMP')
	~	Dmnl
	~		|

E C source share inrg[ind,nrg]=
	GET XLS CONSTANTS('?main', 'energy', 'SOU_SH_FD_H')
	~	Dmnl
	~		|

E C source share post electrification inrg[ind,nrg] :EXCEPT:  [electricity ind, nrg]=
	E C source share inrg[ind,nrg] ~~|
E C source share post electrification inrg[electricity ind, nrg]=
	E C source share electricity sector[nrg]
	~	Dmnl
	~		|

E C total i[ind]=
	E C M i[ind]*E C intensity i[ind]
	~	TJ/Year
	~		|

E C total imp i[ind]=
	E C M imp i[ind]*E C intensity imp i[ind]
	~	TJ/Year
	~		|

e delay gs[gender,skill]= DELAY FIXED (
	e gs[gender,skill], Year 1 , e initial gs[gender,skill])
	~	Dmnl
	~		|

e dm delayed check[electricity technologies]= DELAY FIXED (
	electricity demand expected electrification[electricity technologies], expectation horizon technology
[electricity technologies
	], initial electricity demand+1)
	~	Hours*GW/Year
	~		~	:SUPPLEMENTARY 
	|

E end use before ESc[toind,nrg]=
	sum(a e before ESc[nrg,ind!,toind]*end use share Z inrg delay[toind,nrg])
	~	TJ/Euro constant
	~	End use of fossil fuels by industries. This is the energy use that is \
		subject to electrification.
	|

E end use imp before ESc[toind,nrg]=
	sum(a e imp before ESc[nrg,ind!,toind]*end use share Z inrg delay[toind,nrg])
	~	TJ/Euro constant
	~	End use of fossil fuels by industries. This is the energy use that is \
		subject to electrification.
	|

E EX i[ind]=
	sum(E EX inrg[ind,nrg!])
	~	TJ/Year
	~		~	:SUPPLEMENTARY 
	|

E EX inrg[ind,nrg]=
	E EX source share inrg[ind,nrg]*E EX total i[ind]
