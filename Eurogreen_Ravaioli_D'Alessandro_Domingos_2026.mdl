	~		|

associated E Z imp total ii[ind,toind,techn]=
	associated E Z M imp ii[ind,toind,techn]*E Z intensity imp ii[ind,toind]
	~	TJ/Year
	~		|

associated E Z M ii[ind,toind,techn]=
	z T real iiv[ind,toind,techn]*E Z M share ii[ind,toind]*factor M E Z share delayedee T current
[ind,toind,techn]
	~	Euro constant/Year
	~		|

associated E Z M imp ii[ind,toind,techn]=
	z T real imp iiv[ind,toind,techn]*E Z M share imp ii[ind,toind]*factor M E Z share delayed impee T current
[ind,toind,techn]
	~	Euro constant/Year
	~		|

associated E Z nrgii[nrg,ind,toind,techn]=
	associated E Z total ii[ind,toind,techn]*E Z source share[nrg,ind,toind]
	~	TJ/Year
	~		|

associated E Z total ii[ind,toind,techn]=
	associated E Z M ii[ind,toind,techn]*E Z intensity ii[ind,toind]
	~	TJ/Year
	~		|

associated emission costs i T[ind,techn]=
	associated emissions i[ind,techn]*(1-selection ETS i[ind]) * carbon tax rate
	
	+associated emissions i[ind,techn]*selection ETS i[ind] * ets costs per emissions[ind
]
	~	Euro/Year
	~		|

associated emission sosts i T per unit output[ind,techn]=
	associated emission costs i T[ind,techn]/output expected[ind]
	~	Euro/Euro constant
	~		|

associated emission use Z inrg[ind,nrg,techn]=
	associated E use Z inrg[ind,nrg,techn]*emission use share Z inrg[ind,nrg]
	~	TJ/Year
	~	RES transition switch and exept D1 only for now until electricity module \
		integrated
	|

associated emissions i[ind,techn]=
	sum(associated emission use Z inrg[ind,nrg!,techn]*emission factor nrg[nrg!])
