	GET XLS CONSTANTS('?main', 'regions', 'rents_share_r*')
	~	Dmnl
	~		|

rental tax effective=
	0.092976
	~	
	~	Based on Albarea et al. (2019), https://doi.org/10.1111/roiw.12444
		Evasion rate for rental income applied to the corporate statutory tax rate \
		of 24%.
	|

rents share of mixed income=
	Mixed income rents/Total mixed income pre tax and deductions
	~	
	~		|

replace renew=
	0
	~	Dmnl
	~	1- replace phased out only with renewables
		0- replace phased out with existing energy product mix
	~	:SUPPLEMENTARY 
	|

reproductive life=
	30
	~	Year
	~		|

required capacity expected[e techn] :EXCEPT:      [e hydro]=
	ZIDZ(electricity demand expected by technology[e techn],expected capacity factor[e techn
,e techn]*hours in year) ~~|
required capacity expected[e hydro]=
	max(
	ZIDZ(electricity demand expected by technology[e hydro],expected capacity factor[e hydro
,e hydro]*hours in year),
	capacity initial[e hydro])
	~	GW
	~		|

required storage capacity expected[storage technologies] :EXCEPT: [e hydro]=
	ZIDZ(expected storage charge by technology[storage technologies,storage technologies
],expected capacity factor storage[storage technologies,storage technologies]
	*hours in year) ~~|
required storage capacity expected[e hydro]=
	max(ZIDZ(expected storage charge by technology[e hydro,e hydro],expected capacity factor storage
[
	e hydro,e hydro]
	*hours in year),
	init storage capacity[e hydro])
	~	GW
	~		|

required storage discharge for max generation=
	max generation/(1+current storage share of demand*(1-overall storage efficiency))
	~	GW*h/Year
	~		|

RES electricity generation=
	baseload deficit production[e hydro]+flex deficit production[e hydro]+generation by technology a
	[e hydro]
	
	+baseload deficit production[e wind]+flex deficit production[e wind]+generation by technology a
	[e wind]
	
	+baseload deficit production[e solarpv]+flex deficit production[e solarpv]+generation by technology a
	[e solarpv]
	
	+baseload deficit production[e solarth]+flex deficit production[e solarth]+generation by technology a
	[e solarth]
	
	+baseload deficit production[e nec]+flex deficit production[e nec]+generation by technology a
	[e nec]
	~	GW*h/Year
	~		|

RES generation share electricity=
	RES electricity generation/total generation
	~	Dmnl
	~	Share of renewables electricity over total electricity generated
	|

RES transition=
	IF THEN ELSE(Time<S Time Policy start,0,RES transition switch)
	~	Dmnl
	~	if RES transition active, triggered at time of policy start
	|

RES transition switch=
	0
	~	
	~	1 triggers RES transition (linear extrapolation based on final values in Maeder et \
		al., 2021). 
		0 means that production share and capacity factors remain at the last available \
		historic values.
		Note that the coal phasesout occurs in both cases.
	|

RES trends increase in VRES[e wind,electricity technologies]=
	IF THEN ELSE(Time+expectation horizon technology[electricity technologies]-Year 1+initial year
	>last year lookup tech share
	,
	expected electricity demand technology shareno transition[e wind,electricity technologies
]-lookup techn share[e wind](last year lookup tech share),
	0) ~~|
RES trends increase in VRES[e solarpv,electricity technologies]=
	IF THEN ELSE(Time+expectation horizon technology[electricity technologies]-Year 1+initial year
	>last year lookup tech share
	,
	expected electricity demand technology shareno transition[e solarpv,electricity technologies
]-lookup techn share[e solarpv](last year lookup tech share),
	0)
	~	Dmnl
	~		|

RES trends reduction in ff[e coal,electricity technologies]=
	IF THEN ELSE(Time+expectation horizon technology[electricity technologies]-Year 1+initial year
	>last year lookup tech share
	,
	lookup techn share[e coal](last year lookup tech share)-expected electricity demand technology shareno transition
[e coal,electricity technologies],
	0) ~~|
RES trends reduction in ff[e petroleum,electricity technologies]=
	IF THEN ELSE(Time+expectation horizon technology[electricity technologies]-Year 1+initial year
	>last year lookup tech share
	,
	lookup techn share[e petroleum](last year lookup tech share)-expected electricity demand technology shareno transition
[e petroleum,electricity technologies],
	0) ~~|
RES trends reduction in ff[e gas,electricity technologies]=
	IF THEN ELSE(Time+expectation horizon technology[electricity technologies]-Year 1+initial year
	>last year lookup tech share
	,
	lookup techn share[e gas](last year lookup tech share)-expected electricity demand technology shareno transition
[e gas,electricity technologies],
	0)
	~	Dmnl
	~		|

reserve production potential[e techn]=
	+production capacity[e techn]*hours in year*(max capacity factor[e techn]-current capacity factor
[e techn])
	~	Hours*GW/Year
	~		|

