flag exogenous labour productivity i[ind]=
	IF THEN ELSE(Act exogenous labour productivity<>0 :AND: S exogenous lambda scenario ON i
[ind]=1 :AND: (Time >S Time exogenous lambda),
	Act exogenous labour productivity,
	0)
	~	1
	~	Flag having the value of *Act exogenous labour productivity* only for the \
		sectors selected and from the time of activation
	|

flag wage growth as average i[ind]=
	IF THEN ELSE(Act wage growth as average<>0 :AND: S wage growth as average ON i[ind]=
1 :AND: (Time >S Time wage growth as average),
	Act wage growth as average,
	0)
	~	1
	~	Flag having the value of *Act wage growth as average* only for the sectors \
		selected and from the time of activation
	|

flex deficit production[e techn]=
	ALLOCATE BY PRIORITY(flex deficit production potential[e techn], priority elec[e techn
] , ELMCOUNT(e techn), priority width
	 , flexible deficit)
	~	GW*h/Year
	~	Allocation of flexible deficit production to technologies.
	|

flex deficit production potential[e techn]=
	max(0,deficit production potential[e techn]*flexibility share techn[e techn])
	~	GW*Hour/Year
	~	Flexible excess production capacities by technology.As with the load, for \
		simplicity we assume that the excess capacity has the same flexibility \
		features as overall capacity.
	|

flex share production=
	flexibility share load base-sum(VRES share[e techn!]*flexibility share techn[e techn
!])
	~	Dmnl
	~	The need for flexible dispatch is given by the flexibility needs of the \
		load and increases with VRES share, according to coefficients in Sullivan \
		et al., 2013. In terms of RES share here we only consider RES production \
		directly fed into the grid, as stored production does not exhibit these \
		issues.
	|

flex share production delayed= DELAY FIXED (
	flex share production, TIME STEP, flexibility share load base)
	~	Dmnl
	~	The share of production that needs to be flexible delayed by the minimum \
		delay time in order to avoid circular equations.
	|

flexibility share load base=
	0.532551
	~	Dmnl
	~	The fraction of load that needs to be produced flexibly due to demand \
		fluctuations. Own calculations from loadcurves in Jaxa Rozen et al., 2022.
	|

flexibility share techn[e coal]=
	0.15 ~~|
flexibility share techn[e gas]=
	0.5 ~~|
flexibility share techn[e hydro]=
	0.5 ~~|
flexibility share techn[e nuclear]=
	0 ~~|
flexibility share techn[e petroleum]=
	0.3 ~~|
flexibility share techn[e solarpv]=
	-0.05 ~~|
flexibility share techn[e solarth]=
	0 ~~|
flexibility share techn[e wind]=
	-0.08 ~~|
flexibility share techn[e nec]=
	RES transition*
	(IF THEN ELSE(Time>=S Time Policy start,
	init flex share nec+
	(final flex share nec-init flex share nec)/
	(1+EXP(-steepness logistic curve*(Time-midpoint logistic curve
	))),
	init flex share nec))
	
	+(1-RES transition)*
	(init flex share nec)
	~	Dmnl
	~	Flexibility coefficients for technologies based on Sullivan et al. (2013) and \
		Carrara and Marangoni (2017).
		Due to the change of mix bewtween bio and geothermal in nec, the value for \
		nec is dynamic. For simplicity we again assume a liner extrapolation over \
		time.
	|

flexible deficit=
	total storage discharge deficit
	+flex share production delayed*max(generation deficit-total storage discharge deficit
,0)
	~	GW*h/Year
	~	total deficit generation must cover flexible electricity at least at the \
		amount of storage shortfall. if there is generation deficit exceeding of \
		storage shortfall, we assume that its flexibility characteristics are the \
		same as in the overall load
	|

focalised benefit per capita init=
	3500
	~	Euro/People/Year
	~		|

Focalized benefit per capita=
	focalised benefit per capita init*max(cumulative inflation since policy start,1)
	~	Euro/People/Year
	~		|

foreign assets= INTEG (
	change in net foreign assets,
		initial foreign assets)
	~	Euro
	~		|

fossil fuel reduction=
	0.973513
	~	Dmnl
	~	average reduction in fossil fuel intensity of output in Italy between \
		2010-2019
	|

fossil fuel use per unit output[ind]=
	sum(E Z use per unit output[ind,ff!])
	~	TJ/Euro constant
	~		|

fossil fuel use per unit output initial[ind]=
	INITIAL(fossil fuel use per unit output[ind])
	~	TJ/Euro constant
	~		|

fraction D2 real over gas[regions,quintiles]=
	c hhs ESc real bp rqi[regions,quintiles,gas ind]/
	
	(gas per unit B hhs demand*c hhs ESc real bp rqi[regions,quintiles,mining])
	~	Euro constant/TJ
	~		|

fraction D3 real over heat[regions,quintiles]=
	c hhs ESc real bp rqi[regions,quintiles,heat ind]/
	
	(heat per unit D1 hhs demand*c hhs ESc real bp rqi[regions,quintiles,electricity ind
])
	~	Euro constant/TJ
	~		|

fraction gov costs to get profits equal capital costs=
	government output/(2*consumption of fixed capital gov+intermediated consumption gov+
labour costs gov)
	~	Dmnl
	~		|

fraction government costs govsec[govsec]=
	total government provision costs govsec[govsec]/total costs govsec[govsec]
	~	Dmnl
	~		|

fraction government profits investment capital[govsec]=
	min(1,initial fraction government costs govsec[govsec]+delta public K desired over K i
[govsec
	])
	~	Dmnl
	~		|

fraction new capital[ind] :EXCEPT: [households]=
	ZIDZ(in K i[ind]*Year 1,
	K i[ind]-depreciation K i[ind]*Year 1+in K i[ind]*Year 1) ~~|
fraction new capital[households]=
	1
	~	Dmnl
	~		|

fraction non capitalists=
	0.99
	~	Dmnl
	~		|

fraction of unemployed in JG after init=
	IF THEN ELSE(Time<S Time Policy start JG,
	                0,
	                (Time-S Time Policy start JG)*(final fraction of unemployed/(Final time job guarantee
-S Time Policy start JG))
	                )
	~	Dmnl/Year
	~	linear interpolation of fraction over policy duration
	|

Free ETS i[ind]=
	pre 2023*Free ETS i historic[ind](Time)
	+ (1-pre 2023)*Free ETS i historic[ind](end year ETS data)*max((end year free ETS[ind
]-Time
)/(end year free ETS[ind]-end year ETS data),0)
	~	tCO2eq/Year
	~		|

