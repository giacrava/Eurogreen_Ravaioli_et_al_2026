check L public gov bs 6 i[ind]=
	IF THEN ELSE(Time>=S Time Policy start,
	L public i[ind]-(L public target gov bs 6 or 7 i[ind]+delta L from gov c real policy increase i
[ind]),
	0)
	~	Person
	~		|

check L tot gov bs 6 i[ind]=
	IF THEN ELSE(Time>=S Time Policy start,
	L actual i[ind]-(L tot target gov bs 6 or 7 i[ind]+delta L from gov c real policy increase i
[ind]),
	0)
	~	Person
	~	Check that total job expected by the government (for baseline and \
		eventually for policy) correspond to total jobs created, when Act change \
		baseline gov consumption = 4 and Act change gov consumption = 5 or 6)
	|

