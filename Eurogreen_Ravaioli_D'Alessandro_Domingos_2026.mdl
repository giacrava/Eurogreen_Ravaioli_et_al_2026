per output emission use Z inrg[ind,nrg]=
	E Z use per unit output[ind,nrg]*emission use share Z inrg[ind,nrg]
	~	TJ/Euro constant
	~		|

per unit emissions hh[ind]=
	sum(av energy use per unit hh consumption[ind,nrg!]*emission use share C nrg[nrg!]*emission factor nrg
[nrg!])
	~	tCO2eq/Euro constant
	~		|

per unit emissions hh be[ind]=
	sum(av energy use per unit hh consumption be[ind,nrg!]*emission use share C nrg[nrg!
]*emission factor nrg[nrg!])
	~	tCO2eq/Euro constant
	~		|

per unit emissions hh check=
	sum(per unit emissions hh[ind!]*(c ESc real bp dom i[ind!]+c ESc real bp imp i[ind!]
+shortfall c nom[ind!]/p i[ind!]
	))-emissions C
	~	tCO2eq/Year
	~		~	:SUPPLEMENTARY 
	|

per unit emissions hh check be=
	sum(per unit emissions hh be[ind!]*(c ESc real bp dom i[ind!]+c ESc real bp imp i[ind
!]))-emissions C
	~	tCO2eq/Year
	~		~	:SUPPLEMENTARY 
	|

per unit end use hhs[ind,nrg]=
	av energy use per unit hh consumption[ind,nrg]*end use share C nrg[nrg]
	~	TJ/Euro constant
	~		|

per unit energy use hh domestic[ind,nrg]=
	E C M share i[ind]*E C intensity i[ind]*E C source share post electrification inrg[ind
,nrg]
	~	TJ/Euro constant
	~		|

per unit energy use hh domestic be[ind,nrg]=
	E C M share init i[ind]*E C intensity i[ind]*E C source share inrg[ind,nrg]
	~	TJ/Euro constant
	~		|

per unit energy use hh imp[ind,nrg]=
	E C M imp share i[ind]*E C intensity imp i[ind]*E C source share imp inrg[ind,nrg]
	~	TJ/Euro constant
	~		|

per unit energy use hh imp be[ind,nrg]=
	E C M share init imp i[ind]*E C intensity imp i[ind]*E C source share imp inrg[ind,nrg
]
	~	TJ/Euro constant
	~		|

per unit output E imp Z nrgii[nrg,ind,toind]=
	per unit output E Z imp total ii[ind,toind]*E Z source share imp[nrg,ind,toind]
	~	TJ/Euro constant
	~		|

per unit output E Z ii[ind,toind]=
	per unit output E Z M ii[ind,toind]*E Z intensity ii[ind,toind]
	~	TJ/Euro constant
	~		|

per unit output E Z imp total ii[ind,toind]=
	per unit output imp E Z M ii[ind,toind]*E Z intensity imp ii[ind,toind]
	~	TJ/Euro constant
	~		|

per unit output E Z M ii[ind,toind]=
	a ii[ind,toind]*E Z M share ii[ind,toind]
	~	Dmnl
	~		|

per unit output E Z nrgii[nrg,ind,toind]=
	per unit output E Z ii[ind,toind]*E Z source share[nrg,ind,toind]
	~	TJ/Euro constant
	~		|

per unit output imp E Z M ii[ind,toind]=
	share imp Z ESc ii[ind,toind] * a ii[ind,toind] 
	*E Z M share imp ii[ind,toind]
	~	Dmnl
	~		|

percentage change ESc a imp demand nrg[nrg,toind]=
	IF THEN ELSE(sum(a e imp before ESc[nrg,ind!,toind])=0,0,
	sum(ESc a imp[ind!,toind]*E Z source share imp delay[nrg,ind!,toind])/sum(a e imp before ESc
[nrg,ind!,toind]))
	~	Dmnl
	~	Percentage change in imported AE demand by industry and energy product.
	|

percentage change ESc a nrg demand[nrg,toind] :EXCEPT:       [heat,toind],[elec,toind
]
,[gas,electricity ind]=
	IF THEN ELSE(sum(a e before ESc[nrg,ind!,toind]+a e imp before ESc[nrg,ind!,toind])=
0,0,
	(sum(ESc a[ind!,toind]*E Z source share delay[nrg,ind!,toind])+sum(ESc a imp[ind!,toind
]*E Z source share imp delay
	[nrg,ind!,toind]))
	/(sum(a e before ESc[nrg,ind!,toind])+sum(a e imp before ESc[nrg,ind!,toind]))) ~~|
percentage change ESc a nrg demand[heat,toind]=
	IF THEN ELSE((sum(a e before ESc[heat,ind!,toind]+a e imp before ESc[heat,ind!,toind
])-a e before ESc[heat,toind,toind]
	)=0,0,
	(sum(ESc a[ind!,toind]*E Z source share delay[heat,ind!,toind])+sum(ESc a imp[ind!,toind
]*E Z source share imp delay
	[heat,ind!,toind])-
	(ESc a[toind,toind]*E Z source share delay[heat,toind,toind]+ESc a imp[toind,toind]*
E Z source share imp delay
	[heat,toind,toind])
	)
	/(sum(a e before ESc[heat,ind!,toind])+sum(a e imp before ESc[heat,ind!,toind])-a e before ESc
[heat,toind,toind])) ~~|
percentage change ESc a nrg demand[elec,toind]=
	IF THEN ELSE((sum(a e before ESc[elec,ind!,toind]+a e imp before ESc[elec,ind!,toind
])-a e before ESc[elec,toind,toind]
	)=0,0,
	(sum(ESc a[ind!,toind]*E Z source share delay[elec,ind!,toind])+sum(ESc a imp[ind!,toind
]*E Z source share imp delay
	[elec,ind!,toind])
	-
	(ESc a[toind,toind]*E Z source share delay[elec,toind,toind]+ESc a imp[toind,toind]*
E Z source share imp delay
	[elec,toind,toind])
	)
	/(sum(a e before ESc[elec,ind!,toind])+sum(a e imp before ESc[elec,ind!,toind])-a e before ESc
[elec,toind,toind])) ~~|
percentage change ESc a nrg demand[gas,electricity ind]=
	IF THEN ELSE(((sum(a e before ESc[gas,ind!,electricity ind])+sum(a e imp before ESc[
gas,ind!,electricity ind]))*(end use share Z inrg delay
	[electricity ind,gas]+(1-end use share Z inrg delay[electricity ind,gas])/(1-electricity module switch
*hydro share in gas delayed2
	)))=0,0,
	
	(sum(ESc a[ind!,electricity ind]*E Z source share delay[gas,ind!,electricity ind])+sum
(ESc a imp[ind!,electricity ind
	]*E Z source share imp delay
	[gas,ind!,electricity ind])+changes in hydro use elec)
	
	/((sum(a e before ESc[gas,ind!,electricity ind])+sum(a e imp before ESc[gas,ind!,electricity ind
]))*(end use share Z inrg delay
	[electricity ind,gas]+(1-end use share Z inrg delay[electricity ind,gas])/(1-electricity module switch
*hydro share in gas delayed2
	))))
	~	Dmnl
	~	Percentage change in total AE demand by industry and energy product. For \
		heat and electricity we remove autoproduction from the percentage change, \
		since autoproduction does not require distribution infrastructure. Note \
		that for heat and electricity these calculations are misleading since they \
		assume past source shares while electrification only adds electricity and \
		not heat demand. However, only the calculation for gas is subsequently \
		actually used so for now we keep these calculations for illustrative \
		purposes.
	|

percentage change exp inc e[gender,skill]=
