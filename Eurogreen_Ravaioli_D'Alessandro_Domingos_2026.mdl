num hhs r[regions]=
	sum(num hhs rq[regions,quintiles!])
	~	Household
	~		~	:SUPPLEMENTARY 
	|

num hhs rq[regions,quintiles]=
	pop rq[regions,quintiles]/hhs members init[regions,quintiles]
	~	Household
	~		|

num hhs rq delayed[regions,quintiles]= DELAY FIXED (
	num hhs rq[regions,quintiles], delay time, num hhs rq init[regions,quintiles])
	~	Household
	~	(pop rq[regions,quintiles]/hhs members rq[regions,quintiles])
	|

num hhs rq init[regions,quintiles]=
	GET XLS CONSTANTS('?main', 'regions', 'num_hhs_init_calib')
	~	Household
	~		|

NWB check=
	NWB total - total net labour income
	~	
	~		~	:SUPPLEMENTARY 
	|

NWB rq[regions,quintiles]=
	sum(net labour income per capita gis[female,ind!,low]*L gis[female,ind!,low])*hhs cat shares rq adj
	[regions,inc low e f,quintiles
	] 
	+
	sum(net labour income per capita gis[male,ind!,low]*L gis[male,ind!,low])*hhs cat shares rq adj
	[regions,inc low e m,quintiles] +
	sum(net labour income per capita gis[female,ind!,mid]*L gis[female,ind!,mid])*hhs cat shares rq adj
	[regions,inc mid e f,quintiles
	] 
	+
	sum(net labour income per capita gis[male,ind!,mid]*L gis[male,ind!,mid])*hhs cat shares rq adj
	[regions,inc mid e m,quintiles] +
	sum(net labour income per capita gis[female,ind!,hig]*L gis[female,ind!,hig])*hhs cat shares rq adj
	[regions,inc hig e f,quintiles
	] 
	+
	sum(net labour income per capita gis[male,ind!,hig]*L gis[male,ind!,hig])*hhs cat shares rq adj
	[regions,inc hig e m,quintiles]
	~	
	~	Net Wage Bill, total nominal value per region and quintile
	|

NWB total=
	sum(NWB rq[regions!,quintiles!])
	~	Euro/Year
	~	Total Net Wage Bill
	|

olf rate gs[gender,skill]=
	N olf gs[gender,skill]/working age population gs[gender,skill]
	~	Dmnl
	~	Fraction of people out of labour force over total working age population
	~	:SUPPLEMENTARY 
	|

omega employment=
	0
	~	Dmnl
	~	PREVIOUS 0.015
		sensitivity of hourly wages to employment.
		keep without subscripts for now
		0.0144514
		
		%%%PREVIOUS VALUES MAY.23
		0.3,0.5,0.8
	|

omega lambda[skill]=
	0.3,
	0.4,
	0.5
	~	Dmnl
	~	sensitivity of hourly wages to labour productivity.
		keep without subscripts for now
	|

omega overall lambda=
	0.1
	~	Dmnl
	~		|

omega price=
	IF THEN ELSE(Act Wage Indexation=0,basic omega price,IF THEN ELSE(Time<S Time Policy start
	,basic omega price,Act Wage Indexation*Multiplier Wage Indexation
	))
	~	Dmnl
	~	0.5
		sensitivity of hourly wages to inflation.
		keep without subscripts for now
	|

ongoing investment financing[e techn]= INTEG (
	new capacity investment costs[e techn]-completely financed[e techn],
		0)
	~	Euro constant/Year
	~	We assume a linear expense schedule of investment costs over the time of \
		construction.
	|

ongoing investment financing costs=
	sum(ongoing investment financing[e techn!]*capital price technology pp[e techn!])
	~	Euro/Year
	~		|

ordered component Theil L[gender,ind,skill]=
	VECTOR SORT ORDER(component Theil L[gender,ind,skill],1)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

other benefits exp=
	other benefits per cap*(sum(N olf gs[gender!,low]))
	~	Euro/Year
	~	OR
		other_benefits_per_cap*(sum(Working_age_population_cgs[cohorts!,gender!,low\
		]))
	|

other benefits exp check=
	other benefits exp - other benefits total
	~	
	~		~	:SUPPLEMENTARY 
	|

other benefits per cap=
	(IF THEN ELSE(Time<S Time Policy start,
	             init other benefits per cap*CPI,
	             (1-Act BI)*init other benefits per cap*CPI
	             ))
	~	Euro/(Year*Person)
	~		|

other benefits rq[regions,quintiles]=
	other benefits per cap*pop d[inc low o f]*hhs cat shares rq adj[regions,inc low o f,
	quintiles] + 
	other benefits per cap*pop d[inc low o m]*hhs cat shares rq adj[regions,inc low o m,
	quintiles]
	~	Euro/Year
	~	Total nominal income from other benefits per region-quintile
	|

other benefits rq total=
	sum(other benefits rq[regions!,quintiles!])
	~	
	~		~	:SUPPLEMENTARY 
	|

other benefits total=
	sum(other benefits rq[regions!,quintiles!])
	~	Euro/Year
	~		|

other transfers exp=
	transfers exp-GPB exp-GUB exp
	~	Euro/Year
	~		|

our pension relevant salaries[gender,skill]=
	DELAY FIXED( in pension relevant salaries[gender,skill] , average time of receiving pensions
[gender] , initial average pension relevant past salaries[gender,skill])
	~	Euro constant/(Year*Person)
	~		|

out cumulative interest rate= DELAY FIXED (
	in interest rate, average duration of government bonds ,init i+init spread b)
	~	1/Year
	~		|

out cumulative salary[gender,skill]= DELAY FIXED (
	in cumulative salary[gender,skill], average duration of working time g at time of retirement
[gender] ,initial average salary[gender,skill])
	~	Euro constant/(Year*Person)
	~		|

out ETS i[ind]=
	min(emissions ETS i[ind],surrendered ETS allowances i[ind])
	~	tCO2eq/Year
	~		|

out ETS i expected[ind]=
	min(expected emissions ets[ind],surrendered ETS allowances i expected[ind])
	~	tCO2eq/Year
	~		|

Out JG L gs[gender,skill]= DELAY FIXED (
	in JG L gs[gender,skill], JG time, 0)
	~	People/Year
	~		|

Out JG L reskilled[gender,low]=
	Out JG L gs[gender,low]*low skill transformation JG[gender,low]
	+Out JG L gs[gender,mid]*mid skill transformation JG[gender,low]
	+Out JG L gs[gender,hig]*hig skill transformation JG[gender,low] ~~|
Out JG L reskilled[gender,mid]=
	Out JG L gs[gender,low]*low skill transformation JG[gender,mid]
	+Out JG L gs[gender,mid]*mid skill transformation JG[gender,mid]
	+Out JG L gs[gender,hig]*hig skill transformation JG[gender,mid] ~~|
Out JG L reskilled[gender,hig]=
	Out JG L gs[gender,low]*low skill transformation JG[gender,hig]
	+Out JG L gs[gender,mid]*mid skill transformation JG[gender,hig]
	+Out JG L gs[gender,hig]*hig skill transformation JG[gender,hig]
	~	People/Year
	~		|

out Loans i[ind]=
	profits residual[ind]+debt repayment i[ind]
	~	Euro/Year
	~		|

output expected[ind] :EXCEPT:      [careserv]=
	y real delayed[ind]*(1+
	IF THEN ELSE(activated output expected covid shocks=1,output expected shocks[ind],
	output expected trend[ind]*expectations adjustment time)) ~~|
output expected[careserv]=
	IF THEN ELSE((Act Change baseline gov consumption=6:OR:Act Change baseline gov consumption
=7) :AND: Time > S Time Change baseline gov consumption
	 ,
	tot c real target gov bs 6 or 7 i[careserv],
	y real delayed[careserv]*(1+
	IF THEN ELSE(activated output expected covid shocks=1,output expected shocks[careserv
],
	output expected trend[careserv]*expectations adjustment time)))
	~	Euro constant/Year
	~	output perceived[ind]*(1+output expected trend[ind]*(expectation \
		horizon+expectations adjustment time)
		The expected electricity demand based on trend based expectations. The \
		expectations adjustment time is added to the expectation horizon in the \
		exponent, as we use the perceived value as a basis. However, the perceived \
		value is already delayed by the expectations adjustment time, which is why \
		we add this time perdiod in the exponent. We simplify by ignoring \
		compounding of the growth rate, but as the time horizon is short, this is \
		a reasonable approximation.
	|

output expected 2[ind]=
	output expected[ind]*(1+output expected trend[ind]*expectations adjustment time)
	~	Euro constant/Year
	~		|

output expected by technology expectations horizon[electricity technologies]=
	y real delayed unconstrained[electricity ind]*(1+output expected trend unconstrained
[electricity ind]*(expectation horizon technology
	[electricity technologies]+1))
	~	Euro constant/Year
	~		|

output expected shocks[ind]=
	IF THEN ELSE(Time=10,covid shock[ind],IF THEN ELSE(Time=11,covid rebound[ind],0))
	~	
	~		|

output expected trend[ind] :EXCEPT:    [careserv]=
	IF THEN ELSE(active shocks time=1,
	0,
	
	(output perceived[ind]-output perceived delayed[ind])/output perceived delayed[ind]/
	expectations adjustment time) ~~|
output expected trend[careserv]=
	IF THEN ELSE((Act Change baseline gov consumption=6:OR:Act Change baseline gov consumption
=7) :AND: Time > S Time Change baseline gov consumption,
	g population total,
	IF THEN ELSE(active shocks time=1,
	0,
	(output perceived[careserv]-output perceived delayed[careserv])/output perceived delayed
	[careserv]/
	expectations adjustment time))
	~	Dmnl
	~	The trend formed in the expectation formation for output.
		During times of strong shocks, trend is assumed to be 0
	|

output expected trend unconstrained[ind]=
	(output perceived unconstrained[ind]-output perceived delayed unconstrained[ind])/output perceived delayed unconstrained
[ind]/
	expectations adjustment time
	~	Dmnl/Year
	~	The trend formed in the expectation formation for output.
	|

output gap i[ind]=
	(y real unconstrained i[ind]-y real i[ind])/y real unconstrained i[ind]
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

output perceived[ind]= INTEG (
	output perceived adjustment[ind],
		y real init[ind])
	~	Euro constant/Year
	~	Smoothed output for expectation formation.
	|

output perceived adjustment[ind]=
	(y real i[ind]-output perceived[ind])/expectations adjustment time
	~	Euro constant/Year/Year
	~	Adjustement of perceived output w.r.t. to actual observed output
	|

output perceived adjustment unconstrained[ind]=
	(y real unconstrained i[ind]-output perceived unconstrained[ind])/expectations adjustment time
	~	Euro constant/Year/Year
	~	Adjustement of perceived output w.r.t. to actual observed output
	|

output perceived delayed[ind]= INTEG (
	output perceived delayed adjustment[ind],
		y real init[ind])
	~	Euro constant/Year
	~	Smoothed output for expectation formation delayed, to calculate \
		expectation trend.
	|

output perceived delayed adjustment[ind]=
	(output perceived[ind]-output perceived delayed[ind])/expectations adjustment time
	~	Euro constant/(Year*Year)
	~	Adjustement of perceived output delayed w.r.t. to output perceived.
	|

output perceived delayed adjustment unconstrained[ind]=
	(output perceived unconstrained[ind]-output perceived delayed unconstrained[ind])/expectations adjustment time
	~	Euro constant/(Year*Year)
	~	Adjustement of perceived output delayed w.r.t. to output perceived.
	|

output perceived delayed unconstrained[ind]= INTEG (
	output perceived delayed adjustment unconstrained[ind],
		y real init[ind])
	~	Euro constant/Year
	~	Smoothed output for expectation formation delayed, to calculate \
		expectation trend.
	|

output perceived unconstrained[ind]= INTEG (
	output perceived adjustment unconstrained[ind],
		y real init[ind])
	~	Euro constant/Year
	~	Smoothed output for expectation formation.
	|

output share i[ind]=
	y real i[ind]/sum(y real i[ind!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

output to GDP ratio=
	ZIDZ(tot y real,GDP real)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

overall ETS balance old=
	sum(Free ETS i old[ind!](Time)) - sum(CO2 ETS i[ind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

overall storage efficiency=
	sum(current charge share by technology[storage technologies!]*efficiency by storage technology
[storage technologies!])
	~	Dmnl
	~	we assume fixed fractions so that most limiting technology limits whole \
		system and not another storage technology can compensate due to their \
		different characteristics
	|

