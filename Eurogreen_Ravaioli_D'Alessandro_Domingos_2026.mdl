fin corp tax fraction=
	IF THEN ELSE(fin inc tax role=0,financial income tax base delayed/corporate tax base delayed
,fin inc tax role
)
	~	Dmnl
	~		|

fin inc tax rate bonds effective=
	0.048425
	~	Dmnl
	~	Based on Albarea et al. (2019), https://doi.org/10.1111/roiw.12444
		Evasion rate for rentals (including capital income) applied to a statutory \
		tax rate of 12.5%.
	|

fin inc tax rate eq effective=
	0.100724
	~	Dmnl
	~	Based on Albarea et al. (2019), https://doi.org/10.1111/roiw.12444
		Evasion rate for rentals (including capital income) applied to a statutory \
		tax rate of 26%.
	|

fin inc tax role=
	0.8
	~	Dmnl
	~	The fraction of desired expenses covered by tax increase that should be levied on \
		financial income tax. If the financial income tax is not sufficient, \
		residual revenue is generated by the corporate tax.
		0: levied on corporate income and financial income proportional to their tax base
		value between 0 and 1 triggers this value to be the fraction levied on \
		financial income
	|

fin rev check=
	fin tax rev-fin tax rev gs
	~	
	~		|

fin tax rev=
	sum(fin tax rq[regions!,quintiles!])
	~	Euro/Year
	~	government revenue from financial income tax
	|

fin tax rev gs=
	fin inc tax rate bonds effective*sum(gross fin inc gs bonds[gender!,skill!])+
	fin inc tax rate eq effective*sum(gross fin inc gs eq[gender!,skill!])+
	fin inc tax rate bonds effective*gross fin inc cap bonds+
	fin inc tax rate eq effective*gross fin inc cap eq
	~	
	~		|

fin tax rq[regions,quintiles]=
	fin inc tax rate eq effective*GFI rq eq[regions,quintiles]
	+fin inc tax rate bonds effective*GFI rq bonds[regions,quintiles]
	~	Euro/Year
	~	Before, Without evasion nor different effective tax rates:
		GFI rq[regions,quintiles] *financial income tax rate
	|

