convergence=
	EXP(-conversion slope*Time/Year 1)
	~	Dmnl
	~	1-(Time/30)^0.5
		1-(Time/(40*Year 1))^0.5
	|

convergence 11=
	EXP(-conversion slope*11/Year 1)
	~	
	~		|

convergence factor elec late[electricity technologies]=
	IF THEN ELSE(Time+expectation horizon technology[electricity technologies]-Year 1<late elec convergence start time
,1,
	EXP(-conversion slope*(Time+expectation horizon technology[electricity technologies]
-Year 1-late elec convergence start time
	)/Year 1))
	~	Dmnl
	~		|

conversion=
	1e+09
	~	Euro
	~		|

conversion slope=
	1/10
	~	Dmnl
	~		|

corp tax i[ind]=
	max(corp tax rate*(profits post interest i[ind]-depreciation K i[ind]*price capital pp i
[ind]),0)
	~	Euro/Year
	~	corporate income tax paid by industry
	|

corp tax i effective[ind]=
	corp tax i rents[ind]+corp tax selfemp i[ind]+corp tax non MI i[ind]
	~	
	~		|

corp tax i rents[ind]=
	max(rental tax effective*profits postimpr rents share i[ind]*(profits post interest i
[ind]-depreciation K i[ind]*price capital pp i
	[ind]),0)
	~	
	~		|

corp tax non MI i[ind]=
	max(corp tax rate*profits postimpr nonMI share i[ind]*(profits post interest i[ind]-
depreciation K i[ind]*price capital pp i
	[ind]),0)
	~	
	~		|

corp tax rate=
	min(max tax rate,
	IF THEN ELSE(Time>S Time Policy start:AND:Act additional expense compensation=1,
	max(desired corporate income tax rate+financing gap financial/corporate tax base delayed
,corp tax rate from 2017
	),
	
	IF THEN ELSE(Time<7,"corp tax rate 2010-2016",corp tax rate from 2017)
	*IF THEN ELSE(Time<S Time Policy start,1,
	                1+min(S Time end-S Time Policy start,Time-S Time Policy start)*(S corp tax rate
	/(S Time end-S Time Policy start))
	                )
	))
	~	Dmnl
	~		|

"corp tax rate 2010-2016"=
	0.275
	~	Dmnl
	~		|

corp tax rate from 2017=
	0.24
	~	Dmnl
	~		|

corp tax rev=
	sum(corp tax i[ind!])
	~	Euro/Year
	~		|

corp tax rev effective=
	sum(corp tax i effective[ind!])
	~	
	~		|

corp tax selfemp i[ind]=
	max(selfemp capital income tax effective*profits postimpr selfemp share i[ind]*(profits post interest i
[ind]-depreciation K i[ind]*price capital pp i
	[ind]),0)
	~	
	~		|

corporate tax base=
