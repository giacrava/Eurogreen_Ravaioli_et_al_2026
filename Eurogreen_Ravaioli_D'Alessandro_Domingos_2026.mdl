	~	1
	~		~	:SUPPLEMENTARY 
	|

min c hhs rq=
	VMIN(c hhs rq[regions!,quintiles!])
	~	
	~	Minimum nominal consumption of households over regions and quintiles
	~	:SUPPLEMENTARY 
	|

min delta a[toind]=
	min(sum(a ii[ind!,toind]),
	min(IF THEN ELSE(draw T2 i[toind]=1,sum(a T iiv[ind!,toind,T2]),1e+06),
	min(IF THEN ELSE(draw T3 i[toind]=1,sum(a T iiv[ind!,toind,T3]),1e+06),IF THEN ELSE(
draw T4 i[toind]=1,sum(a T iiv[ind!
	,toind,T4]),1e+06))))
	~	Dmnl
	~		|

min delta a ii[ind,toind]=
	-2.07237
	~	Dmnl
	~	5th percentila of all changes
		not normalised: -0.13205776
	|

min delta lambda pos[ind]=
	0
	~	percentage
