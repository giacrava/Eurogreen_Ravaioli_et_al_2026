beta hhs i[regions,quintiles,ind]=
	IF THEN ELSE(Act Wellbeing Module=0,beta aids[regions,quintiles,ind],
	WB beta aids[regions,quintiles,ind])
	~	Dmnl
	~	basic beta hhs i[regions,quintiles,ind]
		*(1+ beta elasticities rqi[quintiles,ind,regions]
		*Cumulative inflation ind price to CPI ratio rqi[regions,quintiles,ind])
		
		EQUATION UNTIL 28.03.2024
		basic beta hhs i[regions,quintiles,ind]
		*(pp i cumulative elasticity inflation[ind]*pp i[ind])
		
		EQUATION UNTIL 16.02.2024
		
		basic beta hhs i[regions,quintiles,ind]
		* (1 + elast beta hhs i[ind]*(infl cumulative hhs pp i[ind] - av infl cumulative hhs \
		rq[regions,quintiles])/(euro 1/goods 1) )
		+ basic beta hhs i[regions,quintiles,ind]
		* sum(-elast beta hhs i[ind!]*(infl cumulative hhs pp i[ind!]-av infl \
		cumulative hhs rq[regions,quintiles])*basic beta hhs \
		i[regions,quintiles,ind!]/(euro 1/goods 1) )
	|

beta hhs i balanced[regions,quintiles,ind]=
	beta hhs i[regions,quintiles,ind]/sum(beta hhs i[regions,quintiles,ind!])
	~	Dmnl
	~		|

beta hhs i balanced check[regions,quintiles]=
	sum(beta hhs i balanced[regions,quintiles,ind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

beta hhs i check[regions,quintiles]=
	sum(beta hhs i[regions,quintiles,ind!])
	~	
	~		~	:SUPPLEMENTARY 
	|

beta hhs mean balanced i[ind]=
	sum(beta hhs i balanced[regions!,quintiles!,ind]
	 * c hhs rq[regions!,quintiles!]
	 * num hhs rq delayed[regions!,quintiles!])
	
	/ sum(c hhs rq[regions!,quintiles!] * num hhs rq delayed[regions!,quintiles!])
	~	1
	~		|

betas rqp initial[regions,coicop,q1]=
	GET XLS CONSTANTS( '?main' , 'regions' , 'beta_q1' ) ~~|
betas rqp initial[regions,coicop,q2]=
	GET XLS CONSTANTS( '?main' , 'regions' , 'beta_q2' ) ~~|
betas rqp initial[regions,coicop,q3]=
	GET XLS CONSTANTS( '?main' , 'regions' , 'beta_q3' ) ~~|
betas rqp initial[regions,coicop,q4]=
	GET XLS CONSTANTS( '?main' , 'regions' , 'beta_q4' ) ~~|
betas rqp initial[regions,coicop,q5]=
	GET XLS CONSTANTS( '?main' , 'regions' , 'beta_q5' )
	~	
	~		|

BI check=
	IF THEN ELSE(Time<S Time Policy start,Euro 0,Act BI*BI per capita)*sum(pop d[inc cat
!]) - BI total
	~	
	~		~	:SUPPLEMENTARY 
	|

BI exp=
	IF THEN ELSE(Time<S Time Policy start,
	             0,
	             Act BI*BI per capita*sum(adult population s[skill!]))
	~	Euro/Year
	~		|

BI exp check=
	BI exp - BI total
	~	
	~		~	:SUPPLEMENTARY 
	|

BI per capita=
	BI per capita init*max(cumulative inflation since policy start,1)
	~	Euro/(Year*Person)
	~		|

BI per capita init=
	5000
	~	Euro/(Year*Person)
	~		|

BI per capita received=
	IF THEN ELSE(Time<S Time Policy start,Euro 0,Act BI*BI per capita)
	~	Euro/(Year*Person)
	~		|

BI rq[regions,quintiles]=
	IF THEN ELSE(Time<S Time Policy start,Euro 0,
	Act BI*BI per capita*sum(pop d[inc cat!]*hhs cat shares rq adj[regions,inc cat!,quintiles
	])
	)
	~	Euro/Year
	~	Basic income, total nominal value per region-quintile
	|

BI total=
	sum(BI rq[regions!,quintiles!])
	~	Euro/Year
	~		|

biofuel increase=
	1.0859
	~	Dmnl
	~	average increase in biofuel intensity of output in Italy between 2010-2019
	|

births g[gender]=
	(fertility rate/(2*reproductive life))
	*(Pop 1524 g[female]+Pop 2544 g[female])
	~	People/Year
	~	*1.3
	|

bottom 50 direct emissions C intensity=
	sum(direct emissions hh rq[regions!,quintiles!]*bottom 50 rq[regions!,quintiles!])/
	sum(c hhs ESc nom bp rqi desired[regions!,quintiles!,ind!]*num hhs rq delayed[regions
!,quintiles!]*bottom 50 rq[regions
	!,quintiles!])
	~	tCO2eq/Euro
	~		~	:SUPPLEMENTARY 
	|

bottom 50 direct emissions per capita=
	sum(direct emissions hh rq[regions!,quintiles!]*bottom 50 rq[regions!,quintiles!])/
	sum(pop rq[regions!,quintiles!]*bottom 50 rq[regions!,quintiles!])
	~	tCO2eq/(Year*Person)
	~		~	:SUPPLEMENTARY 
