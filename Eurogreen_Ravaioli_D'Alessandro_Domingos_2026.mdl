lab prod delay= DELAY FIXED (
	lab prod, Year 1 , 100)
	~	
	~		|

lab saving techn[ind]=
	IF THEN ELSE(max delta lambda[ind]=g lambda T2 i[ind],2,
	IF THEN ELSE(max delta lambda[ind]=g lambda T3 i[ind],3,
	IF THEN ELSE(max delta lambda[ind]=g lambda T4 i[ind],4,
	1)))
	~	Dmnl
	~		|

labour costs gov=
	sum(labour costs i[govsec!])
	~	Euro/Year
	~		|

labour costs i[ind]=
	sum(GWB gis[gender!,ind,skill!])+sum(soc sec contr employer gis[gender!,ind,skill!]*
L gis[gender!,ind,skill!])
	~	Euro/Year
	~		|

labour demand s[skill]=
	sum(L is unconstrained[ind!,skill])
	~	People/Year
	~		|

labour force[gender,skill]=
	min(LFPR gs[gender,skill]*sum(Working age population cgs[cohorts!,gender,skill]),working age population gs
[gender,skill])
	~	Person
	~		|

labour productivity=
	(grid share electricity sector*lambda electricity[e distribution]
	+(1-grid share electricity sector)*sum(production shares[e techn!]*lambda electricity
[e techn!]))
	~	Euro constant/People/Hour
	~	Total labour productivity as weighted average of grid and electricity labour \
		productivity.
		Since they are from 2015, we scale locomotion values with the initial \
		labour productivity for D1 in 2010. We assume this scaling factor and \
		innovations in labour productivity equally to all technologies.
	|

labour productivyt delay= DELAY FIXED (
	labour productivity, Year 1, initial labour productivity)
	~	Euro constant/(Hours*Person)
	~		|

labour scarcity[skill]=
	labour demand s[skill]/sum(labour force[gender!,skill])
	~	Dmnl
	~		|

labour scarcity s[skill]=
	1-min(ratio L supply demand s[skill],1)
	~	
	~		|

labour scarcity sensitivity=
	min(min(min(VMAX(max sensitivity low[gender!,skill!]),VMAX(max sensitivity mid[gender
!,skill!])),
	VMAX(max sensitivity hig[gender!,skill!])),
	labour scarcity sensitivity init)
	~	Dmnl
	~		|

labour scarcity sensitivity init=
	0.05
	~	Dmnl
	~		|

labour share=
	sum(labour costs i[ind!])
	/(sum(labour costs i[ind!])+Profits-wage WTR gov total cost)
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

labour supply=
	sum(labour supply gs[gender!,skill!])
	~	People
	~		~	:SUPPLEMENTARY 
	|

labour supply gs[gender,skill]=
	LFPR gs[gender,skill]*sum(Working age population cgs[cohorts!,gender,skill])-JG L gs
[gender,skill]
	~	People
	~		|

labour supply s[skill]=
	sum(labour supply gs[gender!,skill])
	~	People/Year
	~		|

lambda=
	sum(lambda i[ind!]*tot hours sh i[ind!])
	~	Euro constant/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

lambda delay i[ind]= DELAY FIXED (
	lambda i[ind], Year 1 , initial lambda i[ind])
	~	Goods/People/Hours
	~		|

lambda diffusion i[ind]=
	lambda i[ind]
	~	Euro constant/(Hours*Person)
	~	lambda i[ind]*(1+delta lambda chosen delay[ind]*fraction new capital[ind])
	|

lambda electricity[electricity subs]=
	GET XLS CONSTANTS('?main', 'electricity', 'lambda_elec*' )
	~	Euro constant/People/Hour
	~	Labour productivity by electricity technology. Source: Locomotion. taken \
		from Primary_Inputs_EXO_1
	|

lambda i[ind] :EXCEPT:       [electricity ind]=
	lambda post delta scenario pre electricity i[ind] ~~|
lambda i[electricity ind]=
	lambda post delta scenario pre electricity i[electricity ind]+electricity module switch
*g lambda electricity delayed
	*lambda post delta scenario pre electricity i[electricity ind]
	~	Euro constant/(Hours*Person)
	~		|

lambda i wcd[ind]=
	lambda i[ind]/(1+delta damage multiplier i[ind])
	~	Goods/People/Hours
	~		~	:SUPPLEMENTARY 
	|

lambda mi[macroind]=
	sum(lambda i[ind!]*ind to macroind map[ind!,macroind]*tot hours i[ind!])/sum(tot hours i
[ind!]*ind to macroind map[ind!,macroind])
	~	Euro constant/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

lambda noncareserv=
	sum(lambda i[noncareserv!]*tot hours i[noncareserv!])/sum(tot hours i[noncareserv!])
	~	Euro constant/(Hours*Person)
	~		|

lambda policy end i[ind]=SAMPLE IF TRUE(
	Time=S Time Shift end+1, lambda delay i[ind], 0)
	~	Euro constant/(Hours*Person)
	~		|

lambda policy start i[ind]=SAMPLE IF TRUE(
	Time=S Time Policy start, lambda delay i[ind], 0)
	~	Euro constant/(Hours*Person)
	~		|

lambda post delta scenario pre electricity i[ind]=
	IF THEN ELSE(flag exogenous labour productivity i[ind]<>0,
	exogenous lambda i[ind]+delta lambda scenario timestep i[ind],
	lambda pre electricity i[ind]+delta lambda scenario timestep i[ind])
	~	Euro constant/(Hours*Person)
	~		|

lambda pre electricity i[ind]= INTEG (
	in lambda[ind],
		initial lambda i[ind])
	~	Goods/People/Hours
	~		|

lambda pre electricity i delay[ind]= DELAY FIXED (
	lambda pre electricity i[ind], 1, init lambda pre electricity i[ind])
	~	Euro constant/(Hours*Person)
	~		|

lambda T iv[ind,T1]=
	lambda diffusion i[ind] ~~|
lambda T iv[ind,T2]=
	lambda i[ind]*(1+g lambda T2 i[ind]*fraction new capital[ind]) ~~|
lambda T iv[ind,T3]=
	lambda i[ind]*(1+g lambda T3 i[ind]*fraction new capital[ind]) ~~|
lambda T iv[ind,T4]=
	lambda i[ind]*(1+g lambda T4 i[ind]*fraction new capital[ind])
	~	Goods/(People*Hours)
	~		|

lambda Time Policy start i[ind]=SAMPLE IF TRUE(
	Time=S Time Policy start, lambda i[ind], 0)
	~	Euro constant/(Hours*Person)
	~		|

last year lookup capacity factor=
	2018
