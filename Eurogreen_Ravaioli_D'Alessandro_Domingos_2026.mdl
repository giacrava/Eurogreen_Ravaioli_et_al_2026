	~	Euro/Year
	~		|

delta gov c nom care services=
	sum(delta gov c nom i[careserv!])
	~	Euro/Year
	~		|

delta gov c nom care services per capita=
	delta gov c nom care services/population total
	~	Euro/(Person*Year)
	~		|

delta gov c nom i[ind]=
	delta gov c real i[ind]*p i[ind]
	~	Euro/Year
	~		|

delta gov c real care services=
	sum(delta gov c real i[careserv!])
	~	Euro constant/Year
	~		|

delta gov c real care services per capita=
	sum(delta gov c real i[careserv!])/population total
	~	Euro constant/Year
	~		|

delta gov c real care services to GPD=
	ZIDZ(delta gov c real care services,GDP real)
	~	1
	~		|

delta gov c real i[ind]=
	IF THEN ELSE(Act Change baseline gov consumption=7 :AND: Time > S Time Shift end,
	0,
	IF THEN ELSE(Time >= S Time Policy start :AND: Act change gov consumption=1,
				(gov c real delay i[ind] - delta gov c real i delay[ind]) * (1+ trend impact gov c delayed
	[ind])  
				* min(S change government consumption i[ind], 
					 S change government consumption i[ind] * Policy time increment),
				IF THEN ELSE(Time >= S Time Policy start :AND: Act change gov consumption=2,
							 min(S change government consumption i[ind], S change government consumption i
	[ind] * Policy time increment) * GDP real delay,
							 IF THEN ELSE(Time >= S Time Policy start :AND: Act change gov consumption=3,
										min(S change government consumption i[ind], S change government consumption i
	[ind] * Policy time increment) * GDP real Time Policy start delay,
	                                                              IF THEN ELSE(Time >= S Time Policy start
	 :AND: (Act change gov consumption =4 :OR: Act change gov consumption =5),
	 									   ZIDZ(Jobs to create Act change gov consumption 45 i[ind]*lambda i[ind
]*hours i[ind
	], (1-share imp gov i[ind])),
										0
	)))))
	~	Euro constant/Year
	~	Additional government final expenditure when Act change gov consumption!=0
	|

delta gov c real i delay[ind]= DELAY FIXED (
	delta gov c real i[ind], 1, delta gov c real i init[ind])
	~	Euro constant/Year
	~		|

delta gov c real i init[ind]= INITIAL(
	0)
	~	Euro constant/Year
	~		|

delta I gov real add depr i[ind]=
	IF THEN ELSE(Act change gov investment=2,
	             delta I gov real i[ind]*depreciation rates i[ind],
	0)
	~	Euro constant/Year/Year
	~	Change in I desired i to cover additional depreciation, when Act change \
		gov investment=2
