	IF THEN ELSE(track tech choice[ind]=2, g lambda T2 i[ind], 
	IF THEN ELSE(track tech choice[ind]=3, g lambda T3 i[ind],
	g lambda T4 i[ind])))
	~	Dmnl
	~		|

