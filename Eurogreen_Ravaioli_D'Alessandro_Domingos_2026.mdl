	~		|

Auctioned ETS cost i expected[ind]=
	auctioned ETS i expected[ind]*p ETS
	~	Euro/Year
	~		|

auctioned ETS i[ind]=
	IF THEN ELSE(ETS auctioning supply>sum(ETS auctioning demand i[ind!]), 
	ETS auctioning demand i[ind],
	ETS auctioning supply*ZIDZ(ETS auctioning demand i[ind],sum(ETS auctioning demand i[
ind!])) 
	)
	~	tCO2eq/Year
	~		|

auctioned ETS i expected[ind]=
	IF THEN ELSE(ETS auctioning supply>sum(ETS auctioning demand i expected[ind!]), 
	ETS auctioning demand i expected[ind],
	ETS auctioning supply*ZIDZ(ETS auctioning demand i expected[ind],sum(ETS auctioning demand i expected
[ind!])) 
	)
