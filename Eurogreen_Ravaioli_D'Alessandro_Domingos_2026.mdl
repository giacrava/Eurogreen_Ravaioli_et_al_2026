	+sum(Div i[ind!])*equities shares cap
	+bank profit transfers cap
	~	Euro/Year
	~	gross financial income capitalists
	|

gross fin inc cap bonds=
	(average interest rate)*b cap
	~	
	~		|

gross fin inc cap eq=
	+sum(Div i[ind!])*equities shares cap
	+bank profit transfers cap
	~	
	~		|

gross fin inc gs[gender,low]=
	0 ~~|
gross fin inc gs[gender,mid]=
	(average interest rate)*b gs[gender,mid] ~~|
gross fin inc gs[gender,hig]=
	(average interest rate)*b gs[gender,hig]
	+sum(Div i[ind!])*equities shares gs[gender,hig]
	+bank profit transfers gs[gender,hig]
	~	Euro/Year
	~	gross financial income by skill
	|

gross fin inc gs bonds[gender,low]=
	0 ~~|
gross fin inc gs bonds[gender,mid]=
	(average interest rate)*b gs[gender,mid] ~~|
gross fin inc gs bonds[gender,hig]=
	(average interest rate)*b gs[gender,hig]
	~	Euro/Year
	~	gross financial income by skill
	|

gross fin inc gs eq[gender,low]=
