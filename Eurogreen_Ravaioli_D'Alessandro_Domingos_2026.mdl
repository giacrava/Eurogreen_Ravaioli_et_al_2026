	~		~	:SUPPLEMENTARY 
	|

yd share top 10 bottom 50 ratio=
	yd share top 10/yd share bottom 50
	~	1
	~		~	:SUPPLEMENTARY 
	|

yd share top 10 pre tt=
	sum(yd rq pre tt[regions!,quintiles!]*top 10 rq[regions!,quintiles!])/
	sum(yd rq pre tt[regions!,quintiles!])
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

yd shares rq[regions,quintiles]=
	(yd rq[regions,quintiles]/CPI rq[regions,quintiles])/sum(yd rq[regions!,quintiles!]/
CPI rq[regions!,quintiles!])
	~	
	~		|

yd shares rq after tls[regions,quintiles]=
	(yd rq after tls[regions,quintiles]/CPI rq[regions,quintiles])/sum(yd rq after tls[regions
!,quintiles!]/CPI rq[regions!,quintiles!])
	~	
	~		|

