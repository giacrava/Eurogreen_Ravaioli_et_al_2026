financial income tax rate=
	min(
	max tax rate,
	IF THEN ELSE(Time>=S Time Policy start:AND:Act additional expense compensation=1,
	max(desired financial income tax rate+financing gap corporate/financial income tax base delayed
	,financial income tax rate from 2014)
	,
	
	IF THEN ELSE(Time<4*Year 1, "financial income tax rate 2010-2013", financial income tax rate from 2014
	)*IF THEN ELSE(Time<S Time Policy start,
	                1,
	                1+min(S Time end-S Time Policy start,Time-S Time Policy start)*(Act fin tax
	*S fintax/(S Time end-S Time Policy start))
	                )
	))
	~	Dmnl
	~		|

"financial income tax rate 2010-2013"=
	0.2
	~	Dmnl
	~		|

financial income tax rate from 2014=
	0.26
	~	Dmnl
	~		|

Financial industry revenue i[ind]=
	debt repayment i[ind]+interest payment i[ind]
	~	Euro [0,?]
	~		~	:SUPPLEMENTARY 
	|

financing gap corporate=
	corporate tax base delayed*max(desired corporate income tax rate-max tax rate,0)
	~	
	~		|

financing gap financial=
	financial income tax base delayed*max(desired financial income tax rate-max tax rate
	,0)
