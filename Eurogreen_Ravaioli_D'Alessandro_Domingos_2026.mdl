	in time use dt[inc mid e f,unpaid w]*pop d[inc mid e f] +
	in time use dt[inc mid e m,unpaid w]*pop d[inc mid e m] +
	in time use dt[inc hig e f,unpaid w]*pop d[inc hig e f] +
	in time use dt[inc hig e m,unpaid w]*pop d[inc hig e m])* Year 1/People 1
