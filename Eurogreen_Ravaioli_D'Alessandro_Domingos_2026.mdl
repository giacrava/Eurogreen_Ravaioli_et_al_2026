L gis wage cat[m finance hig] = L gis[male,finance,hig] ~~|
L gis wage cat[m realestate hig] = L gis[male,realestate,hig] ~~|
L gis wage cat[m profserv hig] = L gis[male,profserv,hig] ~~|
L gis wage cat[m public hig] = L gis[male,public,hig] ~~|
L gis wage cat[m education hig] = L gis[male,education,hig] ~~|
L gis wage cat[m health hig] = L gis[male,health,hig] ~~|
L gis wage cat[m households hig] = L gis[male,households,hig]
	~	Person
	~		|

L gs[gender,skill]=
	sum(L gis[gender,ind!,skill])
	~	People
	~		|

L gs mi[macroind, gender, skill]=
	sum(L gis[gender,ind!,skill]*ind to macroind map[ind!,macroind])
	~	Person
	~		~	:SUPPLEMENTARY 
	|

L gs share i[ind, skill, gender]=
	L gis[gender,ind,skill]/L constrained i[ind]
	~	
	~	Share of workers by gender and skill in each industry
	~	:SUPPLEMENTARY 
	|

L i actual[ind]=
	sum(L gis[gender!,ind,skill!])
	~	
	~		|

L i constrained[ind]=
	sum(L is[ind,skill!])
	~	People
	~	employment by industry
	|

L i delay[ind]= DELAY FIXED (
	L i constrained[ind],1,L i initial[ind])
	~	
	~		|

L i initial[ind]= INITIAL(
	L i constrained[ind])
	~	
	~		|

L i unconstrained[ind]=
	ZIDZ(y real unconstrained i[ind],lambda i[ind]*hours i[ind])
	~	People/Year
	~		|

L indirect and induced gov bs 6 policy 4 or 5 i[ind]=
	IF THEN ELSE(Time>=S Time Policy start,
	L actual i[ind]-(delta L from gov c real policy increase i[ind]+L tot target gov bs 6 or 7 i
[ind]),
	0)
	~	Person
	~	Difference between current jobs in each sector and jobs that would be expected based \
		on baseline target for total jobs + policy target for additional jobs in \
		each sector of the government.
		Works only if no full-employment constraint is reached, otherwise it will \
		become negative.
	|

L is[ind,skill]=
	ZIDZ(y real i[ind]*skill share demand is[ind,skill],lambda i[ind]*hours i[ind])
	~	People/Year [0,?]
	~	employment by industry and skill
	|

L is unconstrained[ind,skill]=
	L i unconstrained[ind]*skill share demand is[ind,skill]
	~	People/Year
	~		|

L mi[macroind]=
	sum(L constrained i[ind!]*ind to macroind map[ind!,macroind])
	~	Person
	~		~	:SUPPLEMENTARY 
	|

L per 1000 people delay i[ind]= DELAY FIXED (
	L per 1000 people i[ind], 1, L per 1000 people init i[ind])
	~	
	~		|

L per 1000 people i[ind]=
	L actual i[ind]/population total*1000
	~	1
	~		|

L per 1000 people init i[ind]= INITIAL(
	L per 1000 people i[ind])
	~	
	~		|

L private delay i[ind]= DELAY FIXED (
	L private i[ind],1,0)
	~	Person
	~		|

L private i[ind]=
	L actual i[ind]-L public i[ind]
	~	Person
	~		|

L private init i[ind]= INITIAL(
	L private i[ind])
	~	Person
	~		|

L prod=
	sum(L prod i[ind!]*tot hours sh i[ind!])
	~	Euro constant/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

L prod i[ind]=
	lambda i[ind]*y real i 0[ind]/VA real i[ind]
	~	Euro constant/(Hours*Person)
	~		|

L prod mi[macroind]=
	sum(L prod i[ind!]*ind to macroind map[ind!,macroind]*tot hours i[ind!])/sum(ind to macroind map
[ind!,macroind]*tot hours i[ind!])
	~	Euro constant/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

L public=
	sum(L public i[ind!])
	~	Person
	~	Public employment across all sectors (not considering government market \
		output!)
	|

L public i[ind] :EXCEPT: [govsec]=
	0 ~~|
L public i[govsec]=
	L actual i[govsec]*gov share i[govsec]
	~	Person
	~		|

L public per 1000 people i[ind]=
	L per 1000 people i[ind]*gov share i[ind]
	~	
	~		|

L public share=
	L public/L tot
	~	1
	~	Share of public employment across all sectors (not considering government \
		market output!)
	|

L public share i[ind]=
	L public i[ind]/L actual i[ind]
	~	1
	~		|

L public target gov bs 6 or 7 i[ind]=
	IF THEN ELSE(Time>=S Time Change baseline gov consumption :AND: (Act Change baseline gov consumption
 = 6 :OR: Act Change baseline gov consumption = 7),
	L tot target gov bs 6 or 7 i[ind]-L private delay i[ind],
	0)
	~	Person
	~	Current policy target of public orkers in the sectors when Act Change baseline gov \
		consumption = 6 or 7, given by the target of total number of workers * the \
		share of final output produced by the government, which corresponds to its \
		share of final demand and of non-market output (i.e. the public service \
		provisioning)
		
		Previous with share: L tot target gov bs 6 i[ind]*gov share delay i[ind]
	|

L public with policy target gov bs 6 or 7 and change gov cons 4 or 5 i[ind]=
	delta L from gov c real policy increase i[ind]+L public target gov bs 6 or 7 i[ind]
	~	Person
	~		|

L s[skill]=
	sum(L is[ind!,skill])
	~	Person/Year
	~		|

L sh i[ind]=
	L constrained i[ind]/L tot
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

L sh is[ind, skill]=
	L is[ind,skill]/L constrained i[ind]
	~	Dmnl
	~		|

L sh mi[macroind]=
	sum(L sh i[ind!]*ind to macroind map[ind!,macroind])
	~	1
	~		|

L sh mis[macroind, skill]=
	sum(L sh is[ind!,skill]*ind to macroind map[ind!,macroind]*L constrained i[ind!])/sum
(ind to macroind map
	[ind!,macroind]*L constrained i[ind!])
	~	1
	~		~	:SUPPLEMENTARY 
	|

L sh s[skill]=
	L s[skill]/L tot
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

L share wage cat[wage cat]=
	L gis wage cat[wage cat]/sum(L gis wage cat[wage cat!])
	~	Dmnl
	~		|

L share wage cat ordered[gini w order]=
	VECTOR REORDER(L share wage cat[wage cat],wage cat order[wage cat])
	~	Dmnl
	~		|

L T gisv[gender,ind,skill,techn]=
	L T isv[ind,skill,techn]*male share is[ind,skill]
	~	People/Year
	~		|

L T isv[ind,skill,techn]=
	L T iv[ind,techn]*skill share demand T isv[ind,skill,techn]
	~	People/Year
	~		|

L T iv[ind,techn]=
	ZIDZ(output expected[ind],(lambda T iv[ind,techn]*hours i[ind]))
	~	People/Year
	~		|

L tot=
	sum(L constrained i[ind!])
	~	People
	~		|

L tot abs target gov bs 6 per 1000 people i[ind] :EXCEPT:      [health], [education]=
	0 ~~|
L tot abs target gov bs 6 per 1000 people i[health]=SAMPLE IF TRUE(
	Time=S Time Change baseline gov consumption, L per 1000 people delay i[health], 0) ~~|
L tot abs target gov bs 6 per 1000 people i[education]=SAMPLE IF TRUE(
	Time=S Time Change baseline gov consumption, L per 1000 people delay i[education], 0
)
	~	1
	~	Policy target of workers in the sectors when Act Change baseline gov \
		consumption = 6
	|

L tot abs target gov bs 7 people care services=
	sum(L tot abs target gov bs 7 people i[govsec!])
	~	Person
	~		|

L tot abs target gov bs 7 people i[ind]=
	0
	~	Person
	~		|

L tot abs target gov bs 7 per 1000 people after policy i[ind]=SAMPLE IF TRUE(
	Time=S Time Shift end+1, L tot abs target gov bs 7 per 1000 people delay i[ind], 0)
	~	1
	~		|

L tot abs target gov bs 7 per 1000 people delay i[ind]= DELAY FIXED (
	L tot abs target gov bs 7 per 1000 people i[ind], 1, 0)
	~	
	~		|

L tot abs target gov bs 7 per 1000 people i[ind]=
	L tot abs target gov bs 7 people i[ind]/population total delay*1000
	~	
	~		|

L tot target gov bs 6 or 7 i[ind]=
	L tot target gov bs 6 or 7 per 1000 people i[ind]*population total delay/1000 *
	IF THEN ELSE(Act exogenous labour productivity=3,
	(1-delta perc lambda from Time Policy start i[ind]),
	1)
	~	Person
	~	Current policy target of workers in the sectors when Act Change baseline \
		gov consumption = 6
	|

L tot target gov bs 6 or 7 per 1000 people i[ind]=
	IF THEN ELSE(Time>=S Time Change baseline gov consumption :AND: Act Change baseline gov consumption
 = 6,
	L tot abs target gov bs 6 per 1000 people i[ind],
	IF THEN ELSE(Time>=S Time Change baseline gov consumption :AND: Act Change baseline gov consumption
 = 7,
	IF THEN ELSE(Time<=S Time Shift end,
	L unconstrained before change gov cons per 1000 people i[ind]+(L tot abs target gov bs 7 per 1000 people i
[ind]-L unconstrained before change gov cons per 1000 people i[ind]) * min(1, (Time-S Time Change baseline gov consumption
+1)/(S Time Shift end-S Time Change baseline gov consumption+1)),
	L tot target gov bs 7 per 1000 people after policy i[ind]),
	0))
	~	1
	~	Current policy target of workers in each sectors when Act Change baseline \
		gov consumption = 6
	|

L tot target gov bs 7 per 1000 people after policy i[ind]=
	L tot abs target gov bs 7 per 1000 people after policy i[ind]+delta L from gov c real per 1000 people after policy i
[ind]
	~	1
	~	When Act change baseline gov consumption = 7, after the end of policy \
		introduction the government aims at keeping the number of workers in \
		healthcare and education stable at the target of the last year of policy \
		introduction.
	|

L tot with policy target gov bs 6 or 7 and change gov cons 4 or 5 i[ind]=
	delta L from gov c real policy increase i[ind]+L tot target gov bs 6 or 7 i[ind]
	~	Person
	~		|

L tot with policy target gov bs 6 or 7 and change gov cons 4 or 5 per 1000 people i[ind
]=
	L tot with policy target gov bs 6 or 7 and change gov cons 4 or 5 i[ind]/population total delay
*1000
	~	1
	~		|

