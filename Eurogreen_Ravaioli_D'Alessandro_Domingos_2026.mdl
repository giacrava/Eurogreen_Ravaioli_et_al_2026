delta I gov real i[ind]=
	delta K i[ind]
	~	Euro constant/Year
	~	Additional investment by the government to cover the expand capacity to \
		cover the additional consumption for the policy
	|

delta K i[ind]=
	ZIDZ(delta y FC i[ind],capital productivity dynamic[ind])
	~	Euro constant/Year
	~		|

delta L from gov c real per 1000 people after policy i[ind]=SAMPLE IF TRUE(
	Time=S Time Shift end+1, delta L from gov c real per 1000 people delay i[ind], 0)
	~	1
	~		|

delta L from gov c real per 1000 people delay i[ind]= DELAY FIXED (
