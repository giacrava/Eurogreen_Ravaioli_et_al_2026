decrease skill transition shares[skill]=
	IF THEN ELSE(labour scarcity[skill]=VMAX(labour scarcity[skill!]),
	0,
	labour scarcity[skill]/(sum(labour scarcity[skill!])-VMAX(labour scarcity[skill!]))
	)
	~	Dmnl
	~		|

def gdp=
	gov def/GDP nom
	~	Dmnl
	~		|

def gdp delay=
	DELAY FIXED(def gdp,1,0)
	~	
	~		|

deficit production potential[e techn] :EXCEPT:   [e gas]=
	production capacity[e techn]*hours in year*max capacity factor[e techn]
	-generation by technology a[e techn] ~~|
deficit production potential[e gas]=
	production capacity[e gas]*hours in year*max capacity factor[e gas]
	-generation by technology a[e gas]-storage discharge a[power2gas]
	~	GW*Hour/Year
	~	Excess production capacities by technology.
	|

deficit rule covergence factor=
	1/7
	~	Dmnl
	~	Flexible adjusmtent time, within 7 years
	|

deficit rule fraction=
	IF THEN ELSE(CHANGE DEF RULE=0,((gov def spending trigger*GDP nom+tot gov rev-gov exp minus gov c
)/gov exp gov c),alternative fraction)
	~	
	~		|

deficit rule impact=
	(1-delay deficit rule fraction)*deficit rule covergence factor
	~	
	~		|

deficit rule time switch=
	IF THEN ELSE(Time>S Time Policy start:AND:switch off deficit rule=1,
	1,
	0)
	~	
	~		~	:SUPPLEMENTARY 
	|

delay deficit rule fraction=
	DELAY FIXED(deficit rule fraction,1,1)
	~	
	~		|

