in wage gis[gender,ind,skill]=
	in wage no policy gis[gender,ind,skill]+
	
	IF THEN ELSE(Time=S Time Policy start,
	Act minimum wage*(min wage average change gis[gender,ind,skill]*(Coefficient wage dispersion
	[gender,ind
	,skill]*wage gis[gender,ind,skill]))
	,0)
	
	+IF THEN ELSE(Time=S Time Policy start,
	Act maximum wage*(max wage average change gis[gender,ind,skill]*(Coefficient wage dispersion
	[gender,ind,skill]*wage gis[gender,ind,skill]))
	,0)
	
	+IF THEN ELSE(Time <S Time Policy start,0,
	Act WTR wage*delta wage WTR[gender,ind,skill])
	
	+yearly increase in care wages gis[gender,skill,ind]
	~	Euro/Person/Hour/Year
	~	previous formula 10/05/23
		IF THEN ELSE(wage gis[gender,ind,skill]<50*euro 1,
		wage gis[gender,ind,skill]*(omega lambda*g lamba i[ind]+omega price*inflation+ omega \
		employment*g e gs[gender,skill])
		                           +IF THEN ELSE(average wage changes gis[gender,ind,skill] \
		< -1.96* euro 1,0* euro 1, 
		0.5*min wage average change gis[gender,ind,skill]*(Coefficient wage \
		dispersion[gender,ind,skill]*wage delay gis[gender,ind,skill])),
		min(0* euro 1,wage gis[gender,ind,skill]*(omega lambda*g lamba i[ind]+ omega \
		price*inflation+omega employment[skill]*g e gs[gender,skill])+ IF THEN \
		ELSE(average wage changes gis[gender,ind,skill] < -1.96* euro 1,0* euro 1, \
		0.5*min wage average change gis[gender,ind,skill]*(Coefficient wage \
		dispersion[gender,ind,skill]*wage delay gis[gender,ind,skill])
		)))+IF THEN ELSE(Time <S Time Policy start,0* People 1 ,Act WTR wage*delta wage \
		WTR[gender,ind,skill])
		
		%%%%%%%%%%%%%%%
		wage_gis[gender,ind,skill]*(
		omega_lambda*g_lamba_i[ind]+
		omega_price*inflation+
		omega_employment*(1/(1-e_gs[gender,skill]))
		                           )
	|

in wage no policy gis[gender,ind,skill] :EXCEPT:   [gender,careserv,skill]=
	wage gis[gender,ind,skill]*(omega lambda[skill]*g lamba i[ind]+omega price*inflation
	+ omega employment*g L i[ind]+unempl wage sensitivity*(1-u s[skill])+wage adjustment constrain s
	[ind,skill]+omega overall lambda*g lab prod) ~~|
in wage no policy gis[gender,careserv,skill]=
	IF THEN ELSE(flag wage growth as average i[careserv]=1,
	wage gis[gender,careserv,skill]*mean g wage noncareserv gs[gender,skill],
	wage gis[gender,careserv,skill]*(omega lambda[skill]*g lamba i[careserv]+omega price
*inflation
	+ omega employment*g L i[careserv]+unempl wage sensitivity*(1-u s[skill])+wage adjustment constrain s
	[careserv,skill]+omega overall lambda*g lab prod))
	~	Euro/Person/Hour/Year
	~		|

