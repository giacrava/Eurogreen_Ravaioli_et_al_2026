lookup capacity factor[e techn]=
	GET XLS LOOKUPS('?main', 'electricity' , 'time_capacity' , 'initial_capacity_factor'
 )
	~	Dmnl
	~	Since the current values are used to plan investment (i.e. future capital stock), \
		i.e. they represent an expectation, we shift the lookup by one year. Thus, \
		production shares for 2011 are drawn in 2010 to plan production for 2011.
		Source: own calculations based on Eurostat energy balance, Jaxa-Rozen et al., 2022 \
		and Bolson et al., 2022 for petroluem.
		Jaxa-Rozen et al., 2022 data corrected for autoproduction: scaled by non \
		autoproduction shares using Eurostat capacity by operator shares where \
		available (i.e. solar,hydro, wind) and Eurostat energy balance production \
		shares by operator as proxy for other technologies
	|

lookup storage capacity factor[storage technologies](
	GET XLS LOOKUPS('?main', 'electricity' , 'time_capacity' , 'init_capacity_factor_storage'
 ))
	~	Dmnl
	~		~	:SUPPLEMENTARY 
