wage cat share ordered[gini w order]=
	VECTOR REORDER(wage cat share[wage cat],wage cat order[wage cat])
	~	Dmnl
	~		|

wage delay= DELAY FIXED (
	wage, 1, initial wage)
	~	Euro/(Person*Hours)
	~		|

wage g mi[gender, macroind]=
	sum(wage gis[gender,ind!,skill!]*actual hours i[ind!]*L gis[gender,ind!,skill!]*ind to macroind map
[ind!,macroind])/
	sum(actual hours i[ind!]*L gis[gender,ind!,skill!]*ind to macroind map[ind!,macroind
])
	~	Euro/(Hours*Person)
	~		~	:SUPPLEMENTARY 
	|

wage gi[gender, ind]=
	sum(wage gis[gender,ind,skill!]*actual hours i[ind]*L gis[gender,ind,skill!])/sum
	(actual hours i[ind]*L gis[gender,ind,skill!])
	~	
	~		|

wage gis[gender,ind,skill]= INTEG (
	in wage gis[gender,ind,skill],
		wages initial gis[gender,ind,skill])
	~	Euro/Person/Hour [0,?]
	~	hourly wage
	|

wage gis cat[f agri low]=
	wage gis[female,agri,low]*actual hours i[agri] ~~|
wage gis cat[f mining low]=
	wage gis[female,mining,low]*actual hours i[mining] ~~|
wage gis cat[f manufacturing low]=
	wage gis[female,manufacturing,low]*actual hours i[manufacturing] ~~|
wage gis cat[f petroleum low]=
	wage gis[female,petroleum,low]*actual hours i[petroleum] ~~|
wage gis cat[f vehicles low]=
	wage gis[female,vehicles,low]*actual hours i[vehicles] ~~|
wage gis cat[f electricity low]=
