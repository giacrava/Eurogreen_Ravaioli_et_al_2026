	~	Difference of industry wage change and mean wage change across all \
		industries
	~	:SUPPLEMENTARY 
	|

delta end use ff[ind,ff]=
	-electrified Z end use[ind,ff]-electrified Z end use imp[ind,ff] ~~|
delta end use ff[electricity ind,bio]=
	0
	~	TJ/Euro constant
	~		|

delta exogenous lambda[ind]=
	exogenous lambda i[ind]-exogenous lambda delay i[ind]
